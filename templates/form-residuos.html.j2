{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Gestión de Residuos{% endblock %}
{% block tipo_ficha %}residuos{% endblock %}
{% block body_class %}residuos{% endblock %}
{% block header_icon %}<i data-lucide="recycle"></i>{% endblock %}
{% block header_title %}GESTIÓN DE RESIDUOS{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones() }}

    <div class="card">
        <h2 class="section-title"><i data-lucide="trash"></i>Recogida de Residuos - Año {{ fase_anterior }}</h2>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 20%;">Tipo de Residuo</th>
                        <th style="width: 20%;">Producción (T/año)</th>
                        <th style="width: 15%;">Nº Contenedores</th>
                        <th style="width: 20%;">Periodicidad</th>
                        <th style="width: 25%;">Destino (Vertedero/Planta)</th>
                    </tr>
                </thead>
                <tbody>
                    {# Usamos los slugs exactos que espera tu script de PDF en Google Apps Script #}
                    {% set tipos = [
                        ('Envases', 'envases'), ('Papel y Cartón', 'papel'), 
                        ('Vidrio', 'vidrio'), ('Pilas', 'pilas'), 
                        ('Voluminosos', 'voluminosos'), ('Resto', 'resto')
                    ] %}
                    {% for nombre, slug in tipos %}
                    <tr>
                        <td style="font-weight: 500;">{{ nombre }}</td>
                        <td><input type="number" step="0.01" class="form-input" id="prod_{{ slug }}" name="prod_{{ slug }}" placeholder="0.00"></td>
                        <td><input type="number" class="form-input" id="cont_{{ slug }}" name="cont_{{ slug }}" placeholder="0"></td>
                        <td>
                            <select class="form-select" id="period_{{ slug }}" name="period_{{ slug }}">
                                <option value="Diaria">Diaria</option>
                                <option value="Semanal">Semanal</option>
                                <option value="Quincenal">Quincenal</option>
                                <option value="A demanda">A demanda</option>
                            </select>
                        </td>
                        <td><input type="text" class="form-input" id="dest_{{ slug }}" name="dest_{{ slug }}" placeholder="Ej: Planta X"></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <h2 class="section-title"><i data-lucide="sparkles"></i>Limpieza Viaria</h2>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label">Nº de personas destinadas a limpieza viaria:</label>
                <input type="number" class="form-input" name="personas_limpieza" id="personasLimpieza">
            </div>
        </div>
    </div>

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');
    
    ['nombre', 'depto', 'email'].forEach(f => document.getElementById(`contacto_${f}`).value = localStorage.getItem(`eiel_user_${f}`) || "");

    if(checkConf) checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            const formData = new FormData(document.getElementById('mainForm'));
            return Object.fromEntries(formData.entries());
        });
    };
});
</script>
{% endblock %}