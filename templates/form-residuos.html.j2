{% extends "base.html.j2" %}

{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block title %}EIEL - Gestión de Residuos{% endblock %}
{% block header_icon %}<i data-lucide="recycle"></i>{% endblock %}
{% block header_title %}GESTIÓN DE RESIDUOS{% endblock %}

{% block content %}

{# --- SECCIÓN: INSTRUCCIONES --- #}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul>
        <li>Rellene los datos requeridos acerca de recogida de residuos y limpieza viaria. Si no dispone de algún dato, indíquelo en el apartado de <strong>Observaciones</strong>.</li>
    </ul>
</div>

{# --- SECCIÓN: RECOGIDA DE RESIDUOS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="trash"></i>Recogida de Residuos - Año {{ fase_anterior }}</h2>
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 22%;">TIPO DE RESIDUO</th>
                    <th style="width: 20%;">PRODUCCIÓN (T/AÑO)</th>
                    <th style="width: 15%;">Nº CONTENEDORES</th>
                    <th style="width: 20%;">PERIODICIDAD</th>
                    <th style="width: 23%;">DESTINO</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="label-caps">🟡 Plásticos y Envases</td>
                    <td><input type="number" id="prod_plastico" class="form-input" placeholder="t/año" step="any"></td>
                    <td><input type="number" id="cont_plastico" class="form-input" placeholder="0"></td>
                    <td>
                        <select id="period_plastico" class="form-select select-periodicidad">
                            <option value="">Seleccionar...</option>
                            <option value="diaria">Diaria</option>
                            <option value="dias alternos">Días alternos</option>
                            <option value="semanal">Semanal</option>
                            <option value="quincenal">Quincenal</option>
                            <option value="otros">Otros</option>
                            <option value="sin periodicidad">Sin periodicidad</option>
                        </select>
                    </td>
                    <td><input type="text" id="dest_plastico" class="form-input" placeholder="Vertedero/Planta"></td>
                </tr>

                <tr>
                    <td class="label-caps">🔵 Papel y Cartón</td>
                    <td><input type="number" id="prod_papel" class="form-input" placeholder="t/año" step="any"></td>
                    <td><input type="number" id="cont_papel" class="form-input" placeholder="0"></td>
                    <td>
                        <select id="period_papel" class="form-select select-periodicidad">
                            <option value="">Seleccionar...</option>
                            <option value="diaria">Diaria</option>
                            <option value="dias alternos">Días alternos</option>
                            <option value="semanal">Semanal</option>
                            <option value="quincenal">Quincenal</option>
                            <option value="otros">Otros</option>
                            <option value="sin periodicidad">Sin periodicidad</option>
                        </select>
                    </td>
                    <td><input type="text" id="dest_papel" class="form-input" placeholder="Vertedero/Planta"></td>
                </tr>

                <tr>
                    <td class="label-caps">🟢 Vidrio</td>
                    <td><input type="number" id="prod_vidrio" class="form-input" placeholder="t/año" step="any"></td>
                    <td><input type="number" id="cont_vidrio" class="form-input" placeholder="0"></td>
                    <td>
                        <select id="period_vidrio" class="form-select select-periodicidad">
                            <option value="">Seleccionar...</option>
                            <option value="diaria">Diaria</option>
                            <option value="dias alternos">Días alternos</option>
                            <option value="semanal">Semanal</option>
                            <option value="quincenal">Quincenal</option>
                            <option value="otros">Otros</option>
                            <option value="sin periodicidad">Sin periodicidad</option>
                        </select>
                    </td>
                    <td><input type="text" id="dest_vidrio" class="form-input" placeholder="Vertedero/Planta"></td>
                </tr>

                <tr>
                    <td class="label-caps">🟤 Orgánico</td>
                    <td><input type="number" id="prod_organico" class="form-input" placeholder="t/año" step="any"></td>
                    <td><input type="number" id="cont_organico" class="form-input" placeholder="0"></td>
                    <td>
                        <select id="period_organico" class="form-select select-periodicidad">
                            <option value="">Seleccionar...</option>
                            <option value="diaria">Diaria</option>
                            <option value="dias alternos">Días alternos</option>
                            <option value="semanal">Semanal</option>
                            <option value="quincenal">Quincenal</option>
                            <option value="otros">Otros</option>
                            <option value="sin periodicidad">Sin periodicidad</option>
                        </select>
                    </td>
                    <td><input type="text" id="dest_organico" class="form-input" placeholder="Vertedero/Planta"></td>
                </tr>

                <tr>
                    <td class="label-caps">⚫ No selectiva/resto</td>
                    <td><input type="number" id="prod_resto" class="form-input" placeholder="t/año" step="any"></td>
                    <td><input type="number" id="cont_resto" class="form-input" placeholder="0"></td>
                    <td>
                        <select id="period_resto" class="form-select select-periodicidad">
                            <option value="">Seleccionar...</option>
                            <option value="diaria">Diaria</option>
                            <option value="dias alternos">Días alternos</option>
                            <option value="semanal">Semanal</option>
                            <option value="quincenal">Quincenal</option>
                            <option value="otros">Otros</option>
                            <option value="sin periodicidad">Sin periodicidad</option>
                        </select>
                    </td>
                    <td><input type="text" id="dest_resto" class="form-input" placeholder="Vertedero/Planta"></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

{# --- SECCIÓN: LIMPIEZA VIARIA --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="brush-cleaning"></i>Limpieza Viaria</h2>
    <div class="form-group">
        <label for="personasLimpieza" class="form-label">
            Número de personas dedicadas a la limpieza viaria
        </label>
        <input type="number" id="personasLimpieza" class="form-input" placeholder="Ej: 5" min="0">
    </div>
</div>

{# --- SECCIÓN: REQUERIMIENTOS --- #}
{% if avisos_personalizados and avisos_personalizados|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        {# Título con formato estándar y nuevo icono Lucide #}
        <h2 class="section-title">
            <i data-lucide="circle-plus"></i> Otra información solicitada
        </h2>
        
        {# Introducción con formato de ayuda estándar #}
        <p class="form-help" style="margin-bottom: 1.5rem;">
            Se ha detectado falta de información o incidencias en la Gestión de Residuos que requieren su atención en el apartado de <strong>Observaciones</strong> y/o <strong>Documentación Adjunta</strong>.  
        </p>

        <ul class="requerimientos-list" style="list-style: none; padding: 0;">
            {% for aviso in avisos_personalizados %}
            <div class="aviso-item">
                <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                
                <div style="flex: 1;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 15px;">
                        <span style="font-weight: 600; color: var(--text-primary); font-size: 0.95rem; line-height: 1.4;">
                            {{ aviso.mensaje }}
                        </span>
                        
                        {% if aviso.url %}
                        <a href="{{ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm">
                            Mapa <i data-lucide="map"></i>
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </ul>
    </div>
</div>
{% endif %}

{# --- SECCIÓN: OBSERVACIONES --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" placeholder="Indique aquí cualquier incidencia, aclaración o dato relevante..."></textarea>
    </div>
</div>

{# --- SECCIÓN: ADJUNTOS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="folder"></i>Documentación Adjunta (Opcional)</h2>
    <div class="file-upload-area" onclick="document.getElementById('fileInput').click()">
        <div class="upload-icon">📎</div>
        <div style="font-weight: 600;">Haga clic para adjuntar archivos</div>
        <p class="upload-help">(Planos, fotos, informes, análisis...)</p>
        <input type="file" id="fileInput" multiple style="display: none;">
    </div>
    <div id="fileList" class="file-list-container"></div>
</div>

{# --- SECCIÓN: DATOS DE CONTACTO --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required>
        </div>
       <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;">
            </div>
    </div>
</div>

{# --- SECCIÓN: DECLARACIÓN RESPONSABLE --- #}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text">
                <strong>Declaración de veracidad:</strong> Como responsable, 
                confirmo que los datos introducidos son correctos y actualizados.
            </span>
        </label>
    </div>

{# --- SECCIÓN: ENVÍO --- #}
    <div id="progressContainer" class="progress-container hidden">
        <div class="progress-labels">
            <span id="progressText">Preparando envío...</span>
            <span id="progressPercentage">0%</span>
        </div>
        <div class="progress-track">
            <div id="progressBar"></div>
        </div>
    </div>
    
    <div id="mensaje" class="message hidden"></div>

    <button id="btnEnviar" class="btn btn-primary" disabled>
        Enviar Datos
    </button>
</div>

{% endblock %}
{% block scripts %}
<script>
document.addEventListener("DOMContentLoaded", () => {
    
    // 0. ACTIVADOR DE TEMA
    document.body.classList.add('theme-residuos');
    
    // Ejecuta la creación de iconos de Lucide
    if (window.lucide) {
        lucide.createIcons();
    }
    
    // 1. SETUP DE ESTILOS
    const header = document.querySelector('.site-header');
    if(header) header.classList.add('header-residuos');
    
    // Lógica para cambiar el color de la periodicidad al seleccionar
    document.querySelectorAll('.select-periodicidad').forEach(select => {
        // Aplicar color si ya viene con valor (por si el formulario se recarga)
        if (select.value !== "") select.classList.add('has-value');

        select.addEventListener('change', function() {
            if (this.value !== "") {
                this.classList.add('has-value');
            } else {
                this.classList.remove('has-value');
            }
        });
    });

    // 2. CONFIGURACIÓN GLOBAL
    window.EIEL_CONFIG = {
        muniCode: "{{ muni_code }}",
        muniName: "{{ muni_display }}",
        fase: "{{ fase_actual }}",
        urlGenerarPdf: "{{ url_generar_pdf }}",
        urlAdjuntos: "{{ url_adjuntos }}",
        urlLogger: "{{ url_logger }}",
        hasAvisos: {{ 'true' if avisos_personalizados and avisos_personalizados|length > 0 else 'false' }},
        yearActual: new Date().getFullYear() // Año dinámico para validaciones
    };

    // 3. INICIALIZACIÓN UI
    // 3.1 Marcado visual de obligatoriedad en observaciones
    if (window.EIEL_CONFIG.hasAvisos) {
        const labelObs = document.querySelector("label[for='observaciones']");
        if (labelObs) {
            labelObs.innerHTML += " <span class='text-required'>(* Obligatorio)</span>";
        }
    }

    // 3.2 Mapeo de campos Residuos
    const RESIDUO_FIELDS = [
      { type: "Plásticos y Envases (amarillo)", prod: "prod_plastico", cont: "cont_plastico", period: "period_plastico", dest: "dest_plastico" },
      { type: "Papel y Cartón (azul)", prod: "prod_papel", cont: "cont_papel", period: "period_papel", dest: "dest_papel" },
      { type: "Vidrio (verde)", prod: "prod_vidrio", cont: "cont_vidrio", period: "period_vidrio", dest: "dest_vidrio" },
      { type: "Orgánico (marrón)", prod: "prod_organico", cont: "cont_organico", period: "period_organico", dest: "dest_organico" },
      { type: "No selectiva/resto", prod: "prod_resto", cont: "cont_resto", period: "period_resto", dest: "dest_resto" },
    ];

    // 4. SERVICIOS Y UTILIDADES DE UI
    const UIProgress = {
    container: document.getElementById("progressContainer"),
    bar: document.getElementById("progressBar"),
    text: document.getElementById("progressText"),
    percent: document.getElementById("progressPercentage"),
    //Variable para recordar el punto más alto alcanzado
    maxReached: 0, 

   
    show(totalTasks) {
        this.maxReached = 0;
        if (this.container) this.container.classList.remove('hidden');
        this.update(0, totalTasks, "Iniciando envío...");
    },

    update(completed, total, message) {
        const msg = message.toLowerCase();
        // Detectamos si es el paso del registro o PDF
        const isFinalStep = msg.includes("pdf") || msg.includes("registro") || msg.includes("justificante");
        
        let targetPercentage = 0;
        if (total > 0) {
            const fileWeight = 90 / total;
            targetPercentage = isFinalStep ? 95 : Math.round(completed * fileWeight);
        } else {
            targetPercentage = isFinalStep ? 95 : 0;
        }

        // --- EL BLOQUEO DE SEGURIDAD ---
        // Solo actualizamos si el nuevo porcentaje es mayor al que ya mostramos
        if (targetPercentage > this.maxReached) {
            this.maxReached = targetPercentage;
            if (this.bar) this.bar.style.width = this.maxReached + "%";
            if (this.percent) this.percent.textContent = this.maxReached + "%";
        }
        
        // El texto sí lo actualizamos siempre para dar feedback constante
        if (this.text && message) this.text.textContent = message;
    },

    complete() {
        this.maxReached = 100;
        if (this.bar) {
            this.bar.style.width = "100%";
            this.bar.classList.add("progress-success");
        }
        if (this.percent) this.percent.textContent = "100%";
        if (this.text) this.text.textContent = "✅ ¡Envío completado con éxito! Se ha enviado un justificante al email facilitado";
    }
    };

    const UploadService = {
        toBase64: file => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        }),

        async uploadFile(file, tipoFicha, muniCode, seccion = "DOCUMENTACION", idEnvio) {
            try {
                const base64 = await this.toBase64(file);
                const userEmail = document.getElementById("contactoEmail").value || "anonimo";
                const payload = {
                    filename: file.name,
                    mimeType: file.type,
                    bytesBase64: base64, 
                    municipio: muniCode,
                    usuario: userEmail,
                    tipo: tipoFicha,
                    seccion: seccion,
                    id_envio: idEnvio
                };
                await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                    method: 'POST', mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                return true;
            } catch (e) { return false; }
        }
    };

    // 5. GESTIÓN DE ARCHIVOS (UI)
    let archivos = [];
    const fileInput = document.getElementById("fileInput");
    const fileList = document.getElementById("fileList");

    if (fileInput) {
        fileInput.onchange = () => {
            archivos.push(...Array.from(fileInput.files));
            renderArchivos();
            fileInput.value = '';
        };
    }

    window.eliminarArchivo = (i) => {
        archivos.splice(i, 1);
        renderArchivos();
    };
    
    function renderArchivos() {
        if (!fileList) return;
        if (archivos.length === 0) {
            fileList.innerHTML = '';
            return;
        }
        fileList.innerHTML = archivos.map((f, i) => `
            <div class="file-item">
                <span>📄 ${f.name}</span>
                <button type="button" onclick="eliminarArchivo(${i})" class="btn-danger-icon">
                    <i data-lucide="trash-2" style="width:18px;"></i>
                </button>
            </div>
        `).join("");

        if (window.lucide) lucide.createIcons();
    }

    // 6. LÓGICA DE ENVÍO Y VALIDACIÓN
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConformidad = document.getElementById("checkConformidad");
    const mensajeDiv = document.getElementById("mensaje");

    function mostrarMensaje(texto, tipo) {
        if (!mensajeDiv) return;
        mensajeDiv.textContent = texto;
        mensajeDiv.className = `message ${tipo}`; 
        mensajeDiv.classList.remove('hidden');
        mensajeDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // Control de habilitación del botón de envío
    if (checkConformidad && btnEnviar) {
        checkConformidad.addEventListener('change', function() {
            btnEnviar.disabled = !this.checked;
        });
    }

    // Listener principal de envío
    if (btnEnviar) {
        btnEnviar.addEventListener("click", async () => {
            
            // Preparación del proceso y bloqueo de interfaz
            const idBatch = "ENVIO_" + new Date().getTime();
            toggleFormFreeze(true);

            // Limpieza proactiva de mensajes previos
            if (mensajeDiv) mensajeDiv.classList.add('hidden'); 

            // Lectura de variables generales y específicas
            const nombreContacto = document.getElementById("contactoNombre").value.trim();
            const departamentoVal = document.getElementById("contactoDepartamento").value.trim();
            const emailContacto = document.getElementById("contactoEmail").value.trim();
            const emailConfirmInput = document.getElementById("contactoEmailConfirm");
            const emailConfirm = emailConfirmInput ? emailConfirmInput.value.trim() : emailContacto;
            const obsField = document.getElementById("observaciones");
            const obsValue = obsField.value.trim();
            const regexEmail = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

            // VALIDACIONES

            // Identidad y Email
            if (nombreContacto.length < 2) {
                mostrarMensaje("⚠️ El nombre es demasiado corto.", "warning");
                toggleFormFreeze(false); return;
            }

            if (!regexEmail.test(emailContacto) || emailContacto.toLowerCase() !== emailConfirm.toLowerCase()) {
                mostrarMensaje("⚠️ Verifique que el Email sea válido y coincida.", "error");
                toggleFormFreeze(false); return;
            }

            // Validación de requerimientos (Observaciones mínimas si hay avisos)
            if (window.EIEL_CONFIG.hasAvisos && obsValue.length < 15) {
                mostrarMensaje("⚠️ Es neceario responder en Observaciones a la información solicitada. (mín. 15 caracteres.).", "error");
                obsField.focus(); 
                toggleFormFreeze(false); return;
            }
            
            // Persistencia de datos del técnico
            localStorage.setItem("eiel_user_name", nombreContacto);
            localStorage.setItem("eiel_user_email", emailContacto);
            localStorage.setItem("eiel_user_dept", departamentoVal);

            // PROCESO DE SUBIDA A GOOGLE DRIVE
            const totalArchivos = archivos.length;
            let completados = 0;
            UIProgress.show(totalArchivos);

            try {
                if (totalArchivos > 0) {
                    for (const file of archivos) {
                        await UploadService.uploadFile(file, 'residuos', window.EIEL_CONFIG.muniCode, 'DOCUMENTACION', idBatch);
                        completados++;
                        UIProgress.update(completados, totalArchivos, `Subido: ${file.name}`);
                    }
                }

                // RECOPILACIÓN DE DATOS PARA EL PAYLOAD
                UIProgress.update(completados, totalArchivos, "Generando justificante y registrando datos...");
                
                const payload = {
                    tipo_formulario: "residuos",
                    fase: window.EIEL_CONFIG.fase,
                    id_envio: idBatch,
                    observaciones: obsValue,
                    nombre_contacto: nombreContacto,
                    departamento_contacto: departamentoVal,
                    email_contacto: emailContacto,
                    municipio_codigo: window.EIEL_CONFIG.muniCode,
                    municipio_nombre: window.EIEL_CONFIG.muniName,
                    timestamp_envio: new Date().toISOString(),
                    archivos_adjuntos: archivos.map(a => a.name).join("\n"),

                    residuos_data: [
                        { 
                            tipo: "Plásticos y Envases (amarillo)", 
                            produccion: document.getElementById("prod_plastico").value, 
                            contenedores: document.getElementById("cont_plastico").value,
                            periodicidad: document.getElementById("period_plastico").value,
                            vertedero: document.getElementById("dest_plastico").value
                        },
                        { 
                            tipo: "Papel y Cartón (azul)", 
                            produccion: document.getElementById("prod_papel").value, 
                            contenedores: document.getElementById("cont_papel").value,
                            periodicidad: document.getElementById("period_papel").value,
                            vertedero: document.getElementById("dest_papel").value
                        },
                        { 
                            tipo: "Vidrio (verde)", 
                            produccion: document.getElementById("prod_vidrio").value, 
                            contenedores: document.getElementById("cont_vidrio").value,
                            periodicidad: document.getElementById("period_vidrio").value,
                            vertedero: document.getElementById("dest_vidrio").value
                        },
                        { 
                            tipo: "Orgánico (marrón)", 
                            produccion: document.getElementById("prod_organico").value, 
                            contenedores: document.getElementById("cont_organico").value,
                            periodicidad: document.getElementById("period_organico").value,
                            vertedero: document.getElementById("dest_organico").value
                        },
                        { 
                            tipo: "No selectiva/resto", 
                            produccion: document.getElementById("prod_resto").value, 
                            contenedores: document.getElementById("cont_resto").value,
                            periodicidad: document.getElementById("period_resto").value,
                            vertedero: document.getElementById("dest_resto").value
                        }
                    ],

                    personas_limpieza: document.getElementById("personasLimpieza").value
                };

                // Envío al servidor
                await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                    method: "POST",
                    mode: "no-cors",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                // Finalización y limpieza
                UIProgress.complete();
                if (mensajeDiv) mensajeDiv.classList.add('hidden'); 

                // Reseteo de estado y UI
                archivos = [];
                renderArchivos(); 

                document.querySelectorAll("input, select, textarea").forEach(el => {
                   if (!['button', 'submit', 'checkbox'].includes(el.type)) el.value = '';
                   if (el.tagName === 'SELECT') {
                       el.selectedIndex = 0;
                       el.classList.remove('has-value');
                   }
                });

                if (checkConformidad) checkConformidad.checked = false;
                btnEnviar.disabled = true;

            } catch (error) {
                console.error("Error en el proceso de residuos:", error);
                mostrarMensaje(`❌ Error técnico: ${error.message}`, "error");
                toggleFormFreeze(false);
            }
        });
    }
});
</script>
{% endblock %}