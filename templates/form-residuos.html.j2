{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'residuos' %}

{% block title %}EIEL - Gestión de Residuos{% endblock %}
{% block header_icon %}<i data-lucide="recycle"></i>{% endblock %}
{% block header_title %}GESTIÓN DE RESIDUOS{% endblock %}

{% block content %}
<form id="formResiduos">
    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li>Rellene los datos de producción y gestión por tipo de residuo.</li>
            <li>Justifique cualquier dato ausente en el apartado de <strong>Observaciones</strong>.</li>
        </ul>
    </div>

    {# 3. RECOGIDA DE RESIDUOS #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="trash"></i>Recogida de Residuos - Año {{ fase_anterior }}</h2>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 22%;">TIPO DE RESIDUO</th>
                        <th style="width: 20%;">PRODUCCIÓN (T/AÑO)</th>
                        <th style="width: 15%;">Nº CONTENEDORES</th>
                        <th style="width: 20%;">PERIODICIDAD</th>
                        <th style="width: 23%;">DESTINO</th>
                    </tr>
                </thead>
                <tbody>
                    {% set tipos = [
                        {'id': 'plastico', 'label': '🟡 Plásticos y Envases'},
                        {'id': 'papel', 'label': '🔵 Papel y Cartón'},
                        {'id': 'vidrio', 'label': '🟢 Vidrio'},
                        {'id': 'organico', 'label': '🟤 Orgánico'},
                        {'id': 'resto', 'label': '⚫ No selectiva/resto'}
                    ] %}
                    {% for t in tipos %}
                    <tr>
                        <td class="label-caps">{{ t.label }}</td>
                        <td><input type="number" id="prod_{{ t.id }}" class="form-input" placeholder="t/año" step="any"></td>
                        <td><input type="number" id="cont_{{ t.id }}" class="form-input" placeholder="0"></td>
                        <td>
                            <select id="period_{{ t.id }}" class="form-select select-periodicidad">
                                <option value="">Seleccionar...</option>
                                <option value="diaria">Diaria</option>
                                <option value="dias alternos">Días alternos</option>
                                <option value="semanal">Semanal</option>
                                <option value="quincenal">Quincenal</option>
                                <option value="otros">Otros</option>
                                <option value="sin periodicidad">Sin periodicidad</option>
                            </select>
                        </td>
                        <td><input type="text" id="dest_{{ t.id }}" class="form-input" placeholder="Vertedero/Planta"></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# 4. LIMPIEZA VIARIA #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="brush-cleaning"></i>Limpieza Viaria</h2>
        <div class="form-group">
            <label for="personasLimpieza" class="form-label">Número de personas dedicadas a la limpieza viaria</label>
            <input type="number" id="personasLimpieza" class="form-input" placeholder="Ej: 5" min="0">
        </div>
    </div>

    {# 5. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Otra información solicitada</h2>
        <p class="form-help form-help-spacer">Se ha detectado falta de información que requiere solución.</p>
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}
                    <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm">
                        <i data-lucide="map"></i> Mapa
                    </a>
                    {% endif %}
                </div>
                
                {# CONTENEDOR DE RESPUESTA CORREGIDO (FONDO BLANCO Y ANCHO TOTAL) #}
                <div style="margin-left: 28px; background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0; box-sizing: border-box; width: calc(100% - 28px);">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" 
                              placeholder="Responda aquí..." 
                              style="width: 100% !important; box-sizing: border-box; display: block; margin-bottom: 15px; background: white; border: 1px solid #cbd5e1;"></textarea>
                    
                    <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosReq('{{ req_id }}')">
                        <i data-lucide="paperclip"></i> Adjuntar
                    </button>
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 6. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
{% endblock %}

{% block scripts %}
<script>
// Variables para acumular archivos
let archivosGenerales = [];
let colaAdjuntosReq = {};
let reqIdActual = null;

document.addEventListener("DOMContentLoaded", () => {
    // A. Manejo de archivos generales (Drag & Drop e Input)
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosGenerales = [...archivosGenerales, ...Array.from(fileInput.files)];
            renderArchivos();
            fileInput.value = ""; 
        });
    }

    // B. Manejo de adjuntos para Requerimientos
    const inputReq = document.getElementById('hiddenInputReq');
    window.gestionarAdjuntosReq = (id) => { reqIdActual = id; if(inputReq) inputReq.click(); };

    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            const files = Array.from(inputReq.files);
            colaAdjuntosReq[reqIdActual] = [...(colaAdjuntosReq[reqIdActual] || []), ...files];
            renderColaReq(reqIdActual);
            inputReq.value = "";
        });
    }

    // C. Lógica de Envío
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) checkConf.addEventListener('change', () => btnEnviar.disabled = !checkConf.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "RESIDUOS_" + Date.now();
        
        if (document.getElementById("contactoEmail").value !== document.getElementById("contactoEmailConfirm").value) {
            return Swal.fire("Error", "Los emails de contacto no coinciden.", "error");
        }

        toggleFormFreeze(true);

        const listaTareas = [];
        // Añadir archivos generales acumulados
        archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
        
        Object.entries(colaAdjuntosReq).forEach(([id, list]) => {
            list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${parseInt(id)+1}` }));
        });

        UIProgress.show(listaTareas.length);

        try {
            await UploadService.uploadFiles(listaTareas, 'RESIDUOS', window.EIEL_CONFIG.muniCode, idBatch, 1);
            UIProgress.update(listaTareas.length, listaTareas.length, "Generando PDF...");

            const payload = {
                tipo_formulario: "residuos",
                id_envio: idBatch,
                municipio: window.EIEL_CONFIG.muniCode,
                residuos_data: [
                    { tipo: "Plásticos y Envases", produccion: document.getElementById("prod_plastico").value, contenedores: document.getElementById("cont_plastico").value, periodicidad: document.getElementById("period_plastico").value, vertedero: document.getElementById("dest_plastico").value },
                    { tipo: "Papel y Cartón", produccion: document.getElementById("prod_papel").value, contenedores: document.getElementById("cont_papel").value, periodicidad: document.getElementById("period_papel").value, vertedero: document.getElementById("dest_papel").value },
                    { tipo: "Vidrio", produccion: document.getElementById("prod_vidrio").value, contenedores: document.getElementById("cont_vidrio").value, periodicidad: document.getElementById("period_vidrio").value, vertedero: document.getElementById("dest_vidrio").value },
                    { tipo: "Orgánico", produccion: document.getElementById("prod_organico").value, contenedores: document.getElementById("cont_organico").value, periodicidad: document.getElementById("period_organico").value, vertedero: document.getElementById("dest_organico").value },
                    { tipo: "No selectiva/resto", produccion: document.getElementById("prod_resto").value, contenedores: document.getElementById("cont_resto").value, periodicidad: document.getElementById("period_resto").value, vertedero: document.getElementById("dest_resto").value }
                ],
                personas_limpieza: document.getElementById("personasLimpieza").value,
                requerimientos: Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                    pregunta: area.dataset.msg, respuesta: area.value
                })),
                observaciones: document.getElementById("observaciones").value,
                contacto: {
                    nombre: document.getElementById("contactoNombre").value,
                    email: document.getElementById("contactoEmail").value
                }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();

        } catch (error) {
            console.error(error);
            toggleFormFreeze(false);
            Swal.fire("Error", "Fallo al procesar el envío de residuos.", "error");
        }
    });
});

// Función para listar archivos generales
function renderArchivos() {
    const fileList = document.getElementById("fileList");
    if (!fileList) return;
    fileList.innerHTML = archivosGenerales.map((f, i) => `
        <div class="file-item">
            <span>📄 ${f.name}</span>
            <button type="button" onclick="archivosGenerales.splice(${i},1); renderArchivos();" class="btn-danger-icon">
                <i data-lucide="trash-2"></i>
            </button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}

// Función para listar archivos de requerimientos
function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => `
        <div class="file-item" style="margin-bottom:4px; padding:4px 8px; background:#fdfdfd; border:1px solid #e2e8f0; border-radius:6px; display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.75rem;"><i data-lucide="paperclip" style="width:12px;"></i> ${f.name}</span>
            <button type="button" onclick="colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}');" class="btn-danger-icon">
                <i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i>
            </button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}
</script>
{% endblock %}