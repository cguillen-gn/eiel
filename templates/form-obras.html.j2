{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# Configuramos el tema para este formulario #}
{% set ficha_tipo = 'obras' %}

{% block title %}EIEL - Seguimiento de Obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}SEGUIMIENTO DE OBRAS{% endblock %}

{% block content %}
<form id="formObras">
    {# 1. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li><strong>Estado:</strong> Actualice el estado de ejecución de las obras en seguimiento[cite: 1981, 1982].</li>
            <li><strong>Documentación:</strong> Adjunte al menos memoria y planos por cada actuación[cite: 1982].</li>
        </ul>
    </div>

    {# 2. TABLA DE SEGUIMIENTO (Obras Existentes) #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-checks"></i> Obras en Seguimiento</h2>
        
        {# CORRECCIÓN: Verificamos si la variable existe y tiene datos #}
        {% if obras_seguimiento and obras_seguimiento|length > 0 %}
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">ID</th>
                        <th>Denominación de la Obra</th>
                        <th style="width: 200px;">Estado Actual</th>
                        <th style="width: 120px; text-align: center;">Adjuntos</th>
                    </tr>
                </thead>
                <tbody>
                    {# Si los datos vienen como JSON string desde el backend, usamos |fromjson #}
                    {% set lista_obras = obras_seguimiento if obras_seguimiento is iterable else obras_seguimiento|fromjson %}
                    {% for obra in lista_obras %}
                    <tr>
                        <td class="text-xs">{{ obra.id }}</td>
                        <td>
                            <div class="obra-column-container">
                                <span class="item-title">{{ obra.denominacion }}</span>
                                <span class="text-xs">{{ obra.expediente }}</span>
                            </div>
                        </td>
                        <td>
                            <select class="form-select select-estado-obra" data-id="{{ obra.id }}">
                                <option value="En Ejecución" {% if obra.estado == 'En Ejecución' %}selected{% endif %}>En Ejecución</option>
                                <option value="Finalizada" {% if obra.estado == 'Finalizada' %}selected{% endif %}>Finalizada</option>
                                <option value="Paralizada" {% if obra.estado == 'Paralizada' %}selected{% endif %}>Paralizada</option>
                            </select>
                        </td>
                        <td style="text-align: center;">
                            <input type="file" id="file_obra_{{ obra.id }}" class="hidden input-adjunto-obra" data-id="{{ obra.id }}" multiple>
                            {# Botón unificado con el nuevo estándar de style.css #}
                            <button type="button" class="btn btn-secondary btn-sm" 
                                    onclick="document.getElementById('file_obra_{{ obra.id }}').click()"
                                    title="Adjuntar documentación">
                                <i data-lucide="paperclip"></i> <span class="count-adjuntos" id="count_{{ obra.id }}">0</span>
                            </button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="sin-uso-intro">ℹ️ No hay obras en seguimiento registradas para este municipio.</p>
        {% endif %}
    </div>

    {# 3. SECCIÓN DE OTRAS OBRAS DETECTADAS #}
    {# CORRECCIÓN: Filtramos la cadena para asegurar que no sea un array vacío de texto #}
    {% if otras_obras_json and otras_obras_json != "[]" and otras_obras_json != "" %}
    <div class="card">
        <h2 class="section-title"><i data-lucide="search-code"></i> Otras obras detectadas</h2>
        <p class="sin-uso-intro">ℹ️ Se han detectado las siguientes actuaciones adicionales en su municipio:</p>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 70%;">Denominación</th>
                        <th style="width: 30%;">¿Ha finalizado?</th>
                    </tr>
                </thead>
                <tbody>
                    {% set otras_obras = otras_obras_json|fromjson %}
                    {% for o in otras_obras %}
                    <tr>
                        <td class="item-title">{{ o.denominacion }}</td>
                        <td>
                            <select class="form-select select-otra-obra" data-deno="{{ o.denominacion }}">
                                <option value="No">No / En curso</option>
                                <option value="Si">Sí, finalizada</option>
                            </select>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {# 4. BLOQUES UNIFICADOS (Macros) #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
{% endblock %}