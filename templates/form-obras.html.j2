{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'obras' %}

{% block title %}EIEL - Obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}OBRAS{% endblock %}

{% block content %}
<form id="formObras">
    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li><strong>Estado:</strong> Rellene el estado en todas las obras del listado de seguimiento. </li>
            <li><strong>Documentación:</strong> Adjunte el proyecto de cada obra o la documentación disponible.</li>
        </ul>
    </div>

    {# 3. SEGUIMIENTO DE OBRAS #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-checks"></i> SEGUIMIENTO DE OBRAS</h2>
        <div class="table-wrapper table-margin-reset">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%;" class="td-ubicacion">Id</th>
                        <th style="width: 55%;">Denominación</th>
                        <th style="width: 20%;" class="td-ubicacion">Estado</th>
                        <th style="width: 20%;" class="td-ubicacion">Documentación</th>
                    </tr>
                </thead>
                <tbody>
                    {% for o in obras %}
                    {# Generamos el ID único de la obra para vincular datos y adjuntos #}
                    {% set codigo_obra = o.clave ~ o.mun ~ o.orden %}
                    <tr class="fila-obra">
                        <td class="td-ubicacion text-xs" style="font-weight: 500; color: var(--text-secondary);">
                            {{ codigo_obra[-3:] }}
                        </td>
                        <td>
                            <div class="obra-column-container">
                                <span class="item-title">{{ o.nombre }}</span>
                                {% if o.plan_obra and "licitaciones" not in o.plan_obra|lower and "contratos menores" not in o.plan_obra|lower %}
                                <div class="obra-details-row">
                                    <span class="subvencion-badge">SUBVENCIÓN</span>
                                    <span class="header-plan" style="font-size: 0.8rem !important; color: #94a3b8 !important; font-weight: 500;">
                                        {{ o.plan_obra }}
                                    </span>
                                </div>
                                {% endif %}
                            </div>
                        </td>
                        <td class="td-ubicacion">
                            {% set estado_inicial = "Finalizada" if o.cond == 2 else ("No iniciada" if o.cond == 1 else "") %}
                            <select class="form-select select-estado-obra" 
                                    data-obra-id="{{ codigo_obra }}"
                                    data-clave="{{ o.clave }}"
                                    data-orden="{{ o.orden }}"
                                    data-nombre="{{ o.nombre }}" 
                                    data-plan="{{ o.plan_obra }}"
                                    data-original="{{ estado_inicial }}">
                                <option value="" {% if o.cond == 0 %}selected{% endif %}>Seleccionar...</option>
                                <option value="No iniciada">No iniciada</option>
                                <option value="En ejecución">En ejecución</option>
                                <option value="Paralizada">Paralizada</option>
                                <option value="Finalizada" {% if o.cond == 2 %}selected{% endif %}>Finalizada</option>
                                <option value="Desconocido">Desconocido / Sin datos</option>
                            </select>
                        </td>
                        <td class="td-ubicacion">
                            {% if o.proyecto == 'RE' %}
                                <div class="form-help" style="font-size: 0.75rem; font-weight: 600;">No requiere documentación</div>
                            {% else %}
                                <div class="adjuntos-obra-wrapper">
                                    {# Botón vinculado al input file oculto específico de esta obra #}
                                    <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('file_obra_{{ codigo_obra }}').click()">
                                        <i data-lucide="paperclip"></i> Adjuntar
                                    </button>
                                    <input type="file" id="file_obra_{{ codigo_obra }}" style="display:none" multiple onchange="manejarAdjuntoObra('{{ codigo_obra }}', this)">
                                    
                                    {# Contenedor de lista: se rellena vía JS con renderColaObras('{{ codigo_obra }}') #}
                                    <div id="lista_adjuntos_{{ codigo_obra }}" class="file-list-container mini-file-list" style="margin-top: 8px;"></div>
                                </div>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# 4. OTRAS OBRAS DETECTADAS #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-plus"></i> OTRAS OBRAS DETECTADAS</h2>
        <div class="card-body">
            <p class="form-help" style="margin-bottom: 1.5rem;">Añada filas para registrar obras ejecutadas o a ejecutar por el ayuntamiento.</p>
            <div class="table-wrapper" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 40%;">Denominación de la Obra</th>
                            <th style="width: 20%;">Estado</th>
                            <th style="width: 20%;">Observaciones</th>
                            <th style="width: 15%; text-align: center;">Documentación</th>
                            <th style="width: 5%;"></th> 
                        </tr>
                    </thead>
                    <tbody id="bodyNuevasObras"></tbody>
                </table>
            </div>
            <div style="margin-top: 1rem;">
                <button type="button" class="btn btn-secondary btn-sm" onclick="window.agregarFilaNuevaObra()" style="background: white;">
                    <i data-lucide="plus"></i> Añadir otra obra
                </button>
            </div>
        </div>
    </div>

    {# 5. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Información solicitada</h2>
        <p class="form-help form-help-spacer">Responda a cada punto y adjunte documentación si es necesario.</p>
        <ul class="requerimientos-list" style="list-style: none; padding: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 12px; padding: 15px; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; color: var(--text-primary); font-size: 0.95rem;">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}
                        <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm">
                            <i data-lucide="map"></i> Mapa
                        </a>
                    {% endif %}
                </div>
                <div style="margin-left: 28px; background: #f8fafc; padding: 16px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" 
                              [cite_start]placeholder="Responda aquí..." style="width: 100%; box-sizing: border-box; display: block; margin-bottom: 12px; background: white;"></textarea>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosReq('{{ req_id }}')">
                        <i data-lucide="paperclip"></i> Adjuntar
                    </button>
                    {{ ui.ayuda_archivo() }}
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 6. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>

<input type="file" id="hiddenFileInput" multiple style="display: none;">
{% endblock %}


{% block scripts %}
<script>

// 1. ESTADO GLOBAL (Unificado para sincronización con borradores)
window.colaAdjuntos = {};    // Para obras (Seguimiento y Nuevas)
window.colaAdjuntosReq = {}; // Para requerimientos
let idObraActual = null;
let reqIdActual = null;
let contadorNuevas = 0;

// 2. FUNCIONES DE GESTIÓN DE ADJUNTOS (Seguimiento y Nuevas Obras)
window.gestionarAdjuntos = function(id) {
    idObraActual = id;
    const input = document.getElementById('hiddenFileInput');
    if (input) input.click();
};

window.manejarAdjuntoObra = function(idObra, input) {
    if (!input.files.length) return;
    if (!window.colaAdjuntos[idObra]) window.colaAdjuntos[idObra] = [];
    
    window.colaAdjuntos[idObra].push(...Array.from(input.files));
    renderAdjuntos(idObra);
    marcarComoSucio(); // Activa el botón de guardar borrador en base.html.j2
    input.value = ""; 
};

window.renderAdjuntos = function(id) {
    const contenedor = document.getElementById(`lista_adjuntos_${id}`);
    if (!contenedor) return;
    
    const archivos = window.colaAdjuntos[id] || [];
    contenedor.innerHTML = archivos.map((f, i) => {
        const isCloud = f.status === 'cloud';
        return `
            <div class="file-item" style="font-size:0.75rem; display:flex; justify-content:space-between; align-items:center; ${isCloud ? 'border-left: 3px solid #10b981; background: #f0fdf4;' : 'border: 1px solid #e2e8f0;'}">
                <span>${isCloud ? '☁️' : '📄'} ${f.name.substring(0,15)}${f.name.length > 15 ? '...' : ''}</span>
                <button type="button" onclick="window.colaAdjuntos['${id}'].splice(${i},1); renderAdjuntos('${id}'); marcarComoSucio();" class="btn-danger-icon">
                    <i data-lucide="trash-2" style="width:14px;"></i>
                </button>
            </div>`;
    }).join("");
    if (window.lucide) lucide.createIcons();
};

// 3. FUNCIONES DE GESTIÓN DE REQUERIMIENTOS
window.gestionarAdjuntosReq = function(id) {
    reqIdActual = id;
    const input = document.getElementById('hiddenInputReq');
    if (input) input.click();
};

window.renderColaReq = function(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    
    const archivos = window.colaAdjuntosReq[id] || [];
    contenedor.innerHTML = archivos.map((f, i) => {
        const isCloud = f.status === 'cloud';
        return `
            <div class="file-item" style="font-size:0.75rem; display:flex; justify-content:space-between; align-items:center; ${isCloud ? 'border-left: 3px solid #10b981; background: #f0fdf4;' : 'border: 1px solid #e2e8f0;'}">
                <span>${isCloud ? '☁️' : '📎'} ${f.name.substring(0,15)}...</span>
                <button type="button" onclick="window.colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}'); marcarComoSucio();" class="btn-danger-icon">
                    <i data-lucide="trash-2" style="width:14px;"></i>
                </button>
            </div>`;
    }).join("");
    if (window.lucide) lucide.createIcons();
};

// 4. FUNCIONES DE FILAS DINÁMICAS (Otras Obras)
window.agregarFilaNuevaObra = function() {
    const tbody = document.getElementById('bodyNuevasObras');
    if (!tbody) return;

    contadorNuevas++;
    const idT = `NUEVA_${contadorNuevas}`;
    const tr = document.createElement('tr');
    tr.id = `fila_${idT}`; tr.className = 'fila-nueva-obra';
    tr.innerHTML = `
        <td><input type="text" class="form-input input-nueva-nombre" placeholder="Ej: Calle Mayor"></td>
        <td><select class="form-select input-nueva-estado"><option value="">Seleccionar...</option><option value="No iniciada">No iniciada</option><option value="En ejecución">En ejecución</option><option value="Paralizada">Paralizada</option><option value="Finalizada">Finalizada</option></select></td>
        <td><textarea class="form-input input-nueva-obs" rows="1" style="min-height: 40px; height: 40px; resize: none;"></textarea></td>
        <td style="text-align:center;">
            <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntos('${idT}')"><i data-lucide="paperclip"></i> Adjuntar</button>
            <div id="lista_adjuntos_${idT}" class="file-list-container mini-file-list" style="margin-top: 5px;"></div>
        </td>
        <td style="text-align:center;">
            <button type="button" onclick="this.closest('tr').remove()" class="btn-danger-icon"><i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i></button>
        </td>`;
    tbody.appendChild(tr);
    if (window.lucide) lucide.createIcons();
    marcarComoSucio();
};

// 5. INICIALIZACIÓN Y EVENTOS
document.addEventListener("DOMContentLoaded", () => {
    const updateSelectColor = (el) => {
        el.value !== "" ? el.classList.add('has-value') : el.classList.remove('has-value');
    };

    document.querySelectorAll('.form-select').forEach(sel => updateSelectColor(sel));
    document.addEventListener('change', (e) => {
        if (e.target.classList.contains('form-select')) updateSelectColor(e.target);
    });

    // Listeners de Inputs de Archivos
    const inputObras = document.getElementById('hiddenFileInput');
    if (inputObras) {
        inputObras.addEventListener('change', () => {
            if (!idObraActual) return;
            if (!window.colaAdjuntos[idObraActual]) window.colaAdjuntos[idObraActual] = [];
            window.colaAdjuntos[idObraActual].push(...Array.from(inputObras.files));
            renderAdjuntos(idObraActual);
            marcarComoSucio();
        });
    }

    const inputReq = document.getElementById('hiddenInputReq');
    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            if (!window.colaAdjuntosReq[reqIdActual]) window.colaAdjuntosReq[reqIdActual] = [];
            window.colaAdjuntosReq[reqIdActual].push(...Array.from(inputReq.files));
            renderColaReq(reqIdActual);
            marcarComoSucio();
        });
    }

    // Lógica de Envío
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) {
        checkConf.addEventListener('change', () => { btnEnviar.disabled = !checkConf.checked; });
    }

    btnEnviar.addEventListener("click", async () => {
        const email = document.getElementById("contactoEmail").value;
        const emailConfirm = document.getElementById("contactoEmailConfirm").value;
        if (email !== emailConfirm) return Swal.fire("Error", "Los correos electrónicos no coinciden.", "error");

        const idBatch = "OBRAS_" + Date.now();
        toggleFormFreeze(true);

        const listaTareas = [];

        // Recolectar Archivos Generales
        if (typeof archivosGenerales !== 'undefined') {
            archivosGenerales.forEach(f => { if (!f.status || f.status !== 'cloud') listaTareas.push({ file: f, seccion: 'GENERAL' }); });
        }

        // Recolectar Archivos de Requerimientos
        Object.entries(window.colaAdjuntosReq).forEach(([id, list]) => {
            list.forEach(f => { if (!f.status || f.status !== 'cloud') listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${id}` }); });
        });

        // Recolectar Archivos de Obras (Seguimiento y Nuevas)
        Object.entries(window.colaAdjuntos).forEach(([id, list]) => {
            list.forEach(f => { if (!f.status || f.status !== 'cloud') listaTareas.push({ file: f, seccion: `OBRA_${id}` }); });
        });

        UIProgress.show(listaTareas.length);

        try {
            if (listaTareas.length > 0) {
                await UploadService.uploadFiles(listaTareas, 'OBRAS', window.EIEL_CONFIG.muniCode, idBatch, 1);
            }

            const payload = {
                tipo_formulario: "obras",
                id_envio: idBatch,
                id_borrador_procedencia: idBorradorOrigen, // ID del borrador para la promoción de archivos
                muni_code: window.EIEL_CONFIG.muniCode,
                datos_obras_json: JSON.stringify(Array.from(document.querySelectorAll('.select-estado-obra')).map(s => ({
                    id_obra: s.dataset.obraId,
                    estado: s.value
                }))),
                otras_obras_json: JSON.stringify(Array.from(document.querySelectorAll('.fila-nueva-obra')).map(f => ({
                    nombre: f.querySelector('.input-nueva-nombre').value,
                    estado: f.querySelector('.input-nueva-estado').value,
                    observaciones: f.querySelector('.input-nueva-obs').value
                }))),
                respuestas_requerimientos_json: JSON.stringify(Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                    pregunta: area.dataset.msg,
                    id: area.dataset.id,
                    respuesta: area.value
                }))),
                observaciones: document.getElementById("observaciones").value,
                contacto: { 
                    nombre: document.getElementById("contactoNombre").value, 
                    departamento: document.getElementById("contactoDepartamento").value,
                    email: email 
                }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            formIsDirty = false;
            UIProgress.complete();
        } catch (error) {
            console.error(error);
            toggleFormFreeze(false);
            Swal.fire("Error", "Hubo un fallo en el proceso de envío.", "error");
        }
    });
});

// Función de apoyo para base.html.j2: Renderiza todas las colas al importar borrador
window.renderArchivos = function() {
    Object.keys(window.colaAdjuntos).forEach(id => renderAdjuntos(id));
    Object.keys(window.colaAdjuntosReq).forEach(id => renderColaReq(id));
};
</script>
{% endblock %}