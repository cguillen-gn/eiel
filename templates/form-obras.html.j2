{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# Configuramos el tema para este formulario #}
{% set ficha_tipo = 'obras' %}

{% block title %}EIEL - Seguimiento de Obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}SEGUIMIENTO DE OBRAS{% endblock %}

{% block content %}
<form id="formObras">
    {# 1. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li><strong>Estado:</strong> Actualice el estado de ejecución de las obras en seguimiento.</li>
            <li><strong>Documentación:</strong> Adjunte al menos memoria y planos por cada actuación.</li>
        </ul>
    </div>

    {# 2. TABLA DE SEGUIMIENTO (Obras Existentes) #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-checks"></i> Obras en Seguimiento</h2>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%;" class="td-ubicacion">Id</th>
                        <th style="width: 60%;">Denominación</th>
                        <th style="width: 20%;" class="td-ubicacion">Estado</th>
                        <th style="width: 15%;" class="td-ubicacion">Documentación</th>
                    </tr>
                </thead>
                <tbody>
                    {% for o in obras %}
                    {% set codigo_obra = o.clave ~ o.mun ~ o.orden %}
                    <tr class="fila-obra">
                        <td class="td-ubicacion text-xs" style="font-weight: 500; color: var(--text-secondary);">
                            {{ codigo_obra[-3:] }}
                        </td>
                        <td>
                            <div class="obra-column-container">
                                <span class="item-title">{{ o.nombre }}</span>
                                {% if o.plan_obra and "licitaciones" not in o.plan_obra|lower and "contratos menores" not in o.plan_obra|lower %}
                                <div class="obra-details-row">
                                    <span class="subvencion-badge">SUBVENCIÓN</span>
                                    <span class="header-plan" style="font-size: 0.8rem !important; color: #94a3b8 !important; font-weight: 500;">
                                        {{ o.plan_obra }}
                                    </span>
                                </div>
                                {% endif %}
                            </div>
                        </td>
                        <td class="td-ubicacion">
                            {% set estado_inicial = "Finalizada" if o.cond == 2 else ("No iniciada" if o.cond == 1 else "") %}
                            <select class="form-select select-estado-obra" 
                                    data-obra-id="{{ codigo_obra }}"
                                    data-clave="{{ o.clave }}"
                                    data-orden="{{ o.orden }}"
                                    data-nombre="{{ o.nombre }}" 
                                    data-plan="{{ o.plan_obra }}"
                                    data-original="{{ estado_inicial }}">
                                <option value="" {% if o.cond == 0 %}selected{% endif %}>Seleccionar...</option>
                                <option value="No iniciada" {% if o.cond == 1 %}selected{% endif %}>No iniciada</option>
                                <option value="En ejecución">En ejecución</option>
                                <option value="Paralizada">Paralizada</option>
                                <option value="Finalizada" {% if o.cond == 2 %}selected{% endif %}>Finalizada</option>
                                <option value="Desconocido">Desconocido / Sin datos</option>
                            </select>
                        </td>
                        <td class="td-ubicacion">
                            {% if o.proyecto == 'RE' %}
                                <div class="form-help" style="font-size: 0.75rem; font-weight: 600;">No requiere documentación</div>
                            {% else %}
                                <input type="file" id="file_obra_{{ codigo_obra }}" class="hidden input-adjunto-obra" data-id="{{ codigo_obra }}" multiple>
                                <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('file_obra_{{ codigo_obra }}').click()" title="Adjuntar documentación">
                                    <i data-lucide="paperclip"></i> Adjuntar
                                </button>
                            {% endif %}
                            <div id="lista_adjuntos_{{ codigo_obra }}" class="file-list-container" style="margin-top: 5px;"></div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# 3. OTRAS OBRAS DETECTADAS (Entrada Manual) #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-plus"></i> OTRAS OBRAS DETECTADAS</h2>
        <p class="form-help" style="margin-bottom: 1.5rem;">
            Añada filas para registrar obras <strong>ejecutadas o a ejecutar por el ayuntamiento</strong> que no figuran en el listado superior.
        </p>
        <div class="table-wrapper" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40%;">Denominación de la Obra</th>
                        <th style="width: 20%;">Estado</th>
                        <th style="width: 20%;">Observaciones</th>
                        <th style="width: 15%; text-align: center;">Documentación</th>
                        <th style="width: 5%;"></th> 
                    </tr>
                </thead>
                <tbody id="bodyNuevasObras"></tbody>
            </table>
        </div>
        <div style="margin-top: 1rem;">
            <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('file_${idTemp}').click()" title="Adjuntar documentación">
                <i data-lucide="paperclip"></i> Adjuntar
            </button>
        </div>
    </div>

    {# 4. BLOQUES UNIFICADOS (Macros) #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
{% endblock %}

{% block scripts %}
<script>
let archivosPorObra = {}; // Diccionario: { id_obra: [File, File...] }
let contadorNuevas = 0;

function renderAdjuntos(id) {
    const contenedor = document.getElementById(`lista_adjuntos_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (archivosPorObra[id] || []).map((f, i) => `
        <div class="file-item" style="font-size:0.7rem; border:1px solid #e2e8f0; margin-bottom:2px; padding:2px; border-radius:4px; display:flex; justify-content:space-between; align-items:center;">
            <span title="${f.name}">📄 ${f.name.substring(0,12)}...</span>
            <button type="button" onclick="eliminarArchivo('${id}', ${i})" class="btn-danger-icon"><i data-lucide="trash-2" style="width:12px;"></i></button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}

window.eliminarArchivo = (id, index) => { 
    archivosPorObra[id].splice(index, 1);
    renderAdjuntos(id); 
};

window.agregarFilaNuevaObra = () => {
    contadorNuevas++; 
    const idTemp = `NUEVA_${contadorNuevas}`;
    const tbody = document.getElementById('bodyNuevasObras');
    const tr = document.createElement('tr');
    tr.id = `fila_${idTemp}`;
    tr.className = 'fila-nueva-obra';
    tr.innerHTML = `
        <td><input type="text" class="form-input input-nueva-nombre" data-temp-id="${idTemp}" placeholder="Ej: Urbanización C/La Paz"></td>
        <td><select class="form-select input-nueva-estado"><option value="">Seleccionar...</option><option value="No iniciada">No iniciada</option><option value="En ejecución">En ejecución</option><option value="Paralizada">Paralizada</option><option value="Finalizada">Finalizada</option></select></td>
        <td><textarea class="form-input input-nueva-obs" rows="1" style="min-height:40px; height:40px; resize:none;"></textarea></td>
        <td style="text-align:center;">
            <input type="file" id="file_${idTemp}" class="hidden" multiple onchange="adjuntarNueva('${idTemp}', this)">
            <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('file_${idTemp}').click()"><i data-lucide="paperclip"></i> <span id="count_${idTemp}">0</span></button>
            <div id="lista_adjuntos_${idTemp}" class="file-list-container" style="margin-top:5px;"></div>
        </td>
        <td><button type="button" class="btn-danger-icon" onclick="document.getElementById('fila_${idTemp}').remove()"><i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i></button></td>`;
    tbody.appendChild(tr);
    if (window.lucide) lucide.createIcons();
};

window.adjuntarNueva = (id, input) => {
    archivosPorObra[id] = [...(archivosPorObra[id] || []), ...Array.from(input.files)];
    renderAdjuntos(id);
};

document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll('.input-adjunto-obra').forEach(input => {
        input.addEventListener('change', (e) => {
            const id = e.target.dataset.id;
            archivosPorObra[id] = [...(archivosPorObra[id] || []), ...Array.from(e.target.files)];
            renderAdjuntos(id);
        });
    });

    agregarFilaNuevaObra(); // Iniciar con una fila vacía

    const btnEnviar = document.getElementById("btnEnviar");
    btnEnviar.addEventListener("click", async () => {
        const idBatch = "OBRAS_" + Date.now();
        toggleFormFreeze(true);

        const listaTareas = [];
        Object.entries(archivosPorObra).forEach(([id, files]) => {
            files.forEach(f => listaTareas.push({ file: f, seccion: id }));
        });

        UIProgress.show(listaTareas.length);

        try {
            await UploadService.uploadFiles(listaTareas, 'OBRAS', window.EIEL_CONFIG.muniCode, idBatch, 3);
            UIProgress.update(listaTareas.length, listaTareas.length, "Generando PDF...");

            const payload = {
                tipo: "obras",
                id_envio: idBatch,
                seguimiento: Array.from(document.querySelectorAll('.select-estado-obra')).map(s => ({
                    obra: s.dataset.obraId, estado: s.value
                })),
                nuevas: Array.from(document.querySelectorAll('.fila-nueva-obra')).map(f => ({
                    nombre: f.querySelector('.input-nueva-nombre').value,
                    estado: f.querySelector('.input-nueva-estado').value
                })),
                observaciones: document.getElementById("observaciones").value,
                contacto: { nombre: document.getElementById("contactoNombre").value, email: document.getElementById("contactoEmail").value }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();
        } catch (error) {
            console.error(error);
            toggleFormFreeze(false);
        }
    });
});
</script>
{% endblock %}