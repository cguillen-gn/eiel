{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# Configuramos el tema para este formulario #}
{% set ficha_tipo = 'obras' %}

{% block title %}EIEL - Seguimiento de Obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}SEGUIMIENTO DE OBRAS{% endblock %}

{% block content %}
<form id="formObras">
    {# 1. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li><strong>Estado:</strong> Actualice el estado de ejecución de las obras en seguimiento.</li>
            <li><strong>Documentación:</strong> Adjunte al menos memoria y planos por cada actuación.</li>
        </ul>
    </div>

    {# 2. TABLA DE SEGUIMIENTO (Obras Existentes) #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-checks"></i> Obras en Seguimiento</h2>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">ID</th>
                        <th>Denominación de la Obra</th>
                        <th style="width: 200px;">Estado Actual</th>
                        <th style="width: 120px;">Adjuntos</th>
                    </tr>
                </thead>
               <tbody>
                    {% if obras_json and obras_json != "[]" %}
                        {% for obra in obras_json | fromjson %}
                        <tr>
                            <td class="td-ubicacion text-xs" style="font-weight: 500; color: var(--text-secondary);">{{ obra.id }}</td>
                            <td>
                                <div class="obra-column-container">
                                    <span class="item-title">{{ obra.denominacion }}</span>
                                    <span class="text-xs" style="color: var(--text-secondary);">{{ obra.expediente }}</span>
                                </div>
                            </td>
                            <td>
                                <select class="form-select select-estado-obra" data-id="{{ obra.id }}">
                                    <option value="En Ejecución" {% if obra.estado == 'En Ejecución' %}selected{% endif %}>En Ejecución</option>
                                    <option value="Finalizada" {% if obra.estado == 'Finalizada' %}selected{% endif %}>Finalizada</option>
                                    <option value="Paralizada" {% if obra.estado == 'Paralizada' %}selected{% endif %}>Paralizada</option>
                                </select>
                            </td>
                            <td class="td-ubicacion">
                                <input type="file" id="file_obra_{{ obra.id }}" class="hidden input-adjunto-obra" data-id="{{ obra.id }}" multiple>
                                <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('file_obra_{{ obra.id }}').click()" title="Adjuntar documentación específica">
                                    <i data-lucide="paperclip"></i> <span class="count-adjuntos" id="count_{{ obra.id }}">0</span>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 2rem; color: var(--text-secondary); font-style: italic;">
                                No hay obras en seguimiento registradas para este municipio.
                            </td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    {# 3. SECCIÓN DE NUEVAS OBRAS (Si aplica) #}
    {% if otras_obras_json and otras_obras_json != "[]" and otras_obras_json != "null" %}
    <div class="card">
        <h2 class="section-title"><i data-lucide="search-code"></i> Otras obras detectadas</h2>
        <p class="sin-uso-intro">ℹ️ Se han detectado las siguientes actuaciones adicionales en su municipio:</p>
        <div class="table-wrapper">
          <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 70%;">Denominación de la actuación detectada</th>
                        <th style="width: 30%; text-align: center;">¿Ha finalizado?</th>
                    </tr>
                </thead>
                <tbody>
                    {% set lista_otras = otras_obras_json | fromjson %}
                    {% for o in lista_otras %}
                    <tr>
                        <td><span class="item-title">{{ o.denominacion }}</span></td>
                        <td>
                            <select class="form-select select-otra-obra" data-deno="{{ o.denominacion }}">
                                <option value="No">No / En curso</option>
                                <option value="Si">Sí, finalizada</option>
                            </select>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
      </div>
    </div>
    {% endif %}

    {# 4. BLOQUES UNIFICADOS (Macros) #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
{% endblock %}

{% block scripts %}
<script>
// --- [1] ESTADO LOCAL DE ARCHIVOS ---
let archivosGenerales = [];
let archivosPorObra = {}; // Diccionario: { id_obra: [File, File...] }

document.addEventListener("DOMContentLoaded", () => {
    
    // -- Manejo de adjuntos específicos por obra --
    document.querySelectorAll('.input-adjunto-obra').forEach(input => {
        input.addEventListener('change', (e) => {
            const idObra = e.target.dataset.id;
            const nuevos = Array.from(e.target.files);
            archivosPorObra[idObra] = [...(archivosPorObra[idObra] || []), ...nuevos];
            document.getElementById(`count_${idObra}`).textContent = archivosPorObra[idObra].length;
        });
    });

    // -- Manejo de adjuntos generales (vía Macro) --
    const fileInputGral = document.getElementById('fileInput');
    fileInputGral.addEventListener('change', () => {
        archivosGenerales = [...archivosGenerales, ...Array.from(fileInputGral.files)];
        const listGral = document.getElementById('fileList');
        listGral.innerHTML = archivosGenerales.map((f, i) => `
            <div class="file-item">
                <span>${f.name}</span>
                <button type="button" class="btn-remove" onclick="archivosGenerales.splice(${i},1); document.dispatchEvent(new Event('DOMContentLoaded'));">Eliminar</button>
            </div>`).join('');
    });

    // -- ENVÍO DE DATOS --
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    checkConf.addEventListener('change', () => btnEnviar.disabled = !checkConf.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "OBRAS_" + Date.now();
        
        toggleFormFreeze(true);

        // A. PREPARAR LISTA TOTAL DE TAREAS PARA EL MOTOR
        const listaTareas = [];
        
        // 1. Añadir generales
        archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
        
        // 2. Añadir por obra
        Object.entries(archivosPorObra).forEach(([id, files]) => {
            files.forEach(f => listaTareas.push({ file: f, seccion: `OBRA_${id}` }));
        });

        UIProgress.show(listaTareas.length);

        try {
            // B. SUBIDA POR LOTES (Concurrencia = 3)
            // Aquí es donde aplicamos la potencia para Obras
            await UploadService.uploadFiles(listaTareas, 'OBRAS', window.EIEL_CONFIG.muniCode, idBatch, 3);

            UIProgress.update(listaTareas.length, listaTareas.length, "Registrando estados y generando PDF...");

            // C. PAYLOAD FINAL
            const payload = {
                tipo: "obras",
                id_envio: idBatch,
                municipio: window.EIEL_CONFIG.muniCode,
                seguimiento: Array.from(document.querySelectorAll('.select-estado-obra')).map(s => ({
                    id: s.dataset.id,
                    estado: s.value
                })),
                observaciones: document.getElementById("observaciones").value,
                contacto: {
                    nombre: document.getElementById("contactoNombre").value,
                    email: document.getElementById("contactoEmail").value
                }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { 
                method: "POST", 
                mode: "no-cors", 
                body: JSON.stringify(payload) 
            });

            UIProgress.complete();
            if (window.lucide) lucide.createIcons();

        } catch (error) {
            console.error(error);
            Swal.fire("Error", "Fallo al enviar los datos de obras.", "error");
            toggleFormFreeze(false);
        }
    });
});
</script>
{% endblock %}