{% extends "base.html.j2" %}
{% import "macros.html.j2" as components %}

{% block title %}EIEL - Obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}SEGUIMIENTO DE OBRAS{% endblock %}

{% block content %}

{# 1. Instrucciones #}
{{ components.render_instrucciones([
    '<strong>Estado:</strong> Actualice el estado de ejecución para cada obra del listado.',
    '<strong>Documentación:</strong> Adjunte al menos memoria y planos para cada actuación. Si no dispone de ellos, justifíquelo en Observaciones.',
    'Si existen obras nuevas no listadas, descríbalas en el apartado de <strong>Observaciones Finales</strong>.'
]) }}

{# 2. Requerimientos dinámicos #}
{{ components.render_requerimientos(avisos_personalizados) }}

{# 3. SECCIÓN ESPECÍFICA: LISTADO DE OBRAS #}
<div class="card">
    <h2 class="section-title"><i data-lucide="list-checks"></i> Listado de Seguimiento</h2>
    <div class="table-wrapper">
        <table class="data-table" id="tablaObras">
            <thead>
                <tr>
                    <th style="width: 10%;">ID</th>
                    <th style="width: 45%;">Denominación de la Obra</th>
                    <th style="width: 20%;">Estado Actual</th>
                    <th style="width: 25%;">Documentación</th>
                </tr>
            </thead>
            <tbody>
                {% for obra in obras %}
                <tr class="obra-row" data-obra-id="{{ obra.id }}" data-obra-nombre="{{ obra.denominacion }}">
                    <td style="font-family: monospace; font-weight: bold;">{{ obra.id }}</td>
                    <td>
                        <div style="font-weight: 600;">{{ obra.denominacion }}</div>
                        <div style="font-size: 0.75rem; color: var(--text-secondary);">{{ obra.descripcion or '' }}</div>
                    </td>
                    <td>
                        <select class="form-select val-estado">
                            <option value="">Seleccionar...</option>
                            <option value="EJECUTADA" {% if obra.estado == 'EJECUTADA' %}selected{% endif %}>Ejecutada</option>
                            <option value="EN EJECUCION" {% if obra.estado == 'EN EJECUCION' %}selected{% endif %}>En ejecución</option>
                            <option value="EN PROYECTO" {% if obra.estado == 'EN PROYECTO' %}selected{% endif %}>En proyecto</option>
                            <option value="PARALIZADA" {% if obra.estado == 'PARALIZADA' %}selected{% endif %}>Paralizada</option>
                            <option value="ANULADA" {% if obra.estado == 'ANULADA' %}selected{% endif %}>Anulada</option>
                        </select>
                    </td>
                    <td>
                        <div class="adjunto-obra-container">
                            <input type="file" id="file_obra_{{ obra.id }}" class="hidden" 
                                   onchange="handleFileSelectObra(event, '{{ obra.id }}')">
                            <label class="btn" for="file_obra_{{ obra.id }}" style="padding: 5px 10px; font-size: 0.8rem; background: #f1f5f9; border: 1px dashed var(--border); width: 100%; justify-content: center;">
                                <i data-lucide="upload-cloud"></i> Subir Doc.
                            </label>
                            <div id="file_list_obra_{{ obra.id }}" class="file-list-mini" style="margin-top: 5px; font-size: 0.7rem; color: var(--success);"></div>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# 4. Observaciones y Footer #}
{{ components.render_observaciones_finales() }}
{{ components.render_footer_envio() }}

{% endblock %}

{% block scripts %}
<script>
/**
 * LÓGICA ESPECÍFICA DE OBRAS
 */
let colaAdjuntosObras = {}; // { obraId: File }

// Manejar archivos específicos de cada obra
window.handleFileSelectObra = function(event, obraId) {
    const file = event.target.files[0];
    if (!file) return;

    if (file.size > 15 * 1024 * 1024) { // 15MB para proyectos de obra
        Swal.fire("Archivo pesado", "El límite para proyectos es 15MB", "warning");
        event.target.value = "";
        return;
    }

    colaAdjuntosObras[obraId] = file;
    document.getElementById(`file_list_obra_${obraId}`).innerHTML = `
        <i data-lucide="file-check"></i> ${file.name}
    `;
    lucide.createIcons();
};

document.addEventListener('DOMContentLoaded', () => {
    
    document.getElementById('btnEnviar').addEventListener('click', async () => {
        
        processSubmit(async () => {
            const datosObras = [];
            const nombresArchivosObras = [];

            // 1. Procesar cada fila de la tabla
            const filas = document.querySelectorAll('.obra-row');
            
            for (const fila of filas) {
                const obraId = fila.dataset.obraId;
                const obraNombre = fila.dataset.obraNombre;
                const estado = fila.querySelector('.val-estado').value;
                let adjuntoNombre = "No aportado";

                // 2. Si hay un archivo para esta obra, lo subimos antes de cerrar el payload
                // Nota: uploadToDrive está disponible globalmente en form-handler.js
                if (colaAdjuntosObras[obraId]) {
                    UI.showProgress(`Subiendo doc. obra ${obraId}...`);
                    const uploaded = await uploadToDrive(colaAdjuntosObras[obraId], `OBRA_${obraId}`, "ENV_OBRAS_" + Date.now());
                    if (uploaded) adjuntoNombre = uploaded;
                }

                datosObras.push({
                    id: obraId,
                    denominacion: obraNombre,
                    estado: estado,
                    archivo: adjuntoNombre
                });
            }

            return {
                datos_obras_json: JSON.stringify(datosObras)
            };
        });
    });
});
</script>
{% endblock %}