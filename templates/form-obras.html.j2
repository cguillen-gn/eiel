﻿{% extends "base.html.j2" %}

{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block title %}EIEL - Obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}OBRAS{% endblock %}

{% block content %}

{# --- SECCIÓN: INSTRUCCIONES --- #}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul>
        <li><strong>Estado:</strong> Rellene el estado en todas las obras del listado de seguimiento.</li>
        <li><strong>Documentación:</strong> Adjunte proyecto de cada obra o la información disponible. Si no dispone de documentación, justifíquelo en el apartado final de <strong>Observaciones</strong>.</li>
    </ul>
</div>

{# --- SECCIÓN: SEGUIMIENTO DE OBRAS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="list-checks"></i> SEGUIMIENTO DE OBRAS</h2>
    <div class="table-wrapper" style="margin: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 5%;" class="td-ubicacion">Id</th>
                    <th style="width: 60%;">Denominación</th>
                    <th style="width: 20%;" class="td-ubicacion">Estado</th>
                    <th style="width: 15%;" class="td-ubicacion">Documentación</th>
                </tr>
            </thead>
            
            <tbody>
                {% for o in obras %}
                {% set codigo_obra = o.clave ~ o.mun ~ o.orden %}
                <tr class="fila-obra">
                    
                    <td class="td-ubicacion text-xs" style="font-weight: 500; color: var(--text-secondary);">
                        {{ codigo_obra[-3:] }}
                    </td>

                    <td>
                        <div class="obra-column-container">
                            <div class="item-title-row">
                                <span class="item-title">{{ o.nombre }}</span>
                            </div>

                            {% if o.plan_obra %}
                                <div class="obra-details-row">
                                    <span class="subvencion-badge">SUBVENCIÓN</span>
                                    <span class="header-plan">{{ o.plan_obra }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </td>
                  
                    
                    
                    <td class="td-ubicacion">
                        {% set estado_inicial = "Finalizada" if o.cond == 2 else ("No iniciada" if o.cond == 1 else "") %}
                        <select class="form-select select-estado" 
                            data-obra-id="{{ codigo_obra }}"
                            data-clave="{{ o.clave }}"
                            data-orden="{{ o.orden }}"
                            data-nombre="{{ o.nombre }}" 
                            data-plan="{{ o.plan_obra }}"
                            data-original="{{ estado_inicial }}"
                            data-requiere-doc="{{ 'false' if o.proyecto == 'RE' else 'true' }}">
                            
                            <option value="" {% if o.cond == 0 %}selected{% endif %}>
                                Seleccionar...
                            </option>
                            <option value="No iniciada">No iniciada</option>
                            <option value="En ejecución">En ejecución</option>
                            <option value="Paralizada">Paralizada</option>
                            <option value="Finalizada" {% if o.cond == 2 %}selected{% endif %}>
                                Finalizada
                            </option>
                        </select>
                    </td>

                    <td class="td-ubicacion">
                        {% if o.proyecto == 'RE' %}
                            <div class="form-help" style="font-size: 0.75rem; font-weight: 600;">
                            No requiere documentación
                            </div>
                        {% else %}
                            <button type="button" class="btn btn-secondary btn-sm" 
                                    onclick="gestionarAdjuntos('{{ codigo_obra }}')">
                                <i data-lucide="paperclip"></i> Adjuntar
                            </button>
                            <div id="lista_adjuntos_{{ codigo_obra }}" class="file-list-container" style="margin-top: 5px;"></div>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# --- SECCIÓN: OTRAS OBRAS --- #}
<div class="card" style="border-style: dashed; background-color: #f8fafc;">
    <h2 class="section-title"><i data-lucide="list-plus"></i> OTRAS OBRAS DETECTADAS</h2>
    <div class="card-body">
        <p class="form-help" style="margin-bottom: 1.5rem;">
            Añada filas para registrar obras <strong>ejecutadas o a ejecutar por el ayuntamiento</strong> que no figuran en el listado superior.
        </p>

        <div class="table-wrapper" style="margin: 0; background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%;"></th> <th style="width: 55%;">Denominación de la Obra</th>
                        <th style="width: 20%;" class="td-ubicacion">Estado</th>
                        <th style="width: 15%;" class="td-ubicacion">Documentación</th>
                        <th style="width: 5%;"></th> </tr>
                </thead>
                <tbody id="bodyNuevasObras">
                    </tbody>
            </table>
        </div>

        <div style="margin-top: 1rem;">
            <button type="button" class="btn btn-secondary btn-sm" onclick="agregarFilaNuevaObra()" style="background: white;">
                <i data-lucide="plus"></i> Añadir otra obra
            </button>
        </div>
    </div>
</div>

{# --- SECCIÓN: REQUERIMIENTOS --- #}
{% if avisos_personalizados and avisos_personalizados|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h2 class="section-title">
            <i data-lucide="circle-plus"></i> Información solicitada
        </h2>
        
        <p class="form-help" style="margin-bottom: 1.5rem;">
            Se ha detectado falta de información o incidencias en las Obras que requieren su atención. Responda a cada punto y adjunte documentación si es necesario.
        </p>

        <ul class="requerimientos-list" style="list-style: none; padding: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; align-items: stretch; gap: 10px; padding: 15px; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; color: var(--text-primary); font-size: 0.95rem;">{{ aviso.mensaje }}</span>
                    </div>
                    
                    {% if aviso.url %}
                        {% set final_url = aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url %}
                        <a href="{{ final_url }}" target="_blank" class="btn btn-secondary btn-sm" style="display: flex; align-items: center; gap: 5px; text-decoration: none; background: white; border: 1px solid #cbd5e1;">
                            <i data-lucide="map" style="width: 14px; height: 14px;"></i> Mapa
                        </a>
                    {% endif %}
                </div>
                
                <div style="margin-left: 28px; background: #f8fafc; padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="2" 
                              placeholder="Responda o aclare este punto aquí..." style="font-size: 0.85rem; margin-bottom: 8px; background: white;"></textarea>
                    
                    <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 10px;">
                        <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntosReq('{{ req_id }}')" style="background: white; border: 1px solid #cbd5e1;">
                            <i data-lucide="paperclip" style="width: 14px;"></i> Adjuntar doc.
                        </button>
                        <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin: 0; display: flex; flex-direction: column; gap: 4px; width: 100%;"></div>
                    </div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
</div>
{% endif %}

{# --- SECCIÓN: OBSERVACIONES --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" style="font-family: inherit;" placeholder="Indique aquí cualquier incidencia, aclaración o dato relevante..."></textarea>
    </div>
</div>

{# --- SECCIÓN: DATOS DE CONTACTO --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required>
        </div>
        <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;">
            </div>
    </div>
</div>

{# --- SECCIÓN: DECLARACIÓN RESPONSABLE --- #}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text">
                <strong>Declaración de veracidad:</strong> Como responsable, 
                confirmo que los datos introducidos son correctos y actualizados.
            </span>
        </label>
    </div>

    
{# --- SECCIÓN: ENVÍO --- #}

<div id="mensaje" class="message hidden"></div>

<div id="progressContainer" class="progress-container hidden">
    <div class="progress-labels">
        <span id="progressText">Preparando envío...</span>
        <span id="progressPercentage">0%</span>
    </div>
    <div class="progress-track">
        <div id="progressBar"></div>
    </div>
</div>

    

    
    <button id="btnEnviar" class="btn btn-primary btn-obras" disabled>
        Enviar Datos
    </button>
    
    
</div>

<input type="file" id="hiddenFileInput" multiple style="display: none;">

{% endblock %}

{% block scripts %}
<script>
document.addEventListener("DOMContentLoaded", () => {
    
    // 0. ACTIVADOR DE TEMA
    document.body.classList.add('theme-obras');
    
    // Ejecuta la creación de iconos de Lucide
    if (window.lucide) {
        lucide.createIcons();
    }

    // 1. SETUP DE ESTILOS
    const header = document.querySelector('.site-header');
    if(header) header.classList.add('header-obras');
    
    // Cambio de color dinámico para los estados
    document.querySelectorAll('.select-estado').forEach(select => {
        if (select.value !== "") select.classList.add('has-value');
        
        select.addEventListener('change', function() {
            if (this.value !== "") 
                this.classList.add('has-value');
            else 
                this.classList.remove('has-value');
        });
    });

    // 2. CONFIGURACIÓN GLOBAL
    window.EIEL_CONFIG = {
        muniCode: "{{ muni_code }}",
        muniName: "{{ muni_display }}",
        fase: "{{ fase_actual }}",
        urlGenerarPdf: "{{ url_generar_pdf }}",
        urlAdjuntos: "{{ url_adjuntos }}",
        urlLogger: "{{ url_logger }}",
        hasAvisos: {{ 'true' if avisos_personalizados and avisos_personalizados|length > 0 else 'false' }},
        yearActual: new Date().getFullYear() // Año dinámico para validaciones
    };

    // 3. INICIALIZACIÓN UI
    // 3.1 Marcado visual de obligatoriedad en observaciones
    if (window.EIEL_CONFIG.hasAvisos) {
        const labelObs = document.querySelector("label[for='observaciones']");
        if (labelObs) {
            labelObs.innerHTML += " <span class='text-required'>(* Obligatorio)</span>";
        }
    }

    // 4. SERVICIOS Y UTILIDADES DE UI
    const UIProgress = {
    container: document.getElementById("progressContainer"),
    bar: document.getElementById("progressBar"),
    text: document.getElementById("progressText"),
    percent: document.getElementById("progressPercentage"),
    // Variable para recordar el punto más alto alcanzado
    maxReached: 0, 

    show(totalTasks) {
        this.maxReached = 0; // Reiniciamos al empezar
        if (this.container) this.container.classList.remove('hidden');
        this.update(0, totalTasks, "Iniciando envío...");
    },

    update(completed, total, message) {
        const msg = message.toLowerCase();
        // Detectamos si es el paso del registro o PDF
        const isFinalStep = msg.includes("pdf") || msg.includes("registro") || msg.includes("justificante");
        
        let targetPercentage = 0;
        if (total > 0) {
            const fileWeight = 90 / total;
            targetPercentage = isFinalStep ? 95 : Math.round(completed * fileWeight);
        } else {
            targetPercentage = isFinalStep ? 95 : 0;
        }

        // --- EL BLOQUEO DE SEGURIDAD ---
        // Solo actualizamos si el nuevo porcentaje es mayor al que ya mostramos
        if (targetPercentage > this.maxReached) {
            this.maxReached = targetPercentage;
            if (this.bar) this.bar.style.width = this.maxReached + "%";
            if (this.percent) this.percent.textContent = this.maxReached + "%";
        }
        
        // El texto sí lo actualizamos siempre para dar feedback constante
        if (this.text && message) this.text.textContent = message;
    },

    complete() {
        this.maxReached = 100;
        if (this.bar) {
            this.bar.style.width = "100%";
            this.bar.classList.add("progress-success");
        }
        if (this.percent) this.percent.textContent = "100%";
        if (this.text) this.text.textContent = "✅ ¡Envío completado con éxito! Se ha enviado un justificante al email facilitado";
    }
    };

    const UploadService = {
        toBase64: file => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        }),

        async uploadFile(file, tipoFicha, muniCode, codigoObra = null, idEnvio) {
            try {
                const base64 = await this.toBase64(file);
                const contactoEmail = document.getElementById("contactoEmail")?.value || "anonimo";

                const payload = {
                    filename: file.name,
                    mimeType: file.type,
                    bytesBase64: base64, 
                    municipio: muniCode,
                    usuario: contactoEmail,
                    tipo: tipoFicha,
                    seccion: codigoObra,
                    id_envio: idEnvio
                };
                
                await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                    method: 'POST',
                    mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                return true;
            } catch (e) {
                console.error("Error subiendo:", e);
                return false;
            }
        }
    };

    // 5. UTILIDADES Y GESTIÓN DE FILAS DE OBRAS
    const UIProgress = {
        container: document.getElementById("progressContainer"),
        bar: document.getElementById("progressBar"),
        text: document.getElementById("progressText"),
        percent: document.getElementById("progressPercentage"),
        maxReached: 0,
        show(totalTasks) {
            this.maxReached = 0;
            if (this.container) this.container.classList.remove('hidden');
            this.update(0, totalTasks, "Iniciando envío...");
        },
        update(completed, total, message) {
            const isFinalStep = message.toLowerCase().includes("pdf") || message.toLowerCase().includes("registro");
            let targetPercentage = total > 0 ? (isFinalStep ? 95 : Math.round(completed * (90 / total))) : (isFinalStep ? 95 : 0);
            if (targetPercentage >= this.maxReached) {
                this.maxReached = targetPercentage;
                if (this.bar) this.bar.style.width = this.maxReached + "%";
                if (this.percent) this.percent.textContent = this.maxReached + "%";
            }
            if (this.text) this.text.textContent = message;
        },
        complete() {
            if (this.bar) { this.bar.style.width = "100%"; this.bar.classList.add("progress-success"); }
            if (this.percent) this.percent.textContent = "100%";
            if (this.text) this.text.textContent = "✅ ¡Envío completado! Justificante generado correctamente.";
        }
    };

    const UploadService = {
        toBase64: file => new Promise((resolve, reject) => {
            const reader = new FileReader(); reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        }),
        async uploadFile(file, tipoFicha, muniCode, seccion, idEnvio) {
            try {
                const base64 = await this.toBase64(file);
                const userEmail = document.getElementById("contactoEmail").value || "anonimo";
                const payload = {
                    filename: file.name, mimeType: file.type, bytesBase64: base64, 
                    municipio: muniCode, usuario: userEmail, tipo: tipoFicha,
                    seccion: seccion, id_envio: idEnvio
                };
                await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                    method: 'POST', mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                return true;
            } catch (e) { return false; }
        }
    };

    // --- GESTIÓN DE ADJUNTOS POR OBRA (Tabla Seguimiento y Nuevas) ---
    let colaAdjuntos = {}; 
    let idObraActual = null;
    const inputObras = document.getElementById('hiddenInputAdjuntos');

    window.gestionarAdjuntos = (id) => { idObraActual = id; inputObras.click(); };

    if (inputObras) {
        inputObras.addEventListener('change', () => {
            const files = Array.from(inputObras.files);
            if (!files.length || !idObraActual) return;
            if (!colaAdjuntos[idObraActual]) colaAdjuntos[idObraActual] = [];
            colaAdjuntos[idObraActual].push(...files);
            renderAdjuntos(idObraActual);
            inputObras.value = ""; idObraActual = null;
        });
    }

    function renderAdjuntos(id) {
        const contenedor = document.getElementById(`lista_adjuntos_${id}`);
        if (!contenedor) return;
        contenedor.innerHTML = (colaAdjuntos[id] || []).map((f, i) => `
            <div class="file-item" style="font-size:0.7rem; border:1px solid #e2e8f0; margin-bottom:2px; padding:2px; border-radius:4px; display:flex; justify-content:space-between; align-items:center;">
                <span title="${f.name}">📄 ${f.name.substring(0,10)}...</span>
                <button type="button" onclick="eliminarArchivo('${id}', ${i})" class="btn-danger-icon"><i data-lucide="trash-2" style="width:12px;"></i></button>
            </div>
        `).join("");
        if (window.lucide) lucide.createIcons();
    }

    window.eliminarArchivo = (id, index) => { colaAdjuntos[id].splice(index, 1); renderAdjuntos(id); };

    // --- GESTIÓN DE FILAS PARA OTRAS OBRAS (Nuevas) ---
    let contadorNuevas = 0;
    window.agregarFilaNuevaObra = () => {
        contadorNuevas++;
        const idTemp = `NUEVA_${Date.now()}`;
        const tbody = document.getElementById('bodyNuevasObras');
        const tr = document.createElement('tr');
        tr.className = 'fila-nueva-obra';
        tr.innerHTML = `
            <td style="text-align: center; color: #64748b;">${contadorNuevas}</td>
            <td><input type="text" class="form-input input-nueva-nombre" data-temp-id="${idTemp}" placeholder="Nombre de la obra detectada..."></td>
            <td>
                <select class="form-select input-nueva-estado">
                    <option value="">Seleccionar...</option>
                    <option value="Finalizada">Finalizada</option>
                    <option value="En ejecución">En ejecución</option>
                    <option value="Paralizada">Paralizada</option>
                </select>
            </td>
            <td style="text-align: center;">
                <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntos('${idTemp}')">
                    <i data-lucide="paperclip" style="width:14px;"></i> Adjuntar
                </button>
                <div id="lista_adjuntos_${idTemp}" class="file-list-container" style="margin-top: 5px;"></div>
            </td>
        `;
        tbody.appendChild(tr);
        if (window.lucide) lucide.createIcons();
    };

    // --- GESTIÓN DE ADJUNTOS PARA REQUERIMIENTOS ---
    let colaAdjuntosReq = {};
    let reqIdActual = null;
    const inputReq = document.getElementById('hiddenInputReq');

    window.gestionarAdjuntosReq = (id) => { reqIdActual = id; inputReq.click(); };

    if (inputReq) {
        inputReq.addEventListener('change', () => {
            const files = Array.from(inputReq.files);
            if (!files.length || reqIdActual === null) return;
            if (!colaAdjuntosReq[reqIdActual]) colaAdjuntosReq[reqIdActual] = [];
            colaAdjuntosReq[reqIdActual].push(...files);
            renderColaReq(reqIdActual);
            inputReq.value = ""; reqIdActual = null;
        });
    }

    function renderColaReq(id) {
        const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
        if (!contenedor) return;
        contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => `
            <div class="file-item" style="margin-bottom:4px; padding:4px 8px; border:1px solid #e2e8f0; border-radius:6px; display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <span style="font-size:0.75rem;"><i data-lucide="paperclip" style="width:12px;"></i> ${f.name}</span>
                <button type="button" onclick="eliminarArchivoReq('${id}', ${i})" class="btn-danger-icon"><i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i></button>
            </div>
        `).join("");
        if (window.lucide) lucide.createIcons();
    }

    window.eliminarArchivoReq = (id, i) => { colaAdjuntosReq[id].splice(i, 1); renderColaReq(id); };

    // 6. LÓGICA DE ENVÍO Y VALIDACIÓN (OBRAS - FINAL UNIFICADA)
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConformidad = document.getElementById("checkConformidad");
    const mensajeDiv = document.getElementById("mensaje");

    function mostrarMensaje(texto, tipo) {
        if (!mensajeDiv) return;
        mensajeDiv.textContent = texto;
        mensajeDiv.className = `message ${tipo}`;
        mensajeDiv.classList.remove('hidden');
        mensajeDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    if (checkConformidad && btnEnviar) {
        checkConformidad.addEventListener('change', function() { btnEnviar.disabled = !this.checked; });
    }

    // Inicialización
    agregarFilaNuevaObra();

    if (btnEnviar) {
        btnEnviar.addEventListener("click", async () => {
            const idBatch = "ENVIO_" + new Date().getTime();
            toggleFormFreeze(true);
            if (mensajeDiv) mensajeDiv.classList.add('hidden'); 

            // 1. Recopilar respuestas a requerimientos
            const respuestasReq = [];
            document.querySelectorAll('.txt-resp-req').forEach(area => {
                const id = area.dataset.id;
                const resp = area.value.trim();
                const archivosFila = colaAdjuntosReq[id] || [];
                if (resp.length > 0 || archivosFila.length > 0) {
                    respuestasReq.push({ pregunta: area.dataset.msg, respuesta: resp, archivos: archivosFila.map(f => f.name).join("; ") });
                }
            });

            // VALIDACIONES DE OBRAS
            const selects = document.querySelectorAll('.fila-obra .select-estado');
            let todasRellenas = true;
            selects.forEach(s => { if(!s.value) todasRellenas = false; });

            if (!todasRellenas) {
                mostrarMensaje("⚠️ Por favor, rellene el estado de todas las obras del listado.", "warning");
                toggleFormFreeze(false); return;
            }

            const obsValue = document.getElementById("observaciones").value.trim();
            if (window.EIEL_CONFIG.hasAvisos && respuestasReq.length === 0 && obsValue.length < 15) {
                mostrarMensaje("⚠️ Debe responder a los requerimientos o justificarlo en Observaciones generales.", "error");
                toggleFormFreeze(false); return;
            }

            // 2. Cálculo de tareas y Subida Paralela
            const numObrasFiles = Object.values(colaAdjuntos).flat().length;
            const numReqFiles = Object.values(colaAdjuntosReq).flat().length;
            const totalTareas = numObrasFiles + numReqFiles;
            
            UIProgress.show(totalTareas);
            let completados = 0;

            try {
                const tareasSubida = [];
                // Subida Obras
                Object.entries(colaAdjuntos).forEach(([id, listado]) => {
                    listado.forEach(file => {
                        tareasSubida.push((async () => {
                            await UploadService.uploadFile(file, 'obras', window.EIEL_CONFIG.muniCode, id, idBatch);
                            completados++; UIProgress.update(completados, totalTareas, `Subido: ${file.name}`);
                        })());
                    });
                });
                // Subida Requerimientos
                Object.entries(colaAdjuntosReq).forEach(([id, listado]) => {
                    listado.forEach(file => {
                        tareasSubida.push((async () => {
                            await UploadService.uploadFile(file, 'obras', window.EIEL_CONFIG.muniCode, 'RESPUESTA_REQUERIMIENTOS', idBatch);
                            completados++; UIProgress.update(completados, totalTareas, `Subido: ${file.name}`);
                        })());
                    });
                });

                if (tareasSubida.length > 0) await Promise.all(tareasSubida);

                // 3. Recopilación de datos de tablas
                const estadosObras = [];
                selects.forEach(select => {
                    const idO = select.dataset.obraId;
                    estadosObras.push({
                        obra: idO, clave: select.dataset.clave, orden: select.dataset.orden,
                        nombre: select.dataset.nombre, plan: select.dataset.plan,
                        estado: select.value, modificado: select.value !== select.dataset.original,
                        archivos: (colaAdjuntos[idO] || []).map(f => f.name).join("; ")
                    });
                });

                const nuevasObrasData = [];
                document.querySelectorAll(".fila-nueva-obra").forEach(fila => {
                    const inputN = fila.querySelector(".input-nueva-nombre");
                    if (inputN && inputN.value.trim()) {
                        const idT = inputN.dataset.tempId;
                        nuevasObrasData.push({
                            nombre: inputN.value.trim(),
                            estado: fila.querySelector(".input-nueva-estado")?.value || "",
                            archivos: (colaAdjuntos[idT] || []).map(f => f.name).join("; ")
                        });
                    }
                });

                UIProgress.update(completados, totalTareas, "Generando justificante...");
                const payload = {
                    tipo_formulario: "obras",
                    fase: window.EIEL_CONFIG.fase,
                    id_envio: idBatch,
                    observaciones: obsValue,
                    nombre_contacto: document.getElementById("contactoNombre").value.trim(),
                    departamento_contacto: document.getElementById("contactoDepartamento").value.trim(),
                    email_contacto: document.getElementById("contactoEmail").value.trim(),
                    municipio_codigo: window.EIEL_CONFIG.muniCode,
                    municipio_nombre: window.EIEL_CONFIG.muniName,
                    timestamp_envio: new Date().toISOString(),
                    datos_obras_json: JSON.stringify(estadosObras),
                    otras_obras_json: JSON.stringify(nuevasObrasData),
                    respuestas_requerimientos_json: JSON.stringify(respuestasReq)
                };

                await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                    method: "POST", mode: "no-cors",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                UIProgress.complete();
                
                // --- LIMPIEZA FINAL ---
                colaAdjuntos = {}; colaAdjuntosReq = {}; contadorNuevas = 0;
                document.querySelectorAll(".file-list-container").forEach(el => el.innerHTML = "");
                document.getElementById("bodyNuevasObras").innerHTML = "";
                agregarFilaNuevaObra();
                document.querySelectorAll("input, select, textarea").forEach(el => {
                   if (!['button', 'submit', 'checkbox'].includes(el.type)) el.value = '';
                   if (el.tagName === 'SELECT') el.selectedIndex = 0;
                });
                if (checkConformidad) checkConformidad.checked = false;
                btnEnviar.disabled = true;

            } catch (error) {
                console.error(error);
                mostrarMensaje(`❌ Error técnico: ${error.message}`, "error");
                toggleFormFreeze(false);
            }
        });
    }
});
</script>
{% endblock %}