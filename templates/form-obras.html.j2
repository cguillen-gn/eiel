﻿{% extends "base.html.j2" %}

{% block bloque_fase %}
    Fase {{ fase_actual }}
{% endblock %}

{% block title %}OBRAS{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}OBRAS{% endblock %}

{% block content %}

{# --- INSTRUCCIONES --- #}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul>
        <li><strong>Estado:</strong> Rellene el estado en todas las obras del listado.</li>
        <li><strong>Documentación:</strong> Adjunte proyecto de la obra o la documentación disponible. Si no dispone de documentación, justifíquelo en el apartado final de observaciones.</li>
    </ul>
</div>

{# --- TABLA DE OBRAS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="list-checks"></i> SEGUIMIENTO DE OBRAS</h2>
    <div class="table-wrapper" style="margin: 0;">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 5%;" class="td-ubicacion">Id</th>
                    <th style="width: 60%;">Denominación</th>
                    <th style="width: 20%;" class="td-ubicacion">Estado</th>
                    <th style="width: 15%;" class="td-ubicacion">Documentación</th>
                </tr>
            </thead>
            
            <tbody>
                {% for o in obras %}
                {% set codigo_obra = o.clave ~ o.mun ~ o.orden %}
                <tr class="fila-obra">
                    
                    <td class="td-ubicacion text-xs" style="font-weight: 500; color: var(--text-secondary);">
                        {{ codigo_obra[-3:] }}
                    </td>

                    <td>
                        <div class="obra-column-container">
                            <div class="item-title-row">
                                <span class="item-title">{{ o.nombre }}</span>
                            </div>

                            {% if o.plan_obra %}
                                <div class="obra-details-row">
                                    <span class="subvencion-badge">SUBVENCIÓN</span>
                                    <span class="header-plan">{{ o.plan_obra }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </td>
                  
                    
                    
                    <td class="td-ubicacion">
                        <select class="form-select select-estado" 
                            data-obra-id="{{ codigo_obra }}"
                            data-clave="{{ o.clave }}"
                            data-orden="{{ o.orden }}"
                            data-nombre="{{ o.nombre }}" 
                            data-plan="{{ o.plan_obra }}"
                            data-original="{{ estado_inicial }}"
                            data-requiere-doc="{{ 'false' if o.proyecto == 'RE' else 'true' }}">
                            
                            <option value="" {% if o.cond == 0 %}selected{% endif %}>
                                Seleccionar...
                            </option>
                            <option value="No iniciada">No iniciada</option>
                            <option value="En ejecución">En ejecución</option>
                            <option value="Paralizada">Paralizada</option>
                            <option value="Finalizada" {% if o.cond == 2 %}selected{% endif %}>
                                Finalizada
                            </option>
                        </select>
                    </td>

                    <td class="td-ubicacion">
                        {% if o.proyecto == 'RE' %}
                            <div class="form-help" style="font-size: 0.75rem; font-weight: 600;">
                            No requiere documentación
                            </div>
                        {% else %}
                            <button type="button" class="btn btn-secondary btn-sm" 
                                    onclick="gestionarAdjuntos('{{ codigo_obra }}')">
                                <i data-lucide="paperclip"></i> Adjuntar
                            </button>
                            <div id="lista_adjuntos_{{ codigo_obra }}" class="file-list-container" style="margin-top: 5px;"></div>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# --- TARJETA DE OTRAS OBRAS --- #}
<div class="card" style="border-style: dashed; background-color: #f8fafc;">
    <h2 class="section-title"><i data-lucide="plus-circle"></i> OTRAS OBRAS DETECTADAS</h2>
    <div class="card-body">
        <p class="form-help" style="margin-bottom: 1.5rem;">
            Añada filas para registrar obras que <strong>no figuran en el listado oficial</strong> superior.
        </p>

        <div class="table-wrapper" style="margin: 0; background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%;"></th> <th style="width: 55%;">Denominación de la Obra</th>
                        <th style="width: 20%;" class="td-ubicacion">Estado</th>
                        <th style="width: 15%;" class="td-ubicacion">Documentación</th>
                        <th style="width: 5%;"></th> </tr>
                </thead>
                <tbody id="bodyNuevasObras">
                    </tbody>
            </table>
        </div>

        <div style="margin-top: 1rem;">
            <button type="button" class="btn btn-secondary btn-sm" onclick="agregarFilaNuevaObra()" style="background: white;">
                <i data-lucide="plus"></i> Añadir otra obra
            </button>
        </div>
    </div>
</div>


{# --- REQUERIMIENTOS --- #}
{% if avisos_personalizados and avisos_personalizados|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h4 class="requerimientos-title">⚠️ Otra información solicitada</h4>
        <p class="requerimientos-intro">
            Se ha detectado falta de información o incidencias en las <strong>Obras</strong>. Por favor, responda en <strong>Observaciones</strong>.
        </p>
        <ul class="requerimientos-list">
            {% for aviso in avisos_personalizados %}
                <li class="requerimiento-item-box prioridad-{{ 'alta' if aviso.prioridad == 'alta' else 'media' }}">
                    <span class="requerimiento-icon">{{ '🔴' if aviso.prioridad == 'alta' else '🔸' }}</span>
                    <div class="requerimiento-content-text">
                        <span class="requerimiento-msg">{{ aviso.mensaje }}</span>
                        {% if aviso.url %}
                            <a href="{{ aviso.url }}" target="_blank" class="btn-geoportal">
                                <i data-lucide="globe"></i> Ver en Geoportal
                            </a>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    </div>
</div>
{% endif %}

{# --- OBSERVACIONES --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" style="font-family: inherit;" placeholder="Indique aquí cualquier incidencia, aclaración o dato relevante..."></textarea>
    </div>
</div>

{# --- CONTACTO Y ENVÍO --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required>
        </div>
        <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;">
            </div>
    </div>
</div>

{# --- DECLARACIÓN RESPONSABLE --- #}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text">
                <strong>Declaración de veracidad:</strong> Como responsable, 
                confirmo que los datos introducidos son correctos y actualizados.
            </span>
        </label>
    </div>
    
    <div id="progressContainer" class="progress-container hidden">
        <div class="progress-labels">
            <span id="progressText">Preparando envío...</span>
            <span id="progressPercentage">0%</span>
        </div>
        <div class="progress-track">
            <div id="progressBar"></div>
        </div>
    </div>

    <button id="btnEnviar" class="btn btn-primary btn-obras" disabled>
        Enviar Datos
    </button>
    
    <div id="mensaje" class="message"></div>
</div>

<input type="file" id="hiddenFileInput" multiple style="display: none;">

{% endblock %}

{% block scripts %}
<script>
document.addEventListener("DOMContentLoaded", () => {
    
    // 0. ACTIVADOR DE TEMA
    document.body.classList.add('theme-obras');
    
    // Ejecuta la creación de iconos de Lucide
    if (window.lucide) {
        lucide.createIcons();
    }

    // 1. SETUP DE ESTILOS
    const header = document.querySelector('.site-header');
    if(header) header.classList.add('header-obras');
    
    // Cambio de color dinámico para los estados
    document.querySelectorAll('.select-estado').forEach(select => {
        if (select.value !== "") select.classList.add('has-value');
        
        select.addEventListener('change', function() {
            if (this.value !== "") 
                this.classList.add('has-value');
            else 
                this.classList.remove('has-value');
        });
    });

    // 2. CONFIGURACIÓN GLOBAL
    window.EIEL_CONFIG = {
        muniCode: "{{ muni_code }}",
        muniName: "{{ muni_display }}",
        fase: "{{ fase_actual }}",
        urlGenerarPdf: "{{ url_generar_pdf }}",
        urlAdjuntos: "{{ url_adjuntos }}",
        urlLogger: "{{ url_logger }}",
        hasAvisos: {{ 'true' if avisos_personalizados and avisos_personalizados|length > 0 else 'false' }},
        yearActual: new Date().getFullYear() // Año dinámico para validaciones
    };

    // 3. INICIALIZACIÓN UI
    // 3.1 Marcado visual de obligatoriedad en observaciones
    if (window.EIEL_CONFIG.hasAvisos) {
        const labelObs = document.querySelector("label[for='observaciones']");
        if (labelObs) {
            labelObs.innerHTML += " <span style='color:#ef4444; font-weight:bold;'>(* Obligatorio por requerimiento)</span>";
        }
    }

    // 4. SERVICIOS Y UTILIDADES DE UI
    const UIProgress = {
    container: document.getElementById("progressContainer"),
    bar: document.getElementById("progressBar"),
    text: document.getElementById("progressText"),
    percent: document.getElementById("progressPercentage"),
    // Variable para recordar el punto más alto alcanzado
    maxReached: 0, 

    show(totalTasks) {
        this.maxReached = 0; // Reiniciamos al empezar
        if (this.container) this.container.classList.remove('hidden');
        this.update(0, totalTasks, "Iniciando envío...");
    },

    update(completed, total, message) {
        const msg = message.toLowerCase();
        // Detectamos si es el paso del registro o PDF
        const isFinalStep = msg.includes("pdf") || msg.includes("registro") || msg.includes("justificante");
        
        let targetPercentage = 0;
        if (total > 0) {
            const fileWeight = 90 / total;
            targetPercentage = isFinalStep ? 95 : Math.round(completed * fileWeight);
        } else {
            targetPercentage = isFinalStep ? 95 : 0;
        }

        // --- EL BLOQUEO DE SEGURIDAD ---
        // Solo actualizamos si el nuevo porcentaje es mayor al que ya mostramos
        if (targetPercentage > this.maxReached) {
            this.maxReached = targetPercentage;
            if (this.bar) this.bar.style.width = this.maxReached + "%";
            if (this.percent) this.percent.textContent = this.maxReached + "%";
        }
        
        // El texto sí lo actualizamos siempre para dar feedback constante
        if (this.text && message) this.text.textContent = message;
    },

    complete() {
        this.maxReached = 100;
        if (this.bar) {
            this.bar.style.width = "100%";
            this.bar.classList.add("progress-success");
        }
        if (this.percent) this.percent.textContent = "100%";
        if (this.text) this.text.textContent = "✅ ¡Envío completado con éxito! Se ha enviado un justificante al email facilitado";
    }
    };

    const UploadService = {
        toBase64: file => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        }),

        async uploadFile(file, tipoFicha, muniCode, codigoObra = null, idEnvio) {
            try {
                const base64 = await this.toBase64(file);
                const contactoEmail = document.getElementById("contactoEmail")?.value || "anonimo";

                const payload = {
                    filename: file.name,
                    mimeType: file.type,
                    bytesBase64: base64, 
                    municipio: muniCode,
                    usuario: contactoEmail,
                    tipo: tipoFicha,
                    seccion: codigoObra,
                    id_envio: idEnvio
                };
                
                await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                    method: 'POST',
                    mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                return true;
            } catch (e) {
                console.error("Error subiendo:", e);
                return false;
            }
        }
    };

    // 5. GESTIÓN DE ARCHIVOS (UNIFICADA: OFICIALES Y NUEVAS)
    let colaAdjuntos = {}; 
    let obraActualSeleccion = null;
    let contadorNuevas = 0; // Contador para generar IDs temporales
    const hiddenInput = document.getElementById("hiddenFileInput");

    // 5.1 Lógica Genérica de Adjuntos
    window.gestionarAdjuntos = (idObra) => {
        obraActualSeleccion = idObra;
        hiddenInput.click();
    };

    window.eliminarDeCola = (idObra, index) => {
        if (colaAdjuntos[idObra]) {
            colaAdjuntos[idObra].splice(index, 1);
            renderCola(idObra);
        }
    };

    if(hiddenInput) {
        hiddenInput.onchange = () => {
            const files = Array.from(hiddenInput.files);
            if (!files.length || !obraActualSeleccion) return;

            if (!colaAdjuntos[obraActualSeleccion]) {
                colaAdjuntos[obraActualSeleccion] = [];
            }
            colaAdjuntos[obraActualSeleccion].push(...files);
            renderCola(obraActualSeleccion);
            
            hiddenInput.value = "";
            obraActualSeleccion = null;
        };
    }

    function renderCola(idObra) {
        const contenedor = document.getElementById(`lista_adjuntos_${idObra}`);
        if(!contenedor) return;
        const archivos = colaAdjuntos[idObra] || [];

        if (archivos.length === 0) {
            contenedor.innerHTML = "";
            return;
        }

        contenedor.innerHTML = archivos.map((f, i) => `
            <div class="file-item">
                <span title="${f.name}">
                    <i data-lucide="paperclip" style="width:14px; height:14px;"></i> ${f.name}
                </span>
                <button type="button" onclick="eliminarDeCola('${idObra}', ${i})" class="btn-danger-icon">
                    <i data-lucide="trash-2" style="width:14px; height:14px;"></i>
                </button>
            </div>
        `).join("");

        if (window.lucide) lucide.createIcons();
    }

    // 5.2 Lógica de la Tabla Dinámica (Otras Obras)
    window.agregarFilaNuevaObra = () => {
        contadorNuevas++;
        const idTemp = `NUEVA_${contadorNuevas}`;
        const tbody = document.getElementById("bodyNuevasObras");
        if (!tbody) return;

        const tr = document.createElement("tr");
        tr.id = `fila_${idTemp}`;
        tr.innerHTML = `
            <td class="td-ubicacion">
                <span class="text-xs" style="color: var(--text-secondary); opacity: 0.5;">+</span>
            </td>
            <td>
                <input type="text" class="form-input input-nueva-nombre" data-temp-id="${idTemp}" 
                       placeholder="Ej: Reurbanización calle Mayor ...">
            </td>
            <td class="td-ubicacion">
                <select class="form-select input-nueva-estado select-estado" 
                        onchange="this.classList.toggle('has-value', this.value !== '')">
                    <option value="">Seleccionar...</option>
                    <option value="No iniciada">No iniciada</option>
                    <option value="En ejecución">En ejecución</option>
                    <option value="Paralizada">Paralizada</option>
                    <option value="Finalizada">Finalizada</option>
                </select>
            </td>
            <td class="td-ubicacion">
                <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntos('${idTemp}')">
                    <i data-lucide="paperclip"></i> Adjuntar
                </button>
                <div id="lista_adjuntos_${idTemp}" class="file-list-container" style="margin-top: 5px;"></div>
            </td>
            <td class="td-ubicacion">
                <button type="button" class="btn-danger-icon" onclick="eliminarFilaNueva('${idTemp}')" title="Eliminar fila">
                    <i data-lucide="trash-2" style="width:18px; opacity: 0.7;"></i>
                </button>
            </td>
        `;
        tbody.appendChild(tr);
        if (window.lucide) lucide.createIcons();
    };

    window.eliminarFilaNueva = (idTemp) => {
        const fila = document.getElementById(`fila_${idTemp}`);
        if (fila) fila.remove();
        delete colaAdjuntos[idTemp]; // Limpieza de archivos en memoria al borrar la fila [cite: 288]
    };

    // Inicializamos con una fila vacía para invitar al usuario a escribir
    agregarFilaNuevaObra();

    // 6. LÓGICA DE ENVÍO Y VALIDACIÓN
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConformidad = document.getElementById("checkConformidad"); 
    const mensajeDiv = document.getElementById("mensaje"); 

    function mostrarMensaje(texto, tipo) {
        if(!mensajeDiv) return;
        mensajeDiv.textContent = texto; 
        mensajeDiv.className = `message ${tipo}`; 
        mensajeDiv.classList.remove('hidden');
    }

    // 6.1 Checkbox Habilitador
    if (checkConformidad && btnEnviar) {
    checkConformidad.addEventListener('change', function() {
        btnEnviar.disabled = !this.checked;
        });
    }

    // 6.2 Listener Principal de Envío
    if(btnEnviar) {
        btnEnviar.addEventListener("click", async () => {
            // A. Preparación y Bloqueo UI
            const idBatch = "ENVIO_" + new Date().getTime();
            toggleFormFreeze(true); // Congelamos el formulario durante el proceso [cite: 310]

            // B. Lectura de Variables [cite: 311-312]
            const nombreContacto = document.getElementById("contactoNombre").value.trim(); 
            const emailContacto = document.getElementById("contactoEmail").value.trim(); 
            const emailConfirmInput = document.getElementById("contactoEmailConfirm");
            const emailConfirm = emailConfirmInput ? emailConfirmInput.value.trim() : emailContacto;
            const departamentoVal = document.getElementById("contactoDepartamento").value.trim();
            const obsField = document.getElementById("observaciones");
            const obsValue = obsField.value.trim(); 
            const regexEmail = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

            // C. Validaciones [cite: 313-325]
            // 1: Identidad
            if (nombreContacto.length < 2) {
                mostrarMensaje("⚠️ El nombre es demasiado corto.", "warning");
                toggleFormFreeze(false); 
                return;
            }
            if (!regexEmail.test(emailContacto) || emailContacto.toLowerCase() !== emailConfirm.toLowerCase()) {
                mostrarMensaje("⚠️ Verifique que el Email sea válido y coincida.", "error");
                toggleFormFreeze(false); 
                return;
            }

            // 2: Estados e Integridad de Obras Oficiales
            const selects = document.querySelectorAll(".select-estado");
            let obrasSinEstado = [];
            let obrasFiSinDocs = [];

            selects.forEach(select => {
                const obraId = select.dataset.obraId;
                const clave = select.dataset.clave;
                const requiereDoc = select.dataset.requiereDoc === "true";

                if (!select.value) {
                    obrasSinEstado.push(clave);
                }
                if (select.value === 'Finalizada' && requiereDoc && !(colaAdjuntos[obraId]?.length > 0)) {
                    obrasFiSinDocs.push(clave);
                }
            });

            // 3: Requerimiento de Observaciones (Incluye avisos y validaciones de tabla)
            const requiereObs = obrasSinEstado.length > 0 || obrasFiSinDocs.length > 0 || window.EIEL_CONFIG.hasAvisos;
            if (requiereObs && obsValue.length < 15) {
                let msg = "⚠️ Debe completar las Observaciones (mín. 15 caracteres) por estados faltantes, falta de documentos o avisos pendientes.";
                mostrarMensaje(msg, "error");
                obsField.focus(); 
                toggleFormFreeze(false); 
                return;
            }
            
            // 4: Persistencia
            localStorage.setItem("eiel_user_name", nombreContacto);
            localStorage.setItem("eiel_user_email", emailContacto);
            localStorage.setItem("eiel_user_dept", departamentoVal);

            // D. Subida de Archivos a Google Drive (Unificada) [cite: 328-333]
            const listaArchivosSubida = [];
            for (const [obraId, archivos] of Object.entries(colaAdjuntos)) {
                archivos.forEach(file => listaArchivosSubida.push({ file, obraId }));
            }
            
            const totalArchivos = listaArchivosSubida.length;
            let completados = 0;
            UIProgress.show(totalArchivos);

            if (totalArchivos > 0) {
                const promesas = listaArchivosSubida.map(item => {
                    return UploadService.uploadFile(item.file, 'obra', window.EIEL_CONFIG.muniCode, item.obraId, idBatch)
                        .then(res => {
                            completados++;
                            UIProgress.update(completados, totalArchivos, `Subido: ${item.file.name}`);
                            return res;
                        });
                });
                await Promise.all(promesas);
            }

            // E. Recopilación de Datos para el Registro [cite: 334-347]
            UIProgress.update(completados, totalArchivos, "Enviando datos y generando justificante PDF...");
            
            // 1: Datos de Obras Oficiales
            const estados = [];
            selects.forEach(select => {
                if (select.value) {
                    const obraId = select.dataset.obraId;
                    estados.push({
                        obra: obraId,
                        clave: select.dataset.clave,
                        orden: select.dataset.orden,
                        nombre: select.dataset.nombre,
                        plan: select.dataset.plan,
                        estado: select.value,
                        modificado: select.value !== select.dataset.original,
                        archivos: (colaAdjuntos[obraId] || []).map(f => f.name).join(";")
                    });
                }
            });

            // 2: Datos de Obras Nuevas (Recorrido de la tabla dinámica)
            const nuevasObrasData = [];
            document.querySelectorAll("#bodyNuevasObras tr").forEach(tr => {
                const inputNombre = tr.querySelector(".input-nueva-nombre");
                const inputEstado = tr.querySelector(".input-nueva-estado");

                if (inputNombre) {
                    const idTemp = inputNombre.dataset.tempId;
                    const nombre = inputNombre.value.trim();
                    const estado = inputEstado ? inputEstado.value : ""; 

                    if (nombre) {
                        nuevasObrasData.push({
                            nombre: nombre,
                            estado: estado, 
                            archivos: (colaAdjuntos[idTemp] || []).map(f => f.name).join("; ")
                        });
                    }
                }
            });

            // 3: Verificación de contenido mínimo
            if (estados.length === 0 && nuevasObrasData.length === 0) {
                mostrarMensaje("⚠️ No hay datos para enviar.", "warning");
                UIProgress.container.classList.add('hidden');
                toggleFormFreeze(false);
                return;
            }

            // 4: Recolección total de adjuntos para el Log [cite: 343-345]
            const todosLosAdjuntos = [];
            Object.values(colaAdjuntos).forEach(files => {
                files.forEach(f => todosLosAdjuntos.push(f.name));
            });

            // F. Registro y Envío de PDF [cite: 348-349]
            const payload = {
                tipo_formulario: "obras",
                fase: window.EIEL_CONFIG.fase,
                id_envio: idBatch,
                datos_obras_json: JSON.stringify(estados),
                otras_obras_json: JSON.stringify(nuevasObrasData), // Enviamos la tabla como JSON estructurado
                observaciones: obsValue,
                nombre_contacto: nombreContacto,
                departamento_contacto: departamentoVal,
                email_contacto: emailContacto,
                municipio_codigo: window.EIEL_CONFIG.muniCode,
                municipio_nombre: window.EIEL_CONFIG.muniName,
                timestamp_envio: new Date().toISOString(),
                archivos_adjuntos: todosLosAdjuntos.join("\n")
            };
               
            try {
                await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                    method: "POST", mode: "no-cors",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                // G. Finalización y Limpieza [cite: 350-358]
                UIProgress.complete();
                if(mensajeDiv) mensajeDiv.classList.add('hidden');

                // 1. Limpieza de memoria
                colaAdjuntos = {};
                contadorNuevas = 0;

                // 2. Limpieza VISUAL
                document.querySelectorAll("[id^='lista_adjuntos_']").forEach(div => div.innerHTML = "");
                document.getElementById("bodyNuevasObras").innerHTML = ""; // Vaciamos la tabla
                agregarFilaNuevaObra(); // Añadimos una fila inicial limpia
                
                document.querySelectorAll("input, select, textarea").forEach(el => { 
                    if(!['button', 'submit', 'checkbox'].includes(el.type)) el.value = '';
                    if(el.tagName === 'SELECT') el.selectedIndex = 0;
                });

                if(checkConformidad) checkConformidad.checked = false;
                btnEnviar.disabled = true;

            } catch (error) {
                console.error(error);
                mostrarMensaje(`❌ Error técnico: ${error.message}`, "error");
                toggleFormFreeze(false);
            }
        });
    }
});
</script>
{% endblock %}