{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Seguimiento de Obras{% endblock %}
{% block tipo_ficha %}obras{% endblock %}
{% block body_class %}obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}SEGUIMIENTO DE OBRAS{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones("Rellene el estado de todas las obras del listado y adjunte la documentación técnica disponible (memorias, planos, etc.).") }}

    {# --- SECCIÓN: SEGUIMIENTO DE OBRAS EXISTENTES --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-checks"></i> Obras en Seguimiento</h2>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 10%;">ID</th>
                        <th style="width: 50%;">Denominación de la Obra</th>
                        <th style="width: 20%;">Estado actual</th>
                        <th style="width: 20%;">Adjunto</th>
                    </tr>
                </thead>
                <tbody>
                    {% for obra in obras %}
                    <tr class="obra-row" data-id="{{ obra.id }}">
                        <td style="font-size: 0.8rem; font-weight: 600; color: var(--text-secondary);">{{ obra.id }}</td>
                        <td>
                            <div style="font-weight: 500;">{{ obra.denominacion }}</div>
                            <div style="font-size: 0.75rem; color: var(--text-secondary);">{{ obra.descripcion or '' }}</div>
                        </td>
                        <td>
                            <select class="form-select obra-estado">
                                <option value="Pendiente" {% if obra.estado == 'Pendiente' %}selected{% endif %}>Pendiente</option>
                                <option value="En Ejecución" {% if obra.estado == 'En Ejecución' %}selected{% endif %}>En Ejecución</option>
                                <option value="Finalizada" {% if obra.estado == 'Finalizada' %}selected{% endif %}>Finalizada</option>
                                <option value="Paralizada" {% if obra.estado == 'Paralizada' %}selected{% endif %}>Paralizada</option>
                            </select>
                        </td>
                        <td>
                            <input type="file" id="file-obra-{{ obra.id }}" class="hidden" onchange="handleFiles(this.files, 'OBRA_{{ obra.id }}')">
                            <button type="button" class="btn btn-outline" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;" 
                                    onclick="document.getElementById('file-obra-{{ obra.id }}').click()">
                                <i data-lucide="paperclip" style="width: 14px;"></i> Subir
                            </button>
                            <div id="file-list-OBRA_{{ obra.id }}" class="file-list-container" style="font-size: 0.7rem; margin-top: 5px;"></div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# --- SECCIÓN: OTRAS OBRAS / NUEVAS ACTUACIONES --- #}
    <div class="card">
        <h2 class="section-title" style="color: var(--warning);"><i data-lucide="plus-square"></i> Otras Obras Realizadas o Previstas</h2>
        <div class="card-body">
            <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
                Si se han realizado obras no incluidas en el listado anterior, añádalas aquí indicando descripción y presupuesto.
            </p>
            <div id="nuevas-obras-container">
                </div>
            <button type="button" onclick="addNuevaObra()" class="btn btn-outline" style="width: 100%; border-style: dashed; margin-top: 1rem;">
                <i data-lucide="plus"></i> Añadir otra actuación
            </button>
        </div>
    </div>

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
/**
 * Añadir fila dinámica para nuevas obras
 */
function addNuevaObra() {
    const container = document.getElementById('nuevas-obras-container');
    const id = Date.now(); // ID temporal para los inputs
    const div = document.createElement('div');
    div.className = 'aviso-item nueva-obra-item';
    div.style.borderLeft = '4px solid var(--warning)';
    div.innerHTML = `
        <div class="form-group">
            <label class="form-label">Denominación / Descripción:</label>
            <input type="text" class="form-input n-desc" placeholder="Ej: Renovación red agua Calle Mayor">
        </div>
        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Presupuesto (€):</label>
                <input type="number" class="form-input n-presu">
            </div>
            <div class="form-group">
                <label class="form-label">Año:</label>
                <input type="number" class="form-input n-year" value="${new Date().getFullYear()}">
            </div>
        </div>
        <div class="form-group">
            <div class="upload-zone" onclick="document.getElementById('file-nobra-${id}').click()" style="padding: 0.8rem;">
                <p style="font-size: 0.8rem;"><i data-lucide="upload" style="width:14px"></i> Adjuntar Proyecto/Memoria</p>
                <input type="file" id="file-nobra-${id}" class="hidden" multiple onchange="handleFiles(this.files, 'NUEVA_OBRA_${id}')">
            </div>
            <div id="file-list-NUEVA_OBRA_${id}" class="file-list-container"></div>
        </div>
    `;
    container.appendChild(div);
    lucide.createIcons();
}

document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');
    
    // Auto-relleno de contacto
    ['nombre', 'depto', 'email'].forEach(f => {
        const el = document.getElementById(`contacto_${f}`);
        if(el) el.value = localStorage.getItem(`eiel_user_${f}`) || "";
    });

    if(checkConf) checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            // 1. Recoger estados de obras existentes
            const obrasExistentes = [];
            document.querySelectorAll('.obra-row').forEach(row => {
                obrasExistentes.push({
                    id: row.dataset.id,
                    denominacion: row.querySelector('div').innerText,
                    estado: row.querySelector('.obra-estado').value
                });
            });

            // 2. Recoger datos de nuevas obras
            const obrasNuevas = [];
            document.querySelectorAll('.nueva-obra-item').forEach(item => {
                obrasNuevas.push({
                    descripcion: item.querySelector('.n-desc').value,
                    presupuesto: item.querySelector('.n-presu').value,
                    year: item.querySelector('.n-year').value
                });
            });

            return {
                DATOS_OBRAS_EXISTENTES: JSON.stringify(obrasExistentes),
                DATOS_OBRAS_NUEVAS: JSON.stringify(obrasNuevas)
            };
        });
    };
});
</script>
{% endblock %}