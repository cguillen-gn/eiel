{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'obras' %}

{% block title %}222EIEL - Seguimiento de Obras{% endblock %}
{% block header_icon %}<i data-lucide="construction"></i>{% endblock %}
{% block header_title %}SEGUIMIENTO DE OBRAS{% endblock %}

{% block content %}
<form id="formObras">
    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li><strong>Estado:</strong> Rellene el estado en todas las obras del listado oficial.</li>
            <li><strong>Documentación:</strong> Adjunte proyecto, memoria descriptiva y planos por actuación.</li>
        </ul>
    </div>

    {# 3. SEGUIMIENTO DE OBRAS OFICIALES #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-checks"></i> SEGUIMIENTO DE OBRAS</h2>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%;" class="td-ubicacion">Id</th>
                        <th style="width: 60%;">Denominación</th>
                        <th style="width: 20%;" class="td-ubicacion">Estado</th>
                        <th style="width: 15%;" class="td-ubicacion">Documentación</th>
                    </tr>
                </thead>
                <tbody>
                    {% for o in obras %}
                    {% set codigo_obra = o.clave ~ o.mun ~ o.orden %}
                    <tr class="fila-obra">
                        <td class="td-ubicacion text-xs">{{ codigo_obra[-3:] }}</td>
                        <td>
                            <div class="obra-column-container">
                                <span class="item-title">{{ o.nombre }}</span>
                                {% if o.plan_obra and "licitaciones" not in o.plan_obra|lower and "contratos menores" not in o.plan_obra|lower %}
                                <div class="obra-details-row">
                                    <span class="subvencion-badge">SUBVENCIÓN</span>
                                    <span class="header-plan" style="font-size: 0.8rem; color: #94a3b8; font-weight: 500;">{{ o.plan_obra }}</span>
                                </div>
                                {% endif %}
                            </div>
                        </td>
                        <td class="td-ubicacion">
                            {% set estado_inicial = "Finalizada" if o.cond == 2 else ("No iniciada" if o.cond == 1 else "") %}
                            <select class="form-select select-estado-obra" data-obra-id="{{ codigo_obra }}" data-original="{{ estado_inicial }}">
                                <option value="" {% if o.cond == 0 %}selected{% endif %}>Seleccionar...</option>
                                <option value="No iniciada" {% if o.cond == 1 %}selected{% endif %}>No iniciada</option>
                                <option value="En ejecución">En ejecución</option>
                                <option value="Paralizada">Paralizada</option>
                                <option value="Finalizada" {% if o.cond == 2 %}selected{% endif %}>Finalizada</option>
                                <option value="Desconocido">Desconocido / Sin datos</option>
                            </select>
                        </td>
                        <td class="td-ubicacion">
                            {% if o.proyecto != 'RE' %}
                            <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntos('{{ codigo_obra }}')">
                                <i data-lucide="paperclip"></i> Adjuntar
                            </button>
                            <div id="lista_adjuntos_{{ codigo_obra }}" class="file-list-container" style="margin-top: 5px;"></div>
                            {% else %}
                            <span class="text-xs">No requiere doc.</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# 4. OTRAS OBRAS (Entrada Manual) #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-plus"></i> OTRAS OBRAS DETECTADAS</h2>
        <div class="table-wrapper" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40%;">Denominación</th>
                        <th style="width: 20%;">Estado</th>
                        <th style="width: 20%;">Observaciones</th>
                        <th style="width: 15%; text-align: center;">Documentación</th>
                        <th style="width: 5%;"></th>
                    </tr>
                </thead>
                <tbody id="bodyNuevasObras"></tbody>
            </table>
        </div>
        <button type="button" class="btn btn-secondary btn-sm" onclick="agregarFilaNuevaObra()" style="margin-top: 1rem;">
            <i data-lucide="plus"></i> Añadir otra actuación
        </button>
    </div>

    {# 5. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Otra información solicitada</h2>
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; font-size: 0.95rem;">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}
                    <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm"><i data-lucide="map"></i> Mapa</a>
                    {% endif %}
                </div>
                <div style="margin-left: 28px; background: #f8fafc; padding: 16px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" placeholder="Responda aquí..." style="width: 100%; box-sizing: border-box; margin-bottom: 12px; display: block;"></textarea>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntosReq('{{ req_id }}')"><i data-lucide="paperclip"></i> Adjuntar</button>
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top:10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 6. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
<input type="file" id="hiddenFileInput" multiple style="display: none;">
{% endblock %}

{% block scripts %}
<script>
// 1. ESTADO GLOBAL DEL FORMULARIO
window.colaAdjuntos = {};
window.colaAdjuntosReq = {};
let idObraActual = null;
let reqIdActual = null;
let contadorNuevas = 0;

// 2. FUNCIÓN PARA AÑADIR FILAS DINÁMICAS (Ahora Global)
window.agregarFilaNuevaObra = function() {
    contadorNuevas++;
    const idT = `NUEVA_${contadorNuevas}`;
    const tbody = document.getElementById('bodyNuevasObras');
    if (!tbody) return;

    const tr = document.createElement('tr');
    tr.id = `fila_${idT}`; 
    tr.className = 'fila-nueva-obra';
    tr.innerHTML = `
        <td><input type="text" class="form-input input-nueva-nombre" placeholder="Ej: Calle Mayor"></td>
        <td><select class="form-select input-nueva-estado"><option value="">Seleccionar...</option><option value="En ejecución">En ejecución</option><option value="Finalizada">Finalizada</option></select></td>
        <td><textarea class="form-input" rows="1"></textarea></td>
        <td style="text-align:center;">
            <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntos('${idT}')">
                <i data-lucide="paperclip"></i> Adjuntar
            </button>
            <div id="lista_adjuntos_${idT}" class="file-list-container"></div>
        </td>
        <td style="text-align:center;">
            <button type="button" onclick="this.closest('tr').remove()" class="btn-danger-icon">
                <i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i>
            </button>
        </td>`;
    tbody.appendChild(tr);
    if (window.lucide) lucide.createIcons();
};

// 3. GESTIÓN DE ADJUNTOS (Ahora Global)
window.gestionarAdjuntos = function(id) {
    idObraActual = id;
    const input = document.getElementById('hiddenFileInput');
    if (input) input.click();
};

window.gestionarAdjuntosReq = function(id) {
    reqIdActual = id;
    const input = document.getElementById('hiddenInputReq');
    if (input) input.click();
};

function renderAdjuntos(id) {
    const contenedor = document.getElementById(`lista_adjuntos_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (window.colaAdjuntos[id] || []).map(f => `
        <div class="file-item" style="font-size:0.7rem;">
            <span>📄 ${f.name.substring(0,10)}...</span>
        </div>`).join("");
}

function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (window.colaAdjuntosReq[id] || []).map(f => `
        <div class="file-item" style="font-size:0.75rem;">
            <span>📄 ${f.name}</span>
        </div>`).join("");
}

document.addEventListener("DOMContentLoaded", () => {
    // A. CREAR LA FILA POR DEFECTO INMEDIATAMENTE
    agregarFilaNuevaObra();

    // B. Configuración de Inputs de Archivos
    const inputObras = document.getElementById('hiddenFileInput');
    if (inputObras) {
        inputObras.addEventListener('change', () => {
            if (!idObraActual) return;
            window.colaAdjuntos[idObraActual] = [...(window.colaAdjuntos[idObraActual] || []), ...Array.from(inputObras.files)];
            renderAdjuntos(idObraActual);
        });
    }

    const inputReq = document.getElementById('hiddenInputReq');
    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            window.colaAdjuntosReq[reqIdActual] = [...(window.colaAdjuntosReq[reqIdActual] || []), ...Array.from(inputReq.files)];
            renderColaReq(reqIdActual);
        });
    }

    // C. LÓGICA DE ENVÍO
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) checkConf.addEventListener('change', () => btnEnviar.disabled = !checkConf.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "OBRAS_" + Date.now();
        toggleFormFreeze(true);

        const listaTareas = [];
        Object.entries(window.colaAdjuntos).forEach(([id, list]) => list.forEach(f => listaTareas.push({ file: f, seccion: id })));
        Object.entries(window.colaAdjuntosReq).forEach(([id, list]) => list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${parseInt(id)+1}` })));

        UIProgress.show(listaTareas.length);

        try {
            // Usamos el motor de la base con concurrencia 3
            await UploadService.uploadFiles(listaTareas, 'OBRAS', window.EIEL_CONFIG.muniCode, idBatch, 3);

            const payload = {
                tipo: "obras",
                id_envio: idBatch,
                datos_obras: Array.from(document.querySelectorAll('.select-estado-obra')).map(s => ({
                    obra: s.dataset.obraId, estado: s.value
                })),
                otras_obras: Array.from(document.querySelectorAll('.fila-nueva-obra')).map(f => ({
                    nombre: f.querySelector('.input-nueva-nombre').value, 
                    estado: f.querySelector('.input-nueva-estado').value
                })),
                observaciones: document.getElementById("observaciones").value,
                contacto: { 
                    nombre: document.getElementById("contactoNombre").value, 
                    email: document.getElementById("contactoEmail").value 
                }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();
        } catch (error) {
            console.error(error);
            toggleFormFreeze(false);
            Swal.fire("Error", "Fallo en el envío.", "error");
        }
    });
});
</script>
{% endblock %}