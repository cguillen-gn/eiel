{% extends "base.html.j2" %}
{% import "macros.html.j2" as components %}

{% block title %}EIEL - Viario{% endblock %}
{% block header_icon %}<i data-lucide="milestone"></i>{% endblock %}
{% block header_title %}INFRAESTRUCTURA VIARIA{% endblock %}

{% block content %}

{# 1. Instrucciones #}
{{ components.render_instrucciones([
    'Revise la información relativa a pavimentación, aceras y estado de los viales del municipio.',
    'Responda a los requerimientos específicos y adjunte planos o actas si se han realizado mejoras recientemente.'
]) }}

{# 2. Requerimientos dinámicos #}
{{ components.render_requerimientos(avisos_personalizados) }}

{# 3. SECCIÓN ESPECÍFICA (Si en el futuro añades inventario de calles, iría aquí) #}
{# Por ahora, el formulario se centra en la resolución de incidencias técnicas #}

{# 4. Observaciones y Footer #}
{{ components.render_observaciones_finales() }}
{{ components.render_footer_envio() }}

{% endblock %}

{% block scripts %}
<script>
/**
 * LÓGICA ESPECÍFICA DE VIARIO
 */
document.addEventListener('DOMContentLoaded', () => {
    
    const btnEnviar = document.getElementById('btnEnviar');
    if (btnEnviar) {
        btnEnviar.addEventListener('click', () => {
            // Usamos el procesador global
            processSubmit(() => {
                // Viario actualmente no tiene campos extra fuera de los requerimientos.
                return {}; 
            });
        });
    }
});
</script>
{% endblock %}