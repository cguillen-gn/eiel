{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Viario{% endblock %}
{% block tipo_ficha %}viario{% endblock %}
{% block body_class %}viario{% endblock %}
{% block header_icon %}<i data-lucide="milestone"></i>{% endblock %}
{% block header_title %}VIARIO Y PAVIMENTACIÓN{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones() }}

    {# --- SECCIÓN: ESTADO DEL VIARIO --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="map"></i>Estado de la Pavimentación</h2>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label">Longitud total del viario (km):</label>
                <input type="number" step="0.001" class="form-input" name="longitud_total_viario">
            </div>
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Superficie en BUEN ESTADO (m²):</label>
                    <input type="number" class="form-input" name="sup_buen_estado">
                </div>
                <div class="form-group">
                    <label class="form-label">Superficie en MAL ESTADO (m²):</label>
                    <input type="number" class="form-input" name="sup_mal_estado">
                </div>
            </div>
        </div>
    </div>

    {# --- SECCIÓN: APARCAMIENTOS --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="car"></i>Aparcamientos Públicos</h2>
        <div class="card-body">
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Nº de plazas de aparcamiento:</label>
                    <input type="number" class="form-input" name="num_plazas_aparcamiento">
                </div>
                <div class="form-group">
                    <label class="form-label">Superficie de aparcamiento (m²):</label>
                    <input type="number" class="form-input" name="sup_aparcamiento">
                </div>
            </div>
        </div>
    </div>

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');
    
    // Auto-relleno de contacto desde base
    ['nombre', 'depto', 'email'].forEach(field => {
        const el = document.getElementById(`contacto_${field}`);
        if(el) el.value = localStorage.getItem(`eiel_user_${field}`) || "";
    });

    if(checkConf) checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            const formData = new FormData(document.getElementById('mainForm'));
            return Object.fromEntries(formData.entries());
        });
    };
});
</script>
{% endblock %}