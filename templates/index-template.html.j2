<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EIEL {{ fase_actual }} - Acceso</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css"> 
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="theme-default">

<div class="panel-container">
    {# CABECERA DEL PANEL #}
    <div class="panel-header" id="mainHeader">
        <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">EIEL {{ fase_actual }}</h1>
        <p id="headerSubtitle">Portal de Recogida de Datos</p>
        
        <div id="headerMuniInfo" class="hidden" style="margin-top: 1.5rem; background: rgba(255,255,255,0.2); padding: 1rem; border-radius: 12px;">
            <div id="headerMuniName" style="font-weight: 700; font-size: 1.1rem;"></div>
            <div id="headerCode" style="font-size: 0.85rem; opacity: 0.9;"></div>
        </div>
    </div>

    {# VISTA 1: LOGIN #}
    <div id="viewLogin" style="padding: 2rem;">
        <div class="form-group" style="margin-bottom: 1.5rem;">
            <label class="form-label">1. Seleccione su Municipio</label>
            <select id="muniSelect" class="form-select">
                <option value="">Cargando municipios...</option>
            </select>
        </div>

        <div class="form-group" style="margin-bottom: 2rem;">
            <label class="form-label">2. Código de Acceso</label>
            <input type="password" id="muniCode" class="form-control" placeholder="Introduzca la clave facilitada">
        </div>

        <button id="btnLogin" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 1rem;">
            <i data-lucide="log-in"></i> Acceder al Portal
        </button>
        
        <p id="loginError" class="hidden" style="color: var(--danger); text-align: center; margin-top: 1rem; font-weight: 600; font-size: 0.9rem;"></p>
    </div>

    {# VISTA 2: MENÚ DE FORMULARIOS #}
    <div id="viewMenu" class="hidden" style="padding: 1rem;">
        <div class="menu-grid">
            <a href="#" id="link_agua" class="menu-card"><i data-lucide="droplet"></i><span>Agua</span></a>
            <a href="#" id="link_saneamiento" class="menu-card"><i data-lucide="test-tube"></i><span>Saneamiento</span></a>
            <a href="#" id="link_residuos" class="menu-card"><i data-lucide="recycle"></i><span>Residuos</span></a>
            <a href="#" id="link_alumbrado" class="menu-card"><i data-lucide="lightbulb"></i><span>Alumbrado</span></a>
            <a href="#" id="link_viario" class="menu-card"><i data-lucide="milestone"></i><span>Viario</span></a>
            <a href="#" id="link_cementerios" class="menu-card"><i data-lucide="rose"></i><span>Cementerios</span></a>
            <a href="#" id="link_equipamientos" class="menu-card"><i data-lucide="building-2"></i><span>Equipamientos</span></a>
            <a href="#" id="link_obras" class="menu-card"><i data-lucide="construction"></i><span>Obras</span></a>
        </div>
        
        <div style="padding: 1rem; border-top: 1px solid var(--border); text-align: center;">
            <button onclick="location.reload()" class="btn-back" style="width: 100%; justify-content: center;">
                <i data-lucide="log-out"></i> Cerrar Sesión
            </button>
        </div>
    </div>
</div>

<script>
    // --- DATOS INYECTADOS POR PYTHON ---
    const LISTA_MUNICIPIOS = {{ municipios_lista | safe }};
    const CONFIG_FLAGS = {{ config_flags_json | safe }};
    const URL_LOGIN_API = "{{ url_login_api }}";

    // --- ELEMENTOS UI ---
    const ui = {
        select: document.getElementById('muniSelect'),
        pass: document.getElementById('muniCode'),
        btnLogin: document.getElementById('btnLogin'),
        error: document.getElementById('loginError'),
        viewLogin: document.getElementById('viewLogin'),
        viewMenu: document.getElementById('viewMenu'),
        headerInfo: document.getElementById('headerMuniInfo'),
        headerName: document.getElementById('headerMuniName'),
        headerCode: document.getElementById('headerCode'),
        subtitle: document.getElementById('headerSubtitle')
    };

    // --- INICIALIZACIÓN ---
    document.addEventListener('DOMContentLoaded', () => {
        // Cargar municipios en el select
        ui.select.innerHTML = '<option value="">Seleccionar...</option>' + 
            LISTA_MUNICIPIOS.map(m => `<option value="${m.id}">${m.nombre}</option>`).join('');
        
        lucide.createIcons();
    });

    // --- LÓGICA DE LOGIN ---
    ui.btnLogin.addEventListener('click', async () => {
        const code = ui.select.value;
        const pass = ui.pass.value;

        if (!code || !pass) {
            showError("Seleccione un municipio e introduzca la clave.");
            return;
        }

        ui.btnLogin.disabled = true;
        ui.btnLogin.innerHTML = "Verificando...";

        try {
            const response = await fetch(URL_LOGIN_API, {
                method: 'POST',
                body: JSON.stringify({ codigo: code, password: pass })
            });
            const result = await response.json();

            if (result.valid) {
                showMenu(code, result.nombre, result.isTest);
            } else {
                showError("Clave de acceso incorrecta.");
                ui.btnLogin.disabled = false;
                ui.btnLogin.innerHTML = '<i data-lucide="log-in"></i> Acceder';
                lucide.createIcons();
            }
        } catch (e) {
            showError("Error de conexión con el servidor de seguridad.");
            ui.btnLogin.disabled = false;
        }
    });

    function showMenu(code, name, isTest) {
        // Guardar sesión básica
        localStorage.setItem("eiel_muni_code", code);
        localStorage.setItem("eiel_muni_name", name);
        localStorage.setItem("eiel_is_test", isTest);

        // Actualizar Cabecera
        ui.subtitle.classList.add('hidden');
        ui.headerInfo.classList.remove('hidden');
        ui.headerName.textContent = name;
        ui.headerCode.textContent = "Código INE: " + code;

        // Configurar enlaces según flags de disponibilidad
        const flags = CONFIG_FLAGS[code] || {};
        const servicios = ['agua', 'saneamiento', 'residuos', 'alumbrado', 'viario', 'cementerios', 'equipamientos', 'obras'];

        servicios.forEach(s => {
            const el = document.getElementById(`link_${s}`);
            el.href = `${s}_${code}.html`;
            
            // Si el flag es falso, ocultamos el botón (excepto para los obligatorios)
            if (flags[s] === false) {
                el.style.display = 'none';
            }
        });

        ui.viewLogin.classList.add('hidden');
        ui.viewMenu.classList.remove('hidden');
    }

    function showError(msg) {
        ui.error.textContent = msg;
        ui.error.classList.remove('hidden');
    }
</script>

</body>
</html>