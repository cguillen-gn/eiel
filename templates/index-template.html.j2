<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EIEL {{ fase_actual }} - Acceso</title>
    
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* Estilos específicos para el layout del Index que no están en el base */
        .login-container {
            max-width: 450px;
            margin: 10vh auto;
        }
        .index-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .index-header h1 {
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }
        .menu-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        .btn-menu {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.25rem;
            background: white;
            border: 1px solid var(--border);
            border-radius: 12px;
            text-decoration: none;
            color: var(--text-primary);
            font-weight: 600;
            transition: all 0.2s;
            border-left: 5px solid var(--item-color, var(--primary));
        }
        .btn-menu:hover {
            transform: translateX(5px);
            box-shadow: var(--shadow);
            border-color: var(--item-color);
        }
        .btn-menu i {
            color: var(--item-color);
        }
        .error-message {
            background: #fee2e2;
            color: #b91c1c;
            padding: 0.75rem;
            border-radius: 8px;
            font-size: 0.85rem;
            margin-bottom: 1rem;
            display: none;
            text-align: center;
            border: 1px solid #fecaca;
        }
    </style>
</head>
<body>

    <div class="container login-container">
        
        <div class="index-header">
            <h1>EIEL {{ fase_actual }}</h1>
            <p style="color: var(--text-secondary);">Portal de Encuesta de Infraestructuras</p>
        </div>

        {# --- BLOQUE 1: LOGIN --- #}
        <div id="viewLogin" class="card">
            <div class="section-title">
                <i data-lucide="lock"></i> Acceso al Municipio
            </div>
            <div class="card-body">
                <div id="loginError" class="error-message"></div>

                <div class="form-group">
                    <label class="form-label">1. Seleccione Municipio</label>
                    <select id="muniSelect" class="form-select">
                        <option value="">Cargando municipios...</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">2. Código de Acceso</label>
                    <input type="password" id="muniPass" class="form-input" placeholder="Introduzca la clave">
                </div>

                <button type="button" id="btnLogin" class="btn btn-primary" style="margin-top: 1rem;">
                    <i data-lucide="log-in"></i> Entrar al Portal
                </button>
            </div>
        </div>

        {# --- BLOQUE 2: MENÚ DE FORMULARIOS (Oculto inicialmente) --- #}
        <div id="viewMenu" class="hidden">
            <div class="card card-info" style="margin-bottom: 1.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h4 id="displayMuniName" style="margin:0">Municipio</h4>
                        <span id="displayMuniCode" class="text-xs">Código: 000</span>
                    </div>
                    <button onclick="location.reload()" class="btn btn-outline" style="padding: 0.4rem 0.7rem; font-size: 0.8rem;">
                        Cambiar
                    </button>
                </div>
            </div>

            <h3 style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 1rem; font-weight: 600;">
                FORMULARIOS DISPONIBLES:
            </h3>

            <div class="menu-grid">
                <a href="#" id="link-agua" class="btn-menu" style="--item-color: #0ea5e9;">
                    <i data-lucide="droplet"></i> Abastecimiento de Agua
                </a>
                <a href="#" id="link-saneamiento" class="btn-menu" style="--item-color: #A15908;">
                    <i data-lucide="test-tube"></i> Saneamiento y Depuración
                </a>
                <a href="#" id="link-alumbrado" class="btn-menu" style="--item-color: #eab308;">
                    <i data-lucide="lightbulb"></i> Alumbrado Público
                </a>
                <a href="#" id="link-viario" class="btn-menu" style="--item-color: #8F006B;">
                    <i data-lucide="milestone"></i> Viario y Pavimentación
                </a>
                <a href="#" id="link-residuos" class="btn-menu" style="--item-color: #16a34a;">
                    <i data-lucide="recycle"></i> Gestión de Residuos
                </a>
                <a href="#" id="link-equipamientos" class="btn-menu" style="--item-color: #D81B60;">
                    <i data-lucide="building-2"></i> Equipamientos Municipales
                </a>
                <a href="#" id="link-cementerios" class="btn-menu" style="--item-color: #475569;">
                    <i data-lucide="rose"></i> Cementerios
                </a>
                <a href="#" id="link-obras" class="btn-menu" style="--item-color: #f97316;">
                    <i data-lucide="construction"></i> Seguimiento de Obras
                </a>
            </div>
        </div>

        <div style="text-align: center; margin-top: 2rem; opacity: 0.5; font-size: 0.75rem;">
            &copy; {{ fase_actual }} Geonet Territorial
        </div>
    </div>

    <script>
        // Datos inyectados desde Python
        const MUNICIPIOS = {{ municipios_lista | safe }};
        const FLAGS = {{ config_flags_json | safe }};
        const LOGIN_API = "{{ url_login_api }}";

        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            
            const select = document.getElementById('muniSelect');
            const viewLogin = document.getElementById('viewLogin');
            const viewMenu = document.getElementById('viewMenu');
            const btnLogin = document.getElementById('btnLogin');
            const errorDiv = document.getElementById('loginError');

            // 1. Cargar lista de municipios
            select.innerHTML = '<option value="">Seleccionar...</option>';
            MUNICIPIOS.forEach(m => {
                const opt = document.createElement('option');
                opt.value = m.codigo;
                opt.textContent = m.nombre;
                select.appendChild(opt);
            });

            // 2. Lógica de Login
            btnLogin.onclick = async () => {
                const code = select.value;
                const pass = document.getElementById('muniPass').value;

                if (!code || !pass) {
                    errorDiv.textContent = "Seleccione municipio e introduzca clave.";
                    errorDiv.style.display = "block";
                    return;
                }

                btnLogin.disabled = true;
                btnLogin.innerHTML = '<i data-lucide="loader" class="animate-spin"></i> Validando...';
                lucide.createIcons();

                try {
                    const res = await fetch(LOGIN_API, {
                        method: 'POST',
                        body: JSON.stringify({ codigo: code, password: pass })
                    });
                    const data = await res.json();

                    if (data.valid) {
                        // Guardar sesión
                        localStorage.setItem("eiel_muni_code", code);
                        localStorage.setItem("eiel_muni_name", data.nombre);
                        localStorage.setItem("eiel_is_test", data.isTest || "false");
                        
                        showMenu(code, data.nombre);
                    } else {
                        errorDiv.textContent = "Clave incorrecta para este municipio.";
                        errorDiv.style.display = "block";
                        btnLogin.disabled = false;
                        btnLogin.innerHTML = '<i data-lucide="log-in"></i> Entrar al Portal';
                        lucide.createIcons();
                    }
                } catch (e) {
                    errorDiv.textContent = "Error de conexión con el servidor.";
                    errorDiv.style.display = "block";
                    btnLogin.disabled = false;
                }
            };

            function showMenu(code, name) {
                document.getElementById('displayMuniName').textContent = name;
                document.getElementById('displayMuniCode').textContent = `Código INE: ${code}`;
                
                // Configurar enlaces según flags
                const mFlags = FLAGS[code] || {};
                
                const setLink = (id, fileBase, hasFlag = true) => {
                    const el = document.getElementById(`link-${id}`);
                    if (hasFlag) {
                        el.href = `${fileBase}_${code}.html`;
                        el.style.display = "flex";
                    } else {
                        el.style.display = "none";
                    }
                };

                setLink('agua', 'agua');
                setLink('saneamiento', 'saneamiento', mFlags.saneamiento);
                setLink('alumbrado', 'alumbrado', mFlags.alumbrado);
                setLink('viario', 'viario', mFlags.viario);
                setLink('residuos', 'residuos');
                setLink('equipamientos', 'equipamientos');
                setLink('cementerios', 'cementerios', mFlags.cementerios);
                setLink('obras', 'obras');

                viewLogin.classList.add('hidden');
                viewMenu.classList.remove('hidden');
            }

            // Persistencia: Si ya estaba logueado, mostrar menú directamente
            const savedCode = localStorage.getItem("eiel_muni_code");
            const savedName = localStorage.getItem("eiel_muni_name");
            if (savedCode && savedName) {
                showMenu(savedCode, savedName);
            }
        });
    </script>
</body>
</html>