<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <title>EIEL {{ fase_actual }} - Acceso</title>
    <link rel="stylesheet" href="css/style.css"> 
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
<div class="panel">
    <div class="panel-header" id="mainHeader">
        <h1>EIEL {{ fase_actual }}</h1>
        <p id="headerSubtitle" class="header-subtitle">Portal de Recogida de Datos</p>
        
        <div id="headerMuniInfo" class="header-muni-info">
            <span id="headerMuniName" class="header-muni-name">Nombre del Municipio</span>
            <span id="headerCode" class="header-code-label">000</span>
        </div>
    </div>

    <div id="viewLogin" class="form-section">
        <label class="login-label">1. Municipio</label>
        <select id="muniSelect" class="input-field">
            <option value="">Seleccionar...</option>
        </select>

        <label class="login-label">2. Código de Acceso</label>
        <input type="password" id="muniCode" class="input-field" placeholder="Introduzca el código facilitado">

        <button id="btnLogin" class="btn-entrar">Entrar</button>
        <p id="errorMsg" class="error-msg">Código incorrecto</p>
    </div>

    <div id="viewMenu" class="form-section hidden">
        <div class="btn-grid">
            <a id="lnkObras" href="#" class="btn-menu b-obras">
                <i data-lucide="construction" class="btn-icon"></i> Obras
            </a>
            <a id="lnkEquipamientos" href="#" class="btn-menu b-equipamientos">
                <i data-lucide="building-2" class="btn-icon"></i> Equipamientos
            </a>
            <a id="lnkCementerios" href="#" class="btn-menu b-cementerios" style="display: none;">
                <i data-lucide="rose" class="btn-icon"></i> Cementerios
            </a>
            <a id="lnkResiduos" href="#" class="btn-menu b-residuos">
                <i data-lucide="recycle" class="btn-icon"></i> Residuos
            </a>
            <a id="lnkAgua" href="#" class="btn-menu b-agua">
                <i data-lucide="droplet" class="btn-icon"></i> Abastecimiento de agua
            </a>
            <a id="lnkSaneamiento" href="#" class="btn-menu b-saneamiento" style="display: none;">
                <i data-lucide="test-tube" class="btn-icon"></i> Saneamiento y depuración
            </a>
            <a id="lnkAlumbrado" href="#" class="btn-menu b-alumbrado" style="display: none;">
                <i data-lucide="lightbulb" class="btn-icon"></i> Alumbrado Público
            </a>
            <a id="lnkViario" href="#" class="btn-menu b-viario" style="display: none;">
                <i data-lucide="milestone" class="btn-icon"></i> Viario
            </a>
        </div>

        <div style="margin-top: 1.5rem; text-align: center;">
            <button onclick="logout()" style="color: #94a3b8; font-size: 0.9rem; background: none; border: none; cursor: pointer; text-decoration: underline;">
                Cerrar Sesión
            </button>
        </div>
    </div>
</div>

<footer class="login-footer">
    <p>Gestionado por:</p>
    <div class="contenedor-logos">
        <a href="https://www.diputacionalicante.es" target="_blank"><img src="img/logo_dipu.gif" alt="Diputación" class="logo-img"></a>
        <a href="https://www.geonet.es" target="_blank"><img src="img/logo_geonet.png" alt="GeoNet" class="logo-img"></a>
    </div>
    <p class="copyright">© 2026 Web desarrollada por Geonet Territorial SAU</p>
</footer>

<script>
    /**
     * [1] ESTADO Y CONFIGURACIÓN INICIAL
     * Datos inyectados desde el servidor vía Jinja2.
     */
    const MUNICIPIOS = {{ municipios_lista | safe }}; 
    const URL_LOGIN_API = "{{ url_login_api }}";
    const MUNICIPIOS_FLAGS = {{ config_flags_json | safe }}; 

    /**
     * [2] MAPEO DE ELEMENTOS DEL DOM
     * Referencias centralizadas para evitar consultas repetitivas.
     */
    const ui = {
        login: document.getElementById('viewLogin'),
        menu: document.getElementById('viewMenu'),
        select: document.getElementById('muniSelect'),
        input: document.getElementById('muniCode'),
        btn: document.getElementById('btnLogin'),
        error: document.getElementById('errorMsg'),
        muniInfo: document.getElementById('headerMuniInfo'),
        headerBadge: document.getElementById('headerCode'),
        headerName: document.getElementById('headerMuniName'),
        links: {
            agua: document.getElementById('lnkAgua'),
            obras: document.getElementById('lnkObras'),
            residuos: document.getElementById('lnkResiduos'),
            cementerios: document.getElementById('lnkCementerios'),
            equipamientos: document.getElementById('lnkEquipamientos'),
            alumbrado: document.getElementById('lnkAlumbrado'),
            viario: document.getElementById('lnkViario'),
            saneamiento: document.getElementById('lnkSaneamiento')
        }
    };

    /**
     * [3] GESTIÓN DE SESIÓN Y PERSISTENCIA
     * Funciones para controlar el estado de acceso del usuario.
     */
    window.logout = function() {
        localStorage.clear(); 
        document.getElementById('mainHeader').classList.remove('header-expanded');
        window.location.reload();
    }

    /**
     * Verifica si ya hay una sesión activa al cargar la página.
     */
    function checkSession() {
        const code = localStorage.getItem("eiel_muni_code");
        const name = localStorage.getItem("eiel_muni_name");
        if(code && name) loginSuccess(code, name);
    }


    MUNICIPIOS.forEach(m => {
        const opt = document.createElement('option');
        opt.value = m.code;
        opt.textContent = `${m.name} (${m.code})`; 
        ui.select.appendChild(opt);
    });

    /**
     * [4] LÓGICA DE NEGOCIO Y COMUNICACIÓN (API)
     * Manejo de autenticación y peticiones externas.
     */
    ui.btn.addEventListener('click', async () => {
        const selectedCode = ui.select.value;
        const enteredPass = ui.input.value.trim();

        if(!selectedCode || !enteredPass) {
            showError("Seleccione un municipio e introduzca el código.");
            return;
        }

        ui.btn.disabled = true; 
        ui.btn.textContent = "Verificando..."; 
        ui.error.style.display = 'none';

        try {
            const response = await fetch(URL_LOGIN_API, {
                method: 'POST',
                headers: { "Content-Type": "text/plain" },
                body: JSON.stringify({ codigo: selectedCode, password: enteredPass })
            });
            const data = await response.json();

            if (data.valid === true) {
                const muniLocal = MUNICIPIOS.find(m => m.code === selectedCode);
                const nombreParaGuardar = muniLocal ? muniLocal.name_bonito : data.nombre;
                loginSuccess(selectedCode, nombreParaGuardar);
            } else {
                showError("Código de acceso incorrecto.");
            }
        } catch (error) {
            console.error(error); 
            showError("Error de conexión con el servidor.");
        } finally {
            ui.btn.disabled = false; 
            ui.btn.textContent = "Entrar";
        }
    });

    /**
     * [5] RENDERIZADO Y MANIPULACIÓN DE UI
     * Funciones que actualizan visualmente el portal tras el login.
     */
    function loginSuccess(code, name) {
        
        document.getElementById('mainHeader').classList.add('header-expanded');
        
        localStorage.setItem("eiel_muni_code", code);
        localStorage.setItem("eiel_muni_name", name);

        // Actualización Visual de Cabecera
        ui.muniInfo.style.display = 'flex';  
        ui.headerBadge.textContent = `(Cód. ${code})`;
        
        if (name.includes(" / ")) {
            ui.headerName.innerHTML = name.replace(" / ", "<br>");
        } else {
            ui.headerName.textContent = name;
        }
        
        // Configuración de Enlaces a los HTML generados
        ui.links.agua.href = `agua_${code}.html`;
        ui.links.obras.href = `obras_${code}.html`;
        ui.links.residuos.href = `residuos_${code}.html`;
        ui.links.cementerios.href = `cementerios_${code}.html`;
        ui.links.equipamientos.href = `equipamientos_${code}.html`;

        const flags = MUNICIPIOS_FLAGS[code] || { alumbrado: false, viario: false, saneamiento: false };
        
        ui.links.alumbrado.href = `alumbrado_${code}.html`;
        ui.links.alumbrado.style.display = flags.alumbrado ? 'flex' : 'none';
        
        ui.links.viario.href = `viario_${code}.html`;
        ui.links.viario.style.display = flags.viario ? 'flex' : 'none';
        
        ui.links.saneamiento.href = `saneamiento_${code}.html`;
        ui.links.saneamiento.style.display = flags.saneamiento ? 'flex' : 'none';
        
        ui.links.cementerios.href = `cementerios_${code}.html`;
        ui.links.cementerios.style.display = flags.cementerios ? 'flex' : 'none';

        // Cambio de Vista
        ui.login.classList.add('hidden');
        ui.menu.classList.remove('hidden');
        ui.error.style.display = 'none';
    }

    function showError(msg) {
        ui.error.textContent = msg;
        ui.error.style.display = 'block';
    }

    /**
     * [6] INICIALIZACIÓN DEL CICLO DE VIDA (Lifecycle)
     * Ejecución tras la carga completa del documento.
     */
    document.addEventListener('DOMContentLoaded', () => {
        // --- PARA FIREFOX: Carga robusta de iconos ---
        const initLucide = () => {
            if (window.lucide) {
                lucide.createIcons();
            } else {
                // Reintento si el script externo aún no está disponible
                setTimeout(initLucide, 100);
            }
        };
        initLucide();
        // --- FIN PARA FIREFOX ---
        
        if (!localStorage.getItem("eiel_muni_code")) {
            localStorage.clear();
        }
        checkSession();
    });
</script>
</body>
</html>