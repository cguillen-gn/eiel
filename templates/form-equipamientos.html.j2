{% extends "base.html.j2" %}

{% block bloque_fase %} Fase {{ fase_actual }} {% endblock %}

{% block title %}Equipamientos y Dotaciones{% endblock %}
{% block header_icon %}🏛️{% endblock %}
{% block header_title %}Equipamientos y Dotaciones{% endblock %}

{% block content %}

{# --- INSTRUCCIONES --- #}
<div class="card card-info">
    <h4>ℹ️ Instrucciones</h4>
    <ul>
        <li>
            Rellene los datos requeridos acerca del alumbrado público. Si no dispone de algún dato, indíquelo en el apartado de <strong>Observaciones</strong>.
        </li>
    </ul>
</div>

{# --- ACORDEONES DE EQUIPAMIENTOS GENERALES --- #}
{% set orden_categorias = ['CASA CONSISTORIAL', 'CENTRO CULTURAL', 'CENTRO ENSEÑANZA', 'CENTRO SANITARIO','CENTRO ASISTENCIAL', 'MERCADO/LONJA','PROTECCIÓN CIVIL', 'TANATORIO', 'INSTALACIÓN DEPORTIVA', 'PARQUE'] %}

{# --- DEFINIR ICONOS POR CATEGORÍA --- #}
{% set iconos_cat = {
    'CASA CONSISTORIAL': 'landmark',
    'CENTRO CULTURAL': 'clapperboard',
    'CENTRO ENSEÑANZA': 'graduation-cap',
    'CENTRO SANITARIO': 'hospital',
    'CENTRO ASISTENCIAL': 'accessibility',
    'MERCADO/LONJA': 'shopping-basket',
    'PROTECCIÓN CIVIL': 'shield-alert',
    'TANATORIO': 'church',
    'INSTALACIÓN DEPORTIVA': 'volleyball',
    'PARQUE': 'tree-pine'
} %}


{% for cat_nombre in orden_categorias %}
    {% if cat_nombre in equipamientos_agrupados.general %}
        {% set lista = equipamientos_agrupados.general[cat_nombre] %}
        <details class="card-accordion">
            <summary class="acc-header">
                <i data-lucide="chevron-right" class="acc-chevron"></i>
                <div class="acc-title-box">
                    <i data-lucide="{{ iconos_cat[cat_nombre] if cat_nombre in iconos_cat else 'help-circle' }}" class="acc-icon"></i>
                    <span>{{ cat_nombre }}</span>
                    <span class="acc-badge">({{ lista|length }} registros)</span>
                </div>
            </summary>
            
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="col-foto">Foto</th>
                            <th class="col-mapa">Ubicación</th>
                            <th class="col-deno">Denominación</th>
                            <th class="col-estado">Estado</th>
                            <th class="col-obs">Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for eq in lista %}
                        <tr class="fila-equip" data-id="{{ eq.cod }}">
                            <td class="td-foto">
                                <div style="width: 52px; height: 40px; margin: 0 auto; position: relative; display: flex; align-items: center; justify-content: center;">
                                    {% if eq.url_foto %}
                                        <img src="{{ eq.url_foto }}" 
                                             class="img-thumb" 
                                             alt="Foto"
                                             onclick="abrirVisorImagen(this.src)"
                                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                        
                                        {# Este solo se activa si la imagen de arriba falla #}
                                        <div class="no-photo-placeholder" style="display: none;">
                                            <i data-lucide="camera-off" style="width: 16px;"></i>
                                        </div>
                                    {% else %}
                                        {# Caso normal: No hay foto #}
                                        <div class="no-photo-placeholder">
                                            <i data-lucide="camera-off" style="width: 16px;"></i>
                                        </div>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="td-ubicacion">
                                <a href="{{ eq.url_visor }}" target="_blank" class="btn-mapa-mini">
                                    <i data-lucide="map-pin"></i><span>Mapa</span>
                                </a>
                            </td>
                            <td>
                                <div class="nombre-eq"><strong>{{ eq.nombre }}</strong></div> <small class="cod-eq">Cód: {{ eq.cod }}</small>
                            </td>
                            <td>
                                <div class="estado-wrapper">
                                    <span class="status-dot dot-{{ eq.estado_txt.lower().replace(' ', '').replace('ó', 'o') }}"></span>
                                    <select class="form-select select-estado-eq" data-id="{{ eq.cod }}">
                                        <option value="Bueno" {% if eq.estado_txt == 'Bueno' %}selected{% endif %}>Bueno</option>
                                        <option value="Regular" {% if eq.estado_txt == 'Regular' %}selected{% endif %}>Regular</option>
                                        <option value="Malo" {% if eq.estado_txt == 'Malo' %}selected{% endif %}>Malo</option>
                                        <option value="En ejecución" {% if eq.estado_txt == 'En ejecución' %}selected{% endif %}>En ejecución</option>
                                    </select>
                                </div>
                            </td>
                            <td>
                                <textarea class="form-input txt-obs-eq" rows="1" placeholder="..."></textarea>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </details>
    {% endif %}
{% endfor %}

{# --- SECCIÓN ESPECIAL: EDIFICIOS PÚBLICOS SIN USO (Integrado y Suavizado) --- #}
<details class="card-accordion">
    <summary class="acc-header">
        <i data-lucide="chevron-right" class="acc-chevron"></i>
        <div class="acc-title-box">
            <i data-lucide="door-closed" class="acc-icon"></i>
            <span>EDIFICIOS PÚBLICOS SIN USO</span>
            <span class="acc-badge">({{ equipamientos_agrupados.sin_uso|length }} registros)</span>
        </div>
    </summary>

    <div class="table-wrapper">
        <p class="sin-uso-intro">Indique si estos edificios han pasado a tener un uso concreto o si continúan cerrados.</p>
        <table class="data-table">
            <thead>
                <tr>
                    <th class="col-foto">Foto</th>
                    <th class="col-mapa">Ubicación</th>
                    <th class="col-deno">Denominación</th>
                    <th class="col-obs">¿Tiene uso?</th>
                </tr>
            </thead>
            <tbody>
                {% for su in equipamientos_agrupados.sin_uso %}
                <tr class="fila-sin-uso" data-id="{{ su.cod }}">
                    <td class="td-foto">
                        <div style="width: 52px; height: 40px; margin: 0 auto; position: relative; display: flex; align-items: center; justify-content: center;">
                            {% if su.url_foto %}
                                <img src="{{ su.url_foto }}" 
                                     class="img-thumb" 
                                     alt="Foto"
                                     onclick="abrirVisorImagen(this.src)"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                
                                {# Este solo se activa si la imagen de arriba falla #}
                                <div class="no-photo-placeholder" style="display: none;">
                                    <i data-lucide="camera-off" style="width: 16px;"></i>
                                </div>
                            {% else %}
                                {# Caso normal: No hay foto #}
                                <div class="no-photo-placeholder">
                                    <i data-lucide="camera-off" style="width: 16px;"></i>
                                </div>
                            {% endif %}
                        </div>
                    </td>

                                        <td class="td-ubicacion">
                        <a href="{{ su.url_visor }}" target="_blank" class="btn-mapa-mini"><i data-lucide="map-pin"></i><span>Mapa</span></a>
                    </td>
                    <td>
                        <div class="nombre-eq"><strong>{{ su.nombre }}</strong></div>
                        <small class="cod-eq">Cód: {{ su.cod }}</small>
                    </td>
                    <td>
                        <div class="uso-container">
                            <select class="form-select select-sin-uso" data-id="{{ su.cod }}" 
                                    onchange="const box = document.getElementById('box_uso_{{su.cod}}'); this.value === 'SI' ? box.classList.remove('hidden') : box.classList.add('hidden')">
                                <option value="NO">NO, sigue sin uso</option>
                                <option value="SI">SÍ, ya tiene uso</option>
                            </select>
                            <div id="box_uso_{{su.cod}}" class="hidden" style="margin-top: 8px;">
                                <input type="text" class="form-input txt-nuevo-uso" placeholder="Indique el nuevo uso...">
                            </div>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</details>



{# --- REQUERIMIENTOS --- #}
{% if avisos_personalizados and avisos_personalizados|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h4 class="requerimientos-title">⚠️ Otra información solicitada</h4>
        <p class="requerimientos-intro">
            Se ha detectado falta de información o incidencias en los <strong>Equipamientos</strong>. Por favor, responda en <strong>Observaciones</strong>.
        </p>
        <ul class="requerimientos-list">
            {% for aviso in avisos_personalizados %}
                <li class="requerimiento-item-box prioridad-{{ 'alta' if aviso.prioridad == 'alta' else 'media' }}">
                    <span class="requerimiento-icon">{{ '🔴' if aviso.prioridad == 'alta' else '🔸' }}</span>
                    <div class="requerimiento-content-text">
                        <span class="requerimiento-msg">{{ aviso.mensaje }}</span>
                        {% if aviso.url %}
                            <a href="{{ aviso.url }}" target="_blank" class="btn-geoportal">
                                <i data-lucide="globe"></i> Ver en Geoportal
                            </a>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    </div>
</div>
{% endif %}

{# --- OBSERVACIONES --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" placeholder="Indique aquí cualquier incidencia, aclaración o dato relevante..."></textarea>
    </div>
</div>

{# --- ADJUNTOS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="folder"></i>Documentación Adjunta (Opcional)</h2>
    <div class="file-upload-area" onclick="document.getElementById('fileInput').click()">
        <div class="upload-icon">📎</div>
        <div class="upload-text">Haga clic para adjuntar archivos</div>
        <p class="upload-help">(Planos, fotos, informes, análisis...)</p>
        <input type="file" id="fileInput" multiple style="display: none;">
    </div>
    <div id="fileList" class="file-list-container"></div>
</div>

{# --- DATOS DE CONTACTO --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required>
        </div>
       <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;">
            </div>
    </div>
</div>

{# --- DECLARACIÓN RESPONSABLE --- #}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text">
                <strong>Declaración de veracidad:</strong> Como responsable, 
                confirmo que los datos introducidos son correctos y actualizados.
            </span>
        </label>
    </div>
    
    <div id="progressContainer" class="progress-container">
        <div class="progress-labels">
            <span id="progressText">Preparando envío...</span>
            <span id="progressPercentage">0%</span>
        </div>
        <div class="progress-track">
            <div id="progressBar"></div>
        </div>
    </div>

    <button id="btnEnviar" class="btn btn-primary" onclick="enviarEquipamientos()" disabled>
        Enviar Datos
    </button>
</div>

{% endblock %}

{% block scripts %}
<script>
document.addEventListener("DOMContentLoaded", () => {
       
    // 0. ACTIVADOR DE TEMA (Clase Maestra)
    document.body.classList.add('theme-equipamientos');
    
    // Ejecuta la creación de iconos de Lucide
    if (window.lucide) {
        lucide.createIcons();
    }
    
    // 1. SETUP DE ESTILOS
    const header = document.querySelector('.site-header');
    if(header) header.classList.add('header-equipamientos');
    
    // 2. CONFIGURACIÓN GLOBAL
    window.EIEL_CONFIG = {
        muniCode: "{{ muni_code }}",
        muniName: "{{ muni_display }}",
        fase: "{{ fase_actual }}",
        urlGenerarPdf: "{{ url_generar_pdf }}",
        urlAdjuntos: "{{ url_adjuntos }}",
        urlLogger: "{{ url_logger }}"
    };

    // 3. SELECTOR ESTADOS
    document.querySelectorAll('.select-estado-eq').forEach(sel => {
        sel.addEventListener('change', function() {
            const dot = this.parentNode.querySelector('.status-dot');
            if (dot) {
                dot.className = 'status-dot';
                // Normalizamos: "En ejecución" -> "enejecucion"
                const classValue = this.value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, "");
                dot.classList.add('dot-' + classValue);
            }
        });
    });

    // 4. GESTIÓN DE ADJUNTOS (Limpio y Único)
    let archivosAdjuntos = [];
    const fileInput = document.getElementById('fileInput');
    const fileList = document.getElementById('fileList');

    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosAdjuntos.push(...Array.from(fileInput.files));
            renderFiles();
            fileInput.value = '';
        });
    }

    window.removeFile = (i) => { 
        archivosAdjuntos.splice(i, 1); 
        renderFiles();
    };

    function renderFiles() {
        fileList.innerHTML = archivosAdjuntos.map((f, i) => `
            <div style="display:flex; justify-content:space-between; background:#f1f5f9; padding:8px; border-radius:6px; font-size:0.85rem;">
                <span>📄 ${f.name}</span>
                <button onclick="removeFile(${i})" style="color:red; border:none; background:none; cursor:pointer;">✕</button>
            </div>
        `).join("");
    }

    // --- 5. ACTIVACIÓN DEL BOTÓN DE ENVÍO ---
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");

    if (checkConf && btnEnviar) {
        checkConf.addEventListener('change', function() {
            btnEnviar.disabled = !this.checked;
            btnEnviar.style.opacity = this.checked ? "1" : "0.6";
            btnEnviar.style.cursor = this.checked ? "pointer" : "not-allowed";
        });
    }
    
    // Bloqueo del formulario para evitar múltiples clics
    const toggleFormFreeze = (freeze) => {
        const btn = document.getElementById("btnEnviar");
        if (btn) btn.disabled = freeze;
        document.querySelectorAll('input, select, textarea, button').forEach(el => {
            el.style.pointerEvents = freeze ? 'none' : 'auto';
            if(freeze) el.style.opacity = "0.7";
            else el.style.opacity = "1";
        });
    };

    // Control visual de la barra de progreso
    const UIProgress = {
        show: (totalArchivos) => {
            const container = document.getElementById('progressContainer');
            if (container) container.style.display = 'block'; // Muestra el contenedor oculto
            UIProgress.update(0, totalArchivos, "Iniciando envío...");
        },
        update: (current, total, message) => {
            const percent = total > 0 ? Math.round((current / total) * 100) : 50;
            const bar = document.getElementById('progressBar');
            const txt = document.getElementById('progressText');
            const pctTxt = document.getElementById('progressPercentage');
            
            if (bar) bar.style.width = percent + '%';
            if (txt) txt.innerText = message;
            if (pctTxt) pctTxt.innerText = percent + '%';
        },
        complete: () => {
            UIProgress.update(1, 1, "¡Envío completado!");
            const bar = document.getElementById('progressBar');
            if (bar) bar.classList.add("progress-success");
        }
    };

    // Servicio de subida de archivos (Ajustar según tu backend)
    const UploadService = {
        uploadFile: async (file, tipo, muni, cat, id) => {
            const formData = new FormData();
            formData.append('file', file);
            formData.append('muni', muni);
            formData.append('id_envio', id);
            
            return fetch(window.EIEL_CONFIG.urlAdjuntos, {
                method: 'POST',
                mode: 'no-cors', // Ajustar según configuración de CORS
                body: formData
            });
        }
    };
    

    // --- 6. LA FUNCIÓN DE ENVÍO (MÁXIMA PRIORIDAD) ---
    // La definimos como una función global (window) para que el 'onclick' del HTML la encuentre
    window.enviarEquipamientos = async function() {
        const nombre = document.getElementById("contactoNombre").value.trim();
        const email = document.getElementById("contactoEmail").value.trim();
        const emailConfirm = document.getElementById("contactoEmailConfirm").value.trim();
        const depto = document.getElementById("contactoDepartamento").value.trim();
        const obsGenerales = document.getElementById("observaciones").value.trim();

        // Validaciones básicas de contacto 
        if (!nombre || !email || email !== emailConfirm) {
            Swal.fire("Error", "Verifique los datos de contacto y que el email coincida.", "error");
            return;
        }

        const idEnvio = "EXP_E_" + new Date().getTime(); 
        toggleFormFreeze(true); // Congelamos el formulario como en Obras
        UIProgress.show(archivosAdjuntos.length);

        try {
            // Subida de archivos 
            let nombresArchivos = [];
            for (let i = 0; i < archivosAdjuntos.length; i++) {
                const file = archivosAdjuntos[i];
                UIProgress.update(i, archivosAdjuntos.length, `Subiendo: ${file.name}`);
                await UploadService.uploadFile(file, 'equipamiento', window.EIEL_CONFIG.muniCode, 'GENERAL', idEnvio);
                nombresArchivos.push(file.name);
            }

            // Recopilación de datos de la tabla para el PDF 
            UIProgress.update(archivosAdjuntos.length, archivosAdjuntos.length, "Generando PDF...");
        
        const datosEquipamientos = [];

            // Registros de las tablas de los acordeones
            document.querySelectorAll('.fila-equip').forEach(fila => {
                const categoria = fila.closest('details').querySelector('.acc-header span').textContent.trim();
                datosEquipamientos.push({
                    categoria: categoria,
                    id: fila.dataset.id,
                    nombre: fila.querySelector('.nombre-eq').textContent,
                    estado: fila.querySelector('.select-estado-eq').value,
                    obs: fila.querySelector('.txt-obs-eq').value.trim(),
                    validado_ok: false
                });
            });

            // Registros de la sección "Sin Uso"
            document.querySelectorAll('.fila-sin-uso').forEach(fila => {
                const sigueSinUso = fila.querySelector('.select-sin-uso').value;
                const nuevoUso = fila.querySelector('.txt-nuevo-uso').value.trim();
                const cod = fila.dataset.id;

                datosEquipamientos.push({
                    categoria: "EDIFICIO PÚBLICO SIN USO",
                    id: cod,
                    nombre: fila.querySelector('strong').textContent,
                    estado: sigueSinUso === 'SI' ? 'SIN USO' : 'CON USO',
                    obs: sigueSinUso === 'NO' ? "NUEVO USO: " + nuevoUso : "Confirmado sigue sin uso",
                    validado_ok: true
                });
            });

            // Envío final al Apps Script del PDF 
            const payload = {
                tipo_formulario: "equipamientos",
                fase: window.EIEL_CONFIG.fase,
                id_envio: idEnvio,
                municipio_codigo: window.EIEL_CONFIG.muniCode,
                municipio_nombre: window.EIEL_CONFIG.muniName,
                nombre_contacto: nombre,
                email_contacto: email,
                departamento_contacto: depto,
                observaciones: obsGenerales,
                datos_equipamientos_json: JSON.stringify(datosEquipamientos),
                archivos_adjuntos: nombresArchivos.join("\n")
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                method: "POST",
                mode: "no-cors",
                body: JSON.stringify(payload)
            });

            UIProgress.complete(); 
            Swal.fire("¡Éxito!", "Justificante enviado a su email.", "success").then(() => {
                window.location.href = "index.html";
            });

        } catch (error) {
            console.error(error);
            Swal.fire("Error", "Error en el proceso: " + error.message, "error");
            toggleFormFreeze(false);
        }
    };
    lucide.createIcons();
    
    // Función para ampliar imágenes
    window.abrirVisorImagen = (src) => {
    // Creamos el contenedor del modal si no existe
    let modal = document.getElementById('visorImagenGlobal');
    if (!modal) {
        modal = document.createElement('div');
        modal.id = 'visorImagenGlobal';
        modal.className = 'modal-img';
        modal.innerHTML = `<img src="" id="imgVisor">`;
        modal.onclick = () => modal.style.display = 'none';
        document.body.appendChild(modal);
    }
    
    // Asignamos la imagen y mostramos
    const img = modal.querySelector('img');
    img.src = src;
    modal.style.display = 'flex';
};
    
});




</script>
{% endblock %}