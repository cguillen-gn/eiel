{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'equipamientos' %}

{% block title %}EIEL - Equipamientos{% endblock %}
{% block header_icon %}<i data-lucide="building-2"></i>{% endblock %}
{% block header_title %}EQUIPAMIENTOS{% endblock %}

{% block content %}
<form id="formEquipamientos">
    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            Despliegue cada temática para ver los equipamientos disponibles.
            <li><strong>Estado:</strong> Seleccione el estado de conservación de cada registro.</li>
            <li><strong>Observaciones:</strong> Indique cambios de nombre, uso o ceses de servicio.</li>
        </ul>
    </div>

    {# 3. EQUIPAMIENTOS GENERALES (Agrupados por categoría) #}
    {% set orden_categorias = ['CASA CONSISTORIAL', 'CENTRO CULTURAL', 'CENTRO ENSEÑANZA', 'CENTRO SANITARIO','CENTRO ASISTENCIAL', 'MERCADO/LONJA','PROTECCIÓN CIVIL', 'TANATORIO', 'INSTALACIÓN DEPORTIVA', 'PARQUE'] %}
    {% set iconos_cat = {'CASA CONSISTORIAL': 'landmark', 'CENTRO CULTURAL': 'clapperboard', 'CENTRO ENSEÑANZA': 'graduation-cap', 'CENTRO SANITARIO': 'hospital', 'CENTRO ASISTENCIAL': 'accessibility', 'MERCADO/LONJA': 'shopping-basket', 'PROTECCIÓN CIVIL': 'shield-alert', 'TANATORIO': 'house-heart', 'INSTALACIÓN DEPORTIVA': 'volleyball', 'PARQUE': 'tree-pine'} %}

    {% for cat_nombre in orden_categorias %}
        {% if cat_nombre in equipamientos_agrupados.general and equipamientos_agrupados.general[cat_nombre]|length > 0 %}
            {% set lista = equipamientos_agrupados.general[cat_nombre] %}
            <details class="card-accordion">
                <summary class="acc-header">
                    <i data-lucide="chevron-right" class="acc-chevron"></i>
                    <div class="acc-title-box">
                        <i data-lucide="{{ iconos_cat[cat_nombre] if cat_nombre in iconos_cat else 'help-circle' }}" class="acc-icon"></i>
                        <span>{{ cat_nombre }}</span>
                        <span class="acc-badge">({{ lista|length }})</span>
                    </div>
                </summary>
                <div class="table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th class="col-foto">Foto</th>
                                <th class="col-mapa">Ubicación</th>
                                <th class="col-deno">Denominación</th>
                                <th class="col-estado">Estado</th>
                                <th class="col-obs">Observaciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for eq in lista %}
                            <tr class="fila-equip" data-id="{{ eq.cod }}">
                                <td class="td-foto">
                                    {% if eq.url_foto %}
                                        <img src="{{ eq.url_foto }}" class="img-thumb" onclick="abrirVisorImagen(this.src)" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                        <div class="no-photo-placeholder" style="display: none;"><i data-lucide="camera-off"></i></div>
                                    {% else %}
                                        <div class="no-photo-placeholder"><i data-lucide="camera-off"></i></div>
                                    {% endif %}
                                </td>
                                <td class="td-ubicacion">
                                    <a href="{{ eq.url_visor }}" target="_blank" class="btn btn-secondary btn-sm" style="background: white; border: 1px solid #cbd5e1;">
                                        <i data-lucide="map-pin"></i><span> Mapa</span>
                                    </a>
                                </td>
                                <td><strong>{{ eq.nombre }}</strong><br><small>Cód: {{ eq.cod }}</small></td>
                                <td>
                                    <div class="estado-wrapper">
                                        <span class="status-dot dot-{{ eq.estado_txt.lower().replace(' ', '').replace('ó', 'o') }}"></span>
                                        <select class="form-select select-estado" data-id="{{ eq.cod }}" data-original="{{ eq.estado_txt }}">
                                            <option value="Bueno" {% if eq.estado_txt == 'Bueno' %}selected{% endif %}>Bueno</option>
                                            <option value="Regular" {% if eq.estado_txt == 'Regular' %}selected{% endif %}>Regular</option>
                                            <option value="Malo" {% if eq.estado_txt == 'Malo' %}selected{% endif %}>Malo</option>
                                            <option value="En ejecución" {% if eq.estado_txt == 'En ejecución' %}selected{% endif %}>En ejecución</option>
                                        </select>
                                    </div>
                                </td>
                                <td><textarea class="form-input txt-obs-eq" rows="1" placeholder="..."></textarea></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </details>
        {% endif %}
    {% endfor %}

    {# 4. EDIFICIOS SIN USO #}
    {% if equipamientos_agrupados.sin_uso|length > 0 %}
    <details class="card-accordion">
        <summary class="acc-header">
            <i data-lucide="chevron-right" class="acc-chevron"></i>
            <div class="acc-title-box">
                <i data-lucide="door-closed" class="acc-icon"></i>
                <span>EDIFICIOS PÚBLICOS SIN USO</span>
                <span class="acc-badge">({{ equipamientos_agrupados.sin_uso|length }})</span>
            </div>
        </summary>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="col-foto">Foto</th>
                        <th class="col-mapa">Ubicación</th>
                        <th class="col-deno">Denominación</th>
                        <th class="col-obs">¿Tiene uso?</th>
                    </tr>
                </thead>
                <tbody>
                    {% for su in equipamientos_agrupados.sin_uso %}
                    <tr class="fila-sin-uso" data-id="{{ su.cod }}">
                        <td class="td-foto">
                            {% if su.url_foto %}<img src="{{ su.url_foto }}" class="img-thumb" onclick="abrirVisorImagen(this.src)">{% else %}<div class="no-photo-placeholder"><i data-lucide="camera-off"></i></div>{% endif %}
                        </td>
                        <td class="td-ubicacion"><a href="{{ su.url_visor }}" target="_blank" class="btn btn-secondary btn-sm"><i data-lucide="map-pin"></i></a></td>
                        <td><strong>{{ su.nombre }}</strong><br><small>Cód: {{ su.cod }}</small></td>
                        <td>
                            <select class="form-select select-sin-uso" data-id="{{ su.cod }}" onchange="const box = document.getElementById('box_uso_{{su.cod}}'); this.value === 'SI' ? box.classList.remove('hidden') : box.classList.add('hidden')">
                                <option value="NO">Sigue sin uso</option>
                                <option value="SI">Ya tiene uso</option>
                            </select>
                            <div id="box_uso_{{su.cod}}" class="hidden" style="margin-top: 8px;">
                                <input type="text" class="form-input txt-nuevo-uso" placeholder="Nuevo uso...">
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </details>
    {% endif %}

    {# 5. NOTIFICAR NUEVO EQUIPAMIENTO #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-plus"></i>Notificar Nuevo Equipamiento</h2>
        <div class="table-wrapper" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 30%;">DENOMINACIÓN / UBICACIÓN</th>
                        <th style="width: 32%;">USO(S) / ESTADO</th>
                        <th style="width: 22%;">OBSERVACIONES</th>
                        <th style="width: 15%; text-align: center;">DOC.</th>
                        <th style="width: 5%;"></th>
                    </tr>
                </thead>
                <tbody id="tbodyNuevos"></tbody>
            </table>
        </div>
        <button type="button" class="btn btn-secondary btn-sm" onclick="window.agregarFilaNuevoEquipamiento()" 
                style="margin-top: 1rem; background: white; border: 1px solid #cbd5e1;">
            <i data-lucide="plus"></i> Añadir otro
        </button>
    </div>

    {# 6. REQUERIMIENTOS (DISEÑO CORREGIDO) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Otra información solicitada</h2>
        <p class="form-help form-help-spacer">Responda a cada punto y adjunte documentación si es necesario.</p>
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    {# Dentro del bucle de avisos #}
                    <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                            <span style="font-weight: 600; font-size: 0.95rem;">{{ aviso.mensaje }}</span>
                        </div>
                        {% if aviso.url %}
                        <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" 
                           class="btn btn-secondary btn-sm" style="background: white; border: 1px solid #cbd5e1; display: flex; align-items: center; gap: 5px;">
                            <i data-lucide="map" style="width: 14px; height: 14px;"></i> Mapa
                        </a>
                        {% endif %}
                    </div>

                    <div style="margin-left: 28px; background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0; box-sizing: border-box; width: calc(100% - 28px);">
                        <textarea class="form-input txt-resp-req" ...></textarea>
                        
                        {# Botón Adjuntar con fondo blanco [cite: 420] #}
                        <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosReq('{{ req_id }}')"
                                style="background: white; border: 1px solid #cbd5e1;">
                            <i data-lucide="paperclip"></i> Adjuntar
                        </button>
                        {{ ui.ayuda_archivo() }}
                        <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                    </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 7. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
<input type="file" id="hiddenInputNuevos" multiple style="display: none;">
{% endblock %}

{% block scripts %}
<script>
// Variables de estado
let archivosGenerales = [];
let colaAdjuntosReq = {};
let colaAdjuntosNuevos = {};
let reqIdActual = null;
let filaActualAdjuntos = null;
let contadorNuevosEq = 0;

document.addEventListener("DOMContentLoaded", () => {
    // A. Gestión de adjuntos generales (Arregla el Drag and Drop)
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosGenerales = [...archivosGenerales, ...Array.from(fileInput.files)];
            renderArchivos();
            fileInput.value = "";
        });
    }

    // B. Gestión de adjuntos para Requerimientos
    const inputReq = document.getElementById('hiddenInputReq');
    window.gestionarAdjuntosReq = (id) => { reqIdActual = id; if(inputReq) inputReq.click(); };
    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            colaAdjuntosReq[reqIdActual] = [...(colaAdjuntosReq[reqIdActual] || []), ...Array.from(inputReq.files)];
            renderColaReq(reqIdActual);
            inputReq.value = "";
        });
    }

    // C. Gestión de adjuntos para Nuevos Equipamientos
    const inputNuevos = document.getElementById('hiddenInputNuevos');
    window.gestionarAdjuntosFila = (idFila) => { filaActualAdjuntos = idFila; if(inputNuevos) inputNuevos.click(); };
    if (inputNuevos) {
        inputNuevos.addEventListener('change', () => {
            if (!filaActualAdjuntos) return;
            colaAdjuntosNuevos[filaActualAdjuntos] = [...(colaAdjuntosNuevos[filaActualAdjuntos] || []), ...Array.from(inputNuevos.files)];
            renderFilaAdjuntos(filaActualAdjuntos);
            inputNuevos.value = "";
        });
    }

    // D. Cambio dinámico de puntos de estado
    document.querySelectorAll('.select-estado').forEach(sel => {
        sel.addEventListener('change', function() {
            const dot = this.parentNode.querySelector('.status-dot');
            if (dot) {
                dot.className = 'status-dot';
                const classValue = this.value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, "");
                dot.classList.add('dot-' + classValue);
            }
        });
    });

    // E. Inicializar con una fila de nuevo equipamiento
    window.agregarFilaNuevoEquipamiento();

    // F. Lógica de Envío
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) checkConf.addEventListener('change', () => btnEnviar.disabled = !checkConf.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "EQUIP_" + Date.now();
        if (document.getElementById("contactoEmail").value !== document.getElementById("contactoEmailConfirm").value) {
            return Swal.fire("Error", "Los emails no coinciden.", "error");
        }
        toggleFormFreeze(true);

        const listaTareas = [];
        archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
        Object.entries(colaAdjuntosReq).forEach(([id, list]) => list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${parseInt(id)+1}` })));
        Object.entries(colaAdjuntosNuevos).forEach(([id, list]) => list.forEach(f => listaTareas.push({ file: f, seccion: id })));

        UIProgress.show(listaTareas.length);
        try {
            await UploadService.uploadFiles(listaTareas, 'EQUIPAMIENTOS', window.EIEL_CONFIG.muniCode, idBatch, 1);
            
            const payload = {
                tipo_formulario: "equipamientos",
                id_envio: idBatch,
                datos_equipamientos: Array.from(document.querySelectorAll('.fila-equip')).map(tr => ({
                    id: tr.dataset.id, estado: tr.querySelector('.select-estado').value, obs: tr.querySelector('.txt-obs-eq').value.trim()
                })),
                nuevos_equipamientos: Array.from(document.querySelectorAll('.fila-nuevo-eq')).map(f => ({
                    nombre: f.querySelector('.new-deno').value, uso: f.querySelector('.new-uso').value, estado: f.querySelector('.new-estado').value
                })),
                requerimientos: Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                    pregunta: area.dataset.msg, respuesta: area.value
                })),
                contacto: { nombre: document.getElementById("contactoNombre").value, email: document.getElementById("contactoEmail").value }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();
        } catch (error) {
            console.error(error); toggleFormFreeze(false);
            Swal.fire("Error", "Fallo al enviar los datos.", "error");
        }
    });
});

// --- FUNCIONES DE RENDERIZADO ---
function renderArchivos() {
    const fileList = document.getElementById("fileList");
    if (!fileList) return;
    fileList.innerHTML = archivosGenerales.map((f, i) => `<div class="file-item"><span>📄 ${f.name}</span><button type="button" onclick="archivosGenerales.splice(${i},1); renderArchivos();" class="btn-danger-icon"><i data-lucide="trash-2"></i></button></div>`).join("");
    if (window.lucide) lucide.createIcons();
}

function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => `<div class="file-item" style="font-size:0.75rem; border:1px solid #e2e8f0; border-radius:6px; padding:4px 8px; display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;"><span>📄 ${f.name}</span><button type="button" onclick="colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}');" class="btn-danger-icon"><i data-lucide="trash-2" style="width:14px; color:#ef4444;"></i></button></div>`).join("");
}

function renderFilaAdjuntos(idFila) {
    const contenedor = document.getElementById(`lista_adjuntos_${idFila}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosNuevos[idFila] || []).map((f, i) => `<div class="file-item" style="font-size:0.7rem; border:1px solid #e2e8f0; margin-bottom:2px; padding:2px; display:flex; justify-content:space-between;"><span>📄 ${f.name.substring(0,12)}...</span><button type="button" onclick="colaAdjuntosNuevos['${idFila}'].splice(${i},1); renderFilaAdjuntos('${idFila}');" class="btn-danger-icon"><i data-lucide="trash-2" style="width:10px;"></i></button></div>`).join("");
    if (window.lucide) lucide.createIcons();
}

window.agregarFilaNuevoEquipamiento = () => {
    contadorNuevosEq++;
    const idFila = `NUEVO_EQ_${contadorNuevosEq}`;
    const tbody = document.getElementById('tbodyNuevos');
    if (!tbody) return;
    const tr = document.createElement('tr');
    tr.id = `fila_${idFila}`; tr.className = 'fila-nuevo-eq';
    tr.innerHTML = `
        <td style="vertical-align: top; padding: 12px 8px;"><input type="text" class="form-input new-deno" placeholder="Ej: Edificio Polivalente" style="margin-bottom:8px;"><input type="text" class="form-input new-ubica" placeholder="Ubicación"></td>
        <td style="vertical-align: top; padding: 12px 8px;"><input type="text" class="form-input new-uso" placeholder="Uso" style="margin-bottom:8px;"><select class="form-select new-estado"><option value="">Seleccionar...</option><option value="Bueno">Bueno</option><option value="Regular">Regular</option><option value="Malo">Malo</option></select></td>
        <td style="vertical-align: top; padding: 12px 8px;"><textarea class="form-input new-obs-fila" placeholder="..." style="min-height:88px;"></textarea></td>
        <td style="text-align: center; vertical-align: top; padding: 12px 8px;">
            <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosFila('${idFila}')"
                    style="background: white; border: 1px solid #cbd5e1;">
                <i data-lucide="paperclip"></i> Adjuntar
            </button>
            {{ ui.ayuda_archivo() }}
            <div id="lista_adjuntos_${idFila}" class="file-list-container" style="margin-top:8px;"></div>
        </td>
        <td style="text-align: center; vertical-align: top; padding: 12px 8px;"><button type="button" class="btn-danger-icon" onclick="document.getElementById('fila_${idFila}').remove(); delete colaAdjuntosNuevos['${idFila}'];"><i data-lucide="trash-2"></i></button></td>`;
    tbody.appendChild(tr);
    if (window.lucide) lucide.createIcons();
};
</script>
{% endblock %}