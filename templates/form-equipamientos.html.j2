{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'equipamientos' %}

{% block title %}EIEL - Equipamientos{% endblock %}
{% block header_icon %}<i data-lucide="building-2"></i>{% endblock %}
{% block header_title %}EQUIPAMIENTOS{% endblock %}

{% block content %}
<form id="formEquipamientos">
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            Despliegue cada temática para ver los equipamientos disponibles.
            <li><strong>Estado:</strong> Seleccione el estado de conservación de cada registro.</li>
            <li><strong>Observaciones:</strong> Indique cambios de nombre, uso o ceses de servicio.</li>
        </ul>
    </div>

    {# 2. EQUIPAMIENTOS GENERALES #}
    {% set orden_categorias = ['CASA CONSISTORIAL', 'CENTRO CULTURAL', 'CENTRO ENSEÑANZA', 'CENTRO SANITARIO','CENTRO ASISTENCIAL', 'MERCADO/LONJA','PROTECCIÓN CIVIL', 'TANATORIO', 'INSTALACIÓN DEPORTIVA', 'PARQUE'] %}
    {% set iconos_cat = {'CASA CONSISTORIAL': 'landmark', 'CENTRO CULTURAL': 'clapperboard', 'CENTRO ENSEÑANZA': 'graduation-cap', 'CENTRO SANITARIO': 'hospital', 'CENTRO ASISTENCIAL': 'accessibility', 'MERCADO/LONJA': 'shopping-basket', 'PROTECCIÓN CIVIL': 'shield-alert', 'TANATORIO': 'house-heart', 'INSTALACIÓN DEPORTIVA': 'volleyball', 'PARQUE': 'tree-pine'} %}

    {% for cat_nombre in orden_categorias %}
        {% if cat_nombre in equipamientos_agrupados.general and equipamientos_agrupados.general[cat_nombre]|length > 0 %}
            {% set lista = equipamientos_agrupados.general[cat_nombre] %}
            <details class="card-accordion">
                <summary class="acc-header">
                    <i data-lucide="chevron-right" class="acc-chevron"></i>
                    <div class="acc-title-box">
                        <i data-lucide="{{ iconos_cat[cat_nombre] if cat_nombre in iconos_cat else 'help-circle' }}" class="acc-icon"></i>
                        <span>{{ cat_nombre }}</span>
                        <span class="acc-badge">({{ lista|length }})</span>
                    </div>
                </summary>
                <div class="table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th class="col-foto">Foto</th>
                                <th class="col-mapa">Ubicación</th>
                                <th class="col-deno">Denominación</th>
                                <th class="col-estado">Estado</th>
                                <th class="col-obs">Observaciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for eq in lista %}
                            <tr class="fila-equip" data-id="{{ eq.cod }}">
                                <td class="td-foto">
                                    <div style="width: 52px; height: 40px; margin: 0 auto; display: flex; align-items: center; justify-content: center;">
                                        {% if eq.url_foto %}<img src="{{ eq.url_foto }}" class="img-thumb" onclick="abrirVisorImagen(this.src)">{% else %}<div class="no-photo-placeholder"><i data-lucide="camera-off" style="width: 16px;"></i></div>{% endif %}
                                    </div>
                                </td>
                                <td class="td-ubicacion">
                                    <a href="{{ eq.url_visor }}" target="_blank" class="btn btn-secondary btn-sm" style="background: white; border: 1px solid #cbd5e1; display: flex; align-items: center; gap: 5px;">
                                        <i data-lucide="map-pin"></i><span> Mapa</span>
                                    </a>
                                </td>
                                <td>
                                    <div class="nombre-eq"><strong>{{ eq.nombre }}</strong></div> 
                                    <small class="cod-eq">Cód: {{ eq.cod }}</small>
                                </td>
                                <td>
                                    <div class="estado-wrapper">
                                        <span class="status-dot dot-{{ eq.estado_txt.lower().replace(' ', '').replace('ó', 'o') }}"></span>
                                        <select id="estado_{{ eq.cod }}" class="form-select select-estado" data-id="{{ eq.cod }}" data-original="{{ eq.estado_txt }}">
                                            <option value="Bueno" {% if eq.estado_txt == 'Bueno' %}selected{% endif %}>Bueno</option>
                                            <option value="Regular" {% if eq.estado_txt == 'Regular' %}selected{% endif %}>Regular</option>
                                            <option value="Malo" {% if eq.estado_txt == 'Malo' %}selected{% endif %}>Malo</option>
                                            <option value="En ejecución" {% if eq.estado_txt == 'En ejecución' %}selected{% endif %}>En ejecución</option>
                                        </select>
                                    </div>
                                </td>
                                <td><textarea id="obs_{{ eq.cod }}" class="form-input txt-obs-eq" rows="1" placeholder="..."></textarea></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </details>
        {% endif %}
    {% endfor %}

    {# 3. NUEVOS EQUIPAMIENTOS #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="list-plus"></i>Notificar Nuevo Equipamiento</h2>
        <div class="table-wrapper" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 30%;">DENOMINACIÓN / UBICACIÓN</th>
                        <th style="width: 32%;">USO(S) / ESTADO</th>
                        <th style="width: 22%;">OBSERVACIONES</th>
                        <th style="width: 15%; text-align: center;">DOC.</th>
                        <th style="width: 5%;"></th>
                    </tr>
                </thead>
                <tbody id="tbodyNuevos"></tbody>
            </table>
            <input type="hidden" id="json_nuevos_eq_borrador">
        </div>
        <button type="button" class="btn btn-secondary btn-sm" onclick="window.agregarFilaNuevoEquipamiento()" style="margin-top: 1rem; background: white; border: 1px solid #cbd5e1;"><i data-lucide="plus"></i> Añadir otro equipamiento</button>
    </div>

    {# 4. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Otra información solicitada</h2>
        <p class="form-help form-help-spacer">Responda a cada punto y adjunte documentación si es necesario.</p>
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; font-size: 0.95rem;">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}<a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm" style="background: white; border: 1px solid #cbd5e1; display: flex; align-items: center; gap: 5px;"><i data-lucide="map" style="width: 14px;"></i> Mapa</a>{% endif %}
                </div>
                <div style="margin-left: 28px; background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0; box-sizing: border-box; width: calc(100% - 28px);">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" placeholder="Responda aquí..." style="width: 100% !important; box-sizing: border-box; display: block; margin-bottom: 15px; border: 1px solid #cbd5e1;"></textarea>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosReq('{{ req_id }}')" style="background: white; border: 1px solid #cbd5e1;"><i data-lucide="paperclip"></i> Adjuntar</button>
                    {{ ui.ayuda_archivo() }}
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 5. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
<input type="file" id="hiddenInputNuevos" multiple style="display: none;">
{% endblock %}

{% block scripts %}
<script>
let archivosGenerales = [];
let colaAdjuntosReq = {};
window.colaAdjuntos = {};
let reqIdActual = null;
let filaActualAdjuntos = null;
let contadorNuevosEq = 0;

{# Lógica restaurada de colores en combos #}
const handleSelectColor = (el) => {
    if (el.value === "") el.classList.remove('has-value');
    else el.classList.add('has-value');
};

document.addEventListener("DOMContentLoaded", () => {
    // Inicializar colores de combos
    document.querySelectorAll('.form-select').forEach(select => {
        handleSelectColor(select);
        select.addEventListener('change', () => handleSelectColor(select));
    });

    // Cambios de puntos de estado
    document.querySelectorAll('.select-estado').forEach(sel => {
        sel.addEventListener('change', function() {
            const dot = this.parentNode.querySelector('.status-dot');
            if (dot) {
                dot.className = 'status-dot';
                const classValue = this.value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s/g, "");
                dot.classList.add('dot-' + classValue);
            }
        });
    });

    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosGenerales = [...archivosGenerales, ...Array.from(fileInput.files)];
            renderArchivos();
            fileInput.value = "";
        });
    }

    const inputReq = document.getElementById('hiddenInputReq');
    window.gestionarAdjuntosReq = (id) => { reqIdActual = id; if(inputReq) inputReq.click(); };
    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            colaAdjuntosReq[reqIdActual] = [...(colaAdjuntosReq[reqIdActual] || []), ...Array.from(inputReq.files)];
            renderColaReq(reqIdActual);
            inputReq.value = "";
        });
    }

    const inputNuevos = document.getElementById('hiddenInputNuevos');
    window.gestionarAdjuntosFila = (idFila) => { filaActualAdjuntos = idFila; if(inputNuevos) inputNuevos.click(); };
    if (inputNuevos) {
        inputNuevos.addEventListener('change', () => {
            if (!filaActualAdjuntos) return;
            colaAdjuntos[filaActualAdjuntos] = [...(colaAdjuntos[filaActualAdjuntos] || []), ...Array.from(inputNuevos.files)];
            renderFilaAdjuntos(filaActualAdjuntos);
            inputNuevos.value = "";
        });
    }

    window.agregarFilaNuevoEquipamiento();

    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) checkConf.addEventListener('change', () => btnEnviar.disabled = !checkConf.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "EQUIP_" + Date.now();
        if (document.getElementById("contactoEmail").value !== document.getElementById("contactoEmailConfirm").value) {
            return Swal.fire("Error", "Los emails no coinciden.", "error");
        }
        toggleFormFreeze(true);

        const listaTareas = [];
        archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
        Object.entries(colaAdjuntosReq).forEach(([id, list]) => list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${parseInt(id)+1}` })));
        Object.entries(colaAdjuntos).forEach(([id, list]) => list.forEach(f => listaTareas.push({ file: f, seccion: `NUEVO_EQ_${id}` })));

        UIProgress.show(listaTareas.length);
        try {
            await UploadService.uploadFiles(listaTareas, 'EQUIPAMIENTOS', window.EIEL_CONFIG.muniCode, idBatch, 1);
            
            const payload = {
            tipo_formulario: "equipamientos",
            id_envio: idBatch,
            muni_code: window.EIEL_CONFIG.muniCode,
            muni_display: window.EIEL_CONFIG.muniName,
            id_borrador_procedencia: idBorradorOrigen, 
            
            // Equipamientos existentes (Corregido para evitar 'undefined' en el PDF)
            datos_equipamientos_json: JSON.stringify(Array.from(document.querySelectorAll('.fila-equip')).map(tr => {
                const sel = tr.querySelector('.select-estado');
                return {
                    id: tr.dataset.id, 
                    // Obtenemos el nombre y la categoría para que el PDF los use correctamente
                    nombre: tr.querySelector('.nombre-eq strong').textContent,
                    categoria: tr.closest('details').querySelector('.acc-title-box span').textContent,
                    estado: sel.value, 
                    obs: tr.querySelector('.txt-obs-eq').value.trim(),
                    modificado: sel.value !== sel.dataset.original 
                };
            })),

            // Nuevos Equipamientos (Corregido para mostrar adjuntos en el PDF)
            nuevos_equipamientos_json: JSON.stringify(Array.from(document.querySelectorAll('.fila-nuevo-eq')).map(f => {
                // Obtenemos el ID numérico de la fila
                const idF = f.id.replace('fila_NUEVO_EQ_', ''); 
                return {
                    nombre: f.querySelector('.new-deno').value,
                    direccion: f.querySelector('.new-ubica').value, // Cambiado de 'ubica' a 'direccion' para el PDF
                    uso: f.querySelector('.new-uso').value,
                    estado: f.querySelector('.new-estado').value,
                    observaciones: f.querySelector('.new-obs-fila').value,
                    // Enviamos los nombres de los archivos para la columna 'Docs' del PDF
                    archivo: (window.colaAdjuntos[idF] || []).map(file => file.name).join('; ')
                };
            })),

            respuestas_requerimientos_json: JSON.stringify(Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                pregunta: area.dataset.msg,
                id: area.dataset.id,
                respuesta: area.value
            }))),

            observaciones: document.getElementById("observaciones").value,
            nombre_contacto: document.getElementById("contactoNombre").value,
            email_contacto: document.getElementById("contactoEmail").value,
            departamento_contacto: document.getElementById("contactoDepartamento").value
        };
            
            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();
        } catch (error) {
            console.error(error); toggleFormFreeze(false);
            Swal.fire("Error", "Fallo al enviar los datos.", "error");
        }
    });
});

window.renderArchivos = function() {
    // 1. Renderizar archivos generales
    const fileList = document.getElementById("fileList");
    if (fileList) {
        fileList.innerHTML = archivosGenerales.map((f, i) => {
            const isCloud = f.status === 'cloud';
            return `
            <div class="file-item" style="${isCloud ? 'border-left: 3px solid #10b981; background: #f0fdf4;' : ''}">
                <span>${isCloud ? '☁️' : '📄'} ${f.name}</span>
                <button type="button" onclick="archivosGenerales.splice(${i},1); renderArchivos(); marcarComoSucio();" class="btn-danger-icon">
                    <i data-lucide="trash-2"></i>
                </button>
            </div>`;
        }).join("");
    }

    // 2. Renderizar adjuntos de cada fila dinámica (Nuevos Equipamientos)
    // Esto es lo que faltaba para que se vean los nombres al importar
    Object.keys(window.colaAdjuntos).forEach(idFila => {
        if (typeof renderFilaAdjuntos === 'function') {
            renderFilaAdjuntos(idFila);
        }
    });

    if (window.lucide) lucide.createIcons();
};

function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => `<div class="file-item" style="font-size:0.75rem; border:1px solid #e2e8f0; border-radius:6px; padding:4px 8px; display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; background: #fdfdfd;"><span>📄 ${f.name}</span><button type="button" onclick="colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}');" class="btn-danger-icon"><i data-lucide="trash-2" style="width:14px; color:#ef4444;"></i></button></div>`).join("");
    if (window.lucide) lucide.createIcons();
}

function renderFilaAdjuntos(idFila) {
    const contenedor = document.getElementById(`lista_adjuntos_${idFila}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntos[idFila] || []).map((f, i) => `<div class="file-item" style="font-size:0.7rem; border:1px solid #e2e8f0; margin-bottom:2px; padding:2px; border-radius:4px; display:flex; justify-content:space-between; align-items:center;"><span>📄 ${f.name.substring(0,12)}...</span><button type="button" onclick="colaAdjuntos['${idFila}'].splice(${i},1); renderFilaAdjuntos('${idFila}');" class="btn-danger-icon"><i data-lucide="trash-2" style="width:12px; color: #ef4444;"></i></button></div>`).join("");
    if (window.lucide) lucide.createIcons();
}

window.agregarFilaNuevoEquipamiento = (datos = null) => {
    contadorNuevosEq++;
    // Usamos solo el número como ID interno para evitar conflictos con el motor de la base
    const idFila = contadorNuevosEq; 
    const tbody = document.getElementById('tbodyNuevos');
    if (!tbody) return;

    const tr = document.createElement('tr');
    // El ID del elemento HTML sí lleva el prefijo para ser único
    tr.id = `fila_NUEVO_EQ_${idFila}`; 
    tr.className = 'fila-nuevo-eq';

    const deno = datos ? datos.nombre : "";
    const ubica = datos ? (datos.ubica || datos.direccion) : "";
    const uso = datos ? datos.uso : "";
    const estado = datos ? datos.estado : "";
    const obs = datos ? datos.observaciones : "";

    tr.innerHTML = `
        <td style="vertical-align: top; padding: 12px 8px;">
            <input type="text" class="form-input new-deno" value="${deno}" placeholder="Ej: Edificio Polivalente" style="display: block; margin-bottom: 8px;">
            <input type="text" class="form-input new-ubica" value="${ubica}" placeholder="Ubicación" style="display: block;">
        </td>
        <td style="vertical-align: top; padding: 12px 8px;">
            <input type="text" class="form-input new-uso" value="${uso}" placeholder="Uso" style="display: block; margin-bottom: 8px;">
            <select class="form-select new-estado" style="display: block;">
                <option value="">Seleccionar...</option>
                <option value="Bueno" ${estado === 'Bueno' ? 'selected' : ''}>Bueno</option>
                <option value="Regular" ${estado === 'Regular' ? 'selected' : ''}>Regular</option>
                <option value="Malo" ${estado === 'Malo' ? 'selected' : ''}>Malo</option>
            </select>
        </td>
        <td style="vertical-align: top; padding: 12px 8px;">
            <textarea class="form-input new-obs-fila" placeholder="..." style="display: block; width: 100%; min-height: 88px;">${obs}</textarea>
        </td>
        <td style="text-align: center; vertical-align: top; padding: 12px 8px;">
            <div style="display: flex; flex-direction: column; align-items: center;">
                <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosFila('${idFila}')" style="background: white; border: 1px solid #cbd5e1;">
                    <i data-lucide="paperclip"></i> Adjuntar
                </button>
            </div>
            <div id="lista_adjuntos_${idFila}" class="file-list-container" style="margin-top:8px;"></div>
        </td>
        <td style="text-align: center; vertical-align: top; padding: 12px 8px;">
            <button type="button" class="btn-danger-icon" onclick="document.getElementById('fila_NUEVO_EQ_${idFila}').remove(); delete window.colaAdjuntos['${idFila}'];">
                <i data-lucide="trash-2" style="width:18px; color:#ef4444;"></i>
            </button>
        </td>`;
    tbody.appendChild(tr);

    const nuevoSelect = tr.querySelector('.new-estado');
    if (nuevoSelect) {
        handleSelectColor(nuevoSelect); // Aplicar color inicial
        nuevoSelect.addEventListener('change', () => handleSelectColor(nuevoSelect));
    }
    if (window.lucide) lucide.createIcons();
};

// 1. Antes de guardar el borrador, volcamos las filas dinámicas al campo oculto
window.addEventListener('before_save_draft', () => {
    const filas = Array.from(document.querySelectorAll('.fila-nuevo-eq')).map(f => ({
        nombre: f.querySelector('.new-deno').value,
        ubica: f.querySelector('.new-ubica').value,
        uso: f.querySelector('.new-uso').value,
        estado: f.querySelector('.new-estado').value,
        observaciones: f.querySelector('.new-obs-fila').value
    }));
    const input = document.getElementById('json_nuevos_eq_borrador');
    if (input) input.value = JSON.stringify(filas);
});

// 2. Al importar el borrador, si hay datos, reconstruimos las filas
window.addEventListener('after_import_draft', (e) => {
    const data = e.detail;
    if (data.json_nuevos_eq_borrador) {
        document.getElementById('tbodyNuevos').innerHTML = ""; // Limpiamos actuales
        
        // --- CORRECCIÓN CRÍTICA: Reiniciamos el contador para que los IDs coincidan con el borrador ---
        contadorNuevosEq = 0; 
        
        const filas = JSON.parse(data.json_nuevos_eq_borrador);
        filas.forEach(f => window.agregarFilaNuevoEquipamiento(f));
    }
});

</script>
{% endblock %}