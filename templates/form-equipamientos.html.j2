{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Equipamientos{% endblock %}
{% block tipo_ficha %}equipamientos{% endblock %}
{% block body_class %}equipamientos{% endblock %}
{% block header_icon %}<i data-lucide="building-2"></i>{% endblock %}
{% block header_title %}EQUIPAMIENTOS MUNICIPALES{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones() }}

    {# Definimos el orden de categorías igual que en tu original #}
    {% set orden_categorias = ['CASA CONSISTORIAL', 'CENTRO CULTURAL', 'CENTRO ENSEÑANZA', 'CENTRO SANITARIO','CENTRO ASISTENCIAL', 'MERCADO/LONJA','PROTECCIÓN CIVIL', 'TANATORIO', 'INSTALACIÓN DEPORTIVA', 'PARQUE'] %}

    {% for cat in orden_categorias %}
    {# Filtramos la lista plana que envía tu script original #}
    {% set items = equipamientos | selectattr("tipo_agrupado", "equalto", cat) | list %}
    {% if items | length > 0 %}
    <div class="card">
        <h2 class="section-title"><i data-lucide="package"></i> {{ cat }}</h2>
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 40%;">Nombre / Ubicación</th>
                        <th style="width: 25%;">Estado</th>
                        <th style="width: 35%;">Observaciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for eq in items %}
                    <tr class="eq-row" data-id="{{ eq.id }}" data-cat="{{ cat }}">
                        <td>
                            <div style="font-weight: 600;">{{ eq.nombre }}</div>
                            <div style="font-size: 0.75rem; color: var(--text-secondary);">{{ eq.nucleo }}</div>
                        </td>
                        <td>
                            <select class="form-select eq-estado">
                                {% for est in ['Buen estado', 'Regular', 'Mal estado', 'En ruina'] %}
                                <option value="{{ est }}" {% if eq.estado == est %}selected{% endif %}>{{ est }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td>
                            <input type="text" class="form-input eq-obs" value="{{ eq.observaciones or '' }}">
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
    {% endfor %}

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
// (Lógica de añadir nuevo equipamiento y envío idéntica a la anterior)
function addNuevoEquipamiento() {
    const container = document.getElementById('nuevos-container');
    const div = document.createElement('div');
    div.className = 'aviso-item nuevo-eq-item';
    div.innerHTML = `
        <div class="grid-2">
            <div class="form-group"><label class="form-label">Nombre:</label><input type="text" class="form-input n-nombre"></div>
            <div class="form-group"><label class="form-label">Categoría:</label>
                <select class="form-select n-cat">
                    <option value="CULTURAL">Cultural</option><option value="DEPORTIVO">Deportivo</option><option value="OTRO">Otro</option>
                </select>
            </div>
        </div>
        <input type="text" class="form-input n-obs" placeholder="Obs..." style="margin-top:0.5rem">
    `;
    container.appendChild(div);
    lucide.createIcons();
}

document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');
    ['nombre', 'depto', 'email'].forEach(f => document.getElementById(`contacto_${f}`).value = localStorage.getItem(`eiel_user_${f}`) || "");
    if(checkConf) checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            const existentes = [];
            document.querySelectorAll('.eq-row').forEach(row => {
                existentes.push({ id: row.dataset.id, cat: row.dataset.cat, estado: row.querySelector('.eq-estado').value, obs: row.querySelector('.eq-obs').value });
            });
            const nuevos = [];
            document.querySelectorAll('.nuevo-eq-item').forEach(item => {
                nuevos.push({ nombre: item.querySelector('.n-nombre').value, cat: item.querySelector('.n-cat').value, obs: item.querySelector('.n-obs').value });
            });
            return { DATOS_EXISTENTES: JSON.stringify(existentes), DATOS_NUEVOS: JSON.stringify(nuevos) };
        });
    };
});
</script>
{% endblock %}