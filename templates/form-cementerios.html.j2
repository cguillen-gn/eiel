{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Cementerios{% endblock %}
{% block tipo_ficha %}cementerios{% endblock %}
{% block body_class %}cementerios{% endblock %}
{% block header_icon %}<i data-lucide="rose"></i>{% endblock %}
{% block header_title %}CEMENTERIOS{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones() }}

    {% if cementerios|length == 0 %}
    <div class="card card-body" style="text-align: center; padding: 3rem;">
        <i data-lucide="info" style="width: 48px; height: 48px; color: var(--text-secondary); margin-bottom: 1rem;"></i>
        <p>No hay cementerios registrados para este municipio.</p>
    </div>
    {% else %}
        {% for cem in cementerios %}
        <div class="card cementerio-item" data-id="{{ cem.id }}">
            <h2 class="section-title"><i data-lucide="map-pin"></i> {{ cem.nombre }}</h2>
            <div class="table-wrapper">
                <table class="cementerio-table">
                    <thead>
                        <tr>
                            <th class="header-ocupacion">Tipo</th>
                            <th class="header-ocupacion">Capacidad Total</th>
                            <th class="header-ocupacion">Ocupadas</th>
                            <th class="header-ocupacion">Vacías</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tipo in [('sepulturas', 'Sepulturas'), ('nichos', 'Nichos'), ('columbarios', 'Columbarios'), ('panteones', 'Panteones')] %}
                        <tr>
                            <td class="col-label">{{ tipo[1] }}</td>
                            <td><input type="number" class="form-input val-total" data-tipo="{{ tipo[0] }}" value="{{ cem[tipo[0] ~ '_total'] or 0 }}"></td>
                            <td><input type="number" class="form-input val-ocu" data-tipo="{{ tipo[0] }}" value="{{ cem[tipo[0] ~ '_ocu'] or 0 }}"></td>
                            <td><input type="number" class="form-input val-vacia" data-tipo="{{ tipo[0] }}" value="{{ cem[tipo[0] ~ '_vacia'] or 0 }}" readonly style="background: #f8fafc;"></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Observaciones específicas del cementerio:</label>
                    <textarea class="form-textarea obs-cem" rows="2"></textarea>
                </div>
            </div>
        </div>
        {% endfor %}
    {% endif %}

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');

    // Auto-relleno de contacto
    ['nombre', 'depto', 'email'].forEach(f => document.getElementById(`contacto_${f}`).value = localStorage.getItem(`eiel_user_${f}`) || "");

    // Lógica de cálculo automático de plazas vacías
    document.querySelectorAll('.val-total, .val-ocu').forEach(input => {
        input.addEventListener('input', (e) => {
            const row = e.target.closest('tr');
            const total = parseInt(row.querySelector('.val-total').value) || 0;
            const ocu = parseInt(row.querySelector('.val-ocu').value) || 0;
            row.querySelector('.val-vacia').value = Math.max(0, total - ocu);
        });
    });

    if(checkConf) checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            // Recopilamos los datos de cada cementerio de forma estructurada
            const cementeriosData = [];
            document.querySelectorAll('.cementerio-item').forEach(card => {
                const item = {
                    id: card.dataset.id,
                    nombre: card.querySelector('h2').innerText.trim(),
                    datos: {},
                    observaciones: card.querySelector('.obs-cem').value
                };
                card.querySelectorAll('tbody tr').forEach(row => {
                    const tipo = row.querySelector('.val-total').dataset.tipo;
                    item.datos[tipo] = {
                        total: row.querySelector('.val-total').value,
                        ocu: row.querySelector('.val-ocu').value,
                        vacia: row.querySelector('.val-vacia').value
                    };
                });
                cementeriosData.push(item);
            });

            return {
                DATOS_CEMENTERIOS: JSON.stringify(cementeriosData)
            };
        });
    };
});
</script>
{% endblock %}