{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'cementerios' %}

{% block title %}EIEL - Cementerios{% endblock %}
{% block header_icon %}<i data-lucide="rose"></i>{% endblock %}
{% block header_title %}CEMENTERIOS{% endblock %}

{% block content %}
<form id="formCementerios">
    {# Estado Vacío: Si no hay datos en la base #}
    {% if cementerios|length == 0 %}
    <div class="card empty-state">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🌹</div>
        <h3 style="color: var(--text-secondary);">No hay cementerios registrados</h3>
        <p style="color: var(--text-secondary);">Su municipio no tiene cementerios en la base de datos.</p>
    </div>
    {% else %}

    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li>Rellene los datos de ocupación para cada cementerio del municipio.</li>
            <li>Si no dispone de algún dato, justifíquelo en <strong>Observaciones</strong>.</li>
        </ul>
    </div>

    {# 3. OCUPACIÓN DE CEMENTERIOS #}
    {% for cem in cementerios %}
    <div class="card">
        <h2 class="section-title"><i data-lucide="map-pin"></i> {{ cem.nombre }}</h2>
        
        <div class="cementerio-table-wrapper">
            <table class="cementerio-table">
                <thead>
                    <tr>
                        <th class="header-ocupacion" colspan="2">OCUPACIÓN</th>
                        <th>FOSAS</th>
                        <th>NICHOS</th>
                        <th>COLUMBARIOS</th>
                        <th>OSARIOS</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="label-cell">OCUPADAS</td>
                        <td class="sublabel-cell"></td> 
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="ocupadas_fosas" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="ocupadas_nichos" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="ocupadas_columbarios" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="ocupadas_osarios" placeholder="0"></td>
                    </tr>

                    <tr>
                        <td class="label-cell" rowspan="3">LIBRES</td> 
                        <td class="sublabel-cell">EN CONCESIÓN</td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_concesion_fosas" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_concesion_nichos" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_concesion_columbarios" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_concesion_osarios" placeholder="0"></td>
                    </tr>

                    <tr>
                        <td class="sublabel-cell">PROPIEDAD PRIVADA</td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_propiedad_fosas" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_propiedad_nichos" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_propiedad_columbarios" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_propiedad_osarios" placeholder="0"></td>
                    </tr>

                    <tr>
                        <td class="sublabel-cell">PROPIEDAD MUNICIPAL<br><span class="text-xs">(DISPONIBLES)</span></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_municipal_fosas" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_municipal_nichos" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_municipal_columbarios" placeholder="0"></td>
                        <td><input type="number" min="0" class="input-cem" data-cem="{{ loop.index }}" data-tipo="libres_municipal_osarios" placeholder="0"></td>
                    </tr>

                    <tr class="total-row">
                        <td class="label-cell" colspan="2">TOTAL</td> 
                        <td id="total_fosas_{{ loop.index }}">0</td>
                        <td id="total_nichos_{{ loop.index }}">0</td>
                        <td id="total_columbarios_{{ loop.index }}">0</td>
                        <td id="total_osarios_{{ loop.index }}">0</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    {% endfor %}

    {# 4. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Otra información solicitada</h2>
        <p class="form-help form-help-spacer">Se ha detectado falta de información que requiere solución.</p>
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}
                    <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm">
                        <i data-lucide="map"></i> Mapa
                    </a>
                    {% endif %}
                </div>

                {# CONTENEDOR DE RESPUESTA CORREGIDO (FONDO BLANCO Y ANCHO TOTAL) #}
                <div style="margin-left: 28px; background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0; box-sizing: border-box; width: calc(100% - 28px);">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" 
                              placeholder="Responda aquí..." 
                              style="width: 100% !important; box-sizing: border-box; display: block; margin-bottom: 15px; background: white; border: 1px solid #cbd5e1;"></textarea>
                    
                    <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosReq('{{ req_id }}')">
                        <i data-lucide="paperclip"></i> Adjuntar
                    </button>
                    {{ ui.ayuda_archivo() }}
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 5. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
    {% endif %}
</form>
{% endblock %}

{% block scripts %}
<script>
// Variables locales
let archivosGenerales = []; 
let colaAdjuntosReq = {};
let reqIdActual = null;
const cementeriosDataJS = {{ cementerios_json | safe }};

document.addEventListener("DOMContentLoaded", () => {
    // A. Cálculo de Totales
    function calcularTotales() {
        cementeriosDataJS.forEach((cem, index) => {
            const cemIndex = index + 1;
            const inputs = document.querySelectorAll(`input[data-cem="${cemIndex}"]`);
            let totales = { fosas: 0, nichos: 0, columbarios: 0, osarios: 0 };
            
            inputs.forEach(input => {
                const tipo = input.dataset.tipo;
                const valor = parseInt(input.value) || 0;
                if (tipo.includes('fosas')) totales.fosas += valor;
                if (tipo.includes('nichos')) totales.nichos += valor;
                if (tipo.includes('columbarios')) totales.columbarios += valor;
                if (tipo.includes('osarios')) totales.osarios += valor;
            });
            
            const setTotal = (id, val) => {
                const el = document.getElementById(id);
                if(el) el.textContent = val;
            };

            setTotal(`total_fosas_${cemIndex}`, totales.fosas);
            setTotal(`total_nichos_${cemIndex}`, totales.nichos);
            setTotal(`total_columbarios_${cemIndex}`, totales.columbarios);
            setTotal(`total_osarios_${cemIndex}`, totales.osarios);
        });
    }

    // Escuchar cambios en los inputs numéricos
    document.querySelectorAll('.input-cem').forEach(input => {
        input.addEventListener('input', calcularTotales);
    });

    // B. Manejo de archivos generales
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosGenerales = [...archivosGenerales, ...Array.from(fileInput.files)];
            renderArchivos();
            fileInput.value = ""; 
        });
    }

    // C. Gestión de adjuntos para Requerimientos
    const inputReq = document.getElementById('hiddenInputReq');
    window.gestionarAdjuntosReq = (id) => { reqIdActual = id; if(inputReq) inputReq.click(); };

    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            colaAdjuntosReq[reqIdActual] = [...(colaAdjuntosReq[reqIdActual] || []), ...Array.from(inputReq.files)];
            renderColaReq(reqIdActual);
            inputReq.value = "";
        });
    }

    // D. Lógica de Envío
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) checkConf.addEventListener('change', () => btnEnviar.disabled = !checkConf.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "CEMENTERIOS_" + Date.now();
        
        if (document.getElementById("contactoEmail").value !== document.getElementById("contactoEmailConfirm").value) {
            return Swal.fire("Error", "Los emails de contacto no coinciden.", "error");
        }

        toggleFormFreeze(true);

        const listaTareas = [];
        archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
        
        Object.entries(colaAdjuntosReq).forEach(([id, list]) => {
            list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${parseInt(id)+1}` }));
        });

        UIProgress.show(listaTareas.length);

        try {
            await UploadService.uploadFiles(listaTareas, 'CEMENTERIOS', window.EIEL_CONFIG.muniCode, idBatch, 1);
            UIProgress.update(listaTareas.length, listaTareas.length, "Generando PDF...");

            const cementeriosResult = cementeriosDataJS.map((cem, index) => {
                const cemIndex = index + 1;
                const inputs = document.querySelectorAll(`input[data-cem="${cemIndex}"]`);
                let datos = { nombre: cem.nombre };
                inputs.forEach(i => {
                    const val = parseInt(i.value);
                    datos[i.dataset.tipo] = isNaN(val) ? 0 : val;
                });
                return datos;
            });

            const payload = {
                tipo_formulario: "cementerios",
                id_envio: idBatch,
                municipio: window.EIEL_CONFIG.muniCode,
                cementerios_data: JSON.stringify(cementeriosResult),
                requerimientos: Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                    pregunta: area.dataset.msg, respuesta: area.value
                })),
                observaciones: document.getElementById("observaciones").value,
                contacto: {
                    nombre: document.getElementById("contactoNombre").value,
                    email: document.getElementById("contactoEmail").value
                }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();

        } catch (error) {
            console.error(error);
            toggleFormFreeze(false);
            Swal.fire("Error", "Fallo al procesar el envío de cementerios.", "error");
        }
    });
});

function renderArchivos() {
    const fileList = document.getElementById("fileList");
    if (!fileList) return;
    fileList.innerHTML = archivosGenerales.map((f, i) => `
        <div class="file-item">
            <span>📄 ${f.name}</span>
            <button type="button" onclick="eliminarArchivoGeneral(${i})" class="btn-danger-icon">
                <i data-lucide="trash-2" style="width:18px;"></i>
            </button>
        </div>
    `).join("");
    if (window.lucide) lucide.createIcons();
}

window.eliminarArchivoGeneral = (i) => {
    archivosGenerales.splice(i, 1);
    renderArchivos();
};

function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => `
        <div class="file-item" style="margin-bottom:4px; padding:4px 8px; background:#fdfdfd; border:1px solid #e2e8f0; border-radius:6px; display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.75rem;"><i data-lucide="paperclip" style="width:12px;"></i> ${f.name}</span>
            <button type="button" onclick="colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}');" class="btn-danger-icon">
                <i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i>
            </button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}
</script>
{% endblock %}