{% extends "base.html.j2" %}
{% import "macros.html.j2" as components %}

{% block title %}EIEL - Cementerios{% endblock %}
{% block header_icon %}<i data-lucide="rose"></i>{% endblock %}
{% block header_title %}CEMENTERIOS{% endblock %}

{% block content %}

{# 1. Estado Vacío #}
{% if cementerios|length == 0 %}
<div class="card" style="text-align: center; padding: 3rem;">
    <div style="font-size: 3rem; margin-bottom: 1rem;">🌹</div>
    <h3 style="color: var(--text-secondary);">No hay cementerios registrados</h3>
    <p style="color: var(--text-secondary);">Su municipio no tiene cementerios en la base de datos de la EIEL.</p>
</div>
{% else %}

{# 2. Instrucciones #}
{{ components.render_instrucciones([
    'Actualice los datos de ocupación para cada cementerio del municipio.',
    'Si existen nuevos cementerios o cambios de titularidad, indíquelo en <strong>Observaciones</strong>.'
]) }}

{# 3. Requerimientos dinámicos #}
{{ components.render_requerimientos(avisos_personalizados) }}

{# 4. Listado de Cementerios #}
{% for cem in cementerios %}
<div class="card cementerio-block" data-cem-id="{{ cem.id }}" data-cem-nombre="{{ cem.nombre }}">
    <h2 class="section-title"><i data-lucide="map-pin"></i> {{ cem.nombre }}</h2>
    
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Tipo de Enterramiento</th>
                    <th>Nº Total</th>
                    <th>Nº Ocupados</th>
                    <th>Disponibles</th>
                </tr>
            </thead>
            <tbody>
                {% set tipos = [
                    {'id': 'nichos', 'label': 'Nichos'},
                    {'id': 'sepulturas', 'label': 'Sepulturas / Tumbas'},
                    {'id': 'panteones', 'label': 'Panteones'},
                    {'id': 'columbarios', 'label': 'Columbarios'}
                ] %}
                
                {% for tipo in tipos %}
                <tr class="fila-dato" data-tipo="{{ tipo.id }}">
                    <td style="font-weight: 600;">{{ tipo.label }}</td>
                    <td>
                        <input type="number" class="form-control val-total" 
                               value="{{ cem[tipo.id + '_total'] or 0 }}" 
                               oninput="calcularDisponibles(this)">
                    </td>
                    <td>
                        <input type="number" class="form-control val-ocupado" 
                               value="{{ cem[tipo.id + '_ocupados'] or 0 }}" 
                               oninput="calcularDisponibles(this)">
                    </td>
                    <td>
                        <input type="number" class="form-control val-disponible" 
                               value="{{ (cem[tipo.id + '_total'] or 0) - (cem[tipo.id + '_ocupados'] or 0) }}" 
                               disabled style="background: #f1f5f9;">
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endfor %}

{# 5. Observaciones y Footer #}
{{ components.render_observaciones_finales() }}
{{ components.render_footer_envio() }}

{% endif %}
{% endblock %}

{% block scripts %}
<script>
/**
 * LÓGICA ESPECÍFICA DE CEMENTERIOS
 */

// Función para calcular disponibilidad en tiempo real
function calcularDisponibles(input) {
    const fila = input.closest('tr');
    const total = parseInt(fila.querySelector('.val-total').value) || 0;
    const ocupado = parseInt(fila.querySelector('.val-ocupado').value) || 0;
    const disponibleField = fila.querySelector('.val-disponible');
    
    disponibleField.value = Math.max(0, total - ocupado);
}

document.addEventListener('DOMContentLoaded', () => {
    
    const btnEnviar = document.getElementById('btnEnviar');
    if (!btnEnviar) return;

    btnEnviar.addEventListener('click', () => {
        processSubmit(() => {
            // Recolectar datos de todos los bloques de cementerios
            const datosCementerios = [];
            
            document.querySelectorAll('.cementerio-block').forEach(bloque => {
                const cemId = bloque.dataset.cemId;
                const cemNombre = bloque.dataset.cemNombre;
                const detalle = {};

                bloque.querySelectorAll('.fila-dato').forEach(fila => {
                    const tipo = fila.dataset.tipo;
                    detalle[tipo] = {
                        total: fila.querySelector('.val-total').value || 0,
                        ocupados: fila.querySelector('.val-ocupado').value || 0
                    };
                });

                datosCementerios.push({
                    id: cemId,
                    nombre: cemNombre,
                    datos: detalle
                });
            });

            return {
                cementerios_data_json: JSON.stringify(datosCementerios)
            };
        });
    });
});
</script>
{% endblock %}