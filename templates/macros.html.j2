{# Componente: Datos de Contacto #}
{% macro campo_contacto() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required>
        </div>
        <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required>
        </div>
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;">
        </div>
    </div>
</div>
{% endmacro %}

{# Componente: Observaciones #}
{% macro campo_observaciones() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" placeholder="Indique aquí cualquier incidencia, aclaración o dato relevante..."></textarea>
    </div>
</div>
{% endmacro %}

{# Componente: Texto de ayuda para archivos individuales #}
{% macro ayuda_archivo() %}
<div style="font-size: 0.65rem; color: #94a3b8; margin-top: 4px; font-weight: 500; white-space: nowrap;">
    Máx 35 MB / archivo
</div>
{% endmacro %}

{# Componente: Documentación Adjunta (Zona General) #}
{% macro zona_adjuntos() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="folder"></i>Documentación Adjunta (Opcional)</h2>    
    <div class="file-upload-area" onclick="document.getElementById('fileInput').click()">
        <div class="upload-icon"><i data-lucide="upload-cloud" style="width: 40px; height: 40px; opacity: 0.7;"></i></div>
        <div style="font-weight: 700; font-size: 1.05rem;">Arrastra y suelta archivos aquí</div>
        <div style="font-size: 0.9rem; color: var(--text-secondary);">o <span style="text-decoration: underline; color: var(--primary); cursor: pointer;">haz clic para buscarlos</span></div>
        <p class="upload-help" style="margin-top: 8px;">(Máx 35 MB / archivo)</p>
        <input type="file" id="fileInput" multiple style="display: none;">
    </div>
    <div id="fileList" class="file-list-container"></div>
</div>
{% endmacro %}

{# Componente: Declaración de Veracidad Unificada #}
{% macro declaracion_veracidad() %}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text"><strong>Declaración de veracidad:</strong> Confirmo que los datos introducidos son correctos.</span>
        </label>
    </div>
    <div class="form-actions-group">
        <button type="button" class="btn btn-secondary" onclick="gestionarBorradorNube()" style="background: white; border: 1px solid #cbd5e1; color: var(--text-primary);">
            <i data-lucide="cloud-upload"></i> Guardar Borrador
        </button>
        <button id="btnEnviar" class="btn btn-primary" disabled>
            <i data-lucide="send"></i> Enviar Formulario Definitivo
        </button>
    </div>
</div>
{% endmacro %}

{# Componente: Botón de Carga (Header) #}
{% macro boton_cargar_borrador() %}
<button type="button" class="btn btn-secondary btn-sm" onclick="cargarBorradorNube()" title="Cargar borrador de la nube" style="background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: white;">
    <i data-lucide="cloud-download" style="width: 16px;"></i> Cargar Borrador
</button>
{% endmacro %}

{# Componente: Botón Flotante Lateral #}
{% macro boton_flotante_guardar() %}
<button type="button" class="btn-float-save" onclick="gestionarBorradorNube()">
    <i data-lucide="save" style="width: 20px;"></i>
    <span style="writing-mode: vertical-rl; text-orientation: mixed; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Guardar</span>
</button>
{% endmacro %}

{# Componente: Barra Inferior Fija (Sticky Bar) #}
{% macro barra_fija_envio() %}
<div class="sticky-footer-bar">
    <div class="footer-bar-content">
        <div class="autosave-info">
            <span id="autosave-status" class="hidden">Autoguardado local activo</span>
        </div>
        <div class="footer-bar-actions">
            {# Cambiado data-lucide="cloud-save" por "save" #}
            <button type="button" class="btn btn-secondary btn-borrador" onclick="gestionarBorradorNube()" style="background: white; border: 1px solid #cbd5e1;">
                <i data-lucide="save"></i> Guardar Borrador (Nube)
            </button>
            {# Corregido texto de "Definitive" a "Definitivo" #}
            <button id="btnEnviarBarra" class="btn btn-primary" onclick="document.getElementById('btnEnviar').click()" disabled>
                <i data-lucide="send"></i> Enviar Formulario Definitivo
            </button>
        </div>
    </div>
</div>
{% endmacro %}