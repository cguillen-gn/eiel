{# macros.html.j2 #}

{# Macro para la tarjeta de instrucciones exacta a la tuya #}
{% macro render_instrucciones() %}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul>
        <li>
            Rellene los datos requeridos y justifique cualquier dato que no disponga o no pueda aportar en el apartado de <strong>Observaciones</strong>.
        </li>
    </ul>
</div>
{% endmacro %}

{# Macro para la sección de Requerimientos exacta a la tuya #}
{% macro render_requerimientos(avisos) %}
{% if avisos and avisos|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h2 class="section-title">
            <i data-lucide="circle-plus"></i> Información solicitada
        </h2>
        
        <p class="form-help form-help-spacer">
            Se ha detectado falta de información o incidencias en la EIEL que requieren solución. Responda a cada punto y adjunte documentación si es necesario.
        </p>

        <ul class="requerimientos-list" style="list-style: none; padding: 0;">
            {% for aviso in avisos %}
            <li class="requerimiento-item" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px dashed var(--border);">
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                    <span class="badge badge-warning" style="margin-top: 4px;">Pendiente</span>
                    <div style="flex: 1;">
                        <strong style="color: var(--text-primary); display: block; margin-bottom: 4px;">{{ aviso.nombre }}</strong>
                        <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 8px;">{{ aviso.descripcion }}</p>
                        
                        <div class="form-group" style="margin-top: 10px;">
                            <textarea class="form-control req-respuesta" 
                                      data-req-id="{{ aviso.id }}" 
                                      data-req-nombre="{{ aviso.nombre }}"
                                      placeholder="Escriba aquí la respuesta o justificación..." 
                                      rows="2"></textarea>
                        </div>

                        <div class="file-upload-wrapper" style="margin-top: 10px;">
                            <label class="file-upload-label" style="font-size: 0.85rem; padding: 6px 12px;">
                                <i data-lucide="upload" style="width: 14px; height: 14px;"></i>
                                Adjuntar documento justificativo
                                <input type="file" class="req-file-input" data-req-id="{{ aviso.id }}" hidden>
                            </label>
                            <div class="file-list-container" id="list-req-{{ aviso.id }}" style="margin-top: 5px;"></div>
                        </div>
                    </div>
                </div>
            </li>
            {% endfor %}
        </ul>
    </div>
</div>
{% endif %}
{% endmacro %}