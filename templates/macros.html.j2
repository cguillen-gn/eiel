{# ==========================================================================
   MACROS DE COMPONENTES REUTILIZABLES - EIEL
   ========================================================================== #}

{# 1. SECCIÓN DE INSTRUCCIONES #}
{% macro render_instrucciones(items) %}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul>
        {% for item in items %}
            <li>{{ item | safe }}</li>
        {% endfor %}
    </ul>
</div>
{% endmacro %}

{# 2. SECCIÓN DE REQUERIMIENTOS (INFORMACIÓN SOLICITADA) #}
{% macro render_requerimientos(avisos) %}
{% if avisos and avisos|length > 0 %}
<div class="card card-requerimientos">
    <h2 class="section-title">
        <i data-lucide="circle-plus"></i> Información solicitada
    </h2>
    <p class="form-help" style="margin-bottom: 1.5rem; color: var(--text-secondary); font-size: 0.9rem;">
        Se ha detectado falta de información o incidencias que requieren solución. Responda a cada punto y adjunte documentación si es necesario.
    </p>

    <div class="requerimientos-list">
        {% for aviso in avisos %}
        {% set req_id = loop.index0 %}
        <div class="aviso-item">
            <div class="aviso-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                <span class="aviso-tag">REQUERIMIENTO #{{ req_id + 1 }}</span>
            </div>
            <p class="aviso-texto">{{ aviso.descripcion }}</p>
            
            <div class="aviso-body" style="margin-top: 1rem;">
                <label class="form-label" style="font-size: 0.85rem;">Su respuesta / justificación:</label>
                <textarea class="form-control req-respuesta" 
                          id="req_desc_{{ req_id }}" 
                          rows="2"
                          placeholder="Escriba aquí la respuesta..."></textarea>
                
                <div class="adjunto-req-container" style="margin-top: 1rem;">
                    <input type="file" id="file_req_{{ req_id }}" class="hidden" 
                           onchange="handleFileSelectReq(event, {{ req_id }})">
                    <label class="btn" for="file_req_{{ req_id }}" style="background: #f1f5f9; border: 1px dashed var(--border); width: 100%; justify-content: center;">
                        <i data-lucide="paperclip"></i> Adjuntar documento (opcional)
                    </label>
                    <div id="file_list_req_{{ req_id }}" class="file-list-container" style="margin-top: 0.5rem;"></div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}
{% endmacro %}

{# 3. SECCIÓN DE OBSERVACIONES FINALES #}
{% macro render_observaciones_finales() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="message-square-more"></i> Observaciones Finales</h2>
    <p class="form-help" style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.9rem;">
        Utilice este espacio para aclaraciones generales sobre toda la información enviada en este formulario.
    </p>
    <textarea id="observaciones" class="form-control" rows="4" placeholder="Escriba sus observaciones aquí..."></textarea>
</div>
{% endmacro %}

{# 4. FOOTER DE ENVÍO (CONFORMIDAD Y BOTÓN) #}
{% macro render_footer_envio() %}
<div class="card" style="border-top: 4px solid var(--primary); background: #f8fafc;">
    <div class="conformidad-container" style="display: flex; gap: 1rem; align-items: flex-start; margin-bottom: 1.5rem;">
        <input type="checkbox" id="checkConformidad" style="width: 20px; height: 20px; margin-top: 3px; cursor: pointer;">
        <label for="checkConformidad" style="font-size: 0.95rem; cursor: pointer; color: var(--text-primary);">
            Confirmo que los datos introducidos han sido revisados y son correctos según la situación actual del municipio.
        </label>
    </div>
    
    <div class="form-actions" style="text-align: right;">
        <button type="button" id="btnEnviar" class="btn btn-primary" style="padding: 1rem 3rem; font-size: 1.1rem;" disabled>
            <i data-lucide="send"></i> Enviar Información
        </button>
    </div>
</div>
{% endmacro %}