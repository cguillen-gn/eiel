{# Bloque de Instrucciones #}
{% macro render_instrucciones(texto="Rellene los datos requeridos y justifique cualquier dato en Observaciones.") %}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul><li>{{ texto }}</li></ul>
</div>
{% endmacro %}

{# Bloque de Requerimientos (Información solicitada) #}
{% macro render_requerimientos(avisos) %}
{% if avisos and avisos|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Información solicitada</h2>
        <p style="margin-bottom: 1.5rem; font-size: 0.9rem; color: var(--text-secondary);">Responda a cada punto y adjunte documentación si es necesario.</p>
        <ul style="list-style: none;">
            {% for aviso in avisos %}
            <li class="aviso-item">
                <div class="aviso-text">{{ aviso.mensaje }}</div>
                <div class="form-group">
                    <textarea class="form-textarea req-respuesta" data-reqid="{{ loop.index0 }}" placeholder="Su respuesta..."></textarea>
                </div>
                <div class="upload-zone" onclick="document.getElementById('file-req-{{ loop.index0 }}').click()">
                    <i data-lucide="upload-cloud"></i>
                    <p>Adjuntar documento para este punto</p>
                    <input type="file" id="file-req-{{ loop.index0 }}" class="hidden" multiple onchange="handleFiles(this.files, 'REQ_{{ loop.index0 }}')">
                </div>
                <div id="file-list-REQ_{{ loop.index0 }}" class="file-list-container"></div>
            </li>
            {% endfor %}
        </ul>
    </div>
</div>
{% endif %}
{% endmacro %}

{# Bloque de Contacto y Adjuntos Generales #}
{% macro render_contacto_y_adjuntos() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="user-check"></i> Información de Contacto y Otros Adjuntos</h2>
    <div class="card-body">
        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Nombre del Técnico:</label>
                <input type="text" id="contacto_nombre" class="form-input" placeholder="Nombre completo">
            </div>
            <div class="form-group">
                <label class="form-label">Departamento:</label>
                <input type="text" id="contacto_depto" class="form-input" placeholder="Ej: Urbanismo">
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Email de contacto:</label>
            <input type="email" id="contacto_email" class="form-input" placeholder="correo@municipio.es">
        </div>
        <div class="form-group">
            <label class="form-label">Observaciones Generales:</label>
            <textarea id="observaciones" class="form-textarea" rows="3"></textarea>
        </div>
        <div class="form-group" style="margin-top: 1.5rem;">
            <label class="form-label">Documentación Adicional (Planos, Memorias...):</label>
            <div class="upload-zone" onclick="document.getElementById('file-general').click()">
                <i data-lucide="upload-cloud"></i>
                <p>Haga clic para adjuntar archivos</p>
                <input type="file" id="file-general" class="hidden" multiple onchange="handleFiles(this.files, 'GENERAL')">
            </div>
            <div id="file-list-GENERAL" class="file-list-container"></div>
        </div>
    </div>
</div>
{% endmacro %}

{# Bloque de Botón de Envío #}
{% macro render_boton_envio() %}
<div class="card" style="border: none; background: transparent; box-shadow: none;">
    <div class="form-group" style="display: flex; align-items: flex-start; gap: 10px; background: #fff; padding: 1rem; border-radius: 8px; border: 1px solid var(--border);">
        <input type="checkbox" id="checkConformidad" style="margin-top: 4px; cursor: pointer;">
        <label for="checkConformidad" style="font-size: 0.85rem; color: var(--text-secondary); cursor: pointer;">
            Confirmo que los datos introducidos son correctos y cuento con la autorización para remitir esta información técnica.
        </label>
    </div>
    <button type="button" id="btnEnviar" class="btn btn-primary" disabled style="margin-top: 1rem;">
        <i data-lucide="send"></i> Enviar Información
    </button>
</div>
{% endmacro %}