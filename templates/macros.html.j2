{# Componente: Datos de Contacto #}
{% macro campo_contacto() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required> [cite: 80, 203, 316, 481, 652, 805, 920, 1035]
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required> [cite: 80, 203, 316, 481, 652, 805, 920, 1035]
        </div>
        <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required> [cite: 81, 204, 317, 482, 653, 806, 921, 1036]
        </div>
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;"> [cite: 82, 204, 317, 482, 653, 806, 921, 1036]
        </div>
    </div>
</div>
{% endmacro %}

{# Componente: Observaciones #}
{% macro campo_observaciones() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" placeholder="Indique aquí cualquier incidencia..."></textarea> [cite: 75, 198, 311, 476, 651, 800, 915, 1030]
    </div>
</div>
{% endmacro %}

{# Componente: Documentación Adjunta #}
{% macro zona_adjuntos() %}
<div class="card">
    <h2 class="section-title"><i data-lucide="folder"></i>Documentación Adjunta (Opcional)</h2>    
    <div class="file-upload-area" onclick="document.getElementById('fileInput').click()"> [cite: 76, 199, 312, 477, 715, 801, 916, 1031]
        <div class="upload-icon"><i data-lucide="upload-cloud"></i></div>
        <div class="upload-text">Arrastra y suelta archivos aquí</div> [cite: 77, 200, 313, 478, 802, 917, 1032]
        <div class="upload-subtext">o <span>haz clic para buscarlos</span></div> [cite: 78, 79, 201, 202, 314, 315, 479, 480, 803, 804, 918, 919, 1033, 1034]
        <p class="upload-help">(Planos, fotos, informes... Máx 35 MB / archivo)</p>
        <input type="file" id="fileInput" multiple style="display: none;">
    </div>
    <div id="fileList" class="file-list-container"></div>
</div>
{% endmacro %}

{# Componente: Declaración de Veracidad #}
{% macro declaracion_veracidad() %}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text">
                <strong>Declaración de veracidad:</strong> Como responsable, 
                confirmo que los datos introducidos son correctos y actualizados. [cite: 83, 206, 319, 484, 655, 808, 923, 1038]
            </span>
        </label>
    </div>
    <div id="mensaje" class="message hidden"></div>
    <button id="btnEnviar" class="btn btn-primary" disabled>Enviar Datos</button>
</div>
{% endmacro %}