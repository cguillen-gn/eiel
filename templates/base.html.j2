<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        /* ==========================================================================
           1. CONFIGURACIÓN GLOBAL
           ========================================================================== */
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            hasAvisos: {% if avisos_personalizados|length > 0 %}true{% else %}false{% endif %}
        };

        /* ==========================================================================
           2. SERVICIO DE PROGRESO (UIProgress)
           ========================================================================== */
        const UIProgress = {
            overlay: null,
            show(totalTareas) {
                if (totalTareas === 0) return;
                this.overlay = document.createElement('div');
                this.overlay.className = 'overlay';
                this.overlay.innerHTML = `
                    <div class="progress-card">
                        <div class="spinner"></div>
                        <h3 id="progress-title" style="margin: 1.5rem 0 0.5rem; color: var(--text-primary);">Subiendo archivos...</h3>
                        <p id="progress-note" style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.5rem;">Por favor, no cierre la pestaña</p>
                        <div class="progress-bar-container">
                            <div id="progress-bar-fill" class="progress-bar-fill" style="width: 0%"></div>
                        </div>
                        <div id="progress-text" style="margin-top: 0.75rem; font-weight: 600; font-size: 0.85rem; color: var(--primary);">0 / ${totalTareas}</div>
                    </div>`;
                document.body.appendChild(this.overlay);
            },
            update(completadas, total, mensaje = null) {
                const fill = document.getElementById('progress-bar-fill');
                const text = document.getElementById('progress-text');
                const title = document.getElementById('progress-title');
                if (fill) fill.style.width = `${(completadas / total) * 100}%`;
                if (text) text.textContent = `${completadas} / ${total}`;
                if (mensaje && title) title.textContent = mensaje;
            },
            complete() {
                if (this.overlay) {
                    this.overlay.innerHTML = `
                        <div class="progress-card" style="border-top: 4px solid var(--success);">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">✅</div>
                            <h3 style="color: var(--text-primary); margin-bottom: 0.5rem;">¡Envío completado!</h3>
                            <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">Se ha enviado un justificante a su correo electrónico.</p>
                            <button onclick="window.location.reload()" class="btn btn-primary" style="width: 100%;">Finalizar</button>
                        </div>`;
                }
            }
        };

        /* ==========================================================================
           3. MOTOR DE SUBIDA POR LOTES (UploadService)
           ========================================================================== */
        const UploadService = {
            async uploadFiles(listaTareas, tipoForm, muniCode, idBatch, concurrencia = 2) {
                if (listaTareas.length === 0) return [];
                let completadas = 0;
                const total = listaTareas.length;
                const resultados = [];

                for (let i = 0; i < listaTareas.length; i += concurrencia) {
                    const lote = listaTareas.slice(i, i + concurrencia);
                    await Promise.all(lote.map(async (tarea) => {
                        try {
                            const base64 = await this.fileToBase64(tarea.file);
                            const payload = {
                                municipio: muniCode,
                                tipo: tipoForm,
                                seccion: tarea.seccion,
                                id_envio: idBatch,
                                filename: tarea.file.name,
                                mimeType: tarea.file.type,
                                data: base64
                            };
                            const resp = await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                                method: 'POST', mode: 'no-cors', body: JSON.stringify(payload)
                            });
                            resultados.push({ nombre: tarea.file.name, status: 'ok' });
                        } catch (e) {
                            console.error("Error subiendo:", tarea.file.name, e);
                            resultados.push({ nombre: tarea.file.name, status: 'error' });
                        } finally {
                            completadas++;
                            UIProgress.update(completadas, total);
                        }
                    }));
                }
                return resultados;
            },
            fileToBase64(file) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.readAsDataURL(file);
                    reader.onload = () => resolve(reader.result.split(',')[1]);
                    reader.onerror = error => reject(error);
                });
            }
        };

        /* ==========================================================================
           4. SISTEMA DE AUTOGUARDADO (LocalStorage)
           ========================================================================== */
        const AutoSave = {
            getStorageKey() {
                const formType = window.location.pathname.split("/").pop().split("_")[0];
                return `draft_${formType}_${window.EIEL_CONFIG.muniCode}`;
            },
            save() {
                const formData = {};
                document.querySelectorAll('input:not([type="password"]), select, textarea').forEach(el => {
                    if (el.id && !el.id.includes('EmailConfirm')) {
                        formData[el.id] = el.type === 'checkbox' ? el.checked : el.value;
                    }
                });
                localStorage.setItem(this.getStorageKey(), JSON.stringify({ t: Date.now(), data: formData }));
                const st = document.getElementById('autosave-status');
                if (st) {
                    const now = new Date();
                    st.textContent = `Autoguardado local: ${now.getHours()}:${now.getMinutes().toString().padStart(2, '0')}`;
                }
            },
            restore() {
                const raw = localStorage.getItem(this.getStorageKey());
                if (!raw) return;
                const { data } = JSON.parse(raw);
                Object.entries(data).forEach(([id, val]) => {
                    const el = document.getElementById(id);
                    if (el) {
                        if (el.type === 'checkbox') el.checked = val;
                        else { el.value = val; el.dispatchEvent(new Event('change')); }
                    }
                });
            },
            clear() { localStorage.removeItem(this.getStorageKey()); }
        };

        /* ==========================================================================
           5. GESTIÓN DE BORRADORES EN LA NUBE (Google Sheets)
           ========================================================================== */
        async function gestionarBorradorNube() {
            const formType = window.location.pathname.split("/").pop().split("_")[0];
            const dataToSave = {};
            document.querySelectorAll('input:not([type="password"]), select, textarea').forEach(el => {
                if (el.id && !el.id.includes('EmailConfirm')) {
                    dataToSave[el.id] = el.type === 'checkbox' ? el.checked : el.value;
                }
            });

            Swal.fire({ title: 'Guardando en la nube...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

            try {
                await fetch(window.EIEL_CONFIG.urlGenerarPdf, { 
                    method: 'POST', mode: 'no-cors', 
                    body: JSON.stringify({
                        action: 'save_draft',
                        municipio: window.EIEL_CONFIG.muniCode,
                        tipo_formulario: formType,
                        tecnico: localStorage.getItem("eiel_user_name") || "Técnico",
                        datos_json: JSON.stringify(dataToSave)
                    }) 
                });
                Swal.fire('¡Guardado!', 'El borrador se ha guardado en la nube correctamente.', 'success');
            } catch (error) {
                Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
            }
        }

        async function cargarBorradorNube() {
            const formType = window.location.pathname.split("/").pop().split("_")[0];
            Swal.fire({ title: 'Buscando borradores...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });

            try {
                const url = `${window.EIEL_CONFIG.urlGenerarPdf}?action=list_drafts&muni=${window.EIEL_CONFIG.muniCode}&tipo=${formType}`;
                const resp = await fetch(url);
                const borradores = await resp.json();

                if (!borradores || borradores.length === 0) {
                    return Swal.fire('Sin borradores', 'No hay versiones previas en la nube para este municipio.', 'info');
                }

                const options = {};
                borradores.forEach(b => { options[b.id] = `${b.fecha} - ${b.tecnico}`; });

                const { value: idSel } = await Swal.fire({
                    title: 'Cargar Borrador',
                    input: 'select',
                    inputOptions: options,
                    inputPlaceholder: 'Seleccione una versión',
                    showCancelButton: true,
                    confirmButtonText: 'Cargar Datos'
                });

                if (idSel) {
                    const borrador = borradores.find(x => x.id == idSel);
                    const data = JSON.parse(borrador.datos_json);
                    Object.entries(data).forEach(([id, val]) => {
                        const el = document.getElementById(id);
                        if (el) {
                            if (el.type === 'checkbox') el.checked = val;
                            else { el.value = val; el.dispatchEvent(new Event('change')); }
                        }
                    });
                    Swal.fire('¡Listo!', 'Los datos se han cargado correctamente.', 'success');
                }
            } catch (error) {
                Swal.fire('Error', 'No se pudo recuperar la lista de borradores.', 'error');
            }
        }

        /* ==========================================================================
           6. UTILIDADES DE INTERFAZ
           ========================================================================== */
        function toggleFormFreeze(isFrozen) {
            const elements = document.querySelectorAll('input, select, textarea, button:not(.btn-logout), .btn-borrador');
            elements.forEach(el => {
                el.disabled = isFrozen;
                el.style.opacity = isFrozen ? "0.6" : "1";
                el.style.pointerEvents = isFrozen ? "none" : "auto";
            });
        }

        function abrirVisorImagen(src) {
            Swal.fire({
                imageUrl: src,
                imageAlt: 'Equipamiento',
                width: 'auto',
                showCloseButton: true,
                showConfirmButton: false,
                customClass: { image: 'img-fluid-max' }
            });
        }
    </script>
</head>
<body class="theme-{{ ficha_tipo }}">
    <header class="main-header header-{{ ficha_tipo }}">
        <div class="header-container">
            <div class="header-left">
                <div class="header-icon-box">{% block header_icon %}{% endblock %}</div>
                <div class="header-text-box">
                    <h1 class="header-title">{% block header_title %}{% endblock %}</h1>
                    <p class="header-muni" id="headerMuniName">Cargando municipio...</p>
                </div>
            </div>
            <div class="header-right">
                <div class="fase-badge">{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}</div>
                <button onclick="window.location.href='index.html'" class="btn-logout" title="Volver al Panel">
                    <i data-lucide="grid"></i>
                </button>
            </div>
        </div>
    </header>

    <main class="main-container">
        {% block content %}{% endblock %}
    </main>

    <script>
        /* ==========================================================================
           7. INICIALIZACIÓN Y SINCRONIZACIÓN DE LOGIN
           ========================================================================== */
        document.addEventListener("DOMContentLoaded", () => {
            // Sincronizar nombre del municipio
            const headerName = document.getElementById("headerMuniName");
            if(headerName) headerName.textContent = localStorage.getItem("eiel_muni_name") || "Municipio";

            // Sincronizar campos de contacto desde LocalStorage
            const fieldsMap = {"contactoNombre": "eiel_user_name", "contactoEmail": "eiel_user_email", "contactoDepartamento": "eiel_user_dept"};
            Object.keys(fieldsMap).forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.value = localStorage.getItem(fieldsMap[id]) || "";
                    el.addEventListener('input', (e) => {
                        localStorage.setItem(fieldsMap[id], e.target.value.trim());
                        // Actualizar email de confirmación si existe
                        const confirm = document.getElementById(id + "Confirm");
                        if (confirm) confirm.value = ""; 
                    });
                }
            });

            // Generar iconos Lucide
            if (window.lucide) lucide.createIcons();
        });

        // Logger de acceso
        (function() {
            if (window.location.protocol === 'file:') return;
            const payload = {
                municipio: window.EIEL_CONFIG.muniName,
                codigo: window.EIEL_CONFIG.muniCode,
                fase: window.EIEL_CONFIG.fase,
                tipo: window.location.pathname.split("/").pop().split("_")[0].toUpperCase(),
                ua: navigator.userAgent,
                contacto: localStorage.getItem("eiel_user_name") || "Acceso inicial"
            };
            if (window.EIEL_CONFIG.urlLogger) fetch(window.EIEL_CONFIG.urlLogger, {method: 'POST', mode: 'no-cors', body: JSON.stringify(payload)});
        })();
    </script>

    {% block scripts %}{% endblock %}
</body>
</html>