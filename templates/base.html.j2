<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        /* ==========================================================================
           1. CONFIGURACIÓN GLOBAL
           ========================================================================== */
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            hasAvisos: {% if avisos_personalizados|length > 0 %}true{% else %}false{% endif %}
        };

        /* ==========================================================================
           2. SERVICIO DE PROGRESO (UIProgress)
           ========================================================================== */
        const UIProgress = {
            overlay: null,
            show(totalTareas) {
                if (totalTareas === 0) return;
                this.overlay = document.createElement('div');
                this.overlay.className = 'overlay';
                this.overlay.innerHTML = `
                    <div class="progress-card">
                        <div class="spinner"></div>
                        <h3 id="progress-title" style="margin: 1.5rem 0 0.5rem; color: var(--text-primary);">Subiendo archivos...</h3>
                        <p id="progress-note" style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1.5rem;">Por favor, no cierre la pestaña</p>
                        <div class="progress-bar-container">
                            <div id="progress-bar-fill" class="progress-bar-fill" style="width: 0%"></div>
                        </div>
                        <div id="progress-text" style="margin-top: 0.75rem; font-weight: 600; font-size: 0.85rem; color: var(--primary);">0 / ${totalTareas}</div>
                    </div>`;
                document.body.appendChild(this.overlay);
            },
            update(completadas, total, mensaje = null) {
                const fill = document.getElementById('progress-bar-fill');
                const text = document.getElementById('progress-text');
                const title = document.getElementById('progress-title');
                if (fill) fill.style.width = `${(completadas / total) * 100}%`;
                if (text) text.textContent = `${completadas} / ${total}`;
                if (mensaje && title) title.textContent = mensaje;
            },
            complete() {
                if (this.overlay) {
                    this.overlay.innerHTML = `
                        <div class="progress-card" style="border-top: 4px solid var(--success);">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">✅</div>
                            <h3 style="color: var(--text-primary); margin-bottom: 0.5rem;">¡Envío completado!</h3>
                            <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">Se ha enviado un justificante a su correo electrónico.</p>
                            <button onclick="window.location.reload()" class="btn btn-primary" style="width: 100%;">Finalizar</button>
                        </div>`;
                }
            }
        };

        /* ==========================================================================
           3. MOTOR DE SUBIDA POR LOTES (UploadService)
           ========================================================================== */
        const UploadService = {
            async uploadFiles(listaTareas, tipoForm, muniCode, idBatch, concurrencia = 2) {
                if (listaTareas.length === 0) return [];
                let completadas = 0;
                const total = listaTareas.length;
                const resultados = [];

                for (let i = 0; i < listaTareas.length; i += concurrencia) {
                    const lote = listaTareas.slice(i, i + concurrencia);
                    await Promise.all(lote.map(async (tarea) => {
                        try {
                            const base64 = await this.fileToBase64(tarea.file);
                            const payload = {
                                municipio: muniCode,
                                tipo: tipoForm,
                                seccion: tarea.seccion,
                                id_envio: idBatch,
                                filename: tarea.file.name,
                                mimeType: tarea.file.type,
                                data: base64
                            };
                            const resp = await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                                method: 'POST', mode: 'no-cors', body: JSON.stringify(payload)
                            });
                            resultados.push({ nombre: tarea.file.name, status: 'ok' });
                        } catch (e) {
                            console.error("Error subiendo:", tarea.file.name, e);
                            resultados.push({ nombre: tarea.file.name, status: 'error' });
                        } finally {
                            completadas++;
                            UIProgress.update(completadas, total);
                        }
                    }));
                }
                return resultados;
            },
            fileToBase64(file) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.readAsDataURL(file);
                    reader.onload = () => resolve(reader.result.split(',')[1]);
                    reader.onerror = error => reject(error);
                });
            }
        };
        
        /* ==========================================================================
           5. MOTOR DE BORRADORES (FASE 2: TEXTOS + ADJUNTOS EN LA NUBE)
           ========================================================================== */

        let formIsDirty = false;
        let idBorradorOrigen = null; // Guardará el ID para el envío final

        // AVISO DE SALIDA
        window.addEventListener('beforeunload', (e) => {
            if (formIsDirty) {
                e.preventDefault();
                e.returnValue = 'Tiene cambios sin guardar en el formulario.';
            }
        });

        function activarDetectorCambios() {
            const inputs = document.querySelectorAll('input, select, textarea');
            inputs.forEach(el => {
                el.addEventListener('change', () => marcarComoSucio());
                el.addEventListener('input', () => marcarComoSucio());
            });
        }

        function marcarComoSucio() {
            if (!formIsDirty) {
                formIsDirty = true;
                const btn = document.getElementById('btnGuardarNube');
                if (btn) {
                    btn.disabled = false;
                    btn.classList.add('btn-save-active');
                }
            }
        }

        // FUNCIÓN: GUARDAR (Sube archivos nuevos a TEMP y guarda JSON)
        async function gestionarBorradorNube() {
            const formType = window.location.pathname.split("/").pop().split("_")[0];
            const idLoteTemporal = "TEMP_" + Date.now();
            
            const listaArchivosParaSubir = [];
            if (typeof archivosGenerales !== 'undefined') {
                archivosGenerales.forEach(f => {
                    if (!f.status || f.status !== 'cloud') listaArchivosParaSubir.push({ file: f, seccion: 'GEN_BORRADOR' });
                });
            }
            if (typeof colaAdjuntosReq !== 'undefined') {
                Object.entries(colaAdjuntosReq).forEach(([id, list]) => {
                    list.forEach(f => {
                        if (!f.status || f.status !== 'cloud') listaArchivosParaSubir.push({ file: f, seccion: `REQ_BORRADOR_${parseInt(id)+1}` });
                    });
                });
            }

            Swal.fire({ 
                title: listaArchivosParaSubir.length > 0 ? 'Sincronizando archivos...' : 'Guardando textos...', 
                didOpen: () => Swal.showLoading(), 
                allowOutsideClick: false 
            });

            try {
                if (listaArchivosParaSubir.length > 0) {
                    await UploadService.uploadFiles(listaArchivosParaSubir, 'BORRADOR', window.EIEL_CONFIG.muniCode, idLoteTemporal, 2);
                }

                const dataToSave = { _adjuntos_remotos: [] };

                // Guardar referencias de archivos (locales y nube)
                if (typeof archivosGenerales !== 'undefined') {
                    archivosGenerales.forEach(f => dataToSave._adjuntos_remotos.push({ name: f.name, seccion: 'GENERAL' }));
                }
                if (typeof colaAdjuntosReq !== 'undefined') {
                    Object.entries(colaAdjuntosReq).forEach(([id, list]) => {
                        list.forEach(f => dataToSave._adjuntos_remotos.push({ name: f.name, seccion: `REQUERIMIENTO_${parseInt(id)+1}` }));
                    });
                }

                document.querySelectorAll('input[id], select[id], textarea[id]').forEach(el => {
                    if (!el.id.includes('EmailConfirm')) {
                        dataToSave[el.id] = el.type === 'checkbox' ? el.checked : el.value;
                    }
                });

                await fetch(window.EIEL_CONFIG.urlGenerarPdf, { 
                    method: 'POST', mode: 'no-cors', 
                    body: JSON.stringify({
                        action: 'save_draft',
                        municipio: window.EIEL_CONFIG.muniCode,
                        tipo_formulario: formType,
                        id_envio_temporal: idLoteTemporal,
                        tecnico: localStorage.getItem("eiel_user_name") || "Desconocido",
                        datos_json: JSON.stringify(dataToSave)
                    }) 
                });
                
                formIsDirty = false;
                document.getElementById('btnGuardarNube').disabled = true;
                Swal.fire('¡Borrador guardado!', 'Textos y archivos sincronizados.', 'success');
                verificarBorradoresExistentes();
            } catch (error) {
                Swal.fire('Error', 'No se pudo guardar el borrador.', 'error');
            }
        }

        // FUNCIÓN: IMPORTAR (Recupera textos y reconstruye listas de archivos ☁️)
        async function cargarBorradorNube() {
            const formType = window.location.pathname.split("/").pop().split("_")[0];
            try {
                const url = `${window.EIEL_CONFIG.urlGenerarPdf}?action=list_drafts&muni=${window.EIEL_CONFIG.muniCode}&tipo=${formType}`;
                const resp = await fetch(url);
                const borradores = await resp.json();

                if (!borradores || borradores.length === 0) return;

                const options = {};
                borradores.forEach(b => { 
                    const autor = (b.tecnico === "Desconocido" || !b.tecnico) ? "Autor desconocido" : `Técnico: ${b.tecnico}`;
                    options[b.id] = `${b.fecha} (${autor})`; 
                });

                const { value: idSel } = await Swal.fire({
                    title: 'Importar Borrador',
                    input: 'select',
                    inputOptions: options,
                    inputPlaceholder: 'Seleccione una versión',
                    showCancelButton: true,
                    confirmButtonText: 'Cargar versión'
                });

                if (idSel) {
                    const borrador = borradores.find(x => x.id == idSel);
                    const data = JSON.parse(borrador.datos_json);
                    
                    // 1. Recuperar Textos y Checks
                    Object.entries(data).forEach(([id, val]) => {
                        if (id === "_adjuntos_remotos") return;
                        const el = document.getElementById(id);
                        if (el) {
                            if (el.type === 'checkbox') el.checked = val;
                            else { el.value = val; el.dispatchEvent(new Event('change')); }
                        }
                    });

                    // 2. Recuperar Archivos (Marcándolos como 'cloud')
                    if (data._adjuntos_remotos) {
                        archivosGenerales = [];
                        colaAdjuntosReq = {};
                        data._adjuntos_remotos.forEach(adj => {
                            const mockFile = { name: adj.name, status: 'cloud' };
                            if (adj.seccion === 'GENERAL') {
                                archivosGenerales.push(mockFile);
                            } else if (adj.seccion.startsWith('REQUERIMIENTO_')) {
                                const idReq = parseInt(adj.seccion.split('_')[1]) - 1;
                                if (!colaAdjuntosReq[idReq]) colaAdjuntosReq[idReq] = [];
                                colaAdjuntosReq[idReq].push(mockFile);
                            }
                        });
                        // Llamar a los renders del formulario hijo (Alumbrado/Obras)
                        if (typeof renderArchivos === 'function') renderArchivos();
                        if (typeof renderColaReq === 'function') {
                            Object.keys(colaAdjuntosReq).forEach(id => renderColaReq(id));
                        }
                    }

                    idBorradorOrigen = borrador.id_temporal || null; // Guardamos procedencia
                    formIsDirty = false;
                    Swal.fire('¡Éxito!', 'Borrador recuperado de la nube.', 'success');
                }
            } catch (error) {
                Swal.fire('Error', 'No se pudieron recuperar los borradores.', 'error');
            }
        }

        async function verificarBorradoresExistentes() {
            const formType = window.location.pathname.split("/").pop().split("_")[0];
            try {
                const url = `${window.EIEL_CONFIG.urlGenerarPdf}?action=list_drafts&muni=${window.EIEL_CONFIG.muniCode}&tipo=${formType}`;
                const resp = await fetch(url);
                const borradores = await resp.json();
                const btn = document.getElementById('btnImportarNube');
                if (btn) btn.style.display = (borradores && borradores.length > 0) ? 'flex' : 'none';
            } catch (e) { console.warn("Error al verificar borradores"); }
        }

        /* ==========================================================================
           6. UTILIDADES DE INTERFAZ
           ========================================================================== */
        function toggleFormFreeze(isFrozen) {
            const elements = document.querySelectorAll('input, select, textarea, button:not(.btn-logout), .btn-borrador');
            elements.forEach(el => {
                el.disabled = isFrozen;
                el.style.opacity = isFrozen ? "0.6" : "1";
                el.style.pointerEvents = isFrozen ? "none" : "auto";
            });
        }

        function abrirVisorImagen(src) {
            Swal.fire({
                imageUrl: src,
                imageAlt: 'Equipamiento',
                width: 'auto',
                showCloseButton: true,
                showConfirmButton: false,
                customClass: { image: 'img-fluid-max' }
            });
        }
    </script>
</head>
<body class="theme-{{ ficha_tipo }}">
    {# --- BLOQUE DE CABECERA --- #}
    <header class="site-header header-{{ ficha_tipo }}">
        <div class="header-content">
            <div class="logo-area">
                <h1>EIEL</h1>
                <span class="badge-fase">Fase {{ fase_actual }}</span>
            </div>
            <div class="user-area">
                <span class="header-muni-name-azul">{{ muni_display }}</span>
                {# Corregido: Texto "Salir" en lugar de icono #}
                <a href="index.html" class="btn-logout">Salir</a>
            </div>
        </div>
    </header>

    {# --- ENLACE VOLVER --- #}
    <nav class="breadcrumb-nav">
        <div class="container">
            <a href="index.html" class="back-link">← Volver al listado de formularios</a>
        </div>
    </nav>

    <main class="main-container">
        {# --- TÍTULO Y MUNICIPIO --- #}
        <div class="form-header">
            <div class="icon-header">{% block header_icon %}{% endblock %}</div>
            <div class="title-header">
                <h2>{% block header_title %}{% endblock %}</h2>
                {# Corregido: Clase muni-text-header para texto limpio #}
                <div class="muni-text-header">
                    {{ muni_display }} (Código: {{ muni_code }})
                    <span id="autosave-status"></span>
                </div>
            </div>
        </div>

        {% block content %}{% endblock %}
    </main>

    {{ ui.barra_lateral_borradores() }}

    <script>
        /* ==========================================================================
           7. INICIALIZACIÓN Y SINCRONIZACIÓN DE LOGIN
           ========================================================================== */
        document.addEventListener("DOMContentLoaded", () => {
            // Sincronizar nombre del municipio
            const headerName = document.getElementById("headerMuniName");
            if(headerName) headerName.textContent = localStorage.getItem("eiel_muni_name") || "Municipio";

            // Sincronizar campos de contacto desde LocalStorage
            const fieldsMap = {"contactoNombre": "eiel_user_name", "contactoEmail": "eiel_user_email", "contactoDepartamento": "eiel_user_dept"};
            Object.keys(fieldsMap).forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.value = localStorage.getItem(fieldsMap[id]) || "";
                    el.addEventListener('input', (e) => {
                        localStorage.setItem(fieldsMap[id], e.target.value.trim());
                        // Actualizar email de confirmación si existe
                        const confirm = document.getElementById(id + "Confirm");
                        if (confirm) confirm.value = ""; 
                    });
                }
            });
            
            activarDetectorCambios();
            verificarBorradoresExistentes();

            // Generar iconos Lucide
            if (window.lucide) lucide.createIcons();
        });

        // Logger de acceso
        (function() {
            if (window.location.protocol === 'file:') return;
            const payload = {
                municipio: window.EIEL_CONFIG.muniName,
                codigo: window.EIEL_CONFIG.muniCode,
                fase: window.EIEL_CONFIG.fase,
                tipo: window.location.pathname.split("/").pop().split("_")[0].toUpperCase(),
                ua: navigator.userAgent,
                contacto: localStorage.getItem("eiel_user_name") || "Acceso inicial"
            };
            if (window.EIEL_CONFIG.urlLogger) fetch(window.EIEL_CONFIG.urlLogger, {method: 'POST', mode: 'no-cors', body: JSON.stringify(payload)});
        })();
    </script>

    {% block scripts %}{% endblock %}
</body>
</html>