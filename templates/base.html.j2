{# base.html.j2 #}
{% import "macros.html.j2" as macros with context %}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        // CONFIGURACIÓN GLOBAL
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            isTest: localStorage.getItem("eiel_is_test") === "true"
        };

        // UI PROGRESS MANAGER (Barra de carga)
        const UIProgress = {
            show(steps = 1) {
                if (document.getElementById('uploadOverlay')) return;
                const html = `
                    <div id="uploadOverlay" class="overlay">
                        <div class="progress-card">
                            <div class="spinner"></div>
                            <h3 id="progressTitle">Procesando envío...</h3>
                            <p id="progressStatus">Iniciando transferencia segura</p>
                            <div class="progress-bar-container">
                                <div id="progressBar" class="progress-bar-fill" style="width: 0%"></div>
                            </div>
                            <p id="progressDetail" class="text-xs" style="margin-top:10px; color:#64748b;">No cierre la ventana</p>
                        </div>
                    </div>`;
                document.body.insertAdjacentHTML('beforeend', html);
                this.totalSteps = steps;
                this.currentStep = 0;
            },
            update(text, detail = "") {
                this.currentStep++;
                const percent = Math.min((this.currentStep / this.totalSteps) * 100, 95);
                document.getElementById('progressBar').style.width = percent + '%';
                document.getElementById('progressStatus').innerText = text;
                if (detail) document.getElementById('progressDetail').innerText = detail;
            },
            complete() {
                const bar = document.getElementById('progressBar');
                if (bar) bar.style.width = '100%';
                setTimeout(() => {
                    const overlay = document.getElementById('uploadOverlay');
                    if (overlay) overlay.remove();
                    Swal.fire({ icon: 'success', title: '¡Enviado!', text: 'La información se ha registrado correctamente.', confirmButtonColor: 'var(--primary)' });
                }, 500);
            }
        };

        // MOTOR GLOBAL DE FORMULARIOS (Refactorizado)
        const EIEL_FormManager = {
            archivosGenerales: [],
            colaAdjuntosReq: {},

            init() {
                this.setupFileListeners();
                lucide.createIcons();
            },

            setupFileListeners() {
                // Listener para archivos generales
                const mainInput = document.getElementById('fileInput');
                if (mainInput) {
                    mainInput.addEventListener('change', (e) => {
                        Array.from(e.target.files).forEach(file => this.archivosGenerales.push(file));
                        this.renderList('fileList', this.archivosGenerales);
                    });
                }

                // Listener para archivos de requerimientos
                document.addEventListener('change', (e) => {
                    if (e.target.classList.contains('req-file-input')) {
                        const reqId = e.target.getAttribute('data-req-id');
                        if (!this.colaAdjuntosReq[reqId]) this.colaAdjuntosReq[reqId] = [];
                        Array.from(e.target.files).forEach(file => this.colaAdjuntosReq[reqId].push(file));
                        this.renderList(`list-req-${reqId}`, this.colaAdjuntosReq[reqId], reqId);
                    }
                });
            },

            renderList(containerId, fileArray, reqId = null) {
                const container = document.getElementById(containerId);
                if (!container) return;
                container.innerHTML = fileArray.map((f, idx) => `
                    <div class="file-item">
                        <span class="file-name"><i data-lucide="file-text"></i> ${f.name}</span>
                        <button type="button" class="btn-remove-file" onclick="EIEL_FormManager.removeFile('${containerId}', ${idx}, ${reqId})">
                            <i data-lucide="x"></i>
                        </button>
                    </div>`).join('');
                lucide.createIcons();
            },

            removeFile(containerId, index, reqId) {
                if (reqId) this.colaAdjuntosReq[reqId].splice(index, 1);
                else this.archivosGenerales.splice(index, 1);
                this.renderList(containerId, reqId ? this.colaAdjuntosReq[reqId] : this.archivosGenerales, reqId);
            },

            async uploadFiles(tipoForm) {
                const totalFiles = this.archivosGenerales.length + Object.values(this.colaAdjuntosReq).flat().length;
                if (totalFiles === 0) return [];

                const nombresSubidos = [];
                const idEnvio = "ID_" + Date.now();

                // Subir generales
                for (const file of this.archivosGenerales) {
                    UIProgress.update(`Subiendo: ${file.name}`);
                    const res = await this.toBase64(file);
                    await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                        method: "POST", mode: "no-cors",
                        body: JSON.stringify({ 
                            municipio: window.EIEL_CONFIG.muniCode, tipo: tipoForm, 
                            nombre: file.name, base64: res.split(',')[1], id_envio: idEnvio 
                        })
                    });
                    nombresSubidos.push(file.name);
                }

                // Subir requerimientos
                for (const [reqId, files] of Object.entries(this.colaAdjuntosReq)) {
                    for (const file of files) {
                        UIProgress.update(`Subiendo justificante: ${file.name}`);
                        const res = await this.toBase64(file);
                        await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                            method: "POST", mode: "no-cors",
                            body: JSON.stringify({ 
                                municipio: window.EIEL_CONFIG.muniCode, tipo: tipoForm, seccion: "REQUERIMIENTOS",
                                nombre: `[REQ_${reqId}] ${file.name}`, base64: res.split(',')[1], id_envio: idEnvio 
                            })
                        });
                        nombresSubidos.push(`[REQ_${reqId}] ${file.name}`);
                    }
                }
                return nombresSubidos;
            },

            toBase64: file => new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result);
                reader.onerror = error => reject(error);
            }),

            getRequerimientosData() {
                return Array.from(document.querySelectorAll('.req-respuesta')).map(el => ({
                    id: el.getAttribute('data-req-id'),
                    pregunta: el.getAttribute('data-req-nombre'),
                    respuesta: el.value
                }));
            }
        };
    </script>
</head>
<body>
    {# Barra Superior y Navegación idénticas #}
    <div class="top-bar">
        <div class="top-bar-content">
            <div class="muni-info">
                <span class="muni-badge">{{ muni_code }}</span>
                <span class="muni-name">{{ muni_display }}</span>
            </div>
            <div class="fase-badge">{% block bloque_fase %}{% endblock %}</div>
        </div>
    </div>

    <div class="container">
        <header class="header-main">
            <div class="header-icon">{% block header_icon %}{% endblock %}</div>
            <div class="header-text">
                <h1>{% block header_title %}{% endblock %}</h1>
                <p>Encuesta de Infraestructura y Equipamientos Locales</p>
            </div>
        </header>

        <form id="mainForm">
            {% block content %}{% endblock %}

            <div class="card" style="margin-top: 2rem;">
                <h2 class="section-title"><i data-lucide="message-square"></i> Observaciones Finales</h2>
                <div class="form-group">
                    <textarea class="form-control" name="observaciones" id="observaciones" rows="4" placeholder="Indique cualquier aclaración adicional..."></textarea>
                </div>
            </div>

            <div class="footer-actions">
                <label class="checkbox-container">
                    <input type="checkbox" id="checkConformidad">
                    <span class="checkmark"></span>
                    Confirmo que los datos introducidos son correctos
                </label>
                <button type="submit" id="btnEnviar" class="btn btn-primary" disabled>
                    <i data-lucide="send"></i> Enviar Información
                </button>
                <a href="index.html" class="btn btn-secondary">
                    <i data-lucide="arrow-left"></i> Volver al Menú
                </a>
            </div>
        </form>
    </div>

    {% block scripts %}{% endblock %}

    <script>
        // Logger Silencioso (permanece igual)
        (function() {
            if (window.location.protocol === 'file:') return;
            const payload = {
                municipio: window.EIEL_CONFIG.isTest ? "(PRUEBAS) " + window.EIEL_CONFIG.muniName : window.EIEL_CONFIG.muniName,
                codigo: window.EIEL_CONFIG.muniCode,
                fase: window.EIEL_CONFIG.fase,
                tipo: window.location.pathname.split("/").pop().split("_")[0].toUpperCase(),
                ua: navigator.userAgent,
                contacto: (window.EIEL_CONFIG.isTest ? "[DEV] " : "") + (localStorage.getItem("eiel_user_name") || "Acceso inicial"),
                departamento: localStorage.getItem("eiel_user_dept") || "N/A",
                email: localStorage.getItem("eiel_user_email") || "N/A" 
            };
            if (window.EIEL_CONFIG.urlLogger) {
                fetch(window.EIEL_CONFIG.urlLogger, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            }
        })();

        // Lógica de habilitación del botón Enviar
        const checkConf = document.getElementById('checkConformidad');
        const btnEnv = document.getElementById('btnEnviar');
        if(checkConf && btnEnv) {
            checkConf.addEventListener('change', (e) => btnEnv.disabled = !e.target.checked);
        }

        EIEL_FormManager.init();
    </script>
</body>
</html>