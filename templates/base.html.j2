<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        // 1. CONFIGURACIÓN GLOBAL
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            hasAvisos: {% if avisos_personalizados|length > 0 %}true{% else %}false{% endif %}
        };

        // 2. SERVICIO DE PROGRESO (Interfaz de envío)
        const UIProgress = {
            get el() { return {
                bar: document.getElementById("progressBar"),
                text: document.getElementById("progressText"),
                percent: document.getElementById("progressValue"),
                container: document.getElementById("overlayProgress"),
                success: document.getElementById("successState"),
                elements: document.getElementById("progressElements")
            }},
            show(total) {
                this.el.container.classList.remove('hidden');
                this.el.success.classList.add('hidden');
                this.el.elements.classList.remove('hidden');
                this.update(0, total, "Iniciando envío...");
            },
            update(completed, total, msg) {
                const perc = total > 0 ? Math.round((completed / total) * 90) : 0;
                this.el.bar.style.width = perc + "%";
                this.el.percent.textContent = perc + "%";
                this.el.text.textContent = msg;
            },
            complete() {
                this.el.bar.style.width = "100%";
                this.el.percent.textContent = "100%";
                this.el.elements.classList.add('hidden');
                this.el.success.classList.remove('hidden');
                if (window.lucide) lucide.createIcons();
            }
        };

        // 3. SERVICIO DE SUBIDA (Motor por lotes)
        const UploadService = {
            async uploadFiles(tareas, tipo, muni, idBatch, concurrency = 1) {
                for (let i = 0; i < tareas.length; i += concurrency) {
                    const lote = tareas.slice(i, i + concurrency);
                    await Promise.all(lote.map(async (t) => {
                        const base64 = await this._toBase64(t.file);
                        const payload = {
                            filename: t.file.name,
                            mimeType: t.file.type,
                            bytesBase64: base64,
                            municipio: muni,
                            tipo: tipo,
                            seccion: t.seccion || "GENERAL",
                            id_envio: idBatch
                        };
                        await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                            method: 'POST', mode: 'no-cors',
                            body: JSON.stringify(payload)
                        });
                    }));
                    UIProgress.update(i + lote.length, tareas.length, `Subiendo archivos...`);
                }
            },
            _toBase64: file => new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result.split(',')[1]);
                reader.onerror = e => reject(e);
            })
        };

        // 4. FUNCIONES GLOBALES
        function logout() {
            localStorage.clear();
            window.location.href = "index.html";
        }
        
        function toggleFormFreeze(isFrozen) {
            const elements = document.querySelectorAll('input, select, textarea, button:not(.btn-logout), .btn-remove, .btn-add');
            elements.forEach(el => {
                el.disabled = isFrozen;
                el.style.opacity = isFrozen ? "0.6" : "1";
                el.style.pointerEvents = isFrozen ? "none" : "auto";
            });
        }
        
        window.abrirVisorImagen = (src) => {
            let modal = document.getElementById('visorImagenGlobal') || document.createElement('div');
            if (!document.getElementById('visorImagenGlobal')) {
                modal.id = 'visorImagenGlobal';
                modal.className = 'modal-img';
                modal.innerHTML = `<img src="" id="imgVisor">`;
                modal.onclick = () => modal.style.display = 'none';
                document.body.appendChild(modal);
            }
            modal.querySelector('img').src = src;
            modal.style.display = 'flex';
        };
    </script>
</head>
<body class="theme-{{ ficha_tipo|default('default') }}">
    <header class="site-header">
        <div class="header-content">
            <div class="logo-area">
                <h1>EIEL</h1>
                <span class="badge-fase">Fase {{ fase_actual }}</span>
            </div>
            <div class="user-area">
                <span id="headerMuniName" class="user-email">...</span>
                <button onclick="logout()" class="btn-logout">Salir</button>
            </div>
        </div>
    </header>

    <nav class="breadcrumb-nav">
        <div class="container">
            <a href="index.html" class="back-link">⭠ Volver al listado</a>
        </div>
    </nav>

    <main class="main-container">
        <div class="form-header">
            <div class="icon-header">{% block header_icon %}??{% endblock %}</div>
            <div class="title-header">
                <h2>{% block header_title %}Formulario{% endblock %}</h2>
                <p class="subtitle">{{ muni_display }} ({{ muni_code }})</p>
            </div>
        </div>
        {% block content %}{% endblock %}
    </main>


    <footer class="site-footer">
        <p>Diputación de Alicante - Encuesta de Infraestructura y Equipamientos Locales</p>
    </footer>

    {# --- OVERLAY DE PROGRESO --- #}
    <div id="overlayProgress" class="overlay hidden">
        <div class="progress-card">
            <h3 id="progressTitle">Enviando datos...</h3>
            <div id="progressElements">
                <div class="progress-bar-container"><div id="progressBar" class="progress-bar"></div></div>
                <div class="progress-info"><span id="progressText">Iniciando...</span><span id="progressValue">0%</span></div>
                <p class="paciencia-nota">⌛ No cierre ni refresque la pestaña durante el proceso.</p>
            </div>
            <div id="successState" class="hidden">
                <div style="color: #10b981; font-size: 3rem; margin-bottom: 15px;"><i data-lucide="check-circle-2"></i></div>
                <p>¡Envío realizado correctamente! Se ha enviado un justificante al correo facilitado.</p>
                <a href="index.html" class="btn btn-primary">Volver al Listado</a>
            </div>
        </div>
    </div>

    {# --- BLOQUE DE SCRIPTS DE LOS FORMULARIOS --- #}
    {% block scripts %}{% endblock %}

    <script>
        // VALIDACIÓN DE SESIÓN Y PERSISTENCIA
        document.addEventListener("DOMContentLoaded", () => {
            const muniCode = localStorage.getItem("eiel_muni_code");
            if (!muniCode) return window.location.href = "index.html";
            
            const headerName = document.getElementById("headerMuniName");
            if(headerName) headerName.textContent = localStorage.getItem("eiel_muni_name") || "Municipio";

            const fieldsMap = {"contactoNombre": "eiel_user_name", "contactoEmail": "eiel_user_email", "contactoDepartamento": "eiel_user_dept"};
            Object.keys(fieldsMap).forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.value = localStorage.getItem(fieldsMap[id]) || "";
                    el.addEventListener('input', (e) => localStorage.setItem(fieldsMap[id], e.target.value.trim()));
                }
            });
        });

        // LOGGER Y ICONOS
        (function() {
            if (window.location.protocol === 'file:') return;
            const payload = {
                municipio: "{{ muni_display }}", codigo: "{{ muni_code }}", fase: "{{ fase_actual }}",
                tipo: window.location.pathname.split("/").pop().split("_")[0].toUpperCase(),
                ua: navigator.userAgent,
                contacto: localStorage.getItem("eiel_user_name") || "Acceso inicial"
            };
            if (window.EIEL_CONFIG.urlLogger) fetch(window.EIEL_CONFIG.urlLogger, {method: 'POST', mode: 'no-cors', body: JSON.stringify(payload)});
        })();

        document.addEventListener("DOMContentLoaded", () => { if (window.lucide) lucide.createIcons(); });
    </script>
</body>
</html>