<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        // 1. CONFIGURACIÓN GLOBAL (Centralizada)
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            hasAvisos: {% if avisos_personalizados|length > 0 %}true{% else %}false{% endif %}
        };

        // 2. UTILIDADES DE INTERFAZ
        const UI = {
            toggleFreeze(isFrozen) {
                const selectors = 'input, select, textarea, button:not(.btn-logout), .btn-remove, .btn-add';
                document.querySelectorAll(selectors).forEach(el => {
                    el.disabled = isFrozen;
                    el.classList.toggle('is-frozen', isFrozen);
                });
                const btn = document.getElementById('btnEnviar');
                if (btn) btn.style.cursor = isFrozen ? "wait" : "pointer";
            },

            showImage(src) {
                let modal = document.getElementById('visorImagenGlobal') || this._createImageModal();
                modal.querySelector('img').src = src;
                modal.style.display = 'flex';
            },

            _createImageModal() {
                const modal = document.createElement('div');
                modal.id = 'visorImagenGlobal';
                modal.className = 'modal-img';
                modal.innerHTML = `<img src="" id="imgVisor">`;
                modal.onclick = () => modal.style.display = 'none';
                document.body.appendChild(modal);
                return modal;
            }
        };

        // 3. SERVICIO DE PROGRESO (Unificado)
        const UIProgress = {
            get el() { return {
                container: document.getElementById("overlayProgress"),
                bar: document.getElementById("progressBar"),
                text: document.getElementById("progressText"),
                percent: document.getElementById("progressValue"),
                title: document.getElementById("progressTitle"),
                elements: document.getElementById("progressElements"),
                success: document.getElementById("successState")
            }},
            maxReached: 0,

            show(total) {
                this.maxReached = 0;
                const { container, title, elements, success } = this.el;
                if(title) title.textContent = "Enviando datos...";
                if(elements) elements.classList.remove('hidden');
                if(success) success.classList.add('hidden');
                if(container) container.classList.remove('hidden');
                this.update(0, total, "Iniciando...");
            },

            update(completed, total, message) {
                const isFinal = /pdf|registro|justificante/i.test(message);
                let target = total > 0 ? (isFinal ? 95 : Math.round(completed * (90 / total))) : (isFinal ? 95 : 0);
                
                if (target > this.maxReached) {
                    this.maxReached = target;
                    if(this.el.bar) this.el.bar.style.width = this.maxReached + "%";
                    if(this.el.percent) this.el.percent.textContent = this.maxReached + "%";
                }
                if(this.el.text) this.el.text.textContent = message;
            },

            complete() {
                const { title, elements, success } = this.el;
                if(title) title.textContent = "¡Envío Finalizado!";
                if(elements) elements.classList.add('hidden');
                if(success) success.classList.remove('hidden');
                if(window.lucide) lucide.createIcons();
            }
        };

        // 4. SERVICIO DE SUBIDA (Híbrido: Soporta Lotes)
        const UploadService = {
            async uploadFiles(files, tipo, muni, idBatch, concurrency = 1) {
                let completados = 0;
                const total = files.length;

                // Procesamiento por lotes (concurrente para Obras, secuencial para el resto)
                for (let i = 0; i < total; i += concurrency) {
                    const lote = files.slice(i, i + concurrency);
                    await Promise.all(lote.map(async (tarea) => {
                        try {
                            const base64 = await this._toBase64(tarea.file);
                            const payload = {
                                filename: tarea.file.name,
                                mimeType: tarea.file.type,
                                bytesBase64: base64,
                                municipio: muni,
                                usuario: document.getElementById("contactoEmail")?.value || "anonimo",
                                tipo: tipo,
                                seccion: tarea.seccion || "GENERAL",
                                id_envio: idBatch
                            };
                            await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                                method: 'POST', mode: 'no-cors',
                                body: JSON.stringify(payload)
                            });
                            completados++;
                            UIProgress.update(completados, total, `Subiendo archivos (${completados}/${total})...`);
                        } catch (e) { console.error("Error en subida:", e); }
                    }));
                    if (i + concurrency < total) await new Promise(r => setTimeout(r, 200));
                }
            },

            _toBase64: file => new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result.split(',')[1]);
                reader.onerror = e => reject(e);
            })
        };

        function logout() {
            localStorage.clear();
            window.location.href = "index.html";
        }
    </script>
</head>
<body class="theme-{{ ficha_tipo|default('default') }}">

    <header class="site-header">
        <div class="header-content">
            <div class="logo-area">
                <h1>EIEL</h1>
                <span class="badge-fase">{% block bloque_fase %}Fase --{% endblock %}</span>
            </div>
            <div class="user-area">
                <span id="headerMuniName" class="user-email">...</span>
                <button onclick="logout()" class="btn-logout">Salir</button>
            </div>
        </div>
    </header>

    <nav class="breadcrumb-nav">
        <div class="container">
            <a href="index.html" class="back-link">⭠ Volver al listado</a>
        </div>
    </nav>

    <main class="main-container">
        <div class="form-header">
            <div class="icon-header">{% block header_icon %}??{% endblock %}</div>
            <div class="title-header">
                <h2>{% block header_title %}Formulario{% endblock %}</h2>
                <p class="subtitle">{{ muni_display }} (Código: {{ muni_code }})</p>
            </div>
        </div>

        {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
        <p>Diputación de Alicante - Encuesta de Infraestructura y Equipamientos Locales</p>
    </footer>

    <div id="overlayProgress" class="overlay hidden">
        <div class="progress-card">
            <h3 id="progressTitle">Enviando datos...</h3>
            <div id="progressElements">
                <div class="progress-bar-container">
                    <div id="progressBar" class="progress-bar"></div>
                </div>
                <div class="progress-info">
                    <span id="progressText">Iniciando...</span>
                    <span id="progressValue">0%</span>
                </div>
                <p class="paciencia-nota">
                    ⌛ <b>Nota:</b> Proceso largo. No cierre la pestaña.
                </p>
            </div>
            <div id="successState" class="hidden">
                <div class="success-icon"><i data-lucide="check-circle-2"></i></div>
                <p class="success-text">¡Envío correcto! Recibirá un PDF justificante.</p>
                <a href="index.html" class="btn-primary">Volver al Listado</a>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // A. VALIDACIÓN DE SESIÓN
            const muniCode = localStorage.getItem("eiel_muni_code");
            const muniName = localStorage.getItem("eiel_muni_name");
            if (!muniCode) { window.location.href = "index.html"; return; }
            
            document.getElementById("headerMuniName").textContent = muniName || "Municipio";

            // B. PERSISTENCIA DE CONTACTO
            const contactFields = ["contactoNombre", "contactoEmail", "contactoDepartamento"];
            contactFields.forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                
                // Rellenar
                const saved = localStorage.getItem(`eiel_user_${id}`);
                if (saved) {
                    el.value = saved;
                    if (id === "contactoEmail" && document.getElementById("contactoEmailConfirm")) {
                        document.getElementById("contactoEmailConfirm").value = saved;
                    }
                }
                // Guardar al escribir
                el.addEventListener('input', e => {
                    localStorage.setItem(`eiel_user_${id}`, e.target.value.trim());
                });
            });

            if (window.lucide) lucide.createIcons();
        });
    </script>

    {% block scripts %}{% endblock %}
</body>
</html>