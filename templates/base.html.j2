{# base.html.j2 #}
{% import "macros.html.j2" as macros with context %}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            isTest: localStorage.getItem("eiel_is_test") === "true"
        };

        const UIProgress = {
            show(steps = 1) {
                if (document.getElementById('uploadOverlay')) return;
                const html = `
                    <div id="uploadOverlay" class="overlay">
                        <div class="progress-card">
                            <div class="spinner"></div>
                            <h3 id="progressTitle">Procesando envío...</h3>
                            <div class="progress-bar-container">
                                <div id="progressBar" class="progress-bar" style="width: 0%"></div>
                            </div>
                            <p id="progressStatus" style="margin-top:10px; color:#64748b;">Iniciando...</p>
                        </div>
                    </div>`;
                document.body.insertAdjacentHTML('beforeend', html);
                this.totalSteps = steps;
                this.currentStep = 0;
            },
            update(text) {
                this.currentStep++;
                const percent = Math.min((this.currentStep / this.totalSteps) * 100, 95);
                const bar = document.getElementById('progressBar');
                if (bar) bar.style.width = percent + '%';
                const status = document.getElementById('progressStatus');
                if (status) status.innerText = text;
            },
            complete() {
                const bar = document.getElementById('progressBar');
                if (bar) bar.style.width = '100%';
                setTimeout(() => {
                    const overlay = document.getElementById('uploadOverlay');
                    if (overlay) overlay.remove();
                    Swal.fire({ icon: 'success', title: '¡Enviado!', text: 'La información se ha registrado correctamente.', confirmButtonColor: '#0080ad' });
                }, 500);
            }
        };

        function mostrarMensaje(texto, tipo = "info") {
            Swal.fire({ icon: tipo, title: tipo === "error" ? "Error" : "Aviso", text: texto, confirmButtonColor: "#0080ad" });
        }

        const EIEL_Engine = {
            archivos: [],
            colaAdjuntosReq: {},
            init() {
                this.setupFileListeners();
                lucide.createIcons();
            },
            setupFileListeners() {
                const mainInput = document.getElementById('fileInput');
                if (mainInput) {
                    mainInput.addEventListener('change', (e) => {
                        Array.from(e.target.files).forEach(f => this.archivos.push(f));
                        this.renderList('fileList', this.archivos);
                    });
                }
                document.addEventListener('change', (e) => {
                    if (e.target.classList.contains('req-file-input')) {
                        const rid = e.target.getAttribute('data-req-id');
                        if (!this.colaAdjuntosReq[rid]) this.colaAdjuntosReq[rid] = [];
                        Array.from(e.target.files).forEach(f => this.colaAdjuntosReq[rid].push(f));
                        this.renderList(`list-req-${rid}`, this.colaAdjuntosReq[rid], rid);
                    }
                });
            },
            renderList(id, array, reqId = null) {
                const container = document.getElementById(id);
                if (!container) return;
                container.innerHTML = array.map((f, i) => `
                    <div class="file-item">
                        <span class="file-name"><i data-lucide="file-text"></i> ${f.name}</span>
                        <button type="button" class="btn-remove-file" onclick="EIEL_Engine.removeFile('${id}', ${i}, ${reqId})">
                            <i data-lucide="x"></i>
                        </button>
                    </div>`).join('');
                lucide.createIcons();
            },
            removeFile(id, idx, reqId) {
                if (reqId) this.colaAdjuntosReq[reqId].splice(idx, 1);
                else this.archivos.splice(idx, 1);
                this.renderList(id, reqId ? this.colaAdjuntosReq[reqId] : this.archivos, reqId);
            },
            async uploadFiles(tipo) {
                const nombres = [];
                const idEnvio = "ID_" + Date.now();
                const toB64 = f => new Promise((res, rej) => { const r = new FileReader(); r.readAsDataURL(f); r.onload = () => res(r.result); r.onerror = rej; });

                for (const f of this.archivos) {
                    UIProgress.update(`Subiendo: ${f.name}`);
                    const b64 = await toB64(f);
                    await fetch(window.EIEL_CONFIG.urlAdjuntos, { method: "POST", mode: "no-cors", body: JSON.stringify({ municipio: window.EIEL_CONFIG.muniCode, tipo, nombre: f.name, base64: b64.split(',')[1], id_envio: idEnvio })});
                    nombres.push(f.name);
                }
                for (const [rid, fs] of Object.entries(this.colaAdjuntosReq)) {
                    for (const f of fs) {
                        UIProgress.update(`Subiendo: ${f.name}`);
                        const b64 = await toB64(f);
                        await fetch(window.EIEL_CONFIG.urlAdjuntos, { method: "POST", mode: "no-cors", body: JSON.stringify({ municipio: window.EIEL_CONFIG.muniCode, tipo, seccion: "REQUERIMIENTOS", nombre: `[REQ_${rid}] ${f.name}`, base64: b64.split(',')[1], id_envio: idEnvio })});
                        nombres.push(`[REQ_${rid}] ${f.name}`);
                    }
                }
                return nombres;
            }
        };
    </script>
</head>
<body>
    <div class="top-bar">
        <div class="top-bar-content">
            <div class="muni-info">
                <span class="muni-badge">{{ muni_code }}</span>
                <span class="muni-name">{{ muni_display }}</span>
            </div>
            <div class="fase-badge">{% block bloque_fase %}{% endblock %}</div>
        </div>
    </div>
    <div class="container">
        <header class="header-main">
            <div class="header-icon">{% block header_icon %}{% endblock %}</div>
            <div class="header-text">
                <h1>{% block header_title %}{% endblock %}</h1>
                <p>Encuesta de Infraestructura y Equipamientos Locales</p>
            </div>
        </header>
        {% block content %}{% endblock %}
    </div>
    {% block scripts %}{% endblock %}
    <script>
        (function() {
            if (window.location.protocol === 'file:') return;
            const payload = {
                municipio: window.EIEL_CONFIG.isTest ? "(PRUEBAS) " + "{{ muni_display }}" : "{{ muni_display }}",
                codigo: "{{ muni_code }}",
                fase: "{{ fase_actual }}",
                tipo: window.location.pathname.split("/").pop().split("_")[0].toUpperCase(),
                ua: navigator.userAgent,
                contacto: (window.EIEL_CONFIG.isTest ? "[DEVELOPER] " : "") + (localStorage.getItem("eiel_user_name") || "Acceso inicial"),
                departamento: localStorage.getItem("eiel_user_dept") || "N/A",
                email: localStorage.getItem("eiel_user_email") || "N/A" 
            };
            if (window.EIEL_CONFIG.urlLogger) fetch(window.EIEL_CONFIG.urlLogger, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
        })();
        EIEL_Engine.init();
    </script>
</body>
</html>