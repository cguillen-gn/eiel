<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            isTest: localStorage.getItem("eiel_is_test") === "true"
        };

        const UIProgress = {
            show(steps = 1) {
                if (document.getElementById('uploadOverlay')) return;
                const html = `
                    <div id="uploadOverlay" class="overlay">
                        <div class="progress-card">
                            <div class="spinner"></div>
                            <h3 id="progressTitle">Procesando envío...</h3>
                            <div class="progress-bar-container">
                                <div id="progressBar" class="progress-bar" style="width: 0%"></div>
                            </div>
                            <p id="progressStatus" style="margin-top:10px; color:#64748b;">Iniciando...</p>
                        </div>
                    </div>`;
                document.body.insertAdjacentHTML('beforeend', html);
                this.totalSteps = steps;
                this.currentStep = 0;
            },
            update(text) {
                this.currentStep++;
                const percent = Math.min((this.currentStep / this.totalSteps) * 100, 95);
                const bar = document.getElementById('progressBar');
                if (bar) bar.style.width = percent + '%';
                const status = document.getElementById('progressStatus');
                if (status) status.innerText = text;
            },
            complete() {
                const bar = document.getElementById('progressBar');
                if (bar) bar.style.width = '100%';
                setTimeout(() => {
                    const overlay = document.getElementById('uploadOverlay');
                    if (overlay) overlay.remove();
                    Swal.fire({ icon: 'success', title: '¡Enviado!', text: 'La información se ha registrado correctamente.', confirmButtonColor: '#0080ad' });
                }, 500);
            }
        };

        function mostrarMensaje(texto, tipo = "info") {
            Swal.fire({ icon: tipo, title: tipo === "error" ? "Error" : "Aviso", text: texto, confirmButtonColor: "#0080ad" });
        }

        const EIEL_Engine = {
            archivos: [],
            colaAdjuntosReq: {},
            
            init() {
                this.setupListeners();
                if (typeof lucide !== 'undefined') lucide.createIcons();
            },
            
            setupListeners() {
                // Escucha archivos generales
                const fileInput = document.getElementById('fileInput');
                if (fileInput) {
                    fileInput.addEventListener('change', (e) => {
                        Array.from(e.target.files).forEach(f => this.archivos.push(f));
                        this.renderList('fileList', this.archivos);
                    });
                }
                
                // Escucha archivos de requerimientos (delegación de eventos)
                document.addEventListener('change', (e) => {
                    if (e.target.classList.contains('req-file-input')) {
                        const rid = e.target.getAttribute('data-req-id');
                        if (!this.colaAdjuntosReq[rid]) this.colaAdjuntosReq[rid] = [];
                        Array.from(e.target.files).forEach(f => this.colaAdjuntosReq[rid].push(f));
                        this.renderList(`list-req-${rid}`, this.colaAdjuntosReq[rid], rid);
                    }
                });
            },
            
            renderList(id, array, reqId = null) {
                const container = document.getElementById(id);
                if (!container) return;
                container.innerHTML = array.map((f, i) => `
                    <div class="file-item">
                        <span class="file-name"><i data-lucide="file-text"></i> ${f.name}</span>
                        <button type="button" class="btn-remove-file" onclick="EIEL_Engine.removeFile('${id}', ${i}, ${reqId})">
                            <i data-lucide="x"></i>
                        </button>
                    </div>`).join('');
                if (typeof lucide !== 'undefined') lucide.createIcons();
            },
            
            removeFile(id, idx, reqId) {
                if (reqId) this.colaAdjuntosReq[reqId].splice(idx, 1);
                else this.archivos.splice(idx, 1);
                this.renderList(id, reqId ? this.colaAdjuntosReq[reqId] : this.archivos, reqId);
            },
            
            async uploadFiles(tipoForm) {
                const nombresSubidos = [];
                const idEnvio = "ID_" + Date.now();
                const toBase64 = file => new Promise((res, rej) => { 
                    const reader = new FileReader(); 
                    reader.readAsDataURL(file); 
                    reader.onload = () => res(reader.result.split(',')[1]); 
                    reader.onerror = rej; 
                });

                // Subir generales
                for (const file of this.archivos) {
                    UIProgress.update(`Subiendo: ${file.name}`);
                    const b64 = await toBase64(file);
                    await fetch(window.EIEL_CONFIG.urlAdjuntos, { 
                        method: "POST", mode: "no-cors", 
                        body: JSON.stringify({ municipio: window.EIEL_CONFIG.muniCode, tipo: tipoForm, nombre: file.name, base64: b64, id_envio: idEnvio })
                    });
                    nombresSubidos.push(file.name);
                }

                // Subir requerimientos
                for (const [rid, files] of Object.entries(this.colaAdjuntosReq)) {
                    for (const file of files) {
                        UIProgress.update(`Subiendo justificante: ${file.name}`);
                        const b64 = await toBase64(file);
                        await fetch(window.EIEL_CONFIG.urlAdjuntos, { 
                            method: "POST", mode: "no-cors", 
                            body: JSON.stringify({ municipio: window.EIEL_CONFIG.muniCode, tipo: tipoForm, seccion: "REQUERIMIENTOS", nombre: `[REQ_${rid}] ${file.name}`, base64: b64, id_envio: idEnvio })
                        });
                        nombresSubidos.push(`[REQ_${rid}] ${file.name}`);
                    }
                }
                return nombresSubidos;
            }
        };

        // Iniciar el motor cuando el DOM esté listo
        document.addEventListener('DOMContentLoaded', () => EIEL_Engine.init());
    </script>
   
    
</head>
<body>

    <header class="site-header">
        <div class="header-content">
            <div class="logo-area">
                <h1>EIEL</h1>
                <span class="badge-fase">
                    {% block bloque_fase %}Fase --{% endblock %}
                </span>
            </div>
        
            <div class="user-area">
                <span id="headerMuniName" class="user-email">...</span>
                <button onclick="logout()" class="btn-logout">Salir</button>
            </div>
        </div>
    </header>

    <nav class="breadcrumb-nav">
        <div class="container">
            <a href="index.html" class="back-link">
                ⭠ Volver al listado de formularios
            </a>
        </div>
    </nav>

    <main class="main-container">
        <div class="form-header">
            <div class="icon-header">
                {% block header_icon %}??{% endblock %}
            </div>
            <div class="title-header">
                <h2>{% block header_title %}Formulario{% endblock %}</h2>
                <p class="subtitle">{{ muni_display }} (Código: {{ muni_code }})</p>
            </div>
        </div>

        {% block content %}
        {% endblock %}
    </main>

    <footer class="site-footer" style="text-align: center; padding: 2rem; color: #94a3b8; font-size: 0.85rem;">
        <p>Diputación de Alicante - Encuesta de Infraestructura y Equipamientos Locales</p>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // A. VALIDACIÓN DE SESIÓN DEL MUNICIPIO
            const muniCode = localStorage.getItem("eiel_muni_code");
            const muniName = localStorage.getItem("eiel_muni_name");

            if (!muniCode) {
                console.warn("Acceso no autorizado. Redirigiendo al login...");
                window.location.href = "index.html";
                return;
            }

            // Actualizamos el nombre del municipio en la cabecera
            const headerName = document.getElementById("headerMuniName");
            if(headerName) headerName.textContent = muniName || "Municipio";

            // B. AUTOCOMPLETADO Y PERSISTENCIA PROACTIVA
            const fieldsMap = {
                "contactoNombre": "eiel_user_name",
                "contactoEmail": "eiel_user_email",
                "contactoDepartamento": "eiel_user_dept"
            };

            // 1. Rellenar campos si ya existen datos guardados
            Object.keys(fieldsMap).forEach(id => {
                const savedValue = localStorage.getItem(fieldsMap[id]);
                const inputEl = document.getElementById(id);
                
                if (savedValue && inputEl) {
                    inputEl.value = savedValue;
                    // Caso especial: Sincronizar campo de confirmación de email
                    if (id === "contactoEmail") {
                        const confirmEl = document.getElementById("contactoEmailConfirm");
                        if (confirmEl) confirmEl.value = savedValue;
                    }
                }
            });

            // 2. Guardar datos en tiempo real mientras el técnico escribe (Escucha Activa)
            Object.keys(fieldsMap).forEach(id => {
                const inputEl = document.getElementById(id);
                if (inputEl) {
                    inputEl.addEventListener('input', (e) => {
                        localStorage.setItem(fieldsMap[id], e.target.value.trim());
                    });
                }
            });
            
            // C. Detectar cambios en cualquier campo de entrada de forma global
            document.addEventListener('input', (e) => {
                if (e.target.closest('input, select, textarea')) {
                    formSucio = true;
                }
            });
        });
    </script>
    
    <div id="overlayProgress" class="overlay hidden">
        <div class="progress-card">
            <h3 id="progressTitle" style="margin-bottom: 10px; font-weight: 700; color: #1e293b;">Enviando datos...</h3>
            
            <div id="progressElements">
                <div class="progress-bar-container">
                    <div id="progressBar" class="progress-bar" style="width: 0%; height: 100%; background-color: #10b981; transition: width 0.3s ease;"></div>
                </div>
                <div class="progress-info">
                    <span id="progressText">Iniciando...</span>
                    <span id="progressValue">0%</span>
                </div>
                <p id="pacienciaNota" style="margin-top:20px; font-size:0.85em; color:#64748b; font-style:italic; line-height:1.4; text-align: center; border-top: 1px solid #f1f5f9; padding-top: 15px;">
                    ⌛ <b>Nota:</b> Este proceso puede tardar <b>varios minutos</b> debido al volumen de información y la generación del certificado oficial. Por favor, <b>no cierre ni refresque la pestaña.</b>
                </p>
            </div>

            <div id="successState" class="hidden" style="margin-top: 20px;">
                <div style="color: #10b981; font-size: 3rem; margin-bottom: 15px;">
                    <i data-lucide="check-circle-2" style="width: 60px; height: 60px; margin: 0 auto;"></i>
                </div>
                <p style="color: #475569; font-weight: 500; line-height: 1.6; margin-bottom: 25px;">
                    ¡El envío se ha realizado correctamente!<br>
                    <span style="color: #1e293b; font-weight: 700;">Se ha enviado un justificante en formato PDF al correo electrónico facilitado.</span>
                </p>
                <a href="index.html" class="btn-primary" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; justify-content: center; width: 100%;">
                    <i data-lucide="home" style="width: 18px;"></i>
                    Volver al Listado de Formularios
                </a>
            </div>
        </div>
    </div>

    {% block scripts %}
    {# Aquí se insertarán los scripts específicos de cada formulario #}
    {% endblock %}

    {# --- SCRIPT DEL LOGGER SILENCIOSO (RASTREO DE ACCESOS) --- #}
    <script>
    (function() {
        // No registrar accesos si se abre el archivo localmente
        if (window.location.protocol === 'file:') return;
        const isTest = localStorage.getItem("eiel_is_test") === "true";
        const payload = {
            municipio: isTest ?
                "(PRUEBAS) " + "{{ muni_display }}" : "{{ muni_display }}",
            codigo: "{{ muni_code }}",
            fase: "{{ fase_actual }}",
            tipo: window.location.pathname.split("/").pop().split("_")[0].toUpperCase(),
            ua: navigator.userAgent,
            contacto: (isTest ? "[DEVELOPER] " : "") + (localStorage.getItem("eiel_user_name") || "Acceso inicial"),
            departamento: localStorage.getItem("eiel_user_dept") || "N/A",
            email: localStorage.getItem("eiel_user_email") || "N/A" 
        };

        // Envío al Apps Script de Logs si la URL está configurada en Python
        if (window.EIEL_CONFIG && window.EIEL_CONFIG.urlLogger) {
            fetch(window.EIEL_CONFIG.urlLogger, {
                method: 'POST',
                mode: 'no-cors',
                body: JSON.stringify(payload)
            });
        }
    })();
    </script>
</body>
</html>