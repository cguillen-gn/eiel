<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        // 1. CONFIGURACIÓN GLOBAL (Consolidada)
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            // Detectamos el tipo de formulario desde el nombre del archivo para el JS
            tipoFormulario: "{{ request_path.split('/')[-1].split('_')[0] | upper if request_path else '' }}",
            isTest: localStorage.getItem("eiel_is_test") === "true"
        };
    </script>
</head>

{# 2. CLASE DINÁMICA EN EL BODY PARA TEMAS #}
{% set tipo_slug = request_path.split('/')[-1].split('_')[0] | lower if request_path else 'default' %}
<body class="theme-{{ tipo_slug }}">

    <div class="container">
        <header class="main-header">
            <div class="header-content">
                <div class="header-icon-circle">
                    {% block header_icon %}{% endblock %}
                </div>
                <div class="header-text">
                    <span class="fase-badge">Fase {{ fase_actual }}</span>
                    <h1>{% block header_title %}{% endblock %}</h1>
                    <p class="muni-name">{{ muni_display }} ({{ muni_code }})</p>
                </div>
            </div>
            
            <button onclick="window.location.href='index.html'" class="btn-back">
                <i data-lucide="arrow-left"></i>
                <span>Volver al menú</span>
            </button>
        </header>

        <main class="content-wrapper">
            {% block content %}{% endblock %}
        </main>

        <footer class="main-footer">
            <p>&copy; {{ fase_actual }} - Encuesta de Infraestructura y Equipamientos Locales</p>
        </footer>
    </div>

    <div id="progressOverlay" class="overlay hidden">
        <div class="progress-card">
            <div class="spinner"></div>
            <h3 id="progressText">Enviando información...</h3>
            <div class="progress-bar-container">
                <div id="progressBar" class="progress-bar" style="width: 0%"></div>
            </div>
            <p class="progress-note">Por favor, no cierre la ventana hasta finalizar.</p>
        </div>
    </div>

    <script src="js/form-handler.js"></script>
    
    {% block scripts %}{% endblock %}

    {# Lógica del Logger de accesos (se mantiene igual pero al final) #}
    <script>
    (function() {
        if (window.location.protocol === 'file:') return;
        if (window.EIEL_CONFIG && window.EIEL_CONFIG.urlLogger) {
            const payload = {
                municipio: window.EIEL_CONFIG.isTest ? "(PRUEBAS) " + window.EIEL_CONFIG.muniName : window.EIEL_CONFIG.muniName,
                codigo: window.EIEL_CONFIG.muniCode,
                fase: window.EIEL_CONFIG.fase,
                tipo: window.EIEL_CONFIG.tipoFormulario,
                ua: navigator.userAgent,
                contacto: localStorage.getItem("eiel_user_name") || "Acceso inicial"
            };
            fetch(window.EIEL_CONFIG.urlLogger, { method: 'POST', mode: 'no-cors', body: JSON.stringify(payload) });
        }
    })();
    </script>
</body>
</html>