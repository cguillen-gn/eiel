<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% block title %}EIEL - Encuesta de Infraestructuras{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="assets/favicon.ico">
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        // 1. CONFIGURACIÓN GLOBAL
        window.EIEL_CONFIG = {
            muniCode: "{{ muni_code }}",
            muniName: "{{ muni_display }}",
            fase: "{{ fase_actual }}",
            urlLogger: "{{ url_logger }}",
            urlGenerarPdf: "{{ url_generar_pdf }}",
            urlAdjuntos: "{{ url_adjuntos }}",
            // Verifica si existen avisos personalizados para la validación de observaciones
            hasAvisos: {% if avisos_personalizados|length > 0 %}true{% else %}false{% endif %}
        };
        
        // 2. SERVICIO DE PROGRESO (Gestiona la interfaz de envío)
        const UIProgress = {
            get el() { return {
                bar: document.getElementById("progressBar"),
                text: document.getElementById("progressText"),
                percent: document.getElementById("progressValue"),
                container: document.getElementById("overlayProgress"),
                success: document.getElementById("successState"),
                elements: document.getElementById("progressElements")
            }},
            show(total) {
                this.el.container.classList.remove('hidden');
                this.el.success.classList.add('hidden');
                this.el.elements.classList.remove('hidden');
                this.update(0, total, "Iniciando envío...");
            },
            update(completed, total, msg) {
                const perc = total > 0 ? Math.round((completed / total) * 90) : 0; // Hasta 90% por archivos
                this.el.bar.style.width = perc + "%";
                this.el.percent.textContent = perc + "%";
                this.el.text.textContent = msg;
            },
            complete() {
                this.el.bar.style.width = "100%";
                this.el.percent.textContent = "100%";
                this.el.elements.classList.add('hidden');
                this.el.success.classList.remove('hidden');
                if (window.lucide) lucide.createIcons();
            }
        };

        // 3. SERVICIO DE SUBIDA (Motor híbrido para archivos)
        const UploadService = {
            async uploadFiles(tareas, tipo, muni, idBatch, concurrency = 1) {
                for (let i = 0; i < tareas.length; i += concurrency) {
                    const lote = tareas.slice(i, i + concurrency);
                    await Promise.all(lote.map(async (t) => {
                        const base64 = await this._toBase64(t.file);
                        const payload = {
                            filename: t.file.name,
                            mimeType: t.file.type,
                            bytesBase64: base64,
                            municipio: muni,
                            tipo: tipo,
                            seccion: t.seccion || "GENERAL",
                            id_envio: idBatch
                        };
                        await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                            method: 'POST', mode: 'no-cors',
                            body: JSON.stringify(payload)
                        });
                    }));
                    UIProgress.update(i + lote.length, tareas.length, `Subiendo archivos...`);
                }
            },
            _toBase64: file => new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result.split(',')[1]);
                reader.onerror = e => reject(e);
            })
        };

        // 4. FUNCIONES GLOBALES (Accesibles desde el HTML)
        function logout() {
            // Limpia toda la sesión y datos del técnico por seguridad
            localStorage.clear(); 
            window.location.href = "index.html";
        }
        
        // 5. FUNCIÓN DE BLOQUEO DE FORMULARIO
        function toggleFormFreeze(isFrozen) {
            const selectors = 'input, select, textarea, button:not(.btn-logout), .btn-remove, .btn-add';
            const elements = document.querySelectorAll(selectors);
            
            elements.forEach(el => {
                el.disabled = isFrozen;
                // Efecto visual de "congelado"
                el.style.opacity = isFrozen ? "0.6" : "1";
                if (isFrozen) {
                    el.style.pointerEvents = "none"; 
                } else {
                    el.style.pointerEvents = "auto";
                }
            });

            // Ajuste específico para el botón enviar para mantener el cursor de espera
            const btnEnviar = document.getElementById('btnEnviar');
            if (btnEnviar && isFrozen) {
                btnEnviar.style.cursor = "wait";
            } else if (btnEnviar) {
                btnEnviar.style.cursor = "pointer";
            }
        }
        
        // 6. MODAL DE IMAGEN
        window.abrirVisorImagen = (src) => {
            let modal = document.getElementById('visorImagenGlobal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'visorImagenGlobal';
                modal.className = 'modal-img';
                modal.innerHTML = `<img src="" id="imgVisor">`;
                modal.onclick = () => modal.style.display = 'none';
                document.body.appendChild(modal);
            }
            modal.querySelector('img').src = src;
            modal.style.display = 'flex';
        };
        
    </script>
   
    
</head>
<body class="theme-{{ ficha_tipo|default('default') }}">
    <header class="site-header">
        <div class="header-content">
            <div class="logo-area">
                <h1>EIEL</h1>
                <span class="badge-fase">
                    {% block bloque_fase %}Fase --{% endblock %}
                </span>
            </div>
        
            <div class="user-area">
                <span id="headerMuniName" class="user-email">...</span>
                <button onclick="logout()" class="btn-logout">Salir</button>
            </div>
        </div>
    </header>

    <nav class="breadcrumb-nav">
        <div class="container">
            <a href="index.html" class="back-link">
                ⭠ Volver al listado de formularios
            </a>
        </div>
    </nav>

    <main class="main-container">
        <div class="form-header">
            <div class="icon-header">
                {% block header_icon %}??{% endblock %}
            </div>
            <div class="title-header">
                <h2>{% block header_title %}Formulario{% endblock %}</h2>
                <p class="subtitle">{{ muni_display }} (Código: {{ muni_code }})</p>
            </div>
        </div>

        {% block content %}
        {% endblock %}
    </main>

    <footer class="site-footer">
        <p>Diputación de Alicante - Encuesta de Infraestructura y Equipamientos Locales</p>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // A. VALIDACIÓN DE SESIÓN DEL MUNICIPIO
            const muniCode = localStorage.getItem("eiel_muni_code");
            const muniName = localStorage.getItem("eiel_muni_name");

            if (!muniCode) {
                console.warn("Acceso no autorizado. Redirigiendo al login...");
                window.location.href = "index.html";
                return;
            }

            // Actualizamos el nombre del municipio en la cabecera
            const headerName = document.getElementById("headerMuniName");
            if(headerName) headerName.textContent = muniName || "Municipio";

            // B. AUTOCOMPLETADO Y PERSISTENCIA PROACTIVA
            const fieldsMap = {
                "contactoNombre": "eiel_user_name",
                "contactoEmail": "eiel_user_email",
                "contactoDepartamento": "eiel_user_dept"
            };

            // 1. Rellenar campos si ya existen datos guardados
            Object.keys(fieldsMap).forEach(id => {
                const savedValue = localStorage.getItem(fieldsMap[id]);
                const inputEl = document.getElementById(id);
                
                if (savedValue && inputEl) {
                    inputEl.value = savedValue;
                    // Caso especial: Sincronizar campo de confirmación de email
                    if (id === "contactoEmail") {
                        const confirmEl = document.getElementById("contactoEmailConfirm");
                        if (confirmEl) confirmEl.value = savedValue;
                    }
                }
            });

            // 2. Guardar datos en tiempo real mientras el técnico escribe (Escucha Activa)
            Object.keys(fieldsMap).forEach(id => {
                const inputEl = document.getElementById(id);
                if (inputEl) {
                    inputEl.addEventListener('input', (e) => {
                        localStorage.setItem(fieldsMap[id], e.target.value.trim());
                    });
                }
            });
        });
    </script>
    
    <div id="overlayProgress" class="overlay hidden">
        <div class="progress-card">
            <h3 id="progressTitle" style="margin-bottom: 10px; font-weight: 700; color: #1e293b;">Enviando datos...</h3>
            
            <div id="progressElements">
                <div class="progress-bar-container">
                    <div id="progressBar" class="progress-bar" style="width: 0%; height: 100%; background-color: #10b981; transition: width 0.3s ease;"></div>
                </div>
                <div class="progress-info">
                    <span id="progressText">Iniciando...</span>
                    <span id="progressValue">0%</span>
                </div>
                <p id="pacienciaNota" style="margin-top:20px; font-size:0.85em; color:#64748b; font-style:italic; line-height:1.4; text-align: center; border-top: 1px solid #f1f5f9; padding-top: 15px;">
                    ⌛ <b>Nota:</b> Este proceso puede tardar <b>varios minutos</b> debido al volumen de información y la generación del certificado oficial. Por favor, <b>no cierre ni refresque la pestaña.</b>
                </p>
            </div>

            <div id="successState" class="hidden" style="margin-top: 20px;">
                <div style="color: #10b981; font-size: 3rem; margin-bottom: 15px;">
                    <i data-lucide="check-circle-2" style="width: 60px; height: 60px; margin: 0 auto;"></i>
                </div>
                <p style="color: #475569; font-weight: 500; line-height: 1.6; margin-bottom: 25px;">
                    ¡El envío se ha realizado correctamente!<br>
                    <span style="color: #1e293b; font-weight: 700;">Se ha enviado un justificante en formato PDF al correo electrónico facilitado.</span>
                </p>
                <a href="index.html" class="btn-primary" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none; justify-content: center; width: 100%;">
                    <i data-lucide="home" style="width: 18px;"></i>
                    Volver al Listado de Formularios
                </a>
            </div>
        </div>
    </div>

    {% block scripts %}
    {# Aquí se insertarán los scripts específicos de cada formulario #}
    {% endblock %}

    {# --- SCRIPT DEL LOGGER SILENCIOSO (RASTREO DE ACCESOS) --- #}
    <script>
    (function() {
        // No registrar accesos si se abre el archivo localmente
        if (window.location.protocol === 'file:') return;

        const payload = {
            municipio: "{{ muni_display }}",
            codigo: "{{ muni_code }}",
            fase: "{{ fase_actual }}",
            tipo: window.location.pathname.split("/").pop().split("_")[0].toUpperCase(),
            ua: navigator.userAgent,
            contacto: localStorage.getItem("eiel_user_name") || "Acceso inicial (Técnico de " + (localStorage.getItem("eiel_muni_name") || "N/A") + ")",
            departamento: localStorage.getItem("eiel_user_dept") || "N/A",
            email: localStorage.getItem("eiel_user_email") || "N/A" 
        };

        // Envío al Apps Script de Logs si la URL está configurada en Python
        if (window.EIEL_CONFIG && window.EIEL_CONFIG.urlLogger) {
            fetch(window.EIEL_CONFIG.urlLogger, {
                method: 'POST',
                mode: 'no-cors',
                body: JSON.stringify(payload)
            });
        }
    })();
    </script>
</body>
</html>