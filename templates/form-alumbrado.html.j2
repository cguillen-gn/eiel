{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'alumbrado' %}

{% block title %}EIEL - Alumbrado Público{% endblock %}
{% block header_icon %}<i data-lucide="lightbulb"></i>{% endblock %}
{% block header_title %}ALUMBRADO PÚBLICO{% endblock %}

{% block content %}
<form id="formAlumbrado">
    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li>Rellene los datos requeridos y justifique cualquier dato que no disponga en <strong>Observaciones</strong>.</li>
        </ul>
    </div>

    {# 3. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Información solicitada</h2>
        <p class="form-help form-help-spacer">Se han detectado incidencias que requieren solución. Responda a cada punto.</p>
        
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}
                    <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm">
                        <i data-lucide="map"></i> Mapa
                    </a>
                    {% endif %}
                </div>
                
                {# Contenedor de Respuesta con ancho 100% #}
                <div style="margin-left: 28px; background: #f8fafc; padding: 16px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" 
                              placeholder="Responda o aclare este punto aquí..." 
                              style="width: 100%; box-sizing: border-box; display: block; margin-bottom: 12px; background: white;"></textarea>
                    
                    <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntosReq('{{ req_id }}')">
                        <i data-lucide="paperclip"></i> Adjuntar
                    </button>
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 4. COMPONENTES GLOBALES (Macros) #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
{% endblock %}

{% block scripts %}
<script>
// Gestión de archivos acumulados
let archivosGenerales = [];
let colaAdjuntosReq = {};
let reqIdActual = null;

document.addEventListener("DOMContentLoaded", () => {
    // A. Captura de archivos generales (Drag and Drop / Input)
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosGenerales = [...archivosGenerales, ...Array.from(fileInput.files)];
            renderArchivos();
            fileInput.value = ""; 
        });
    }

    // B. Gestión de adjuntos para Requerimientos
    const inputReq = document.getElementById('hiddenInputReq');
    window.gestionarAdjuntosReq = (id) => { reqIdActual = id; if(inputReq) inputReq.click(); };

    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            const files = Array.from(inputReq.files);
            colaAdjuntosReq[reqIdActual] = [...(colaAdjuntosReq[reqIdActual] || []), ...files];
            renderColaReq(reqIdActual);
            inputReq.value = "";
        });
    }

    // C. Lógica de Envío
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) {
        checkConf.addEventListener('change', function() {
            btnEnviar.disabled = !this.checked;
        });
    }

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "ALUMBRADO_" + Date.now();
        
        // Validación de contacto básica
        if (document.getElementById("contactoEmail").value !== document.getElementById("contactoEmailConfirm").value) {
            return Swal.fire("Error", "Los emails de contacto no coinciden.", "error");
        }

        toggleFormFreeze(true);

        // Preparar lista de subida unificada
        const listaTareas = [];
        archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
        Object.entries(colaAdjuntosReq).forEach(([id, list]) => {
            list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${parseInt(id)+1}` }));
        });

        UIProgress.show(listaTareas.length);

        try {
            // Subida secuencial mediante el motor de la base
            await UploadService.uploadFiles(listaTareas, 'ALUMBRADO', window.EIEL_CONFIG.muniCode, idBatch, 1);

            UIProgress.update(listaTareas.length, listaTareas.length, "Generando justificante...");

            // Payload para el servidor
            const payload = {
                tipo_formulario: "alumbrado",
                fase: window.EIEL_CONFIG.fase,
                id_envio: idBatch,
                observaciones: document.getElementById("observaciones").value.trim(),
                nombre_contacto: document.getElementById("contactoNombre").value.trim(),
                departamento_contacto: document.getElementById("contactoDepartamento").value.trim(),
                email_contacto: document.getElementById("contactoEmail").value.trim(),
                municipio_codigo: window.EIEL_CONFIG.muniCode,
                municipio_nombre: window.EIEL_CONFIG.muniName,
                timestamp_envio: new Date().toISOString(),
                archivos_adjuntos: listaTareas.map(t => t.file.name).join("\n"), 
                respuestas_requerimientos_json: JSON.stringify(Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                    pregunta: area.dataset.msg, 
                    respuesta: area.value.trim()
                })))
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();

        } catch (error) {
            console.error(error);
            toggleFormFreeze(false);
            Swal.fire("Error", "Fallo al procesar el envío de alumbrado.", "error");
        }
    });
});

// Función para listar archivos generales
function renderArchivos() {
    const fileList = document.getElementById("fileList");
    if (!fileList) return;
    fileList.innerHTML = archivosGenerales.map((f, i) => `
        <div class="file-item">
            <span>📄 ${f.name}</span>
            <button type="button" onclick="archivosGenerales.splice(${i},1); renderArchivos();" class="btn-danger-icon">
                <i data-lucide="trash-2"></i>
            </button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}

// Función para listar archivos de requerimientos
function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => `
        <div class="file-item" style="margin-bottom: 4px; padding: 4px 8px; background: #fdfdfd; border: 1px solid #e2e8f0; border-radius: 6px; display: flex; align-items: center; justify-content: space-between;">
            <span style="font-size: 0.75rem; display: flex; align-items: center; gap: 4px;">
                <i data-lucide="paperclip" style="width:12px;"></i> ${f.name}
            </span>
            <button type="button" onclick="colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}');" class="btn-danger-icon">
                <i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i>
            </button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}
</script>
{% endblock %}