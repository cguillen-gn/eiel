{% extends "base.html.j2" %}

{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block title %}EIEL - Alumbrado Público{% endblock %}
{% block header_icon %}<i data-lucide="lightbulb"></i>{% endblock %}
{% block header_title %}ALUMBRADO PÚBLICO{% endblock %}

{% block content %}

{# --- SECCIÓN: INSTRUCCIONES --- #}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul>
        <li>
            Rellene los datos requeridos y justifique cualquier dato que no disponga o no pueda aportar en el apartado de <strong>Observaciones</strong>.
        </li>
    </ul>
</div>

{# --- SECCIÓN: REQUERIMIENTOS --- #}
{% if avisos_personalizados and avisos_personalizados|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h2 class="section-title">
            <i data-lucide="circle-plus"></i> Información solicitada
        </h2>
        
        <p class="form-help" style="margin-bottom: 1.5rem;">
            Se ha detectado falta de información o incidencias en la EIEL que requieren solución. Responda a cada punto y adjunte documentación si es necesario.
        </p>

        <ul class="requerimientos-list" style="list-style: none; padding: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; align-items: stretch; gap: 10px; padding: 15px; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; color: var(--text-primary); font-size: 0.95rem;">{{ aviso.mensaje }}</span>
                    </div>
                    
                    {% if aviso.url %}
                        {% set final_url = aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url %}
                        <a href="{{ final_url }}" target="_blank" class="btn btn-secondary btn-sm" style="display: flex; align-items: center; gap: 5px; text-decoration: none; background: white; border: 1px solid #cbd5e1;">
                            <i data-lucide="map" style="width: 14px; height: 14px;"></i> Mapa
                        </a>
                    {% endif %}
                </div>
                
                <div style="margin-left: 25px; background: #f8fafc; padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0;">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="2" 
                              placeholder="Responda o aclare este punto aquí..." style="font-size: 0.85rem; margin-bottom: 8px;"></textarea>
                    
                    <div style="display: flex; flex-direction: column; align-items: flex-start; gap: 10px;">
                        <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntosReq('{{ req_id }}')" style="background: white; width: auto;">
                            <i data-lucide="paperclip" style="width: 14px;"></i> Adjuntar
                        </button>
                        <div style="font-size: 0.65rem; color: #94a3b8; margin-top: 2px; white-space: nowrap; font-weight: 500;">
                            Máx 35 MB / archivo
                        </div>
                        {# Cambiamos a flex-direction: column para que apilen en vertical #}
                        <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin: 0; display: flex; flex-direction: column; gap: 4px; width: 100%;"></div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
</div>
{% endif %}

{# --- SECCIÓN: OBSERVACIONES --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" placeholder="Indique aquí cualquier incidencia, aclaración o dato relevante..."></textarea>
    </div>
</div>

{# --- SECCIÓN: ADJUNTOS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="folder"></i>Documentación Adjunta (Opcional)</h2>
    <div class="file-upload-area" onclick="document.getElementById('fileInput').click()">
        <div class="upload-icon">
            <i data-lucide="upload-cloud" style="width: 40px; height: 40px; margin-bottom: 10px; opacity: 0.7;"></i>
        </div>
        <div style="font-weight: 700; font-size: 1.05rem; color: var(--text-primary);">
            Arrastra y suelta archivos aquí
        </div>
        <div style="font-size: 0.9rem; color: var(--text-secondary); margin: 5px 0;">
            o <span style="text-decoration: underline; color: var(--primary); cursor: pointer;">haz clic para buscarlos</span>
        </div>
        <p class="upload-help" style="margin-top: 8px;">(Planos, fotos, informes, análisis... Máx 35 MB / archivo)</p>
        <input type="file" id="fileInput" multiple style="display: none;">
    </div>
    <div id="fileList" class="file-list-container"></div>
</div>

{# --- SECCIÓN: DATOS DE CONTACTO --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required>
        </div>
       <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;">
            </div>
    </div>
</div>

{# --- SECCIÓN: DECLARACIÓN RESPONSABLE --- #}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text">
                <strong>Declaración de veracidad:</strong> Como responsable, 
                confirmo que los datos introducidos son correctos y actualizados.
            </span>
        </label>
    </div>
    
{# --- SECCIÓN: ENVÍO --- #}
    <div id="mensaje" class="message hidden"></div>
    
    <button id="btnEnviar" class="btn btn-primary" disabled>
        Enviar Datos
    </button>
</div>

{% endblock %}

{% block scripts %}
<script>
document.addEventListener("DOMContentLoaded", () => {
    
    // 0. ACTIVADOR DE TEMA
    document.body.classList.add('theme-alumbrado');
    
    // Ejecuta la creación de iconos de Lucide
    if (window.lucide) {
        lucide.createIcons();
    }
    
    // 1. SETUP DE ESTILOS
    const header = document.querySelector('.site-header');
    if(header) header.classList.add('header-alumbrado');

    // 2. CONFIGURACIÓN GLOBAL
    window.EIEL_CONFIG = {
        muniCode: "{{ muni_code }}",
        muniName: "{{ muni_display }}",
        fase: "{{ fase_actual }}",
        urlGenerarPdf: "{{ url_generar_pdf }}",
        urlAdjuntos: "{{ url_adjuntos }}",
        urlLogger: "{{ url_logger }}",
        hasAvisos: {{ 'true' if avisos_personalizados and avisos_personalizados|length > 0 else 'false' }},
        yearActual: new Date().getFullYear() 
    };

    // 3. INICIALIZACIÓN UI
    
    // 4. SERVICIOS Y UTILIDADES DE UI
    const UIProgress = {
        container: document.getElementById("overlayProgress"), 
        bar: document.getElementById("progressBar"),
        text: document.getElementById("progressText"),
        percent: document.getElementById("progressValue"), 
        maxReached: 0, 

        show(totalTasks) {
            this.maxReached = 0;
            const title = document.getElementById("progressTitle");
            if (title) title.textContent = "Enviando datos...";
            
            const elements = document.getElementById("progressElements");
            if (elements) elements.classList.remove('hidden');
            
            const success = document.getElementById("successState");
            if (success) success.classList.add('hidden');

            if (this.container) this.container.classList.remove('hidden');
            this.update(0, totalTasks, "Iniciando el envío...");
        },

        update(completed, total, message) {
            const msg = message.toLowerCase();
            const isFinalStep = msg.includes("pdf") || msg.includes("registro") || msg.includes("justificante");
            
            let targetPercentage = 0;
            if (total > 0) {
                const fileWeight = 90 / total;
                targetPercentage = isFinalStep ? 95 : Math.round(completed * fileWeight);
            } else {
                targetPercentage = isFinalStep ? 95 : 0;
            }

            if (targetPercentage > this.maxReached) {
                this.maxReached = targetPercentage;
                if (this.bar) this.bar.style.width = this.maxReached + "%";
                if (this.percent) this.percent.textContent = this.maxReached + "%";
            }
            if (this.text && message) this.text.textContent = message;
        },

        complete() {
            const title = document.getElementById("progressTitle");
            if (title) title.textContent = "¡Envío Finalizado!";
            
            const elements = document.getElementById("progressElements");
            if (elements) elements.classList.add('hidden');
            
            const success = document.getElementById("successState");
            if (success) success.classList.remove('hidden');
            
            if (window.lucide) lucide.createIcons();
        }
    };

    const UploadService = {
        toBase64: file => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        }),

        async uploadFile(file, tipoFicha, muniCode, seccion = "DOCUMENTACION", idEnvio) {
            try {
                const base64 = await this.toBase64(file);
                const userEmail = document.getElementById("contactoEmail").value || "anonimo";
                const payload = {
                    filename: file.name,
                    mimeType: file.type,
                    bytesBase64: base64, 
                    municipio: muniCode,
                    usuario: userEmail,
                    tipo: tipoFicha,
                    seccion: seccion,
                    id_envio: idEnvio
                };
                await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                    method: 'POST', mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                return true;
            } catch (e) { return false; }
        }
    };

    // 5. GESTIÓN DE ARCHIVOS Y ADJUNTOS
    let archivos = [];
    const fileInput = document.getElementById("fileInput");
    const fileList = document.getElementById("fileList");

    if (fileInput) {
        fileInput.onchange = () => {
            const files = Array.from(fileInput.files);
            const LIMITE_BYTES = 35 * 1024 * 1024;

            const validos = files.filter(f => {
                if (f.size > LIMITE_BYTES) {
                    alert(`El archivo "${f.name}" supera el límite de 35 MB y no será añadido.`);
                    return false;
                }
                return true;
            });

            archivos.push(...validos);
            renderArchivos();
            fileInput.value = '';
        };
    }
    
    // --- LÓGICA DRAG & DROP ---
    const dropZone = document.querySelector('.file-upload-area');
    if (dropZone) {
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(name => {
            dropZone.addEventListener(name, e => { e.preventDefault(); e.stopPropagation(); });
        });
        ['dragenter', 'dragover'].forEach(name => {
            dropZone.addEventListener(name, () => dropZone.classList.add('drag-over'));
        });
        ['dragleave', 'drop'].forEach(name => {
            dropZone.addEventListener(name, () => dropZone.classList.remove('drag-over'));
        });
        dropZone.addEventListener('drop', e => {
            const files = Array.from(e.dataTransfer.files);
            if (files.length > 0) {
                archivos.push(...files);
                renderArchivos();
            }
        });
    }

    window.eliminarArchivo = (i) => {
        archivos.splice(i, 1);
        renderArchivos();
    };
    
    function renderArchivos() {
        if (!fileList) return;
        if (archivos.length === 0) {
            fileList.innerHTML = '';
            return;
        }
        fileList.innerHTML = archivos.map((f, i) => `
            <div class="file-item">
                <span>📄 ${f.name}</span>
                <button type="button" onclick="eliminarArchivo(${i})" class="btn-danger-icon">
                    <i data-lucide="trash-2" style="width:18px;"></i>
                </button>
            </div>
        `).join("");

        if (window.lucide) lucide.createIcons();
    }

    // 6. LÓGICA DE ENVÍO Y VALIDACIÓN
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConformidad = document.getElementById("checkConformidad");
    const mensajeDiv = document.getElementById("mensaje");

    function mostrarMensaje(texto, tipo) {
        if (!mensajeDiv) return;
        mensajeDiv.textContent = texto;
        mensajeDiv.className = `message ${tipo}`;
        mensajeDiv.classList.remove('hidden');
        mensajeDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    let colaAdjuntosReq = {};
    let reqIdActual = null;
    const inputReq = document.getElementById('hiddenInputReq');

    window.gestionarAdjuntosReq = (id) => {
        reqIdActual = id;
        inputReq.click();
    };

    if (inputReq) {
        inputReq.addEventListener('change', () => {
            const files = Array.from(inputReq.files);
            if (!files.length || reqIdActual === null) return;

            const LIMITE_BYTES = 35 * 1024 * 1024;
            const validos = files.filter(f => {
                if (f.size > LIMITE_BYTES) {
                    alert(`El archivo "${f.name}" supera el límite de 35 MB y no será añadido.`);
                    return false;
                }
                return true;
            });

            if (validos.length > 0) {
                if (!colaAdjuntosReq[reqIdActual]) colaAdjuntosReq[reqIdActual] = [];
                colaAdjuntosReq[reqIdActual].push(...validos);
                renderColaReq(reqIdActual);
            }

            inputReq.value = ""; reqIdActual = null;
        });
    }

    function renderColaReq(id) {
        const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
        if (!contenedor) return;
        const archivosReq = colaAdjuntosReq[id] || [];
        contenedor.innerHTML = archivosReq.map((f, i) => `
            <div class="file-item" style="margin-bottom: 4px; padding: 4px 8px; background: #fdfdfd; border: 1px solid #e2e8f0; justify-content: space-between; border-radius: 6px; display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 0.75rem; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: flex; align-items: center; gap: 4px;" title="${f.name}">
                    <i data-lucide="paperclip" style="width:12px; height:12px; color: #64748b;"></i> ${f.name}
                </span>
                <button type="button" onclick="eliminarArchivoReq('${id}', ${i})" class="btn-danger-icon" style="padding: 2px; background: transparent; border: none; cursor: pointer;">
                    <i data-lucide="trash-2" style="width:16px; height:16px; color: #ef4444;"></i>
                </button>
            </div>
        `).join("");
        if (window.lucide) lucide.createIcons();
    }

    window.eliminarArchivoReq = (id, i) => {
        colaAdjuntosReq[id].splice(i, 1);
        renderColaReq(id);
    };

    if (checkConformidad && btnEnviar) {
        checkConformidad.addEventListener('change', function() {
            btnEnviar.disabled = !this.checked;
        });
    }

    if (btnEnviar) {
        btnEnviar.addEventListener("click", async () => {
            const idBatch = "ENVIO_" + new Date().getTime();
            if (mensajeDiv) mensajeDiv.classList.add('hidden'); 

            // --- A. VALIDACIÓN DE CONTACTO ---
            const nombre = document.getElementById("contactoNombre").value.trim();
            const email = document.getElementById("contactoEmail").value.trim();
            const emailConf = document.getElementById("contactoEmailConfirm").value.trim();
            const regexEmail = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

            if (nombre.length < 2) {
                mostrarMensaje("⚠️ Por favor, introduzca su nombre y apellidos.", "error");
                return;
            }
            if (!regexEmail.test(email) || email.toLowerCase() !== emailConf.toLowerCase()) {
                mostrarMensaje("⚠️ Verifique que el Email sea válido y coincida en ambos campos.", "error");
                return;
            }
            
            // --- B. VALIDACIÓN FINAL DE PESO DE ARCHIVOS ---
            const LIMITE_BYTES = 35 * 1024 * 1024;
            const todosLosArchivos = [
                ...archivos,
                ...Object.values(colaAdjuntosReq).flat()
            ];

            const archivoExcedido = todosLosArchivos.find(f => f.size > LIMITE_BYTES);
            if (archivoExcedido) {
                mostrarMensaje(`⚠️ El archivo "${archivoExcedido.name}" excede los 35 MB permitidos. Por favor, optimícelo antes de enviar.`, "error");
                return;
            }

            // --- C. VALIDACIÓN 1 A 1 DE REQUERIMIENTOS ---
            const areasReq = document.querySelectorAll('.txt-resp-req');
            let reqIncompletos = false;
            const respuestasReq = [];

            areasReq.forEach(area => {
                const id = area.dataset.id;
                const resp = area.value.trim();
                const adjuntos = colaAdjuntosReq[id] || [];
                
                if (resp === "" && adjuntos.length === 0) {
                    reqIncompletos = true;
                } else {
                    respuestasReq.push({ 
                        pregunta: area.dataset.msg, 
                        respuesta: resp, 
                        archivos: adjuntos.map(f => f.name).join("; ") 
                    });
                }
            });

            if (reqIncompletos) {
                mostrarMensaje("⚠️ Debe dar una respuesta individualizada (texto o adjunto) a cada uno de los requerimientos.", "error");
                return;
            }

            // --- D. PROCESO DE ENVÍO Y SUBIDA ---
            toggleFormFreeze(true);
            const numReqFiles = Object.values(colaAdjuntosReq).flat().length;
            const numGenerales = archivos.length;
            const totalTareas = numReqFiles + numGenerales;
            
            // 1. Iniciamos el progreso global
            UIProgress.show(totalTareas);
            UIProgress.update(0, totalTareas, "Iniciando el envío...");
            
            let completados = 0;

            try {
                // Unificamos tareas
                const listaTareas = [];
                Object.entries(colaAdjuntosReq).forEach(([id, listado]) => {
                    const numReq = parseInt(id) + 1;
                    listado.forEach(file => listaTareas.push({ file, seccion: `REQUERIMIENTO_${numReq}` }));
                });
                archivos.forEach(file => listaTareas.push({ file, seccion: 'GENERAL' }));

                // 2. Subida Secuencial (Uno a uno) manteniendo tu lógica original
                for (const tarea of listaTareas) {
                    try {
                        // Actualización del mensaje con contador dinámico "Subido X de Y"
                        UIProgress.update(
                            completados, 
                            totalTareas, 
                            `Subiendo archivos adjuntos (Subido ${completados} de ${totalTareas} archivos)...`
                        );

                        await UploadService.uploadFile(tarea.file, 'alumbrado', window.EIEL_CONFIG.muniCode, tarea.seccion, idBatch);
                        completados++;
                        
                        // Pausa de estabilidad
                        await new Promise(r => setTimeout(r, 300));
                    } catch (e) {
                        console.error("Fallo en subida individual:", e);
                    }
                }

                // 3. Fase final: Registro y Justificante PDF
                UIProgress.update(completados, totalTareas, "Procesando datos y generando justificante...");

                const nombresTodosAdjuntos = listaTareas.map(t => t.file.name).join("\n");

                const payload = {
                    tipo_formulario: "alumbrado",
                    fase: window.EIEL_CONFIG.fase,
                    id_envio: idBatch,
                    observaciones: document.getElementById("observaciones").value.trim(),
                    nombre_contacto: nombre,
                    departamento_contacto: document.getElementById("contactoDepartamento").value.trim(),
                    email_contacto: email,
                    municipio_codigo: window.EIEL_CONFIG.muniCode,
                    municipio_nombre: window.EIEL_CONFIG.muniName,
                    timestamp_envio: new Date().toISOString(),
                    archivos_adjuntos: nombresTodosAdjuntos, // Lista unificada completa
                    respuestas_requerimientos_json: JSON.stringify(respuestasReq)
                };

                await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                    method: "POST", mode: "no-cors",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                // Finaliza y muestra la pantalla de éxito con el botón de volver
                UIProgress.complete();
                
                // Limpieza de campos y variables (Sin cambios)
                archivos = []; colaAdjuntosReq = {}; renderArchivos(); 
                document.querySelectorAll(".file-list-container").forEach(el => el.innerHTML = "");
                document.querySelectorAll("input, select, textarea").forEach(el => {
                   if (!['button', 'submit', 'checkbox'].includes(el.type)) el.value = '';
                   if (el.tagName === 'SELECT') el.selectedIndex = 0;
                });
                if (checkConformidad) checkConformidad.checked = false;
                btnEnviar.disabled = true;

            } catch (error) {
                console.error(error);
                mostrarMensaje(`❌ Error: ${error.message}`, "error");
                toggleFormFreeze(false);
            }
        });
    }
});
</script>
{% endblock %}