{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Alumbrado Público{% endblock %}
{% block tipo_ficha %}alumbrado{% endblock %}
{% block body_class %}alumbrado{% endblock %}
{% block header_icon %}<i data-lucide="lightbulb"></i>{% endblock %}
{% block header_title %}ALUMBRADO PÚBLICO{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones() }}

    {# --- SECCIÓN: PUNTOS DE LUZ --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="lamp"></i>Puntos de Luz</h2>
        <div class="card-body">
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Nº Total de Puntos de Luz:</label>
                    <input type="number" class="form-input" name="total_puntos_luz">
                </div>
                <div class="form-group">
                    <label class="form-label">% de Tecnología LED:</label>
                    <input type="number" min="0" max="100" class="form-input" name="porcentaje_led" placeholder="0-100">
                </div>
            </div>
        </div>
    </div>

    {# --- SECCIÓN: CENTROS DE MANDO --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="settings"></i>Centros de Mando</h2>
        <div class="card-body">
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Nº de Centros de Mando:</label>
                    <input type="number" class="form-input" name="num_centros_mando">
                </div>
                <div class="form-group">
                    <label class="form-label">% con Telegestión:</label>
                    <input type="number" min="0" max="100" class="form-input" name="porcentaje_telegestion">
                </div>
            </div>
        </div>
    </div>

    {# --- SECCIÓN: CONSUMO --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="zap"></i>Consumo Energético</h2>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label">Consumo anual estimado (kWh/año):</label>
                <input type="number" class="form-input" name="consumo_anual_kwh">
            </div>
        </div>
    </div>

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');
    
    document.getElementById('contacto_nombre').value = localStorage.getItem("eiel_user_name") || "";
    document.getElementById('contacto_depto').value = localStorage.getItem("eiel_user_dept") || "";
    document.getElementById('contacto_email').value = localStorage.getItem("eiel_user_email") || "";

    if(checkConf) checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            const formData = new FormData(document.getElementById('mainForm'));
            return Object.fromEntries(formData.entries());
        });
    };
});
</script>
{% endblock %}