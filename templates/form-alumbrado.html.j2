{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'alumbrado' %}

{% block title %}EIEL - Alumbrado Público{% endblock %}
{% block header_icon %}<i data-lucide="lightbulb"></i>{% endblock %}
{% block header_title %}ALUMBRADO PÚBLICO{% endblock %}

{% block content %}
<form id="formAlumbrado">
    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li>Rellene los datos requeridos y justifique cualquier dato que no disponga o no pueda aportar en el apartado de <strong>Observaciones</strong>.</li>
        </ul>
    </div>

    {# 3. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Información solicitada</h2>
        <p class="form-help form-help-spacer">Responda a cada punto y adjunte documentación si es necesario.</p>
        
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = aviso.id %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}
                    <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm">
                        <i data-lucide="map"></i> Mapa
                    </a>
                    {% endif %}
                </div>
                
                <div style="margin-left: 28px; background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0; box-sizing: border-box; width: calc(100% - 28px);">
                    <textarea id="req_{{ req_id }}" class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" 
                          placeholder="Responda o aclare este punto aquí..." 
                          style="width: 100% !important; max-width: 100%; box-sizing: border-box; display: block; margin-bottom: 15px; border: 1px solid #cbd5e1;"></textarea>
                    
                    <button type="button" class="btn btn-secondary btn-sm" onclick="window.gestionarAdjuntosReq('{{ req_id }}')">
                        <i data-lucide="paperclip"></i> Adjuntar
                    </button>
                    {{ ui.ayuda_archivo() }}
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 4. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>

{% endblock %}

{% block scripts %}
<script>
// Variables locales para la gestión de archivos
let archivosGenerales = [];
let colaAdjuntosReq = {};
let reqIdActual = null;

document.addEventListener("DOMContentLoaded", async () => {
    // --- A. Gestión de adjuntos generales ---
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosGenerales = [...archivosGenerales, ...Array.from(fileInput.files)];
            renderArchivos();
            marcarComoSucio(); // Activa el botón de guardado manual
            fileInput.value = ""; 
        });
    }

    // --- B. Gestión de adjuntos para Requerimientos ---
    const inputReq = document.getElementById('hiddenInputReq');
    window.gestionarAdjuntosReq = (id) => { 
        reqIdActual = id; 
        if(inputReq) inputReq.click(); 
    };

    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (reqIdActual === null) return;
            colaAdjuntosReq[reqIdActual] = [...(colaAdjuntosReq[reqIdActual] || []), ...Array.from(inputReq.files)];
            renderColaReq(reqIdActual);
            marcarComoSucio(); // Activa el botón de guardado manual
            inputReq.value = "";
        });
    }

    // --- C. INICIALIZACIÓN DEL SISTEMA DE BORRADORES ---
    // Funciones heredadas de base.html.j2
    activarDetectorCambios(); 
    verificarBorradoresExistentes();

    // --- D. LÓGICA DE ENVÍO FINAL ---
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    
    if (checkConf && btnEnviar) {
        checkConf.addEventListener('change', () => {
            btnEnviar.disabled = !checkConf.checked;
        });
    }

    if (btnEnviar) {
        btnEnviar.addEventListener("click", async () => {
            const idBatch = "ALUMBRADO_" + Date.now();
            const email = document.getElementById("contactoEmail").value;
            const emailConfirm = document.getElementById("contactoEmailConfirm").value;
            
            if (email !== emailConfirm) {
                return Swal.fire("Error", "Los emails de contacto no coinciden.", "error");
            }

            toggleFormFreeze(true);

            const listaTareas = [];
            archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
            Object.entries(colaAdjuntosReq).forEach(([id, list]) => {
                // Usamos el ID tal cual, ya que es la "llave" única de la base de datos
                list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${id}` }));
            });

            UIProgress.show(listaTareas.length);

            try {
                await UploadService.uploadFiles(listaTareas, 'ALUMBRADO', window.EIEL_CONFIG.muniCode, idBatch, 1);
                UIProgress.update(listaTareas.length, listaTareas.length, "Generando justificante...");

                const payload = {
                    tipo_formulario: "alumbrado",
                    id_envio: idBatch,
                    id_borrador_procedencia: idBorradorOrigen,
                    municipio: window.EIEL_CONFIG.muniCode,
                    observaciones: document.getElementById("observaciones").value,
                    requerimientos: Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                        pregunta: area.dataset.msg, 
                        respuesta: area.value
                    })),
                    contacto: {
                        nombre: document.getElementById("contactoNombre").value,
                        email: email
                    }
                };

                await fetch(window.EIEL_CONFIG.urlGenerarPdf, { 
                    method: "POST", 
                    mode: "no-cors", 
                    body: JSON.stringify(payload) 
                });
                
                // --- LIMPIEZA FINAL ---
                formIsDirty = false; // Desactiva el aviso de salida al finalizar
                UIProgress.complete();
            } catch (error) {
                console.error(error);
                toggleFormFreeze(false);
                Swal.fire("Error", "Fallo al procesar el envío. Por favor, reintente.", "error");
            }
        });
    }
});

// --- E. FUNCIONES DE RENDERIZADO ---

function renderArchivos() {
    const fileList = document.getElementById("fileList");
    if (!fileList) return;
    fileList.innerHTML = archivosGenerales.map((f, i) => {
        // Detectar si el archivo viene de la nube (borrador) o es local
        const isCloud = f.status === 'cloud';
        return `
        <div class="file-item" style="${isCloud ? 'border-left: 3px solid #10b981; background: #f0fdf4;' : ''}">
            <span>${isCloud ? '☁️' : '📄'} ${f.name}</span>
            <button type="button" onclick="archivosGenerales.splice(${i},1); renderArchivos(); marcarComoSucio();" class="btn-danger-icon">
                <i data-lucide="trash-2"></i>
            </button>
        </div>`;
    }).join("");
    if (window.lucide) lucide.createIcons();
}

function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => {
        const isCloud = f.status === 'cloud';
        return `
        <div class="file-item" style="margin-bottom:4px; padding:4px 8px; border-radius:6px; display:flex; justify-content:space-between; align-items:center; ${isCloud ? 'border: 1px solid #10b981; background: #f0fdf4;' : 'background:#fdfdfd; border:1px solid #e2e8f0;'}">
            <span style="font-size:0.75rem;">${isCloud ? '☁️' : '📎'} ${f.name.substring(0,20)}...</span>
            <button type="button" onclick="colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}'); marcarComoSucio();" class="btn-danger-icon">
                <i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i>
            </button>
        </div>`;
    }).join("");
    if (window.lucide) lucide.createIcons();
}
</script>
{% endblock %}