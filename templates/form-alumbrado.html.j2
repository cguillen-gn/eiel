{% extends "base.html.j2" %}
{% import "macros.html.j2" as components %}

{% block title %}EIEL - Alumbrado Público{% endblock %}
{% block header_icon %}<i data-lucide="lightbulb"></i>{% endblock %}
{% block header_title %}ALUMBRADO PÚBLICO{% endblock %}

{% block content %}

{# 1. Instrucciones (vía Macro) #}
{{ components.render_instrucciones([
    'Rellene los datos requeridos y justifique cualquier dato que no disponga o no pueda aportar en el apartado de <strong>Observaciones</strong>.'
]) }}

{# 2. Requerimientos dinámicos (vía Macro) #}
{# Esta sección mostrará automáticamente los avisos de alumbrado y los campos para adjuntar archivos #}
{{ components.render_requerimientos(avisos_personalizados) }}

{# 3. Observaciones y Botón de Envío (vía Macros) #}
{{ components.render_observaciones_finales() }}
{{ components.render_footer_envio() }}

{% endblock %}

{% block scripts %}
<script>
/**
 * LÓGICA ESPECÍFICA DEL FORMULARIO DE ALUMBRADO
 */
document.addEventListener('DOMContentLoaded', () => {
    
    // Configuración del botón de enviar
    const btnEnviar = document.getElementById('btnEnviar');
    if (btnEnviar) {
        btnEnviar.addEventListener('click', () => {
            // Llamamos a la función global 'processSubmit'
            processSubmit(() => {
                // Alumbrado no tiene campos adicionales fuera de los requerimientos en este momento.
                // Si en el futuro añades campos (ej. tipo de lámparas), los recogerías aquí.
                return {}; 
            });
        });
    }
});
</script>
{% endblock %}