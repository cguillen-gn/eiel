{% extends "base.html.j2" %}

{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block title %}EIEL - Abastecimiento de Agua{% endblock %}
{% block header_icon %}<i data-lucide="droplet"></i>{% endblock %}
{% block header_title %}ABASTECIMIENTO DE AGUA{% endblock %}

{% block content %}

{# --- SECCIÓN: INSTRUCCIONES --- #}
<div class="card card-info">
    <h4><i data-lucide="info"></i> Instrucciones</h4>
    <ul>
        <li>
            Rellene los datos requeridos y justifique cualquier dato que no disponga o no pueda aportar en el apartado de <strong>Observaciones</strong>.
        </li>
    </ul>
</div>

{# --- SECCIÓN: REQUERIMIENTOS --- #}
{% if avisos_personalizados and avisos_personalizados|length > 0 %}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h2 class="section-title">
            <i data-lucide="circle-plus"></i> Información solicitada
        </h2>
        
        <p class="form-help form-help-spacer">
            Se ha detectado falta de información o incidencias en la EIEL que requieren solución. Responda a cada punto y adjunte documentación si es necesario.
        </p>

        <ul class="requerimientos-list" style="list-style: none; padding: 0;">
            {% for aviso in avisos_personalizados %}
            <li class="requerimiento-item" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px dashed var(--border);">
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                    <span class="badge badge-warning" style="margin-top: 4px;">Pendiente</span>
                    <div style="flex: 1;">
                        <strong style="color: var(--text-primary); display: block; margin-bottom: 4px;">{{ aviso.nombre }}</strong>
                        <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 8px;">{{ aviso.descripcion }}</p>
                        
                        <div class="form-group" style="margin-top: 10px;">
                            <textarea 
                                class="form-control req-respuesta" 
                                data-req-id="{{ aviso.id }}"
                                data-req-nombre="{{ aviso.nombre }}"
                                placeholder="Escriba aquí la respuesta o justificación..."
                                rows="2"></textarea>
                        </div>

                        <div class="file-upload-wrapper" style="margin-top: 10px;">
                            <label class="file-upload-label" style="font-size: 0.85rem; padding: 6px 12px;">
                                <i data-lucide="upload" style="width: 14px; height: 14px;"></i>
                                Adjuntar documento justificativo
                                <input type="file" class="req-file-input" data-req-id="{{ aviso.id }}" hidden>
                            </label>
                            <div class="file-list-container" id="list-req-{{ aviso.id }}" style="margin-top: 5px;"></div>
                        </div>
                    </div>
                </div>
            </li>
            {% endfor %}
        </ul>
    </div>
</div>
{% endif %}

{# --- SECCIÓN: GESTIÓN DEL SERVICIO --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="briefcase-business"></i>Gestión del Servicio</h2>

    <div class="card-body">
        <div class="form-group">
            <label class="form-label" for="tipo_gestion">Tipo de Gestión:</label>
            <select class="form-select" name="tipo_gestion" id="tipo_gestion">
                <option value="">Seleccionar...</option>
                <option value="Directa (Municipal)">Municipal (Ayuntamiento)</option>
                <option value="Indirecta (Concesionaria)">Empresa Concesionaria</option>
                <option value="Delegada (Diputación/Consorcio)">Delegada (Diputación/Consorcio)</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label" for="entidad_gestion">Nombre de la Entidad/Empresa Gestora:</label>
            <input type="text" class="form-control" name="entidad_gestion" id="entidad_gestion" placeholder="Ej: Aqualia, Hidraqua, Propio Ayuntamiento...">
        </div>
    </div>
</div>

{# --- SECCIÓN: OBSERVACIONES --- #}
<div class="card" style="margin-top: 2rem;">
    <h2 class="section-title"><i data-lucide="message-square"></i> Observaciones Finales</h2>
    <div class="form-group">
        <textarea class="form-control" name="observaciones" id="observaciones" rows="4" placeholder="Indique cualquier aclaración adicional..."></textarea>
    </div>
</div>

{# --- SECCIÓN: ARCHIVOS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="paperclip"></i> Documentación Adjunta</h2>
    <p class="form-help">Adjunte cualquier documento técnico, planos o facturas que justifiquen cambios.</p>
    
    <div class="file-upload-wrapper">
        <label class="file-upload-label">
            <i data-lucide="upload"></i> Seleccionar archivos
            <input type="file" id="fileInput" multiple hidden>
        </label>
        <div id="fileList" class="file-list-container"></div>
    </div>
</div>

{# --- PIE: BOTONES --- #}
<div class="footer-actions">
    <label class="checkbox-container">
        <input type="checkbox" id="checkConformidad">
        <span class="checkmark"></span>
        Confirmo que los datos introducidos son correctos
    </label>

    <button type="button" id="btnEnviar" class="btn btn-primary" disabled>
        <i data-lucide="send"></i> Enviar Información
    </button>
    <a href="index.html" class="btn btn-secondary">
        <i data-lucide="arrow-left"></i> Volver al Menú
    </a>
</div>

{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkConformidad = document.getElementById('checkConformidad');
    const btnEnviar = document.getElementById('btnEnviar');

    if (checkConformidad && btnEnviar) {
        checkConformidad.addEventListener('change', function() {
            btnEnviar.disabled = !this.checked;
        });
    }

    if (btnEnviar) {
        btnEnviar.addEventListener('click', async function(e) {
            e.preventDefault();
            btnEnviar.disabled = true;

            const totalArchivos = EIEL_Engine.archivos.length + Object.values(EIEL_Engine.colaAdjuntosReq).flat().length;
            UIProgress.show(totalArchivos + 1);

            try {
                // 1. Subir archivos
                const nombresTodosAdjuntos = await EIEL_Engine.uploadFiles("agua");

                // 2. Recopilar Requerimientos
                const respuestasReq = Array.from(document.querySelectorAll('.req-respuesta')).map(el => ({
                    id: el.getAttribute('data-req-id'),
                    pregunta: el.getAttribute('data-req-nombre'),
                    respuesta: el.value
                }));

                // 3. Crear Payload
                const payload = {
                    TIPO_FORMULARIO: "agua",
                    NOMBRE_CONTACTO: localStorage.getItem("eiel_user_name") || "No identificado",
                    DEPARTAMENTO_CONTACTO: localStorage.getItem("eiel_user_dept") || "N/A",
                    EMAIL_CONTACTO: localStorage.getItem("eiel_user_email") || "N/A",
                    MUNICIPIO_INE: window.EIEL_CONFIG.muniCode,
                    municipio_nombre: localStorage.getItem("eiel_muni_name") || window.EIEL_CONFIG.muniName,
                    timestamp_envio: new Date().toISOString(),
                    
                    // Datos del form
                    tipo_gestion: document.getElementById('tipo_gestion') ? document.getElementById('tipo_gestion').value : "",
                    entidad_gestion: document.getElementById('entidad_gestion') ? document.getElementById('entidad_gestion').value : "",
                    OBSERVACIONES: document.getElementById('observaciones') ? document.getElementById('observaciones').value : "",

                    archivos_adjuntos: nombresTodosAdjuntos,
                    respuestas_requerimientos_json: JSON.stringify(respuestasReq)
                };

                // 4. Generar PDF
                await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                    method: "POST", mode: "no-cors",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                UIProgress.complete();
                
                // 5. Limpiar formulario
                EIEL_Engine.archivos = []; 
                EIEL_Engine.colaAdjuntosReq = {}; 
                EIEL_Engine.renderList('fileList', []);
                document.querySelectorAll(".file-list-container").forEach(el => el.innerHTML = "");
                document.querySelectorAll("input, select, textarea").forEach(el => {
                   if (!['button', 'submit', 'checkbox'].includes(el.type)) el.value = '';
                   if (el.tagName === 'SELECT') el.selectedIndex = 0;
                });
                if (checkConformidad) checkConformidad.checked = false;
                btnEnviar.disabled = true;

            } catch (error) {
                console.error(error);
                mostrarMensaje(`❌ Error técnico: ${error.message}`, "error");
                btnEnviar.disabled = false;
            }
        });
    }
});
</script>
{% endblock %}