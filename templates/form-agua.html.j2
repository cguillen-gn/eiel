{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% set ficha_tipo = 'agua' %}

{% block title %}EIEL - Abastecimiento de Agua{% endblock %}
{% block header_icon %}<i data-lucide="droplet"></i>{% endblock %}
{% block header_title %}ABASTECIMIENTO DE AGUA{% endblock %}

{% block content %}
<form id="formFicha">
    {# 1. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li>Rellene los datos técnicos y verifique la tabla de depósitos.</li>
            <li>Si no dispone de algún dato, justifíquelo en <strong>Observaciones</strong>.</li>
        </ul>
    </div>

    {# 2. GESTIÓN DEL SERVICIO #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="briefcase-business"></i>Gestión del Servicio</h2>
        <div class="form-group">
            <label class="form-label" for="tipo_gestion">Tipo de Gestión:</label>
            <select class="form-select" name="tipo_gestion" id="tipo_gestion" required>
                <option value="">Seleccionar...</option>
                <option value="Directa (Municipal)">Municipal (Ayuntamiento)</option>
                <option value="Indirecta (Concesionaria)">Empresa Concesionaria</option>
                <option value="Mancomunidad">Mancomunidad / Consorcio</option>
                <option value="Otro">Otro</option>
            </select>
        </div>
        
        <div id="campos_gestion_externa" class="hidden shadow-inner-bg">
            <div class="form-group">
                <label class="form-label" for="nombre_empresa">Nombre de la Empresa / Ente:</label>
                <input type="text" class="form-input" id="nombre_empresa">
            </div>
            <div class="grid-2-col">
                <div class="form-group">
                    <label class="form-label">Técnico Responsable:</label>
                    <input type="text" id="tecnicoNombre" class="form-input">
                </div>
                <div class="form-group">
                    <label class="form-label">Teléfono:</label>
                    <input type="text" id="tecnicoTel" class="form-input">
                </div>
            </div>
        </div>
    </div>

    {# 3. CONSUMO #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="chart-column"></i>Consumo Anual</h2>
        <div class="form-group">
            <label for="consumoInput" class="form-label">Consumo en el año {{ fase_anterior }} (m³):</label>
            <input type="number" id="consumoInput" class="form-input" min="0" placeholder="0">
        </div>
    </div>

    {# 4. DEPÓSITOS (DINÁMICO DESDE SQL) #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="database"></i>Depósitos Municipales</h2>
        {% if depositos_json and depositos_json != "[]" %}
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th style="width: 150px;">Últ. Limpieza (Año)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for d in depositos_json | fromjson %}
                    <tr>
                        <td class="text-xs">{{ d.codigo }}</td>
                        <td><strong>{{ d.nombre }}</strong></td>
                        <td>
                            <input type="number" class="form-input input-limpieza" 
                                   data-codigo="{{ d.codigo }}" 
                                   data-nombre="{{ d.nombre }}"
                                   placeholder="AAAA" min="1950" max="{{ fase_actual }}">
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="empty-msg">No hay depósitos registrados en la base de datos.</p>
        {% endif %}
    </div>

    {# 5. BLOQUES UNIFICADOS (Macros) #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
{% endblock %}

{% block scripts %}
<script>
// --- [1] GESTIÓN DE ARCHIVOS (Estado local) ---
let listaArchivos = [];

function renderArchivos() {
    const container = document.getElementById('fileList');
    container.innerHTML = listaArchivos.map((f, index) => `
        <div class="file-item">
            <span class="file-name">${f.name}</span>
            <button type="button" onclick="eliminarFichero(${index})" class="btn-remove">Eliminar</button>
        </div>
    `).join('');
}

function eliminarFichero(index) {
    listaArchivos.splice(index, 1);
    renderArchivos();
}

document.addEventListener("DOMContentLoaded", () => {
    // --- [2] LÓGICA DE INTERFAZ (Show/Hide) ---
    const selectGestion = document.getElementById('tipo_gestion');
    const divExterno = document.getElementById('campos_gestion_externa');
    
    selectGestion.addEventListener('change', (e) => {
        const mostrar = ['Indirecta (Concesionaria)', 'Mancomunidad', 'Otro'].includes(e.target.value);
        divExterno.classList.toggle('hidden', !mostrar);
    });

    // --- [3] MANEJO DE ADJUNTOS ---
    const fileInput = document.getElementById('fileInput');
    fileInput.addEventListener('change', (e) => {
        listaArchivos = [...listaArchivos, ...Array.from(e.target.files)];
        renderArchivos();
    });

    // --- [4] VALIDACIÓN Y ENVÍO ---
    const checkConformidad = document.getElementById("checkConformidad");
    const btnEnviar = document.getElementById("btnEnviar");

    checkConformidad.addEventListener('change', (e) => btnEnviar.disabled = !e.target.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "AGUA_" + Date.now();
        
        // Validaciones previas
        if (!document.getElementById("contactoEmail").value.includes('@')) {
            return Swal.fire("Error", "El email de contacto no es válido", "error");
        }

        toggleFormFreeze(true);
        UIProgress.show(listaArchivos.length);

        try {
            // A. Subida de archivos (Secuencial = 1)
            const tareas = listaArchivos.map(f => ({ file: f, seccion: 'GENERAL' }));
            await UploadService.uploadFiles(tareas, 'AGUA', window.EIEL_CONFIG.muniCode, idBatch, 1);

            UIProgress.update(tareas.length, tareas.length, "Generando PDF y registrando datos...");

            // B. Envío de datos técnicos
            const payload = {
                tipo_formulario: "agua",
                id_envio: idBatch,
                municipio_codigo: window.EIEL_CONFIG.muniCode,
                datos_tecnicos: {
                    gestion: selectGestion.value,
                    empresa: document.getElementById("nombre_empresa").value,
                    consumo: document.getElementById("consumoInput").value,
                    depósitos: Array.from(document.querySelectorAll('.input-limpieza')).map(i => ({
                        cod: i.dataset.codigo,
                        año: i.value
                    }))
                },
                observaciones: document.getElementById("observaciones").value,
                contacto: {
                    nombre: document.getElementById("contactoNombre").value,
                    email: document.getElementById("contactoEmail").value
                }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                method: "POST", mode: "no-cors",
                body: JSON.stringify(payload)
            });

            UIProgress.complete();

        } catch (error) {
            console.error(error);
            Swal.fire("Error", "Hubo un problema con el envío.", "error");
            toggleFormFreeze(false);
        }
    });
});
</script>
{% endblock %}