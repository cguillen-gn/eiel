{% extends "base.html.j2" %}

{% block bloque_fase %}
    Fase {{ fase_actual }}
{% endblock %}

{% block title %}Abastecimiento de Agua{% endblock %}
{% block header_icon %}🚰{% endblock %}
{% block header_title %}Abastecimiento de Agua{% endblock %}

{% block content %}

{# --- INSTRUCCIONES --- #}
<div class="card card-info"><i data-lucide="info"><h4>Instrucciones</h4>
    <ul>
        <li>
            Rellene los datos requeridos acerca de recogida de residuos y limpieza viaria. 
            Si no dispone de algún dato, indíquelo en el apartado de <strong>Observaciones</strong>.
        </li>
    </ul>
</div>

<h2 class="section-title"><i data-lucide="briefcase-business"></i>Gestión del Servicio</h2>

{# --- GESTIÓN DEL SERVICIO --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="briefcase-business"></i>Gestión del Servicio</h2>

    <div class="card-body">
        <div class="form-group">
            <label class="form-label" for="tipo_gestion">Tipo de Gestión:</label>
            <select class="form-select" name="tipo_gestion" id="tipo_gestion">
                <option value="">Seleccionar...</option>
                <option value="Directa (Municipal)">Municipal (Ayuntamiento)</option>
                <option value="Indirecta (Concesionaria)">Empresa Concesionaria</option>
                <option value="Mancomunidad">Mancomunidad</option>
            </select>
        </div>

        <div id="campos_gestion_externa" class="hidden">
            <div class="form-group">
                <label class="form-label" for="nombre_empresa">Nombre de la Empresa / Ente:</label>
                <input type="text" class="form-input" name="nombre_empresa" id="nombre_empresa"
                       placeholder="Ej: Hidraqua, Aqualia, Mancomunidad del valle...">
            </div>

            <div class="form-section-divider"></div>

            <div class="form-group">
                <label class="form-label label-highlight">
                    Datos de Contacto Técnico (Empresa):
                </label>
                
                <div class="grid-2-col">
                    <input type="text" id="tecnicoNombre" class="form-input" name="contacto_nombre" placeholder="Nombre persona responsable">
                    <input type="text" id="tecnicoTel" class="form-input" name="contacto_telefono" placeholder="Teléfono directo/Móvil">
                    <input type="email" id="tecnicoEmail" class="form-input" name="contacto_email" placeholder="Correo electrónico">
                </div>
                <small class="form-help">
                   Persona a la que dirigirnos en caso de necesitar planos o detalles técnicos específicos.
                </small>
            </div>
        </div>
    </div>
</div>

{# --- CONSUMO ANUAL AGUA POTABLE --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="chart-column"></i>Consumo anual agua potable</h2>
    
    
    <div class="form-group">
        <label for="consumoInput" class="form-label">
            Consumo de agua potable en el año {{ fase_anterior }} (m³)
        </label>
        <input type="number" id="consumoInput" class="form-input" placeholder="Ej: 15000" min="0">
    </div>
</div>

{# --- LIMPIEZA DEPÓSITOS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="bubbles"></i>Depósitos Municipales</h2>
    
    {% if depositos_json and depositos_json != "[]" %}
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Nombre del depósito</th>
                    <th class="td-ubicacion">Última limpieza (año)</th>
                </tr>
            </thead>
            <tbody id="tablaDepositos">
                {% set lista_depositos = depositos_json | fromjson %}
                
                {% for d in lista_depositos %}
                <tr>
                    <td style="font-weight: 500;">
                        {{ d.nombre }}
                    </td>
                    <td class="td-ubicacion">
                        <input 
                            type="number" 
                            class="form-input input-limpieza" 
                            data-nombre="{{ d.nombre }}"
                            placeholder="Ej: {{ fase_anterior }}"
                            value="" 
                            min="1900" 
                            max="{{ fase_actual }}"
                        >
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
        <p class="sin-uso-intro">
            ℹ️ No constan depósitos registrados para este municipio.
        </p>
    {% endif %}
</div>

{# --- REQUERIMIENTOS --- #}
<div class="card card-requerimientos">
    <div class="requerimientos-content">
        <h4 class="requerimientos-title">⚠️ Otra información solicitada</h4>
        </h4>
        <p class="requerimientos-intro">
            Se ha detectado falta de información o incidencias en el <strong>Abastecimiento de agua</strong>.
            Por favor, responda en <strong>Observaciones</strong> y adjunte la documentación necesaria.
        </p>
        <ul class="requerimientos-list">
            {% for aviso in avisos_personalizados %}
                <li class="requerimiento-item-box prioridad-{{ 'alta' if aviso.prioridad == 'alta' else 'media' }}">
                    
                    {# Icono según prioridad #}
                    <span class="requerimiento-icon">
                        {{ '🔴' if aviso.prioridad == 'alta' else '🔸' }}
                    </span>

                    <div class="requerimiento-content-text">
                        <span class="requerimiento-msg">{{ aviso.mensaje }}</span>

                        {# Botón Geoportal (solo si hay URL) #}
                        {% if aviso.url %}
                            <a href="{{ aviso.url }}" target="_blank" class="btn-geoportal">
                                <i data-lucide="globe"></i> Ver en Geoportal
                            </a>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    </div>
</div>

{# --- OBSERVACIONES --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="file-text"></i>Observaciones</h2>
    <div class="form-group">
        <label for="observaciones" class="form-label">Comentarios adicionales:</label>
        <textarea id="observaciones" class="form-input" rows="4" placeholder="Indique aquí cualquier incidencia, aclaración o dato relevante..."></textarea>
    </div>
</div>

{# --- ADJUNTOS --- #}
<div class="card">
    <h2 class="section-title"><i data-lucide="folder"></i>Documentación Adjunta (Opcional)</h2>    
    <div class="file-upload-area" onclick="document.getElementById('fileInput').click()">
        <div class="upload-icon">📎</div>
        <div style="font-weight: 600;">Haga clic para adjuntar archivos</div>
        <p class="upload-help">(Planos, fotos, informes, análisis...)</p>
        <input type="file" id="fileInput" multiple style="display: none;">
    </div>
    <div id="fileList" class="file-list-container"></div>
</div>


{# --- DATOS DE CONTACTO --- #}
<div class="card">
        <h2 class="section-title"><i data-lucide="user"></i>Datos de Contacto</h2>
    
    <div class="grid-2-col">
        <div class="form-group">
            <label class="form-label">Nombre y apellidos *</label>
            <input type="text" id="contactoNombre" class="form-input" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
            <label class="form-label">Departamento</label>
            <input type="text" id="contactoDepartamento" class="form-input" placeholder="Ej: Urbanismo" required>
        </div>
       <div class="form-group">
            <label class="form-label">Email (Para recibir justificante) *</label>
            <input type="email" id="contactoEmail" class="form-input" placeholder="Ej: ejemplo@ayuntamiento.es" required>
        </div>
        
        <div class="form-group">
            <label class="form-label">Confirme su Email *</label>
            <input type="email" id="contactoEmailConfirm" class="form-input" placeholder="Repita el email" required onpaste="return false;">
            </div>
    </div>
</div>

{# --- DECLARACIÓN RESPONSABLE --- #}
<div class="card">
    <div class="conformidad-box">
        <label class="check-label">
            <input type="checkbox" id="checkConformidad" class="check-input">
            <span class="check-text">
                <strong>Declaración de veracidad:</strong> Como responsable, 
                confirmo que los datos introducidos son correctos y actualizados.
            </span>
        </label>
    </div>
    
    <div id="progressContainer" class="progress-container">
        <div class="progress-labels">
            <span id="progressText">Preparando envío...</span>
            <span id="progressPercentage">0%</span>
        </div>
        <div class="progress-track">
            <div id="progressBar"></div>
        </div>
    </div>

    <button id="btnEnviar" class="btn btn-primary" disabled>
        Enviar Datos
    </button>
</div>
    
{% endblock %}

{% block scripts %}
<script>
document.addEventListener("DOMContentLoaded", () => {

    
    // 0. ACTIVADOR DE TEMA
    document.body.classList.add('theme-agua');
    
    // Ejecuta la creación de iconos de Lucide
    if (window.lucide) {
        lucide.createIcons();
    }

    // 1. SETUP DE ESTILOS
    const header = document.querySelector('.site-header');
    if(header) header.classList.add('header-agua');

    // 2. CONFIGURACIÓN GLOBAL
    window.EIEL_CONFIG = {
        muniCode: "{{ muni_code }}",
        muniName: "{{ muni_display }}",
        fase: "{{ fase_actual }}",
        urlGenerarPdf: "{{ url_generar_pdf }}",
        urlAdjuntos: "{{ url_adjuntos }}",
        urlLogger: "{{ url_logger }}",
        hasAvisos: {{ 'true' if avisos_personalizados and avisos_personalizados|length > 0 else 'false' }},
        yearActual: new Date().getFullYear() // Año dinámico para validaciones
    };

    // 3. INICIALIZACIÓN UI
    // 3.1 Marcado visual de obligatoriedad en observaciones
    if (window.EIEL_CONFIG.hasAvisos) {
        const labelObs = document.querySelector("label[for='observaciones']");
        if (labelObs) {
            labelObs.innerHTML += " <span class='text-required'>(* Obligatorio por requerimiento)</span>";
        }
    }
    
    // 3.2 Lógica de gestión del servicio
    const selectGestion = document.getElementById('tipo_gestion');
    const divExterno = document.getElementById('campos_gestion_externa');

    // Solo activamos la lógica si existen los elementos en pantalla
    if (selectGestion && divExterno) {
        
        // Escuchamos cuando el usuario cambia la opción
        selectGestion.addEventListener('change', function() {
            const val = this.value;

            // Si es "Indirecta" o "Mancomunidad", mostramos los campos
            if (val === 'Indirecta (Concesionaria)' || val === 'Mancomunidad') {
                divExterno.classList.remove('hidden');
            } else {
                divExterno.classList.add('hidden');
            }
        });
    }

    // 4. SERVICIOS Y UTILIDADES DE UI
    const UIProgress = {
    container: document.getElementById("progressContainer"),
    bar: document.getElementById("progressBar"),
    text: document.getElementById("progressText"),
    percent: document.getElementById("progressPercentage"),
    //Variable para recordar el punto más alto alcanzado
    maxReached: 0, 

    show(totalTasks) {
        this.maxReached = 0; // Reiniciamos al empezar
        if (this.container) this.container.style.display = 'block';
        this.update(0, totalTasks, "Iniciando envío...");
    },

    update(completed, total, message) {
        const msg = message.toLowerCase();
        // Detectamos si es el paso del registro o PDF
        const isFinalStep = msg.includes("pdf") || msg.includes("registro") || msg.includes("justificante");
        
        let targetPercentage = 0;
        if (total > 0) {
            const fileWeight = 90 / total;
            targetPercentage = isFinalStep ? 95 : Math.round(completed * fileWeight);
        } else {
            targetPercentage = isFinalStep ? 95 : 0;
        }

        // --- EL BLOQUEO DE SEGURIDAD ---
        // Solo actualizamos si el nuevo porcentaje es mayor al que ya mostramos
        if (targetPercentage > this.maxReached) {
            this.maxReached = targetPercentage;
            if (this.bar) this.bar.style.width = this.maxReached + "%";
            if (this.percent) this.percent.textContent = this.maxReached + "%";
        }
        
        // El texto sí lo actualizamos siempre para dar feedback constante
        if (this.text && message) this.text.textContent = message;
    },

    complete() {
        this.maxReached = 100;
        if (this.bar) {
            this.bar.style.width = "100%";
            this.bar.classList.add("progress-success");
        }
        if (this.percent) this.percent.textContent = "100%";
        if (this.text) this.text.textContent = "✅ ¡Envío completado con éxito!";
    }
    };

    const UploadService = {
        toBase64: file => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        }),

        async uploadFile(file, tipoFicha, muniCode, seccion = "DOCUMENTACION", idEnvio) {
            try {
                const base64 = await this.toBase64(file);
                const userEmail = document.getElementById("contactoEmail").value || "anonimo";
                const payload = {
                    filename: file.name,
                    mimeType: file.type,
                    bytesBase64: base64, 
                    municipio: muniCode,
                    usuario: userEmail,
                    tipo: tipoFicha,
                    seccion: seccion,
                    id_envio: idEnvio
                };
                await fetch(window.EIEL_CONFIG.urlAdjuntos, {
                    method: 'POST', mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                return true;
            } catch (e) { return false; }
        }
    };
   
    
    // 5. GESTIÓN DE ARCHIVOS (UI)
    let archivos = [];
    const fileInput = document.getElementById("fileInput");
    const fileList = document.getElementById("fileList");

    if (fileInput) {
        fileInput.onchange = () => {
            archivos.push(...Array.from(fileInput.files));
            renderArchivos();
            fileInput.value = '';
        };
    }

    window.eliminarArchivo = (i) => {
        archivos.splice(i, 1);
        renderArchivos();
    };
    
    function renderArchivos() {
        if (!fileList) return;
        if (archivos.length === 0) {
            fileList.innerHTML = '';
            return;
        }
        fileList.innerHTML = archivos.map((f, i) => `
            <div class="file-item">
                <span>📄 ${f.name}</span>
                <button type="button" onclick="eliminarArchivo(${i})" class="btn-danger-icon">✖</button>
            </div>
        `).join("");
    }

    // 6. LÓGICA DE ENVÍO Y VALIDACIÓN
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConformidad = document.getElementById("checkConformidad");
    const mensajeDiv = document.getElementById("mensaje");

    function mostrarMensaje(texto, tipo) {
        if(!mensajeDiv) return;
        mensajeDiv.textContent = texto;
        mensajeDiv.className = `message ${tipo}`;
        mensajeDiv.classList.remove('hidden');
    }

    // 6.1 Checkbox Habilitador
    if (checkConformidad && btnEnviar) {
        checkConformidad.addEventListener('change', function() {
            if (this.checked) {
                btnEnviar.disabled = false;

            } else {
                btnEnviar.disabled = true;

            }
        });
    }

    // 6.2 Listener Principal de Envío
        if (btnEnviar) {
            btnEnviar.addEventListener("click", async () => {
                // A. Preparación y Bloqueo UI
                // Generamos el ID único del expediente al principio
                const idBatch = "ENVIO_" + new Date().getTime();
                
                // Congelamos el formulario para evitar modificaciones durante el envío
                toggleFormFreeze(true);

                // B. Lectura de Variables        
                const nombreContacto = document.getElementById("contactoNombre").value.trim();
                const departamentoVal = document.getElementById("contactoDepartamento").value.trim();
                const emailContacto = document.getElementById("contactoEmail").value.trim();
                const emailConfirmInput = document.getElementById("contactoEmailConfirm");
                const emailConfirm = emailConfirmInput ? emailConfirmInput.value.trim() : emailContacto;
                const obsField = document.getElementById("observaciones");
                const obsValue = obsField.value.trim();
                const regexEmail = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
                
                const tipoGestion = document.getElementById("tipo_gestion")?.value;
                const empresa = document.getElementById("nombre_empresa")?.value.trim();

                // C. Validaciones
                    // 1: Identidad
                    if (nombreContacto.length < 2) {
                        mostrarMensaje("⚠️ El nombre es demasiado corto (mín. 2 caracteres).", "warning");
                        toggleFormFreeze(false); // Desbloqueamos para permitir corrección
                        return;
                    }
                    if (!regexEmail.test(emailContacto) || emailContacto.toLowerCase() !== emailConfirm.toLowerCase()) {
                        mostrarMensaje("⚠️ Verifique que el Email sea válido y coincida.", "error");
                        toggleFormFreeze(false);
                        return;
                    }

                    // 2: Requerimiento de Observaciones (Avisos pendientes)
                    if (window.EIEL_CONFIG.hasAvisos && obsValue.length < 15) {
                        mostrarMensaje("⚠️ Es OBLIGATORIO responder en 'Observaciones' (mín. 15 caracteres) por requerimientos pendientes.", "error");
                        obsField.focus(); 
                        toggleFormFreeze(false);
                        return;
                    }

                    // 3: Integridad de datos (Año limpieza depósitos)
                    const yearMax = new Date().getFullYear() + 1;
                    let fechaError = false;
                    document.querySelectorAll('.input-limpieza').forEach(input => {
                        const anio = parseInt(input.value);
                        if (anio && (anio < 1900 || anio > yearMax)) fechaError = true;
                    });

                    if (fechaError) {
                        mostrarMensaje(`⚠️ El año de limpieza debe estar entre 1900 y ${yearMax}.`, "error");
                        toggleFormFreeze(false);
                        return;
                    }

                    // 4: Gestión y Empresa
                    if ((tipoGestion === 'Indirecta (Concesionaria)' || tipoGestion === 'Mancomunidad') && !empresa) {
                        mostrarMensaje("⚠️ El nombre de la empresa es obligatorio para este tipo de gestión.", "error");
                        toggleFormFreeze(false);
                        return;
                    }

                    // 5: Persistencia de datos del técnico (Memoria proactiva)
                    localStorage.setItem("eiel_user_name", nombreContacto);
                    localStorage.setItem("eiel_user_email", emailContacto);
                    localStorage.setItem("eiel_user_dept", departamentoVal);

                // D. Subida de Archivos a Google Drive
                const totalArchivos = archivos.length;
                let completados = 0;
                UIProgress.show(totalArchivos);

                if (totalArchivos > 0) {
                    const promesasSubida = archivos.map(file => 
                        UploadService.uploadFile(file, 'agua', window.EIEL_CONFIG.muniCode, 'DOCUMENTACION', idBatch)
                        .then(res => {
                            completados++;
                            UIProgress.update(completados, totalArchivos, `Subido: ${file.name}`);
                            return res;
                        })
                    );
                    await Promise.all(promesasSubida);
                }

                // E. Recopilación de Datos para el Registro
                UIProgress.update(completados, totalArchivos, "Enviando datos y generando justificante PDF...");
                
                    // 1: Datos de limpieza de depósitos
                    const depositosData = [];
                    document.querySelectorAll('.input-limpieza').forEach(input => {
                        depositosData.push({
                            nombre: input.dataset.nombre,
                            limpieza: input.value || "No indicado"
                        });
                    });

                    // 2: Preparación del Payload
                    const payload = {
                        tipo_formulario: "agua",
                        fase: window.EIEL_CONFIG.fase,
                        id_envio: idBatch,
                        gestion_tipo: tipoGestion || "",
                        gestion_empresa: empresa || "",
                        gestion_tecnico_nombre: document.getElementById("tecnicoNombre")?.value || "",
                        gestion_tecnico_tel: document.getElementById("tecnicoTel")?.value || "",
                        gestion_tecnico_email: document.getElementById("tecnicoEmail")?.value || "",
                        consumo: document.getElementById("consumoInput").value || "No indicado",
                        depositos: JSON.stringify(depositosData),
                        observaciones: obsValue,
                        nombre_contacto: nombreContacto,
                        departamento_contacto: departamentoVal,
                        email_contacto: emailContacto,
                        municipio_codigo: window.EIEL_CONFIG.muniCode,
                        municipio_nombre: window.EIEL_CONFIG.muniName,
                        timestamp_envio: new Date().toISOString(),
                        archivos_adjuntos: archivos.map(a => a.name).join("\n")
                    };

                // F. Registro y Envío de PDF
                try {
                    await fetch(window.EIEL_CONFIG.urlGenerarPdf, {
                        method: "POST",
                        mode: "no-cors",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload)
                    });

                    // G. Finalización y Limpieza
                    UIProgress.complete();
                    if(mensajeDiv) mensajeDiv.style.display = 'none';

                    // Reset de variables y UI
                    archivos = [];
                    renderArchivos(); 

                    document.querySelectorAll("input, select, textarea").forEach(el => {
                       if(!['button', 'submit', 'checkbox'].includes(el.type)) el.value = '';
                       if(el.tagName === 'SELECT') el.selectedIndex = 0;
                    });

                    if(checkConformidad) checkConformidad.checked = false;

                    // Bloqueo final del botón tras éxito
                    btnEnviar.disabled = true;


                } catch (error) {
                    console.error(error);
                    mostrarMensaje(`❌ Error técnico: ${error.message}`, "error");
                    // En caso de fallo en el envío, devolvemos el control al usuario
                    toggleFormFreeze(false);
                }
            });
        }
});
</script>
{% endblock %}