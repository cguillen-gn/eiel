{# form-agua.html.j2 #}
{% extends "base.html.j2" %}

{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}
{% block title %}EIEL - Abastecimiento de Agua{% endblock %}
{% block header_icon %}<i data-lucide="droplet"></i>{% endblock %}
{% block header_title %}ABASTECIMIENTO DE AGUA{% endblock %}

{% block content %}
{{ macros.render_instrucciones() }}
{{ macros.render_requerimientos(avisos_personalizados) }}

<div class="card">
    <h2 class="section-title"><i data-lucide="briefcase-business"></i>Gestión del Servicio</h2>
    <div class="card-body">
        <div class="form-group">
            <label class="form-label" for="tipo_gestion">Tipo de Gestión:</label>
            <select class="form-select" name="tipo_gestion" id="tipo_gestion">
                <option value="">Seleccionar...</option>
                <option value="Directa (Municipal)">Municipal (Ayuntamiento)</option>
                <option value="Indirecta (Concesionaria)">Empresa Concesionaria</option>
                <option value="Delegada (Diputación/Consorcio)">Delegada (Diputación/Consorcio)</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label" for="entidad_gestion">Nombre de la Entidad/Empresa Gestora:</label>
            <input type="text" class="form-control" name="entidad_gestion" id="entidad_gestion" placeholder="Ej: Aqualia, Hidraqua, Propio Ayuntamiento...">
        </div>
    </div>
</div>

<div class="card" style="margin-top: 2rem;">
    <h2 class="section-title"><i data-lucide="message-square"></i> Observaciones Finales</h2>
    <div class="form-group">
        <textarea class="form-control" name="observaciones" id="observaciones" rows="4" placeholder="Indique cualquier aclaración adicional..."></textarea>
    </div>
</div>

<div class="card">
    <h2 class="section-title"><i data-lucide="paperclip"></i> Documentación Adjunta</h2>
    <p class="form-help">Adjunte cualquier documento técnico, planos o facturas que justifiquen cambios.</p>
    <div class="file-upload-wrapper">
        <label class="file-upload-label">
            <i data-lucide="upload"></i> Seleccionar archivos
            <input type="file" id="fileInput" multiple hidden>
        </label>
        <div id="fileList" class="file-list-container"></div>
    </div>
</div>

<div class="footer-actions">
    <label class="checkbox-container">
        <input type="checkbox" id="checkConformidad">
        <span class="checkmark"></span>
        Confirmo que los datos introducidos son correctos
    </label>
    <button type="button" id="btnEnviar" class="btn btn-primary" disabled>
        <i data-lucide="send"></i> Enviar Información
    </button>
    <a href="index.html" class="btn btn-secondary">
        <i data-lucide="arrow-left"></i> Volver al Menú
    </a>
</div>
{% endblock %}

{% block scripts %}
<script>
    const checkConf = document.getElementById('checkConformidad');
    const btnEnv = document.getElementById('btnEnviar');
    if(checkConf) checkConf.addEventListener('change', (e) => btnEnv.disabled = !e.target.checked);

    btnEnv.addEventListener('click', async () => {
        const total = EIEL_Engine.archivos.length + Object.values(EIEL_Engine.colaAdjuntosReq).flat().length;
        UIProgress.show(total + 1);

        try {
            const adjuntos = await EIEL_Engine.uploadFiles("agua");
            
            // Recolectar respuestas de requerimientos
            const respuestasReq = Array.from(document.querySelectorAll('.req-respuesta')).map(el => ({
                id: el.getAttribute('data-req-id'),
                pregunta: el.getAttribute('data-req-nombre'),
                respuesta: el.value
            }));

            const payload = {
                TIPO_FORMULARIO: "agua",
                NOMBRE_CONTACTO: localStorage.getItem("eiel_user_name") || "N/A",
                DEPARTAMENTO_CONTACTO: localStorage.getItem("eiel_user_dept") || "N/A",
                EMAIL_CONTACTO: localStorage.getItem("eiel_user_email") || "N/A",
                MUNICIPIO_INE: window.EIEL_CONFIG.muniCode,
                MUNICIPIO_NOMBRE: window.EIEL_CONFIG.muniName,
                FASE: window.EIEL_CONFIG.fase,
                FECHA_ENVIO: new Date().toLocaleString(),
                OBSERVACIONES: document.getElementById('observaciones').value,
                tipo_gestion: document.getElementById('tipo_gestion').value,
                entidad_gestion: document.getElementById('entidad_gestion').value,
                archivos_adjuntos: adjuntos,
                respuestas_requerimientos_json: JSON.stringify(respuestasReq)
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { 
                method: "POST", mode: "no-cors", body: JSON.stringify(payload) 
            });

            UIProgress.complete();
            setTimeout(() => location.reload(), 1500);

        } catch (err) {
            Swal.fire({ icon: 'error', title: 'Error', text: err.message });
        }
    });
</script>
{% endblock %}