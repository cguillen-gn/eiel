{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Abastecimiento de Agua{% endblock %}
{% block tipo_ficha %}agua{% endblock %}
{% block body_class %}agua{% endblock %}
{% block header_icon %}<i data-lucide="droplet"></i>{% endblock %}
{% block header_title %}ABASTECIMIENTO DE AGUA{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones() }}

    {# SECCIONES ESPECÍFICAS DE AGUA (Captación, Depósitos...) #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="waves"></i>Captación</h2>
        <div class="card-body">
            <input type="number" class="form-input" name="volumen_captado" placeholder="Volumen m3/año">
        </div>
    </div>
    {# ... resto de secciones de agua ... #}

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');
    
    // Rellenar contacto
    document.getElementById('contacto_nombre').value = localStorage.getItem("eiel_user_name") || "";
    
    checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            // Aquí solo definimos cómo extraer los datos de ESTE formulario
            const formData = new FormData(document.getElementById('mainForm'));
            return Object.fromEntries(formData.entries());
        });
    };
});
</script>
{% endblock %}