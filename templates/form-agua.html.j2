{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{# 1. CONFIGURACIÓN DEL TEMA #}
{% set ficha_tipo = 'agua' %}

{% block title %}EIEL - Abastecimiento de Agua{% endblock %}
{% block header_icon %}<i data-lucide="droplet"></i>{% endblock %}
{% block header_title %}ABASTECIMIENTO DE AGUA{% endblock %}

{% block content %}
<form id="formAgua">
    {# 2. INSTRUCCIONES #}
    <div class="card card-info">
        <h4><i data-lucide="info"></i> Instrucciones</h4>
        <ul>
            <li>Rellene los datos requeridos y justifique cualquier ausencia de información en <strong>Observaciones</strong>.</li>
        </ul>
    </div>

    {# 3. GESTIÓN DEL SERVICIO #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="briefcase-business"></i>Gestión del Servicio</h2>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label" for="tipo_gestion">Tipo de Gestión:</label>
                <select class="form-select" name="tipo_gestion" id="tipo_gestion">
                    <option value="">Seleccionar...</option>
                    <option value="Directa (Municipal)">Municipal (Ayuntamiento)</option>
                    <option value="Indirecta (Concesionaria)">Empresa Concesionaria</option>
                    <option value="Otro">Otro</option>
                </select>
            </div>

            <div id="campos_gestion_externa" class="hidden shadow-inner-bg">
                <div class="form-group">
                    <label class="form-label" for="nombre_empresa">Nombre de la Empresa / Ente:</label>
                    <input type="text" class="form-input" id="nombre_empresa" placeholder="Ej: Hidraqua, AMAEM, Global Omnium, Aqualia...">
                </div>
                <div class="form-section-divider"></div>
                <div class="form-group">
                    <label class="form-label label-highlight">Datos de Contacto Técnico (Empresa):</label>
                    <div class="grid-2-col">
                        <input type="text" id="tecnicoNombre" class="form-input" placeholder="Nombre persona responsable">
                        <input type="text" id="tecnicoTel" class="form-input" placeholder="Teléfono directo/Móvil">
                        <input type="email" id="tecnicoEmail" class="form-input" placeholder="Correo electrónico">
                    </div>
                </div>
            </div>

            <div id="campos_gestion_otro" class="hidden shadow-inner-bg">
                <div class="form-group">
                    <label class="form-label" for="nombre_gestor">Gestor:</label>
                    <input type="text" class="form-input" id="nombre_gestor" placeholder="Especifique el gestor del servicio...">
                </div>
            </div>
        </div>
    </div>

    {# 4. CONSUMO ANUAL #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="chart-column"></i>Consumo anual agua potable</h2>
        <div class="form-group">
            <label for="consumoInput" class="form-label">Consumo en el año {{ fase_anterior }} (m³)</label>
            <input type="number" id="consumoInput" class="form-input" placeholder="Ej: 15000" min="0">
        </div>
    </div>

    {# 5. LIMPIEZA DEPÓSITOS #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="bubbles"></i>Depósitos Municipales</h2>
        {% if depositos_json and depositos_json != "[]" %}
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 15%;">Cód</th>
                        <th style="width: 60%;">Nombre del depósito</th>
                        <th style="width: 25%;" class="td-ubicacion">Última limpieza (año)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for d in depositos_json | fromjson %}
                    <tr>
                        <td class="td-ubicacion text-xs" style="font-weight: 500; color: var(--text-secondary);">{{ d.codigo }}</td>
                        <td style="font-weight: 500;">{{ d.nombre }}</td>
                        <td class="td-ubicacion">
                            <input type="number" class="form-input input-limpieza" 
                                   data-codigo="{{ d.codigo }}" data-nombre="{{ d.nombre }}"
                                   placeholder="Ej: {{ fase_anterior }}" min="1900" max="{{ fase_actual }}">
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
            <p class="sin-uso-intro">ℹ️ No constan depósitos registrados para este municipio.</p>
        {% endif %}
    </div>

    {# 6. REQUERIMIENTOS (Información Solicitada) #}
    {% if avisos_personalizados and avisos_personalizados|length > 0 %}
    <div class="card card-requerimientos">
        <h2 class="section-title"><i data-lucide="circle-plus"></i> Otra información solicitada</h2>
        <p class="form-help form-help-spacer">Se ha detectado falta de información que requiere solución.</p>
        <ul class="requerimientos-list" style="list-style: none; padding: 0; margin: 0;">
            {% for aviso in avisos_personalizados %}
            {% set req_id = loop.index0 %}
            <li class="aviso-item" style="display: flex; flex-direction: column; gap: 15px; padding: 20px 0; border-bottom: 1px dashed #e2e8f0;">
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div class="status-dot {{ 'dot-alta' if aviso.prioridad == 'Alta' else 'dot-media' }}"></div>
                        <span style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);">{{ aviso.mensaje }}</span>
                    </div>
                    {% if aviso.url %}
                    <a href="{{ aviso.url if 'http' in aviso.url else 'https://' ~ aviso.url }}" target="_blank" class="btn btn-secondary btn-sm">
                        <i data-lucide="map"></i> Mapa
                    </a>
                    {% endif %}
                </div>
                
                {# CONTENEDOR DE RESPUESTA CORREGIDO (FONDO BLANCO Y ANCHO TOTAL) #}
                <div style="margin-left: 28px; background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0; box-sizing: border-box; width: calc(100% - 28px);">
                    <textarea class="form-input txt-resp-req" data-msg="{{ aviso.mensaje }}" data-id="{{ req_id }}" rows="3" 
                              placeholder="Responda aquí..." 
                              style="width: 100% !important; box-sizing: border-box; display: block; margin-bottom: 15px; background: white; border: 1px solid #cbd5e1;"></textarea>
                    
                    <button type="button" class="btn btn-secondary btn-sm" onclick="gestionarAdjuntosReq('{{ req_id }}')">
                        <i data-lucide="paperclip"></i> Adjuntar
                    </button>
                    {{ ui.ayuda_archivo() }}
                    <div id="lista_adjuntos_req_{{ req_id }}" class="file-list-container" style="margin-top: 10px;"></div>
                </div>
            </li>
            {% endfor %}
        </ul>
        <input type="file" id="hiddenInputReq" multiple style="display: none;">
    </div>
    {% endif %}

    {# 7. COMPONENTES GLOBALES #}
    {{ ui.campo_observaciones() }}
    {{ ui.zona_adjuntos() }}
    {{ ui.campo_contacto() }}
    {{ ui.declaracion_veracidad() }}
</form>
{% endblock %}

{% block scripts %}
<script>
let archivosGenerales = [];
let colaAdjuntosReq = {};
let reqIdActual = null;

document.addEventListener("DOMContentLoaded", () => {
    // A. Gestión de visibilidad del Servicio
    const selectGestion = document.getElementById('tipo_gestion');
    const divExterno = document.getElementById('campos_gestion_externa');
    const divOtro = document.getElementById('campos_gestion_otro');

    if (selectGestion) {
        selectGestion.addEventListener('change', function() {
            const val = this.value;
            divExterno.classList.toggle('hidden', val !== 'Indirecta (Concesionaria)');
            divOtro.classList.toggle('hidden', val !== 'Otro');
        });
    }

    // B. Manejo de adjuntos
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
        fileInput.addEventListener('change', () => {
            archivosGenerales = [...archivosGenerales, ...Array.from(fileInput.files)];
            renderArchivos();
            fileInput.value = "";
        });
    }

    const inputReq = document.getElementById('hiddenInputReq');
    window.gestionarAdjuntosReq = (id) => { reqIdActual = id; if(inputReq) inputReq.click(); };

    if (inputReq) {
        inputReq.addEventListener('change', () => {
            if (!reqIdActual) return;
            colaAdjuntosReq[reqIdActual] = [...(colaAdjuntosReq[reqIdActual] || []), ...Array.from(inputReq.files)];
            renderColaReq(reqIdActual);
            inputReq.value = "";
        });
    }

    // C. Lógica de Envío
    const btnEnviar = document.getElementById("btnEnviar");
    const checkConf = document.getElementById("checkConformidad");
    if (checkConf) checkConf.addEventListener('change', () => btnEnviar.disabled = !checkConf.checked);

    btnEnviar.addEventListener("click", async () => {
        const idBatch = "AGUA_" + Date.now();
        
        // Validación de año en depósitos
        let anioInvalido = false;
        document.querySelectorAll('.input-limpieza').forEach(input => {
            const anio = parseInt(input.value);
            if (input.value.trim() !== "" && (isNaN(anio) || anio < 1950 || anio > (parseInt(window.EIEL_CONFIG.fase) + 1))) {
                anioInvalido = true;
                input.style.borderColor = "var(--danger)";
            } else {
                input.style.borderColor = "";
            }
        });

        if (anioInvalido) return Swal.fire("Error", "Revise los años de limpieza de los depósitos.", "error");

        toggleFormFreeze(true);

        const listaTareas = [];
        archivosGenerales.forEach(f => listaTareas.push({ file: f, seccion: 'GENERAL' }));
        Object.entries(colaAdjuntosReq).forEach(([id, list]) => {
            list.forEach(f => listaTareas.push({ file: f, seccion: `REQUERIMIENTO_${parseInt(id)+1}` }));
        });

        UIProgress.show(listaTareas.length);

        try {
            await UploadService.uploadFiles(listaTareas, 'AGUA', window.EIEL_CONFIG.muniCode, idBatch, 1);
            UIProgress.update(listaTareas.length, listaTareas.length, "Generando PDF...");

            const payload = {
                tipo_formulario: "agua",
                id_envio: idBatch,
                municipio: window.EIEL_CONFIG.muniCode,
                gestion: {
                    tipo: selectGestion.value,
                    empresa: document.getElementById("nombre_empresa").value,
                    gestor_otro: document.getElementById("nombre_gestor").value,
                    tecnico: document.getElementById("tecnicoNombre").value
                },
                consumo: document.getElementById("consumoInput").value,
                depositos: JSON.stringify(Array.from(document.querySelectorAll('.input-limpieza')).map(i => ({
                    codigo: i.dataset.codigo, limpieza: i.value || "No indicado"
                }))),
                requerimientos: Array.from(document.querySelectorAll('.txt-resp-req')).map(area => ({
                    pregunta: area.dataset.msg, respuesta: area.value
                })),
                observaciones: document.getElementById("observaciones").value,
                contacto: {
                    nombre: document.getElementById("contactoNombre").value,
                    email: document.getElementById("contactoEmail").value
                }
            };

            await fetch(window.EIEL_CONFIG.urlGenerarPdf, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
            UIProgress.complete();

        } catch (error) {
            console.error(error);
            toggleFormFreeze(false);
            Swal.fire("Error", "Fallo al procesar el envío.", "error");
        }
    });
});

function renderArchivos() {
    const fileList = document.getElementById("fileList");
    if (!fileList) return;
    fileList.innerHTML = archivosGenerales.map((f, i) => `
        <div class="file-item">
            <span>📄 ${f.name}</span>
            <button type="button" onclick="archivosGenerales.splice(${i},1); renderArchivos();" class="btn-danger-icon"><i data-lucide="trash-2"></i></button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}

function renderColaReq(id) {
    const contenedor = document.getElementById(`lista_adjuntos_req_${id}`);
    if (!contenedor) return;
    contenedor.innerHTML = (colaAdjuntosReq[id] || []).map((f, i) => `
        <div class="file-item" style="margin-bottom:4px; padding:4px 8px; background:#fdfdfd; border:1px solid #e2e8f0; border-radius:6px; display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:0.75rem;"><i data-lucide="paperclip" style="width:12px;"></i> ${f.name}</span>
            <button type="button" onclick="colaAdjuntosReq['${id}'].splice(${i},1); renderColaReq('${id}');" class="btn-danger-icon"><i data-lucide="trash-2" style="width:16px; color:#ef4444;"></i></button>
        </div>`).join("");
    if (window.lucide) lucide.createIcons();
}
</script>
{% endblock %}