{% extends "base.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}EIEL - Saneamiento y Depuración{% endblock %}
{% block tipo_ficha %}saneamiento{% endblock %}
{% block body_class %}saneamiento{% endblock %}
{% block header_icon %}<i data-lucide="test-tube"></i>{% endblock %}
{% block header_title %}SANEAMIENTO Y DEPURACIÓN{% endblock %}
{% block bloque_fase %}Fase {{ fase_actual }}{% endblock %}

{% block content %}
    {{ ui.render_instrucciones() }}

    {# --- SECCIÓN: GESTIÓN DEL SERVICIO --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="briefcase-business"></i>Gestión del Servicio</h2>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label" for="tipo_gestion">Tipo de Gestión:</label>
                <select class="form-select" name="tipo_gestion" id="tipo_gestion">
                    <option value="">Seleccionar...</option>
                    <option value="Directa (Municipal)">Municipal (Ayuntamiento)</option>
                    <option value="Indirecta (Concesionaria)">Empresa Concesionaria</option>
                    <option value="Otro">Otro</option>
                </select>
            </div>
            <div id="campos_gestion_externa" class="hidden">
                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Nombre Empresa/Ente:</label>
                        <input type="text" class="form-input" name="empresa_concesionaria" id="empresa_concesionaria">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Teléfono de contacto:</label>
                        <input type="text" class="form-input" name="telefono_gestion" id="telefono_gestion">
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# --- SECCIÓN: VERTIDO --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="log-out"></i>Vertido de Aguas Residuales</h2>
        <div class="card-body">
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Nº de puntos de vertido:</label>
                    <input type="number" class="form-input" name="num_puntos_vertido">
                </div>
                <div class="form-group">
                    <label class="form-label">Tipo de vertido (Cauce, Mar, Pozo...):</label>
                    <input type="text" class="form-input" name="tipo_vertido">
                </div>
            </div>
        </div>
    </div>

    {# --- SECCIÓN: DEPURACIÓN --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="factory"></i>Depuración</h2>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label">Tipo de tratamiento (EDAR, Fosa Séptica...):</label>
                <input type="text" class="form-input" name="tipo_tratamiento_depuracion">
            </div>
            <div class="form-group">
                <label class="form-label">Capacidad de Tratamiento (m³/día):</label>
                <input type="number" class="form-input" name="capacidad_depuracion">
            </div>
        </div>
    </div>

    {# --- SECCIÓN: REDES --- #}
    <div class="card">
        <h2 class="section-title"><i data-lucide="map"></i>Redes de Alcantarillado</h2>
        <div class="card-body">
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Longitud de Red (km):</label>
                    <input type="number" step="0.1" class="form-input" name="longitud_red_saneamiento">
                </div>
                <div class="form-group">
                    <label class="form-label">Nº de Acometidas:</label>
                    <input type="number" class="form-input" name="num_acometidas_saneamiento">
                </div>
            </div>
        </div>
    </div>

    {{ ui.render_requerimientos(avisos_personalizados) }}
    {{ ui.render_contacto_y_adjuntos() }}
    {{ ui.render_boton_envio() }}
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnEnviar = document.getElementById('btnEnviar');
    const checkConf = document.getElementById('checkConformidad');
    const tipoGestion = document.getElementById('tipo_gestion');
    const camposExterna = document.getElementById('campos_gestion_externa');

    // Cargar contacto
    document.getElementById('contacto_nombre').value = localStorage.getItem("eiel_user_name") || "";
    document.getElementById('contacto_depto').value = localStorage.getItem("eiel_user_dept") || "";
    document.getElementById('contacto_email').value = localStorage.getItem("eiel_user_email") || "";

    // Toggle Gestión
    if(tipoGestion) {
        tipoGestion.onchange = () => camposExterna.classList.toggle('hidden', tipoGestion.value !== 'Indirecta (Concesionaria)');
    }

    if(checkConf) checkConf.onchange = () => btnEnviar.disabled = !checkConf.checked;

    btnEnviar.onclick = () => {
        enviarFormularioGlobal(() => {
            const formData = new FormData(document.getElementById('mainForm'));
            return Object.fromEntries(formData.entries());
        });
    };
});
</script>
{% endblock %}